        incBtn.TextColor3 = T.text
        incBtn.BorderSizePixel = 0
        incBtn.Parent = frame
        Instance.new("UICorner", incBtn).CornerRadius = UDim.new(0, 4)

        local function update()
            local val = getter()
            label.Text = labelText .. ": " .. string.format("%.1f", val)
            valLabel.Text = string.format("%.1f", val)
        end

        decBtn.MouseButton1Click:Connect(function()
            local newVal = math.max(minVal, getter() - (maxVal - minVal) / 20)
            setter(newVal)
            update()
        end)
        incBtn.MouseButton1Click:Connect(function()
            local newVal = math.min(maxVal, getter() + (maxVal - minVal) / 20)
            setter(newVal)
            update()
        end)
        return frame
    end

    local function addDropdown(parent, text, options, getter, setter, order)
        local frame = Instance.new("Frame")
        frame.Size = UDim2.new(1, 0, 0, 40)
        frame.BackgroundColor3 = T.card
        frame.LayoutOrder = order
        frame.Parent = parent
        Instance.new("UICorner", frame).CornerRadius = UDim.new(0, 10)

        local label = Instance.new("TextLabel")
        label.Size = UDim2.new(0.5, -10, 1, 0)
        label.Position = UDim2.new(0, 8, 0, 0)
        label.Text = text
        label.Font = Enum.Font.GothamSemibold
        label.TextSize = 10
        label.TextColor3 = T.text
        label.TextXAlignment = Enum.TextXAlignment.Left
        label.BackgroundTransparency = 1
        label.Parent = frame

        local drop = Instance.new("TextButton")
        drop.Size = UDim2.new(0.4, 0, 0, 26)
        drop.Position = UDim2.new(0.55, 0, 0, 7)
        drop.Text = getter()
        drop.Font = Enum.Font.Gotham
        drop.TextSize = 10
        drop.BackgroundColor3 = T.dim
        drop.TextColor3 = T.text
        drop.BorderSizePixel = 0
        drop.Parent = frame
        Instance.new("UICorner", drop).CornerRadius = UDim.new(0, 4)

        local menuOpen = false
        local menu = nil
        drop.MouseButton1Click:Connect(function()
            if menuOpen then return end
            menuOpen = true
            local absPos = drop.AbsolutePosition
            local menuHeight = #options * 26
            menu = Instance.new("Frame")
            menu.Size = UDim2.new(0, 140, 0, menuHeight)
            menu.Position = UDim2.new(0, absPos.X + 5, 0, absPos.Y + 26)
            menu.BackgroundColor3 = T.card
            menu.BorderSizePixel = 0
            menu.ZIndex = 200
            menu.Parent = screenGui
            Instance.new("UICorner", menu).CornerRadius = UDim.new(0, 6)
            local menuStroke = Instance.new("UIStroke")
            menuStroke.Color = T.border
            menuStroke.Thickness = 1
            menuStroke.Parent = menu

            local scroll = Instance.new("ScrollingFrame")
            scroll.Size = UDim2.new(1, 0, 1, 0)
            scroll.BackgroundTransparency = 1
            scroll.BorderSizePixel = 0
            scroll.CanvasSize = UDim2.new(0, 0, 0, menuHeight)
            scroll.AutomaticCanvasSize = Enum.AutomaticSize.Y
            scroll.ScrollBarThickness = 4
            scroll.Parent = menu
            local layout = Instance.new("UIListLayout")
            layout.SortOrder = Enum.SortOrder.LayoutOrder
            layout.Padding = UDim.new(0, 1)
            layout.Parent = scroll

            for _, opt in ipairs(options) do
                local btn = Instance.new("TextButton")
                btn.Size = UDim2.new(1, 0, 0, 26)
                btn.Text = opt
                btn.Font = Enum.Font.Gotham
                btn.TextSize = 10
                btn.BackgroundColor3 = T.dim
                btn.TextColor3 = T.text
                btn.BorderSizePixel = 0
                btn.Parent = scroll
                btn.MouseButton1Click:Connect(function()
                    setter(opt)
                    drop.Text = opt
                    menu:Destroy()
                    menuOpen = false
                end)
            end

            local function closeMenu()
                if menu then menu:Destroy() end
                menuOpen = false
            end
            local clickConn
            clickConn = UserInputService.InputBegan:Connect(function(inp)
                if inp.UserInputType == Enum.UserInputType.MouseButton1 then
                    local mousePos = inp.Position
                    if menu and menu.Parent then
                        local mAbs = menu.AbsolutePosition
                        local mSize = menu.AbsoluteSize
                        if mousePos.X < mAbs.X or mousePos.X > mAbs.X + mSize.X or mousePos.Y < mAbs.Y or mousePos.Y > mAbs.Y + mSize.Y then
                            closeMenu()
                            clickConn:Disconnect()
                        end
                    else
                        clickConn:Disconnect()
                    end
                end
            end)
        end)
        return frame
    end

