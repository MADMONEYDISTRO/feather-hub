local function CreateModule(name, data)
    data.Enabled = false
    data.Name = name
    Modules[name] = data
    return data
end

local function ToggleModule(name, state)
    local m = Modules[name]
    if not m then return end
    if m.Enabled == state then return end
    m.Enabled = state
    if m.OnToggle then m.OnToggle(state) end
end

