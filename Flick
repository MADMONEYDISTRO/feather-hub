local function tpToPlayer(name)
    for _, p in pairs(Players:GetPlayers()) do
        if p ~= LocalPlayer and string.lower(p.Name):find(string.lower(name), 1, true) then
            local char = LocalPlayer.Character
            if char and char:FindFirstChild("HumanoidRootPart") and p.Character and p.Character:FindFirstChild("HumanoidRootPart") then
                char.HumanoidRootPart.CFrame = CFrame.new(p.Character.HumanoidRootPart.Position + Vector3.new(0,3,0))
                notify("Teleport", "Teleported to "..p.Name, "success")
                return
            end
        end
    end
    notify("Error", "Player not found", "error")
end

local function tpToCursor()
    local char = LocalPlayer.Character
    if char and char:FindFirstChild("HumanoidRootPart") then
        char.HumanoidRootPart.CFrame = CFrame.new(Mouse.Hit.Position + Vector3.new(0,3,0))
        notify("Teleport", "Teleported to cursor", "success")
    end
end

local function saveWaypoint(name)
    local char = LocalPlayer.Character
    if char and char:FindFirstChild("HumanoidRootPart") then
        WayPoints[name] = char.HumanoidRootPart.Position
        notify("Waypoint", "Saved: "..name, "success")
    end
end

local function tpToWaypoint(name)
    if WayPoints[name] then
        local char = LocalPlayer.Character
        if char and char:FindFirstChild("HumanoidRootPart") then
            char.HumanoidRootPart.CFrame = CFrame.new(WayPoints[name])
            notify("Waypoint", "Teleported to: "..name, "success")
        end
    else notify("Error", "Waypoint not found", "error") end
end

