local function getEnemyCharacters()
    local enemies = {}
    local myChar = LocalPlayer.Character
    for _, obj in pairs(workspace:GetChildren()) do
        if obj:IsA("Model") and obj:FindFirstChild("Humanoid") and obj:FindFirstChild("HumanoidRootPart") then
            if obj ~= myChar then
                local humanoid = obj:FindFirstChild("Humanoid")
                if humanoid and humanoid.Health > 0 then
                    table.insert(enemies, obj)
                end
            end
        end
    end
    return enemies
end

local function getHitboxPosition(character, partName)
    local part = character:FindFirstChild(partName)
    if not part then part = character:FindFirstChild("HumanoidRootPart") end
    return part and part.Position or nil
end

-- ESP
local function destroyAllESP()
    for _, line in pairs(tracers) do pcall(function() line:Remove() end) end
    for _, hl in pairs(highlights) do pcall(function() hl:Destroy() end) end
    tracers = {}
    highlights = {}
end

local function refreshESP()
    if not espSettings.enabled then destroyAllESP(); return end
    local enemies = getEnemyCharacters()
    local enemyMap = {}
    for _, enemy in ipairs(enemies) do enemyMap[enemy] = true end

    for enemy, line in pairs(tracers) do
        if not enemyMap[enemy] then pcall(function() line:Remove() end); tracers[enemy] = nil end
    end
    for enemy, hl in pairs(highlights) do
        if not enemyMap[enemy] then pcall(function() hl:Destroy() end); highlights[enemy] = nil end
    end

    for _, enemy in ipairs(enemies) do
        if espSettings.tracersEnabled and drawingAvailable and not tracers[enemy] then
            local line = Drawing.new("Line")
            line.Color = espSettings.color
            line.Thickness = 1
            line.Transparency = espSettings.transparency
            line.Visible = true
            tracers[enemy] = line
        end
        if espSettings.highlightsEnabled then
            local pos = getHitboxPosition(enemy, "HumanoidRootPart")
            if pos and LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart") then
                local dist = (pos - LocalPlayer.Character.HumanoidRootPart.Position).Magnitude
                if dist <= espSettings.range then
                    if not highlights[enemy] then
                        local hl = Instance.new("Highlight")
                        hl.FillColor = espSettings.color
                        hl.FillTransparency = espSettings.transparency
                        hl.OutlineColor = espSettings.color
                        hl.OutlineTransparency = 0.3
                        hl.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
                        hl.Adornee = enemy
                        hl.Parent = enemy
                        highlights[enemy] = hl
                    end
                else
                    if highlights[enemy] then highlights[enemy]:Destroy(); highlights[enemy] = nil end
                end
            end
        end
        -- Update existing
        if tracers[enemy] then tracers[enemy].Color = espSettings.color; tracers[enemy].Transparency = espSettings.transparency end
        if highlights[enemy] then highlights[enemy].FillColor = espSettings.color; highlights[enemy].FillTransparency = espSettings.transparency; highlights[enemy].OutlineColor = espSettings.color end
    end
end

RunService.RenderStepped:Connect(function()
    if espSettings.enabled and espSettings.tracersEnabled and drawingAvailable then
        local viewport = Camera.ViewportSize
        local center = Vector2.new(viewport.X / 2, viewport.Y / 2)
        for enemy, line in pairs(tracers) do
            if enemy and enemy.Parent then
                local pos = getHitboxPosition(enemy, "HumanoidRootPart")
                if pos then
                    local vec = Camera:WorldToViewportPoint(pos)
                    local screenPos = Vector2.new(vec.X, vec.Y)
                    if vec.Z < 0 then screenPos = center + (center - screenPos) end
                    screenPos = Vector2.new(math.clamp(screenPos.X, 0, viewport.X), math.clamp(screenPos.Y, 0, viewport.Y))
                    line.From = center
                    line.To = screenPos
                    line.Visible = true
                else line.Visible = false end
            else line.Visible = false end
        end
    end
end)

task.spawn(function()
