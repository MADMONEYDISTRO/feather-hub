local function getEnemyCharacters()
    local enemies = {}
    local myChar = LocalPlayer.Character
    for _, obj in pairs(workspace:GetChildren()) do
        if obj:IsA("Model") and obj:FindFirstChild("Humanoid") and obj:FindFirstChild("HumanoidRootPart") then
            if obj ~= myChar then
                local humanoid = obj:FindFirstChild("Humanoid")
                if humanoid and humanoid.Health > 0 then
                    table.insert(enemies, obj)
                end
            end
        end
    end
    return enemies
end

local function getHitboxPosition(character)
    local part = character:FindFirstChild(settings.aimPart)
    if not part then part = character:FindFirstChild("HumanoidRootPart") end
    return part and part.Position or nil
end

-- ==================== AIMBOT LOGIC ====================
local function getClosestToMouse()
    local closest = nil
    local minScreenDist = math.huge
    local mousePos = UserInputService:GetMouseLocation()
    local cameraPos = Camera.CFrame.Position

    for _, enemy in ipairs(getEnemyCharacters()) do
        local pos = getHitboxPosition(enemy)
        if pos then
            local distWorld = (pos - cameraPos).Magnitude
            if distWorld <= settings.fovDistance then
                local screenPoint, onScreen = Camera:WorldToViewportPoint(pos)
                if onScreen then
                    local screenDist = (Vector2.new(screenPoint.X, screenPoint.Y) - mousePos).Magnitude
                    if screenDist < minScreenDist then
                        minScreenDist = screenDist
                        closest = enemy
                    end
                end
            end
        end
    end
    return closest
end

local function getClosestToPlayer()
    local closest = nil
    local minDist = settings.fovDistance
    local cameraPos = Camera.CFrame.Position

    for _, enemy in ipairs(getEnemyCharacters()) do
        local pos = getHitboxPosition(enemy)
        if pos then
            local dist = (pos - cameraPos).Magnitude
            if dist < minDist then
                minDist = dist
                closest = enemy
            end
        end
    end
    return closest
end

local function getTarget()
    return settings.targetMode == "mouse" and getClosestToMouse() or getClosestToPlayer()
end

local function aimAt(targetChar)
    local aimPart = targetChar:FindFirstChild(settings.aimPart) or targetChar:FindFirstChild("HumanoidRootPart")
    if not aimPart then return end
    local targetPos = aimPart.Position
    if settings.smoothing <= 0 then
        Camera.CFrame = CFrame.new(Camera.CFrame.Position, targetPos)
    else
        local newCF = CFrame.new(Camera.CFrame.Position, targetPos)
        Camera.CFrame = Camera.CFrame:Lerp(newCF, 1 - settings.smoothing)
    end
end

RunService.RenderStepped:Connect(function()
    if settings.aimbotEnabled then
        local target = getTarget()
        if target then aimAt(target) end
    end
end)

-- ==================== ESP SYSTEM ====================
local function destroyAllESP()
    for _, line in pairs(tracers) do pcall(function() line:Remove() end) end
    for _, hl in pairs(highlights) do pcall(function() hl:Destroy() end) end
    tracers = {}
    highlights = {}
end

local function refreshESP()
    if not settings.espEnabled then
        destroyAllESP()
        return
    end

    local enemies = getEnemyCharacters()
    local enemyMap = {}
    for _, enemy in ipairs(enemies) do enemyMap[enemy] = true end

    for enemy, line in pairs(tracers) do
        if not enemyMap[enemy] then
            pcall(function() line:Remove() end)
            tracers[enemy] = nil
        end
    end
    for enemy, hl in pairs(highlights) do
        if not enemyMap[enemy] then
            pcall(function() hl:Destroy() end)
            highlights[enemy] = nil
        end
    end

    for _, enemy in ipairs(enemies) do
        if settings.tracersEnabled and not tracers[enemy] then
            local line = Drawing.new("Line")
            line.Color = settings.espColor
            line.Thickness = 1
            line.Transparency = settings.espTransparency
            line.Visible = true
            tracers[enemy] = line
        end
        if settings.highlightsEnabled and not highlights[enemy] then
            local hl = Instance.new("Highlight")
            hl.FillColor = settings.espColor
            hl.FillTransparency = settings.espTransparency
            hl.OutlineColor = settings.espColor
            hl.OutlineTransparency = 0.3
            hl.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
            hl.Adornee = enemy
            hl.Parent = enemy
            highlights[enemy] = hl
        end
        if settings.tracersEnabled and tracers[enemy] then
            tracers[enemy].Color = settings.espColor
            tracers[enemy].Transparency = settings.espTransparency
        end
        if settings.highlightsEnabled and highlights[enemy] then
            highlights[enemy].FillColor = settings.espColor
            highlights[enemy].FillTransparency = settings.espTransparency
            highlights[enemy].OutlineColor = settings.espColor
        end
    end
end

task.spawn(function()
    while true do
        task.wait(0.5)
        if settings.espEnabled then refreshESP() else destroyAllESP() end
    end
end)

RunService.RenderStepped:Connect(function()
    if not settings.espEnabled or not settings.tracersEnabled then
        for _, line in pairs(tracers) do if line then line.Visible = false end end
        return
    end
    local viewport = Camera.ViewportSize
    local center = Vector2.new(viewport.X / 2, viewport.Y / 2)
    for enemy, line in pairs(tracers) do
        if enemy and enemy.Parent then
            local pos = getHitboxPosition(enemy)
            if pos then
                local vec = Camera:WorldToViewportPoint(pos)
                local screenPos = Vector2.new(vec.X, vec.Y)
                if vec.Z < 0 then screenPos = center + (center - screenPos) end
                screenPos = Vector2.new(math.clamp(screenPos.X, 0, viewport.X), math.clamp(screenPos.Y, 0, viewport.Y))
                line.From = center
                line.To = screenPos
                line.Visible = true
            else
                line.Visible = false
            end
        else
            line.Visible = false
        end
    end
end)

-- ==================== KEYBIND HANDLER ====================
UserInputService.InputBegan:Connect(function(input, gameProcessed)
    if gameProcessed then return end
    if waitingForKeybind then
        if input.KeyCode ~= Enum.KeyCode.Unknown then
            settings.aimKey = input.KeyCode
            waitingForKeybind = false
            if uiElements.keyButton then uiElements.keyButton.Text = settings.aimKey.Name end
            if uiElements.infoLabel then uiElements.infoLabel.Text = "Open/close UI:  ]\nToggle aimbot:  " .. settings.aimKey.Name end
        end
        return
    end
    if input.KeyCode == settings.aimKey then
        settings.aimbotEnabled = not settings.aimbotEnabled
        if uiElements.aimbotPill then
            uiElements.aimbotPill.BackgroundColor3 = settings.aimbotEnabled and Color3.fromRGB(80, 180, 80) or Color3.fromRGB(180, 60, 60)
        end
    end
    if input.KeyCode == Enum.KeyCode.RightBracket then
        settings.uiVisible = not settings.uiVisible
        if screenGui then screenGui.Enabled = settings.uiVisible end
    end
end)

-- ==================== SMOOTH DRAG ====================
local function createSmoothDrag(frame)
    local dragData = {
        active = false,
        startPos = Vector2.new(),
        startFramePos = Vector2.new(),
        currentVel = Vector2.new(),
        targetPos = Vector2.new(),
        connection = nil,
    }

    local function updateDrag()
        if not dragData.active then
            local delta = dragData.targetPos - Vector2.new(frame.Position.X.Offset, frame.Position.Y.Offset)
            dragData.currentVel = dragData.currentVel * 0.85 + delta * 0.2
            local newX = math.clamp(frame.Position.X.Offset + dragData.currentVel.X, 0, workspace.CurrentCamera.ViewportSize.X - frame.AbsoluteSize.X)
            local newY = math.clamp(frame.Position.Y.Offset + dragData.currentVel.Y, 0, workspace.CurrentCamera.ViewportSize.Y - frame.AbsoluteSize.Y)
            frame.Position = UDim2.new(0, newX, 0, newY)
            dragData.targetPos = Vector2.new(newX, newY)
            if delta.Magnitude < 0.5 and dragData.currentVel.Magnitude < 0.5 then
                dragData.connection:Disconnect()
                dragData.connection = nil
            end
        end
    end

    local titleBar = frame:FindFirstChild("TitleBar")
    if not titleBar then return end

    titleBar.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            dragData.active = true
            dragData.startPos = input.Position
            dragData.startFramePos = Vector2.new(frame.Position.X.Offset, frame.Position.Y.Offset)
            dragData.currentVel = Vector2.new()
            if dragData.connection then dragData.connection:Disconnect() end
            dragData.connection = RunService.Heartbeat:Connect(updateDrag)
        end
    end)

    titleBar.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            dragData.active = false
            dragData.targetPos = Vector2.new(frame.Position.X.Offset, frame.Position.Y.Offset)
        end
    end)

    UserInputService.InputChanged:Connect(function(input)
        if dragData.active and input.UserInputType == Enum.UserInputType.MouseMovement then
            local delta = input.Position - dragData.startPos
            local newX = math.clamp(dragData.startFramePos.X + delta.X, 0, workspace.CurrentCamera.ViewportSize.X - frame.AbsoluteSize.X)
            local newY = math.clamp(dragData.startFramePos.Y + delta.Y, 0, workspace.CurrentCamera.ViewportSize.Y - frame.AbsoluteSize.Y)
            frame.Position = UDim2.new(0, newX, 0, newY)
            dragData.targetPos = Vector2.new(newX, newY)
        end
    end)
end

