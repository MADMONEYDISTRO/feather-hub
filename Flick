-- Aimbot
local function getClosestToMouse()
    local closest, minScreenDist = nil, math.huge
    local mousePos = UIS:GetMouseLocation()
    local cameraPos = Camera.CFrame.Position
    for _, enemy in ipairs(getEnemyCharacters()) do
        local pos = getHitboxPosition(enemy, aimbotSettings.aimPart)
        if pos then
            local distWorld = (pos - cameraPos).Magnitude
            if distWorld <= aimbotSettings.fovDistance then
                local screenPoint, onScreen = Camera:WorldToViewportPoint(pos)
                if onScreen then
                    local screenDist = (Vector2.new(screenPoint.X, screenPoint.Y) - mousePos).Magnitude
                    if screenDist < minScreenDist then
                        minScreenDist = screenDist
                        closest = enemy
                    end
                end
            end
        end
    end
    return closest
end

local function getClosestToPlayer()
    local closest, minDist = nil, aimbotSettings.fovDistance
    local cameraPos = Camera.CFrame.Position
    for _, enemy in ipairs(getEnemyCharacters()) do
        local pos = getHitboxPosition(enemy, aimbotSettings.aimPart)
        if pos then
            local dist = (pos - cameraPos).Magnitude
            if dist < minDist then minDist = dist; closest = enemy end
        end
    end
    return closest
end

local function getTarget()
    return aimbotSettings.targetMode == "mouse" and getClosestToMouse() or getClosestToPlayer()
end

local function aimAt(targetChar)
    local aimPart = targetChar:FindFirstChild(aimbotSettings.aimPart) or targetChar:FindFirstChild("HumanoidRootPart")
    if not aimPart then return end
    local targetPos = aimPart.Position
    if aimbotSettings.smoothing <= 0 then
        Camera.CFrame = CFrame.new(Camera.CFrame.Position, targetPos)
    else
        local newCF = CFrame.new(Camera.CFrame.Position, targetPos)
        Camera.CFrame = Camera.CFrame:Lerp(newCF, 1 - aimbotSettings.smoothing)
    end
end

RunService.RenderStepped:Connect(function()
    if aimbotSettings.enabled then
        local target = getTarget()
        if target then aimAt(target) end
    end
end)

UIS.InputBegan:Connect(function(input, gameProcessed)
    if gameProcessed then return end
    if input.KeyCode == aimbotSettings.key then
        aimbotSettings.enabled = not aimbotSettings.enabled
        notify("Aimbot", aimbotSettings.enabled and "Enabled" or "Disabled", "success")
    end
end)

