local Drawing = nil
pcall(function() Drawing = (syn and syn.drawing) or Drawing end)
pcall(function() Drawing = Drawing or (getgenv and getgenv().Drawing) end)
pcall(function() Drawing = Drawing or (getrenv and getrenv().Drawing) end)

if not Drawing then
    print("[Feather] Drawing lib missing, using ScreenGui fallback for tracers.")
    local TracerGui = Instance.new("ScreenGui")
    TracerGui.Name = "FeatherTracers"
    TracerGui.Parent = Player:WaitForChild("PlayerGui")
    Drawing = {
        new = function(_, type)
            if type == "Line" then
                local frame = Instance.new("Frame")
                frame.BorderSizePixel = 0
                frame.BackgroundColor3 = Color3.new(1,1,1)
                frame.AnchorPoint = Vector2.new(0.5,0.5)
                frame.Parent = TracerGui
                local line = {
                    From = Vector3.zero, To = Vector3.zero,
                    Color = Color3.new(1,1,1), Thickness = 1.5,
                    Transparency = 0.5, Visible = true,
                    Remove = function(self) frame:Destroy() end
                }
                function line:Update()
                    if not self.Visible then frame.Visible = false; return end
                    local cam = Workspace.CurrentCamera
                    if not cam then return end
                    local sp1 = cam:WorldToViewportPoint(self.From)
                    local sp2 = cam:WorldToViewportPoint(self.To)
                    if sp1.Z > 0 and sp2.Z > 0 then
                        frame.Visible = true
                        local center = (Vector2.new(sp1.X, sp1.Y) + Vector2.new(sp2.X, sp2.Y)) / 2
                        local distance = (Vector2.new(sp1.X, sp1.Y) - Vector2.new(sp2.X, sp2.Y)).Magnitude
                        local angle = math.atan2(sp2.Y - sp1.Y, sp2.X - sp1.X)
                        frame.Position = UDim2.new(0, center.X, 0, center.Y)
                        frame.Size = UDim2.new(0, distance, 0, self.Thickness)
                        frame.Rotation = math.deg(angle)
                        frame.BackgroundColor3 = self.Color
                        frame.BackgroundTransparency = self.Transparency
                    else
                        frame.Visible = false
                    end
                end
                RS.RenderStepped:Connect(function() pcall(line.Update, line) end)
                return line
            end
        end
    }
else
    print("[Feather] Drawing library found.")
end

local function createDrawing(type, props)
    if not Drawing or not Drawing.new then return nil end
    local obj = Drawing.new(type)
    if not obj then return nil end
    for k, v in pairs(props or {}) do
        pcall(function() obj[k] = v end)
    end
    return obj
end

-- ═══ OPTIMIZED ESP WITH TRACERS ═══
local ESP = {Targets = {}, Settings = {
    Players = false, Items = false, Generators = false, Killer = true,
    Tracers = true, TracerThickness = 1.5, TracerTransparency = 0.5,
    MaxDistance = 1000, RefreshRate = 60
}}

local function getTargetColor(target)
    if target:IsA("Model") then
        local parent = target.Parent
        if parent == Workspace.Players.Survivors then return Color3.new(0.15, 1, 0)
        elseif parent == Workspace.Players.Killers then return Color3.new(1, 0, 0)
        elseif target.Name == "Generator" then return Color3.new(1, 0.9, 0)
        else return Color3.new(0.3, 0.8, 1) end
    end
    return Color3.new(1, 1, 1)
end

function ESP:AddTarget(obj)
    if not obj or not obj.Parent then return end
    if self.Targets[obj] then return end
    local color = getTargetColor(obj)
    local tracer = nil
    if ESP.Settings.Tracers then
        tracer = createDrawing("Line", {
            Visible = false,
            Color = color,
            Thickness = ESP.Settings.TracerThickness,
            Transparency = ESP.Settings.TracerTransparency
        })
    end
    self.Targets[obj] = { Object = obj, Color = color, Tracer = tracer }
end

function ESP:RemoveTarget(obj)
    local data = self.Targets[obj]
    if data then
        if data.Tracer then pcall(function() data.Tracer:Remove() end) end
        self.Targets[obj] = nil
    end
end

function ESP:Update()
    local cam = Workspace.CurrentCamera
    if not cam then return end
    local camPos = cam.CFrame.Position
    for obj, data in pairs(self.Targets) do
        if not obj or not obj.Parent then
            self:RemoveTarget(obj)
            continue
        end
        local pos
        if obj:IsA("Model") then pos = obj:GetPivot().Position
        elseif obj:IsA("BasePart") then pos = obj.Position
        else self:RemoveTarget(obj); continue end
        local dist = (camPos - pos).Magnitude
        local inRange = dist <= ESP.Settings.MaxDistance
        if data.Tracer then
            if ESP.Settings.Tracers and inRange then
                data.Tracer.From = camPos
                data.Tracer.To = pos
                data.Tracer.Color = data.Color
                data.Tracer.Visible = true
            else
                data.Tracer.Visible = false
            end
        end
    end
end

task.spawn(function()
    while true do
        ESP:Update()
        task.wait(1 / ESP.Settings.RefreshRate)
    end
end)

