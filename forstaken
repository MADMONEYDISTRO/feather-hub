local function listen(parent, signal, callback) local c = signal:Connect(callback); table.insert(conns, c); return c end

local function addPlayer(ch) espContainer:Add(ch, {AccentColor=Color3.new(0.149,1,0), ArrowShow=false, ShowLabel=false, GroupName="players"}) end
local function addKiller(ch) espContainer:Add(ch, {AccentColor=Color3.new(1,0,0), ArrowShow=true, ArrowMinDistance=999999, ArrowSize=UDim2.new(0,40,0,40), LabelText="Killer", ShowLabel=true, GroupName="players"}) end
local function addItem(i)
    local cfg = {AccentColor=Color3.new(0.03,0.92,1), ArrowShow=false, ShowLabel=false, GroupName="items"}
    if fsk.prioritizeMedkit and i.Name == "Medkit" then
        cfg = {AccentColor=Color3.new(1,1,1), ArrowShow=true, ArrowMinDistance=999999, ArrowSize=UDim2.new(0,40,0,40), LabelText="Medkit", ShowLabel=true, GroupName="items"}
    end
    espContainer:Add(i, cfg)
end
local function addGenerator(g)
    local progVal = g:FindFirstChild("Progress"); local progress = (progVal and progVal.Value) or 0
    local done = progress >= 100
    espContainer:Add(g, {AccentColor=done and Color3.new(0,0.5,0) or Color3.new(0.98,1,0), ArrowShow=not done, ArrowMinDistance=999999, ArrowSize=UDim2.new(0,20,0,20), ShowLabel=not done, LabelText=tostring(math.floor(progress)).."%", GroupName="generators"})
    if progVal then progVal.Changed:Connect(function() espContainer:Remove(g); addGenerator(g) end) end
end

local function getClosestGenerator()
    local ch = Player.Character; if not ch or not ch.PrimaryPart then return nil end
    local root = ch.PrimaryPart; local closest, shortest = nil, math.huge
    local map = workspace.Map:FindFirstChild("Ingame"); if not map then return nil end; map = map:FindFirstChild("Map"); if not map then return nil end
    for _,obj in ipairs(map:GetChildren()) do if obj.Name=="Generator" and obj:IsA("Model") and obj.PrimaryPart then local d=(root.Position-obj.PrimaryPart.Position).Magnitude; if d<shortest then closest=obj; shortest=d end end end
    return closest
end

