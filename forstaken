local espContainer = ESPIndicator.new({ArrowEdgePadding=50, ArrowShowDistanceText=true, Parent=Player:WaitForChild("PlayerGui")})
local fsk = {players=false, items=false, generators=false, prioritizeMedkit=false, infiniteStamina=false, noCooldownSolve=false}
local solveCD = false
local conns = {}

local function listen(parent, signal, callback) local c = signal:Connect(callback); table.insert(conns, c); return c end

local function addPlayer(ch) 
    espContainer:Add(ch, {AccentColor=Color3.new(0.149,1,0), ArrowShow=false, ShowLabel=false, GroupName="players"})
    if ESP.Settings.Players then ESP:AddTarget(ch) end
end
local function addKiller(ch) 
    espContainer:Add(ch, {AccentColor=Color3.new(1,0,0), ArrowShow=true, ArrowMinDistance=999999, ArrowSize=UDim2.new(0,40,0,40), LabelText="Killer", ShowLabel=true, GroupName="players"})
    if ESP.Settings.Killer then ESP:AddTarget(ch) end
end
local function addItem(i)
    local cfg = {AccentColor=Color3.new(0.03,0.92,1), ArrowShow=false, ShowLabel=false, GroupName="items"}
    if fsk.prioritizeMedkit and i.Name == "Medkit" then
        cfg = {AccentColor=Color3.new(1,1,1), ArrowShow=true, ArrowMinDistance=999999, ArrowSize=UDim2.new(0,40,0,40), LabelText="Medkit", ShowLabel=true, GroupName="items"}
    end
    espContainer:Add(i, cfg)
    if ESP.Settings.Items then ESP:AddTarget(i) end
end
local function addGenerator(g)
    local progVal = g:FindFirstChild("Progress"); local progress = (progVal and progVal.Value) or 0
    local done = progress >= 100
    espContainer:Add(g, {AccentColor=done and Color3.new(0,0.5,0) or Color3.new(0.98,1,0), ArrowShow=not done, ArrowMinDistance=999999, ArrowSize=UDim2.new(0,20,0,20), ShowLabel=not done, LabelText=tostring(math.floor(progress)).."%", GroupName="generators"})
    if ESP.Settings.Generators then ESP:AddTarget(g) end
    if progVal then progVal.Changed:Connect(function() espContainer:Remove(g); addGenerator(g) end) end
end

local function getClosestGenerator()
    local ch = Player.Character; if not ch or not ch.PrimaryPart then return nil end
    local root = ch.PrimaryPart; local closest, shortest = nil, math.huge
    local map = workspace.Map:FindFirstChild("Ingame"); if not map then return nil end; map = map:FindFirstChild("Map"); if not map then return nil end
    for _,obj in ipairs(map:GetChildren()) do if obj.Name=="Generator" and obj:IsA("Model") and obj.PrimaryPart then local d=(root.Position-obj.PrimaryPart.Position).Magnitude; if d<shortest then closest=obj; shortest=d end end end
    return closest
end

local function setupAutoUpdate()
    local s,k = workspace.Players:FindFirstChild("Survivors"), workspace.Players:FindFirstChild("Killers")
    if s then listen(s,s.ChildAdded,function(c) if fsk.players then addPlayer(c) end end); listen(s,s.ChildRemoved,function(c) if fsk.players then espContainer:Remove(c); ESP:RemoveTarget(c) end end) end
    if k then listen(k,k.ChildAdded,function(c) if fsk.players then addKiller(c) end end); listen(k,k.ChildRemoved,function(c) if fsk.players then espContainer:Remove(c); ESP:RemoveTarget(c) end end) end
    local ingame = workspace.Map:FindFirstChild("Ingame")
    if ingame then
        listen(ingame,ingame.ChildAdded,function(c) if fsk.items and c.Name~="Map" then addItem(c) end end)
        listen(ingame,ingame.ChildRemoved,function(c) if fsk.items and c.Name~="Map" then espContainer:Remove(c); ESP:RemoveTarget(c) end end)
        local map = ingame:FindFirstChild("Map")
        if map then listen(map,map.ChildAdded,function(c) if fsk.generators and c.Name=="Generator" then addGenerator(c) end end); listen(map,map.ChildRemoved,function(c) if fsk.generators and c.Name=="Generator" then espContainer:Remove(c); ESP:RemoveTarget(c) end end) end
    end
end

