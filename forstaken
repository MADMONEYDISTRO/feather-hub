    if s then listen(s,s.ChildAdded,function(c) if fsk.players then addPlayer(c) end end); listen(s,s.ChildRemoved,function(c) if fsk.players then espContainer:Remove(c) end end) end
    if k then listen(k,k.ChildAdded,function(c) if fsk.players then addKiller(c) end end); listen(k,k.ChildRemoved,function(c) if fsk.players then espContainer:Remove(c) end end) end
    local ingame = workspace.Map:FindFirstChild("Ingame")
