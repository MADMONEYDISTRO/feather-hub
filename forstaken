function ESPIndicator:_update()
    local cam = workspace.CurrentCamera; if not cam then return end
    local vp = cam.ViewportSize; local vpX, vpY = vp.X, vp.Y
    for target, ind in pairs(self.Indicators) do
        local opts = ind.Options; local arrow = ind.Arrow; local scaler = ind.Scaler
        if not arrow then continue end
        local pos3
        if target:IsA("Model") then pos3 = (target.PrimaryPart and target.PrimaryPart.Position) or target:GetModelCFrame().p
        elseif target:IsA("BasePart") then pos3 = target.Position
        else continue end
        local sp, onS = cam:WorldToViewportPoint(pos3)
        local dist = (cam.CFrame.Position - pos3).Magnitude
        local minD = opts.ArrowMinDistance or self.Settings.ArrowMinDistance
        local pad = opts.ArrowEdgePadding or self.Settings.ArrowEdgePadding
        if onS and dist > minD then
            pcall(function() TS:Create(scaler, TweenInfo.new(0.1), {Scale = 0}):Play() end)
        else
            pcall(function() TS:Create(scaler, TweenInfo.new(0.1), {Scale = 1}):Play() end)
            local hW, hH = (vpX - pad*2)/2, (vpY - pad*2)/2
            local oDir = pos3 - cam.CFrame.Position
            local oLoc = cam.CFrame:VectorToObjectSpace(oDir)
            local d2 = Vector2.new(oLoc.X, oLoc.Y).Unit
            local cX, cY = math.clamp(sp.X, pad, vpX-pad), math.clamp(sp.Y, pad, vpY-pad)
            if cX == sp.X and cY == sp.Y and onS then
                pcall(function() TS:Create(scaler, TweenInfo.new(0.1), {Scale = 0}):Play() end)
            else
                local ev
                if math.abs(d2.Y) > hH/math.sqrt(hW^2 + hH^2) then ev = d2 * math.abs(hH/d2.Y)
                else ev = d2 * math.abs(hW/d2.X) end
                local ax, ay = vpX/2 + ev.X, vpY/2 - ev.Y
                local rot = math.atan2(d2.X, d2.Y)
                pcall(function() TS:Create(arrow, TweenInfo.new(0.1), {Position = UDim2.fromOffset(ax, ay), Rotation = math.deg(rot)}):Play() end)
            end
            if ind.DistanceLabel then
                ind.DistanceLabel.Text = string.format("%dm", math.round(dist))
                local off = (opts.ArrowSize and opts.ArrowSize.Y.Offset or self.Settings.ArrowSize.Y.Offset) + 16
                ind.DistanceLabel.Position = UDim2.new(0.5, 0, 0, off)
            end
        end
    end
end
function ESPIndicator:Destroy()
    if self._updateConn then self._updateConn:Disconnect() end
    if self._cleanupConn then self._cleanupConn:Disconnect() end
    self:ClearAllGroups()
    for _, ind in pairs(self.Indicators) do
        if ind.Highlight then ind.Highlight:Destroy() end
        if ind.Arrow then ind.Arrow:Destroy() end
        if ind.Label then ind.Label:Destroy() end
    end
    self.ScreenGui:Destroy()
    self.Indicators = {}
end

