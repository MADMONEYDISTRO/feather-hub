function Services.ESP:Update()
    for _, player in ipairs(Players:GetPlayers()) do
        if player ~= LocalPlayer then
            local char = self:GetCharacter(player)
            if not self.ESPObjects[player] then
                self.ESPObjects[player] = self:CreateModernTag(player)
            end
            
            local esp = self.ESPObjects[player]
            if char and char:FindFirstChild("HumanoidRootPart") and char:FindFirstChild("Head") then
                local hrp = char.HumanoidRootPart
                local head = char.Head
                local humanoid = char:FindFirstChildOfClass("Humanoid")
                local distance = (hrp.Position - Camera.CFrame.Position).Magnitude
                
                if distance <= self.MaxDistance and humanoid and humanoid.Health > 0 then
                    local team = player.Team
                    local teamName = team and team.Name or "No Team"
                    local accentColor
                    local filterKey
                    if teamName == "Criminals" then
                        accentColor = Color3.fromRGB(255, 80, 80)
                        filterKey = "Criminals"
                    elseif teamName == "Prisoner" or teamName == "Inmates" then
                        accentColor = Color3.fromRGB(255, 165, 0)
                        filterKey = "Prisoners"
                    elseif teamName == "Police" or teamName == "Guards" then
                        accentColor = Color3.fromRGB(80, 150, 255)
                        filterKey = "Guards"
                    else
                        accentColor = Color3.fromRGB(180, 180, 180)
                        filterKey = "Neutrals"
                    end
                    
                    if not self.Filters[filterKey] then
                        esp.Tag.Parent = nil
                        continue
                    end
                    
                    esp.Tag.Adornee = head
                    esp.Tag.Parent = ScreenGui
                    esp.Accent.BackgroundColor3 = accentColor
                    
                    esp.NameLabel.Text = player.DisplayName ~= player.Name and player.DisplayName .. " (@" .. player.Name .. ")" or player.Name
                    esp.TeamLabel.Text = teamName
                    esp.DistLabel.Text = math.floor(distance) .. "m"
                else
                    esp.Tag.Parent = nil
                end
            else
                esp.Tag.Parent = nil
            end
        end
    end
