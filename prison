local fovCircle = nil
local tracerLine = nil

local function updateAimbotVisuals()
    if not Services.Aimbot.Enabled then
        if fovCircle then fovCircle:Remove(); fovCircle = nil end
    else
        if not fovCircle then
            fovCircle = Drawing.new("Circle")
            fovCircle.Color = Color3.fromRGB(0, 255, 150)
            fovCircle.Thickness = 1
            fovCircle.Filled = false
            fovCircle.Transparency = 0.5
            fovCircle.Visible = true
        end
        fovCircle.Radius = Services.Aimbot.FOV
        fovCircle.Position = UserInputService:GetMouseLocation()
    end

    if not Services.Aimbot.Enabled or not Services.Aimbot.LockedTarget then
        if tracerLine then tracerLine:Remove(); tracerLine = nil end
        return
    end

    local targetPart = Services.Aimbot.LockedTarget
    local posTarget, onScreenTarget = Camera:WorldToViewportPoint(targetPart.Position)
    if not onScreenTarget then
        if tracerLine then tracerLine:Remove(); tracerLine = nil end
        return
    end

    local char = LocalPlayer.Character
    local hrp = char and char:FindFirstChild("HumanoidRootPart")
    if not hrp then
        if tracerLine then tracerLine:Remove(); tracerLine = nil end
        return
    end
    local posChar, onScreenChar = Camera:WorldToViewportPoint(hrp.Position + Vector3.new(0, 1, 0))
    if not onScreenChar then
        if tracerLine then tracerLine:Remove(); tracerLine = nil end
        return
    end

    if not tracerLine then
        tracerLine = Drawing.new("Line")
        tracerLine.Thickness = 2
        tracerLine.Color = Color3.fromRGB(110, 95, 210)
        tracerLine.Visible = true
    end
    tracerLine.From = Vector2.new(posChar.X, posChar.Y)
    tracerLine.To = Vector2.new(posTarget.X, posTarget.Y)
end

function Services.Aimbot:GetTarget()
    local closest = nil
    local closestDist = math.huge
    local mousePos = UserInputService:GetMouseLocation()
    
    for _, player in ipairs(Players:GetPlayers()) do
        if player ~= LocalPlayer then
            local char = Services.ESP:GetCharacter(player)
            if char then
                local targetPart = char:FindFirstChild("HumanoidRootPart")
                local humanoid = char:FindFirstChildOfClass("Humanoid")
                if targetPart and humanoid and humanoid.Health > 0 then
                    if self.TargetHostilesOnly then
                        if not (player.Team and (player.Team.Name == "Criminals" or player.Team.Name == "Prisoner")) then
                            continue
                        end
                    end
                    
                    local pos, onScreen = Camera:WorldToViewportPoint(targetPart.Position)
                    if onScreen then
                        local dist = (Vector2.new(pos.X, pos.Y) - mousePos).Magnitude
                        if dist < self.FOV and dist < closestDist then
                            closestDist = dist
                            closest = targetPart
                        end
                    end
                end
            end
        end
    end
    return closest
end

-- ======================== MOVEMENT ========================
-- Prison Life constantly re-enables collision, so noclip runs on its own
-- RunService.Stepped loop (fires each physics frame, before simulation) and
-- forces every character BasePart to CanCollide = false while enabled.
Services.Movement.NoclipParts = {}

function Services.Movement:EnableNoclip()
    self.NoclipEnabled = true
end

function Services.Movement:DisableNoclip()
    self.NoclipEnabled = false
    for part in pairs(self.NoclipParts) do
        if part and part.Parent then
            part.CanCollide = true
        end
    end
    self.NoclipParts = {}
end

-- Persistent noclip driver. Bound to BOTH Stepped (before physics) and
-- Heartbeat (after physics) so Prison Life's CharacterCollision script can
-- never re-enable collision between our passes.
local function noclipStep()
    if not Services.Movement.NoclipEnabled then return end
    local char = LocalPlayer.Character
    if not char then return end
    for _, part in ipairs(char:GetDescendants()) do
        if part:IsA("BasePart") and part.CanCollide then
            Services.Movement.NoclipParts[part] = true
            part.CanCollide = false
        end
    end
end
RunService.Stepped:Connect(noclipStep)
RunService.Heartbeat:Connect(noclipStep)

function Services.Movement:Fly()
    if not self.FlyEnabled then return end
    local char = LocalPlayer.Character
    if not char then return end
    local hrp = char:FindFirstChild("HumanoidRootPart")
    if not hrp then return end
    
    local cameraCF = Camera.CFrame
    local moveDir = Vector3.new(0, 0, 0)
    
    if UserInputService:IsKeyDown(Enum.KeyCode.W) then moveDir = moveDir + cameraCF.LookVector end
    if UserInputService:IsKeyDown(Enum.KeyCode.S) then moveDir = moveDir - cameraCF.LookVector end
    if UserInputService:IsKeyDown(Enum.KeyCode.A) then moveDir = moveDir - cameraCF.RightVector end
    if UserInputService:IsKeyDown(Enum.KeyCode.D) then moveDir = moveDir + cameraCF.RightVector end
    if UserInputService:IsKeyDown(Enum.KeyCode.Space) then moveDir = moveDir + Vector3.new(0, 1, 0) end
    if UserInputService:IsKeyDown(Enum.KeyCode.LeftShift) then moveDir = moveDir - Vector3.new(0, 1, 0) end
    
    if moveDir.Magnitude > 0 then
        moveDir = moveDir.Unit * (self.FlySpeed * 0.016)
        hrp.CFrame = CFrame.new(hrp.Position + moveDir)
        hrp.Velocity = Vector3.new(0, 0, 0)
    else
        hrp.Velocity = Vector3.new(0, 0, 0)
    end
end

