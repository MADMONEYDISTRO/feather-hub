local function makeButton(parent, label, cb, col)
    local base = col or accent
    local bt = Instance.new("TextButton")
    bt.Size = UDim2.new(1,0,0,34)
    bt.BackgroundColor3 = base
    bt.Text = label
    bt.Font = Enum.Font.GothamBold
    bt.TextSize = 12
    bt.TextColor3 = Color3.new(1,1,1)
    bt.AutoButtonColor = false
    bt.BorderSizePixel = 0
    bt.LayoutOrder = nextOrder()
    bt.Parent = parent
    mkC(bt,8)
    bt.MouseEnter:Connect(function() TweenService:Create(bt,tw(),{BackgroundColor3 = base:Lerp(Color3.new(1,1,1),0.15)}):Play() end)
    bt.MouseLeave:Connect(function() TweenService:Create(bt,tw(),{BackgroundColor3 = base}):Play() end)
    bt.MouseButton1Click:Connect(function() pcall(cb) end)
    bt.TouchTap:Connect(function() pcall(cb) end)
    return bt
end

