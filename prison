-- Feather-style toggle. Keeps the original CreateToggle(parent,text,callback,initial) API.
local function CreateToggle(parent, text, callback, initial)
    local st = initial or false
    local r = Instance.new("Frame")
    r.Size = UDim2.new(1,0,0,38)
    r.BackgroundColor3 = cardCol
    r.BorderSizePixel = 0
    r.LayoutOrder = nextOrder()
    r.Parent = parent
    mkC(r,8)
    local lb = Instance.new("TextLabel")
    lb.Size = UDim2.new(1,-70,1,0)
    lb.Position = UDim2.new(0,12,0,0)
    lb.Text = text
    lb.Font = Enum.Font.GothamSemibold
    lb.TextSize = 12
    lb.TextColor3 = txtCol
    lb.TextXAlignment = Enum.TextXAlignment.Left
    lb.BackgroundTransparency = 1
    lb.Parent = r
    local pill = Instance.new("Frame")
    pill.Size = UDim2.new(0,42,0,22)
    pill.Position = UDim2.new(1,-54,0.5,-11)
    pill.BackgroundColor3 = st and accent or dimCol
    pill.BorderSizePixel = 0
    pill.Parent = r
    mkC(pill,11)
    local knob = Instance.new("Frame")
    knob.Size = UDim2.new(0,16,0,16)
    knob.Position = st and UDim2.new(1,-19,0.5,-8) or UDim2.new(0,3,0.5,-8)
    knob.BackgroundColor3 = st and Color3.new(1,1,1) or mutedCol
    knob.BorderSizePixel = 0
    knob.Parent = pill
    mkC(knob,8)
    local hit = Instance.new("TextButton")
    hit.Size = UDim2.new(1,0,1,0)
    hit.BackgroundTransparency = 1
    hit.Text = ""
    hit.Parent = r
    local function visual()
        TweenService:Create(pill,tw(0.15),{BackgroundColor3 = st and accent or dimCol}):Play()
        TweenService:Create(knob,tw(0.15),{Position = st and UDim2.new(1,-19,0.5,-8) or UDim2.new(0,3,0.5,-8), BackgroundColor3 = st and Color3.new(1,1,1) or mutedCol}):Play()
    end
    local function updateToggle(state)
        st = state
        visual()
        pcall(callback, st)
    end
    hit.MouseButton1Click:Connect(function() updateToggle(not st) end)
    hit.TouchTap:Connect(function() updateToggle(not st) end)
    if initial then pcall(callback, true) end
    return updateToggle
end

