-- ======================== GUN MODS ========================
-- Prison Life reads gun stats from ReplicatedStorage.SharedModules.ToolProperties
-- module scripts (NOT from tool attributes). require() returns the same cached
-- table the game's GunController uses, so editing its fields changes the live gun.
Services.GunMods.Cache = {}   -- module -> { key = originalValue }

function Services.GunMods:GetPropsFolder()
    local shared = ReplicatedStorage:FindFirstChild("SharedModules")
    return shared and shared:FindFirstChild("ToolProperties")
end

function Services.GunMods:Apply()
    local folder = self:GetPropsFolder()
    if not folder then
        StatusText.Text = "Gun mods: ToolProperties not found"
        return
    end
    for _, mod in ipairs(folder:GetChildren()) do
        if mod:IsA("ModuleScript") then
            local ok, props = pcall(require, mod)
            if ok and type(props) == "table" then
                local cache = self.Cache[mod]
                if not cache then cache = {}; self.Cache[mod] = cache end
                for key, val in pairs(props) do
                    if type(val) == "number" then
                        local lk = tostring(key):lower()
                        local want, newVal
                        if lk:find("spread") or lk:find("recoil") or lk:find("kick") or lk:find("sway") then
                            want = self.NoSpread; newVal = 0
                        elseif lk:find("ammo") or lk:find("mag") or lk:find("clip") then
                            want = self.InfiniteAmmo; newVal = 9999
                        end
                        if want ~= nil then
                            if want then
                                if cache[key] == nil then cache[key] = val end
                                props[key] = newVal
                            elseif cache[key] ~= nil then
                                props[key] = cache[key]
                                cache[key] = nil
                            end
                        end
                    end
                end
            end
        end
    end
    StatusText.Text = "Gun mods updated (re-equip gun if needed)"
end

