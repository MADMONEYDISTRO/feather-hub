local function populateTeleport()
    local parent = TabFrames["Teleport"]
    -- This tab manages its own canvas size, so turn off the auto sizing
    parent.AutomaticCanvasSize = Enum.AutomaticSize.None
    -- Clear previous children
    for _, child in ipairs(parent:GetChildren()) do
        if not child:IsA("UIListLayout") and not child:IsA("UIPadding") then child:Destroy() end
    end

    -- Use a container with UIListLayout for sections
    local container = Instance.new("Frame")
    container.Size = UDim2.new(1, 0, 1, 0)
    container.BackgroundTransparency = 1
    container.Parent = parent

    local layout = Instance.new("UIListLayout")
    layout.FillDirection = Enum.FillDirection.Vertical
    layout.SortOrder = Enum.SortOrder.LayoutOrder
    layout.Padding = UDim.new(0, 8)
    layout.Parent = container
    layout:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(function()
        parent.CanvasSize = UDim2.new(0, 0, 0, math.max(600, layout.AbsoluteContentSize.Y + 20))
    end)

    -- Location section
    local locSection = Instance.new("Frame")
    locSection.Size = UDim2.new(1, 0, 0, 232)
    locSection.BackgroundColor3 = cardCol
