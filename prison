function Services.GunGrabber:GrabGun(gunName, button)
    local now = tick()
    if now - actionCooldown < cooldownDuration then
        local remaining = math.ceil(cooldownDuration - (now - actionCooldown))
        if button then
            button.Text = "Wait " .. remaining .. "s"
            task.spawn(function()
                while now - actionCooldown < cooldownDuration do
                    task.wait(1)
                    local rem = math.ceil(cooldownDuration - (tick() - actionCooldown))
                    if rem > 0 then
                        button.Text = "Wait " .. rem .. "s"
                    else
                        button.Text = "GRAB " .. gunName
                    end
                end
                button.Text = "GRAB " .. gunName
            end)
        end
        return
    end
    
    actionCooldown = now
    local char = LocalPlayer.Character
    if not char then StatusText.Text = "Error: No character"; return end
    local hrp = char:FindFirstChild("HumanoidRootPart")
    if not hrp then StatusText.Text = "Error: No HRP"; return end
    
    local buttonCF = GunButtons[gunName]
    if not buttonCF then StatusText.Text = "Error: Invalid gun"; return end
    
    local originalCF = hrp.CFrame
    StatusText.Text = "Grabbing " .. gunName .. "..."
    
    hrp.CFrame = buttonCF + Vector3.new(0, 3, 0)
    task.wait(0.1)
    
    VirtualInputManager:SendMouseButtonEvent(0, 0, 0, true, game, 0)
    VirtualInputManager:SendMouseButtonEvent(0, 0, 0, false, game, 0)
    
    for _, obj in pairs(Workspace:GetDescendants()) do
        if obj:IsA("ClickDetector") or obj:IsA("ProximityPrompt") then
            local dist = (obj.Parent.Position - buttonCF.Position).Magnitude
            if dist < 10 then
                if obj:IsA("ClickDetector") then fireclickdetector(obj)
                elseif obj:IsA("ProximityPrompt") then fireproximityprompt(obj) end
            end
        end
    end
    
    task.wait(0.3)
    hrp.CFrame = originalCF
    StatusText.Text = "Grabbed " .. gunName .. "!"
end

