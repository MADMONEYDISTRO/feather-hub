    local targetChar = player.Character
    if not targetChar then StatusText.Text = "Player not in game"; return end
    local targetHRP = targetChar:FindFirstChild("HumanoidRootPart")
    if not targetHRP then StatusText.Text = "Target has no HRP"; return end
    
    hrp.CFrame = targetHRP.CFrame + Vector3.new(0, 3, 0)
    StatusText.Text = "Teleported to " .. player.Name
end

