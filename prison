-- ======================== GROUND SPOOF (always on) ========================
-- Makes the game treat us as standing on solid ground at all times: blocks fall
-- damage and the "in air" anti-exploit flags while flying / noclipping.
local function applyGroundSpoof(char)
    local hum = char:FindFirstChildOfClass("Humanoid") or char:WaitForChild("Humanoid", 5)
    if not hum then return end
    pcall(function()
        hum:SetStateEnabled(Enum.HumanoidStateType.FallingDown, false)
        hum:SetStateEnabled(Enum.HumanoidStateType.Ragdoll, false)
    end)
    hum.StateChanged:Connect(function(_, new)
        if new == Enum.HumanoidStateType.Freefall
        or new == Enum.HumanoidStateType.FallingDown
        or new == Enum.HumanoidStateType.Ragdoll then
            pcall(function() hum:ChangeState(Enum.HumanoidStateType.Running) end)
        end
    end)
end

if LocalPlayer.Character then applyGroundSpoof(LocalPlayer.Character) end
LocalPlayer.CharacterAdded:Connect(applyGroundSpoof)

-- ======================== MAIN LOOP ========================
RunService.RenderStepped:Connect(function()
    -- ESP
    if Services.ESP.Enabled then Services.ESP:Update() end
    
    -- Aimbot
    if Services.Aimbot.Enabled then
        if Services.Aimbot.LockedTarget then
            local targetPart = Services.Aimbot.LockedTarget
            local char = targetPart and targetPart.Parent
            local humanoid = char and char:FindFirstChildOfClass("Humanoid")
            if not char or not humanoid or humanoid.Health <= 0 then
                Services.Aimbot.LockedTarget = nil
            else
                local pos = Camera:WorldToViewportPoint(targetPart.Position)
                local mousePos = UserInputService:GetMouseLocation()
                local move = (Vector2.new(pos.X, pos.Y) - mousePos) * Services.Aimbot.Smoothness
                mousemoverel(move.X, move.Y)
            end
        end
        
        if not Services.Aimbot.LockedTarget then
            local target = Services.Aimbot:GetTarget()
            if target then
                Services.Aimbot.LockedTarget = target
            end
        end
    end
    
    updateAimbotVisuals()
    
    -- Fly modes
    Services.Movement:Fly()
    Services.Movement:VehicleFly()
    
    -- Noclip
    if Services.Movement.NoclipEnabled then
        Services.Movement:EnableNoclip()
    end
    
    -- Gun mods: the live Tool carries its stats as attributes
    -- (FireRate, MaxAmmo, Spread, ...). Patch the equipped tool every frame.
    if Services.GunMods.InfiniteAmmo or Services.GunMods.NoSpread then
        local gchar = LocalPlayer.Character
        local tool = gchar and gchar:FindFirstChildOfClass("Tool")
        if tool then
            for name, val in pairs(tool:GetAttributes()) do
                local lk = tostring(name):lower()
                if type(val) == "number" then
                    if Services.GunMods.NoSpread and (lk:find("spread") or lk:find("recoil") or lk:find("kick")) then
                        tool:SetAttribute(name, 0)
                    elseif Services.GunMods.InfiniteAmmo and (lk:find("ammo") or lk:find("mag") or lk:find("clip")) then
                        tool:SetAttribute(name, 9999)
                    end
                elseif type(val) == "boolean" and Services.GunMods.InfiniteAmmo and lk:find("reload") then
                    tool:SetAttribute(name, false)  -- never stuck reloading
                end
            end
        end
    end

    -- Ground spoof reinforcement: never let the humanoid sit in a falling state
    local gchar = LocalPlayer.Character
    if gchar then
        local ghum = gchar:FindFirstChildOfClass("Humanoid")
        if ghum then
            local s = ghum:GetState()
            if s == Enum.HumanoidStateType.Freefall or s == Enum.HumanoidStateType.FallingDown then
                pcall(function() ghum:ChangeState(Enum.HumanoidStateType.Running) end)
            end
        end
    end

    -- Auto Safe / Never Die: at <=20 HP, hide in the safe zone until full HP, then return
    if Services.AutoSafe.Enabled then
        local char = LocalPlayer.Character
        local hum = char and char:FindFirstChildOfClass("Humanoid")
        local hrp = char and char:FindFirstChild("HumanoidRootPart")
        if hum and hrp and hum.Health > 0 then
            if not Services.AutoSafe.Safe then
                if hum.Health <= Services.AutoSafe.LowHP then
                    Services.AutoSafe.ReturnCFrame = hrp.CFrame   -- remember where we were
                    Services.AutoSafe.Safe = true
                end
            else
                -- pin in the safe zone while healing
                hrp.CFrame = SAFE_ZONE_CFRAME
                hrp.Velocity = Vector3.new(0, 0, 0)
                if hum.Health >= Services.AutoSafe.SafeHP then
                    if Services.AutoSafe.ReturnCFrame then
                        hrp.CFrame = Services.AutoSafe.ReturnCFrame
                    end
                    Services.AutoSafe.Safe = false
                end
            end
        end
        -- live status line under the toggle
        if autoSafeStatusLabel then
            local hp = hum and math.floor(hum.Health) or 0
            if Services.AutoSafe.Safe then
                autoSafeStatusLabel.Text = "IN SAFE ZONE - healing " .. hp .. "/" .. Services.AutoSafe.SafeHP .. " (TP Back to leave)"
            else
                autoSafeStatusLabel.Text = "Watching - HP " .. hp .. " (hides at " .. Services.AutoSafe.LowHP .. ")"
            end
        end
    elseif autoSafeStatusLabel then
        autoSafeStatusLabel.Text = "Auto Safe: off"
    end
end)

