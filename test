                ColorSequenceKeypoint.new(1, Color3.fromRGB(0, 130, 220))
            })
        else
            buttonGradient.Color = ColorSequence.new({
                ColorSequenceKeypoint.new(0, Color3.fromRGB(255, 100, 100)),
                ColorSequenceKeypoint.new(1, Color3.fromRGB(220, 20, 60))
            })
        end
    end)
    
    flightButton.MouseLeave:Connect(function()
        updateUI()
    end)
    
    flightButton.MouseButton1Click:Connect(function()
        local success = toggleFlight()
        if success ~= nil then
            flightButton.BackgroundTransparency = 0.5
            task.wait(0.1)
            flightButton.BackgroundTransparency = 0
        end
    end)
    
