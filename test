function findPlayerCar()
    local carsFolder = workspace:FindFirstChild("Cars")
    if not carsFolder then
        warn(" Cars folder not found")
        return nil
    end
    
    print(" Searching for car owned by: " .. username)
    
    for _, carModel in pairs(carsFolder:GetChildren()) do
        if carModel:IsA("Model") then
            local ownerValue = carModel:FindFirstChild("Owner")
            if ownerValue and type(ownerValue.Value) == "string" then
                if ownerValue.Value == username then
                    print(" Found car by Owner: " .. carModel.Name)
                    return carModel
                end
            end
            
            local currentDriver = carModel:FindFirstChild("CurrentDriver")
            if currentDriver and type(currentDriver.Value) == "string" then
                if currentDriver.Value == username then
                    print(" Found car by CurrentDriver: " .. carModel.Name)
                    return carModel
                end
            end
        end
    end
    
    warn(" No owned car found for: " .. username)
    return nil
end

function getPlayerVehicle()
    local character = player.Character
    if not character then return nil, nil end
    
    local humanoid = character:FindFirstChild("Humanoid")
    if not humanoid then return nil, nil end
    
    if humanoid.SeatPart then
        local seat = humanoid.SeatPart
        
        if seat.Parent and seat.Parent.Name == "Seats" then
            local carModel = seat.Parent.Parent
            if carModel and carModel:IsA("Model") then
                return carModel, seat
            end
        end
        
        local vehicleModel = seat:FindFirstAncestorOfClass("Model")
        if vehicleModel then
            return vehicleModel, seat
        end
        
        return seat, seat
    end
    
    return nil, nil
end

function holdWKey()
    if not W_KEY_HOLD then return end
    
    wKeyHeld = true
    pcall(function()
        VirtualInputManager:SendKeyEvent(true, Enum.KeyCode.W, false, nil)
        print(" Holding W key...")
    end)
end

function releaseWKey()
    if not W_KEY_HOLD or not wKeyHeld then return end
    
    wKeyHeld = false
    pcall(function()
        VirtualInputManager:SendKeyEvent(false, Enum.KeyCode.W, false, nil)
        print(" Released W key")
    end)
end

function startHover(vehicle)
    if not vehicle or not vehicle:IsA("Model") then return end
    
    local primaryPart = vehicle.PrimaryPart
    if not primaryPart then
        warn(" Vehicle has no PrimaryPart")
        return
    end
    
    originalPosition = primaryPart.Position
    
    local moveToStartTweenInfo = TweenInfo.new(1.5, Enum.EasingStyle.Quad, Enum.EasingDirection.Out)
    local moveToStartTween = TweenService:Create(primaryPart, moveToStartTweenInfo, {Position = startCFrame.Position})
    
    moveToStartTween:Play()
    moveToStartTween.Completed:Wait()
    
    print(" Car moved to start position: " .. tostring(startCFrame.Position))
    createNotification("Hover Started", "Vehicle moved to start position", "success")
    
    holdWKey()
    
    local startPos = primaryPart.Position
    hoverConnection = RunService.Heartbeat:Connect(function(deltaTime)
        if not vehicle or not vehicle.PrimaryPart then
            if hoverConnection then hoverConnection:Disconnect() end
            return
        end
        
        local time = tick() * HOVER_SPEED
        local oscillation = math.sin(time) * HOVER_DISTANCE
        
        local newPosition = Vector3.new(
            startPos.X + (oscillation * hoverDirection),
            startPos.Y + (math.sin(time * 0.5) * 2),
            startPos.Z
        )
        
        vehicle:PivotTo(CFrame.new(newPosition) * CFrame.Angles(0, math.rad(oscillation * 0.5), 0))
    end)
    
    print(" Hover animation started from specified CFrame")
end

function stopHover(vehicle)
    if hoverConnection then
        hoverConnection:Disconnect()
        hoverConnection = nil
    end
    
    releaseWKey()
    
    if vehicle and vehicle:IsA("Model") and vehicle.PrimaryPart then
        if originalPosition then
            local returnTweenInfo = TweenInfo.new(1.5, Enum.EasingStyle.Quad, Enum.EasingDirection.InOut)
            local returnTween = TweenService:Create(vehicle.PrimaryPart, returnTweenInfo, {Position = originalPosition})
            
            returnTween:Play()
            returnTween.Completed:Wait()
            
            vehicle:PivotTo(CFrame.new(originalPosition))
        end
        
        print(" Car returned to ground")
        createNotification("Hover Stopped", "Vehicle returned to ground", "warning")
    end
end

function toggleFlight()
    local ownedCar = findPlayerCar()
    local currentVehicle, seat = getPlayerVehicle()
    local vehicleToUse = ownedCar or currentVehicle
    
    if not vehicleToUse then
        createNotification("No Vehicle", "Get in a car or own one first", "error")
        return
    end
    
    if not isFlying then
        print(" Starting hover flight...")
        isFlying = true
        currentVehicle = vehicleToUse
        startHover(vehicleToUse)
        updateUI()
        return true
    else
        print(" Stopping hover flight...")
        isFlying = false
        stopHover(currentVehicle)
        currentVehicle = nil
        updateUI()
        return false
    end
end

