local function ti(t, style, dir)
    return TweenInfo.new(t or 0.3, style or Enum.EasingStyle.Quad, dir or Enum.EasingDirection.Out)
end

local function animateButton(btn, hover, normal)
    btn.MouseEnter:Connect(function()
        TweenService:Create(btn, ti(), {BackgroundColor3 = hover}):Play()
    end)
    btn.MouseLeave:Connect(function()
        TweenService:Create(btn, ti(), {BackgroundColor3 = normal}):Play()
    end)
end

