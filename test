--  UI UPDATE FUNCTION
-- ══════════════════════════════════════════

function updateUI()
    if not flightUI or not flightUI.Parent then return end
    
    local mainFrame = flightUI:FindFirstChild("MainFrame")
    if not mainFrame then return end
    
    local statusIcon = mainFrame:FindFirstChild("StatusIcon", true)
    local statusLabel = mainFrame:FindFirstChild("StatusLabel", true)
    local statusSub = mainFrame:FindFirstChild("StatusSub", true)
    local flightButton = mainFrame:FindFirstChild("FlightButton", true)
    local buttonText = flightButton and flightButton:FindFirstChild("ButtonText")
    local buttonGradient = flightButton and flightButton:FindFirstChild("UIGradient")
    
    if isFlying then
        if statusIcon then
            statusIcon.Text = "🟢"
            statusIcon.TextColor3 = colors.success
        end
        if statusLabel then
            statusLabel.Text = "SYSTEM: ACTIVE"
            statusLabel.TextColor3 = colors.success
        end
        if statusSub then
            statusSub.Text = "ALT: " .. FLIGHT_HEIGHT .. "m"
        end
        if buttonText then
            buttonText.Text = "DISENGAGE FLIGHT"
        end
        if buttonGradient then
            buttonGradient.Color = ColorSequence.new({
                ColorSequenceKeypoint.new(0, colors.error),
                ColorSequenceKeypoint.new(1, Color3.fromRGB(200, 0, 50))
            })
        end
    else
        if statusIcon then
            statusIcon.Text = ""
            statusIcon.TextColor3 = colors.warning
        end
        if statusLabel then
            statusLabel.Text = "SYSTEM: STANDBY"
            statusLabel.TextColor3 = colors.warning
        end
        if statusSub then
            statusSub.Text = "Press F to activate"
        end
        if buttonText then
            buttonText.Text = "AUTO FARM"
        end
        if buttonGradient then
            buttonGradient.Color = ColorSequence.new({
                ColorSequenceKeypoint.new(0, colors.accent),
                ColorSequenceKeypoint.new(1, Color3.fromRGB(0, 100, 200))
            })
        end
    end
end

