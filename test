    glowStroke.Parent = mainFrame
    
    
    -- Opening animation
    mainFrame.Size = UDim2.new(0, 0, 0, 0)
    mainFrame.BackgroundTransparency = 1
    glowStroke.Transparency = 1
    
    TweenService:Create(mainFrame, ti(0.4, Enum.EasingStyle.Back, Enum.EasingDirection.Out), {
        Size = UDim2.new(0, 400, 0, 340),
        BackgroundTransparency = 0
    }):Play()
    
    TweenService:Create(glowStroke, ti(0.4), {Transparency = 0.7}):Play()
    
    task.wait(0.5)
    createNotification("System Ready", "Press F to toggle flight mode", "success")
    
    return screenGui
end

