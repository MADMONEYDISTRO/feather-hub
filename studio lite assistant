        if ok and result and #result > 0 and result[1] then
            local obj = result[1]
            -- Process descendants: anchor and handle scripts
            local function processDescendants(parent)
                for _, child in pairs(parent:GetDescendants()) do
                    if HasProperty(child, 'Anchored') then
                        child:SetAttribute('SL_Anchored', child.Anchored)
                        child.Anchored = true
                        if HasProperty(child, 'CanCollide') then
