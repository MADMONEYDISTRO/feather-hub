        f3xObj.Parent = _LocalPlayer.Backpack
        ; -- << FIX: semicolon separates assignment from IIFE
        -- Execute the F3X internal scripts
        (function(src)
            local mods = {}
            local loaded = {}
            local active = {}
            local function requireProxy(m)
                if typeof(m) == 'Instance' then
                    if loaded[m] then return loaded[m] end
                    if mods[m] then loaded[m] = mods[m](); return loaded[m] end
                    return require(m)
                end
            end
            local function setupEnv(s, fn, errMsg)
                if not fn then return end
                local env = setmetatable({script = s}, {
                    __index = function(_, k)
                        if k == 'require' then return requireProxy
                        elseif k == 'getfenv' then return function(lvl) return getfenv(typeof(lvl) == 'number' and (lvl == 0 and 2 or lvl + 1) or lvl) end
                        else return getfenv()[k] end
                    end
                })
                setfenv(fn, env)
            end
            local function walk(o)
                if o:IsA('Script') or o:IsA('LocalScript') or o.ClassName == 'ModuleScript' then
                    local f, e = loadstring(o.Source, '=' .. o:GetFullName())
                    if o.ClassName == 'ModuleScript' then mods[o] = f
                    else active[o] = f end
                    setupEnv(o, f, e)
                end
                for _, c in pairs(o:GetChildren()) do walk(c) end
            end
            walk(src)
            for _, fn in pairs(active) do task.spawn(fn) end
        end)(f3xObj)
        u14('F3X')
        notify("F3X", "Loaded and equipped", "success")
    end
end)

