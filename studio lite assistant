-- Mobile drag
do
    local dragging, dragStartPos, winStartPos, activeTouch
    local function beginDrag(pos) dragging = true; dragStartPos = pos; winStartPos = win.Position end
    local function updateDrag(pos)
        if not dragging then return end
        local d = pos - dragStartPos
        local vp = Workspace.CurrentCamera.ViewportSize
        win.Position = UDim2.new(0, math.clamp(winStartPos.X.Offset + d.X, 0, vp.X - WIN_W), 0, math.clamp(winStartPos.Y.Offset + d.Y, 0, vp.Y - WIN_H))
    end
    local function endDrag() dragging = false; dragStartPos = nil; winStartPos = nil; activeTouch = nil end
    hdr.InputBegan:Connect(function(i)
        if i.UserInputType == Enum.UserInputType.MouseButton1 then beginDrag(i.Position)
        elseif i.UserInputType == Enum.UserInputType.Touch then activeTouch = i; beginDrag(i.Position)
            i.Changed:Connect(function()
                if i.UserInputState == Enum.UserInputState.Change then updateDrag(i.Position)
                elseif i.UserInputState == Enum.UserInputState.End or i.UserInputState == Enum.UserInputState.Cancel then endDrag() end
            end)
        end
    end)
    UserInputService.InputChanged:Connect(function(i)
        if dragging and not activeTouch and i.UserInputType == Enum.UserInputType.MouseMovement then updateDrag(i.Position) end
    end)
    UserInputService.InputEnded:Connect(function(i)
        if i.UserInputType == Enum.UserInputType.MouseButton1 then endDrag() end
    end)
end

