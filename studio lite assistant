                        if HasProperty(child, 'AssemblyAngularVelocity') then
                            child:SetAttribute('SL_AssemblyAngularVelocity', child.AssemblyAngularVelocity)
                        end
                    elseif child:IsA('Script') then
                        MakeScript('Script', child)
                    elseif child:IsA('LocalScript') then
                        MakeScript('LocalScript', child)
                    elseif child:IsA('ModuleScript') then
                        MakeScript('ModuleScript', child)
                    end
                end
            end
            processDescendants(obj)
            -- Handle the root object
            if obj:IsA('Script') then
                MakeScript('Script', obj)
            elseif obj:IsA('LocalScript') then
                MakeScript('LocalScript', obj)
            elseif obj:IsA('ModuleScript') then
                MakeScript('ModuleScript', obj)
            end
            if obj:IsA('Sky') then
                obj.Parent = game:GetService('Lighting')
            else
                obj.Parent = Workspace
            end
            local cf = Workspace.FlyCameraFocus.CFrame
            if obj:IsA('Model') then
                obj:MoveTo(cf.Position)
            elseif obj:IsA('Folder') then
                local p = obj.Parent
                local m = Instance.new('Model', p)
                obj.Parent = m
                m:MoveTo(cf.Position)
                obj.Parent = p
                m:Destroy()
            end
            statusLbl.Text = "Successfully Inserted"
            statusLbl.TextColor3 = T.green
            notify("Model Inserter", "Model inserted!", "success")
        else
            statusLbl.Text = "Error! Model not found."
            statusLbl.TextColor3 = T.red
            notify("Model Inserter", "Model not found", "error")
        end
    else
        statusLbl.Text = "Invalid Model ID"
        statusLbl.TextColor3 = T.red
    end
    task.delay(3, function()
        if statusLbl then statusLbl.Text = "" end
    end)
end)

