        workspace.CurrentCamera.CFrame = CFrame.lookAt(root.Position + Vector3.new(0, 8, 0), root.Position - Vector3.new(0, 10, 0))
    end
end

-- Anti-teleport (kept)
local FORBIDDEN_ZONE = Vector3.new(-40.88, 2902.75, 0.68)
local FORBIDDEN_RADIUS = 200
local function getSnapTarget() if summerMainEnabled and summerMainLockCF then return summerMainLockCF elseif summerIslandEnabled and summerIslandPathCF then return summerIslandPathCF end return nil end
local function isInForbiddenZone(pos) return (pos - FORBIDDEN_ZONE).Magnitude < FORBIDDEN_RADIUS end
local function snapBackIfForbidden() local root = getRoot(); local target = getSnapTarget() if not root or not target then return end if isInForbiddenZone(root.Position) and (root.Position - target.Position).Magnitude > 15 then root.CFrame = target end end
