-- ══════════════════════════════════════════
--  FARM LOGIC
-- ══════════════════════════════════════════

local function setStatus(txt, color)
    statusLbl.Text       = txt
    statusLbl.TextColor3 = color or C.text
end

local function tweenTo(cf, stepIdx)
    highlightStep(stepIdx)
    local t = TweenService:Create(
        root,
        TweenInfo.new(TWEEN_TIME, Enum.EasingStyle.Linear, Enum.EasingDirection.Out),
        { CFrame = cf }
    )
    t:Play()
    t.Completed:Wait()
end

local function runFarm()
    while farmEnabled do

        -- 1. Teleport to start
        highlightStep(1)
        setStatus("Teleporting to start...", C.yellow)
        root.CFrame = startCF
        task.wait(0.2)
        if not farmEnabled then break end

        -- 2. Tween waypoint 1 -> 2
        setStatus("Tweening: point 1 -> 2", C.green)
        tweenTo(secondCF, 2)
        if not farmEnabled then break end
        task.wait(DELAY_BETWEEN)

        -- 3. Tween waypoint 2 -> 3
        setStatus("Tweening: point 2 -> 3", C.green)
        tweenTo(thirdCF, 3)
        if not farmEnabled then break end
        task.wait(DELAY_BETWEEN)

        -- 4. Tween waypoint 3 -> 4
        setStatus("Tweening: point 3 -> 4", C.green)
        tweenTo(fourthCF, 4)
        if not farmEnabled then break end
        task.wait(DELAY_BETWEEN)

        -- Loop complete
        loopCount = loopCount + 1
        loopNumLbl.Text = tostring(loopCount)
        setStatus("Loop " .. loopCount .. " done - restarting", C.accent)
        highlightStep(0)
        root.CFrame = startCF
        task.wait(1)
    end

    setStatus("Idle - press ON to start", C.muted)
    highlightStep(0)
    strip.BackgroundColor3 = C.accent
end

-- ══════════════════════════════════════════
--  TOGGLE HANDLER
-- ══════════════════════════════════════════

local function setToggle(on)
    farmEnabled = on

    if on then
        TweenService:Create(pill, tw(), {BackgroundColor3 = C.green}):Play()
        TweenService:Create(knob, tw(), {
            Position         = UDim2.new(1, -28, 0.5, -12),
            BackgroundColor3 = Color3.new(1, 1, 1),
        }):Play()
        pillTxt.Text       = "ON"
        pillTxt.TextColor3 = Color3.new(1, 1, 1)
        strip.BackgroundColor3 = C.green
        farmThread = task.spawn(runFarm)
    else
        if farmThread then
            task.cancel(farmThread)
            farmThread = nil
        end
        TweenService:Create(pill, tw(), {BackgroundColor3 = C.dim}):Play()
        TweenService:Create(knob, tw(), {
            Position         = UDim2.new(0, 4, 0.5, -12),
            BackgroundColor3 = C.muted,
        }):Play()
        pillTxt.Text       = "OFF"
        pillTxt.TextColor3 = C.muted
        strip.BackgroundColor3 = C.accent
        setStatus("Idle - press ON to start", C.muted)
        highlightStep(0)
    end
end

pill.MouseButton1Click:Connect(function()
    setToggle(not farmEnabled)
end)
