local function getRealHatchCount()
    local leaderstats = player:FindFirstChild("leaderstats")
    if leaderstats then
        local hatches = leaderstats:FindFirstChild("Hatches") or leaderstats:FindFirstChild("Eggs Hatched") or leaderstats:FindFirstChild("EggsHatched") or leaderstats:FindFirstChild("Total Hatches")
        if hatches and hatches.Value then return hatches.Value end
    end
    pcall(function()
        if localData and localData.Get then
            local d = localData:Get()
            if d then
                if d.Stats and d.Stats.EggsHatched then return d.Stats.EggsHatched end
                if d.EggsHatched then return d.EggsHatched end
                if d.Hatches then return d.Hatches end
                if d.Stats and d.Stats.Hatches then return d.Stats.Hatches end
            end
        end
    end)
    for _, v in ipairs(player:GetDescendants()) do
        local n = v.Name:lower()
        if (v:IsA("IntValue") or v:IsA("NumberValue")) and (n:find("hatch") or n:find("egg")) then return v.Value end
