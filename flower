        fortuneStatusLbl.Text = "🔄 Hatching..."; fortuneStatusLbl.TextColor3 = greenAccent
        local sessionReal = getSessionHatches(); local checkVal = sessionReal or fortuneAttempts
        if fortuneTarget > 0 and checkVal >= fortuneTarget then
            fortuneEnabled = false; fortuneLockConn:Disconnect()
            if fortuneOriginCF then pcall(function() teleportTo(fortuneOriginCF) end) end
            local finalReal = getSessionHatches()
            fortuneStatusLbl.Text = ("✅ Done! %d hatched — returned"):format(finalReal or fortuneAttempts); fortuneStatusLbl.TextColor3 = goldAccent
            fortuneBtn.Text = "▶  START FORTUNE HATCH"; fortuneBtn.BackgroundColor3 = shamrockGreen
            break
        end
        task.wait(0.3)
    end
    fortuneLockConn:Disconnect()
    if not fortuneEnabled and fortuneOriginCF then pcall(function() teleportTo(fortuneOriginCF) end); fortuneStatusLbl.Text = "⏸ Stopped — returned to origin"; fortuneStatusLbl.TextColor3 = textGrey end
end

