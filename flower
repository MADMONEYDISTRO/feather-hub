end

-- ════════════════════════════════════════════════════════
--  PRIORITY QUEUE
-- ════════════════════════════════════════════════════════

local function getNextRoute()
    local now = tick()
    for _, route in ipairs(ROUTES) do
        if now >= (nextReadyAt[route.id] or 0) then return route, 0 end
    end
    local soonest, soonestTime = nil, math.huge
    for _, route in ipairs(ROUTES) do
        local ra = nextReadyAt[route.id] or 0
        if ra < soonestTime then soonestTime = ra; soonest = route end
    end
    return soonest, soonestTime - now
end

-- ════════════════════════════════════════════════════════
--  MAIN FARM LOOP
-- ════════════════════════════════════════════════════════

local function farmLoop()
    for _, route in ipairs(ROUTES) do nextReadyAt[route.id] = 0 end
    while farmEnabled do
        local route, waitTime = getNextRoute()
        if waitTime > 0 then
            setStatus(string.format("⏳ Idle %.1fs (%d retry)", waitTime, #RetrySystem.retryQueue),
                Color3.fromRGB(255,200,100))
            currentRoute = nil
            local deadline = tick() + waitTime
            while farmEnabled and tick() < deadline do
                local cr = getNextRoute()
                if cr and cr.id ~= route.id and (nextReadyAt[cr.id] or 0) <= tick() then break end
                task.wait(0.1)
            end
        end
        if farmEnabled then
            local nextRoute = getNextRoute()
            if nextRoute then
                currentRoute = nextRoute; runRoute(nextRoute); currentRoute = nil
            end
        end
    end
    currentRoute = nil
    setStatus("⏸ Idle – Press Start", Color3.fromRGB(200,200,200))
    highlightRoute(0)
end

