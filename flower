local function startEasterMainLock()
    if easterMainLockConn then easterMainLockConn:Disconnect() end
    easterMainLockConn = RunService.Heartbeat:Connect(function()
        if not easterMainEnabled then
            easterMainLockConn:Disconnect()
            easterMainLockConn = nil
            easterMainLockCF   = nil
            return
        end
        if easterMainLockCF then
            local root = getRoot()
            if root then
                local dist = (root.Position - easterMainLockCF.Position).Magnitude
                if dist > 5 then
                    root.CFrame = easterMainLockCF
                    easterMainStatusLbl.Text       = "⚠️ Out of range — snapping back..."
                    easterMainStatusLbl.TextColor3 = Color3.fromRGB(255,200,50)
                end
            end
        end
    end)
end

local function stopEasterMainLock()
    easterMainLockCF = nil
    if easterMainLockConn then
        easterMainLockConn:Disconnect()
        easterMainLockConn = nil
    end
    pcall(function()
        local char = player.Character
        if char then
            local hum = char:FindFirstChildOfClass("Humanoid")
            local root = char:FindFirstChild("HumanoidRootPart")
            if hum then
                hum.WalkSpeed   = 16
                hum.JumpPower   = 50
                hum.AutoRotate  = true
            end
            if root then
                root.Anchored = false
            end
        end
    end)
end

local function easterMainLoop()
    easterCollected = 0
    startEasterMainLock()

    while easterMainEnabled and sg.Parent do
        local items = getEasterMainItems()

        if #items == 0 then
            easterMainStatusLbl.Text       = "🔍 Scanning for Easter items..."
            easterMainStatusLbl.TextColor3 = Color3.fromRGB(200,200,100)
            task.wait(0.8)
        else
            easterMainStatusLbl.Text       = ("🐣 Farming %d items..."):format(#items)
            easterMainStatusLbl.TextColor3 = easterPink

            for _, cf in ipairs(items) do
                if not easterMainEnabled then break end
                easterMainLockCF = cf

                pcall(function()
                    local root = getRoot()
                    if root then root.CFrame = cf end
                end)

                easterCollected = easterCollected + 1
                easterMainCountLbl.Text = ("Collected: %d"):format(easterCollected)

                task.wait(0.07)
            end

            task.wait(0.4)
        end
    end

    stopEasterMainLock()
end

