-- ════════════════════════════════════════════════════════
--  MOVEMENT
-- ════════════════════════════════════════════════════════

local function moveToPosition(targetCF, duration)
    local root = getRoot()
    if speedMode == "INSTANT" then
        root.CFrame = targetCF; task.wait(0.1)
    elseif speedMode == "FAST" then
        local t = TweenService:Create(root, TweenInfo.new(duration or 0.5, Enum.EasingStyle.Linear), {CFrame=targetCF})
        t:Play(); t.Completed:Wait(); task.wait(interactionDelay)
    else
        local t = TweenService:Create(root, TweenInfo.new(duration or 1.5, Enum.EasingStyle.Linear), {CFrame=targetCF})
        t:Play(); t.Completed:Wait(); task.wait(interactionDelay + 0.2)
    end
end

-- ════════════════════════════════════════════════════════
--  ROUTE EXECUTION
-- ════════════════════════════════════════════════════════

local function runRoute(route)
    if not farmEnabled then return end
    highlightRoute(route.id)
    setStatus("🌱 Farming "..route.name.."...", route.color)
    nextReadyAt[route.id] = tick() + route.cooldown

    for i, wp in ipairs(route.waypoints) do
        if not farmEnabled then break end
        setStatus(string.format("%s: point %d/%d", route.name, i, #route.waypoints), route.color)
        moveToPosition(wp, speedMode=="SAFE" and 1.5 or 0.5)
        task.wait(0.2)
        if not verifySpot(wp) then
            markForRetry(wp, route.id)
            setStatus(string.format("⚠ %s pt %d → retry", route.name, i), Color3.fromRGB(255,200,100))
        else
            markSuccessful(wp)
        end
        updateUI()
    end

    routeCounts[route.id] = routeCounts[route.id] + 1
    totalCycles = totalCycles + 1
    updateUI(); highlightRoute(0)
end

-- ════════════════════════════════════════════════════════
--  RETRY LOOP
-- ════════════════════════════════════════════════════════

local function retryLoop()
    while farmEnabled do
        if #RetrySystem.retryQueue > 0 and currentRoute == nil then
            local spot = getNextRetrySpot()
            if spot then
                setStatus(string.format(" Retry attempt %d/%d", spot.failCount, RetrySystem.maxRetries),
                    Color3.fromRGB(255,200,100))
                local ok = retrySpot(spot)
                setStatus(ok and " Retry OK!" or " Retry failed – queued again",
                    ok and Color3.fromRGB(100,255,100) or Color3.fromRGB(255,150,50))
                updateUI(); task.wait(1)
            end
        end
        task.wait(0.5)
    end
end

