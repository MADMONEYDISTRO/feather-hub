-- Main Easter collectibles (anywhere, no Y filter)
local function getEasterMainItems()
    local found = {}
    local seen  = {}
    local searchRoot = workspace:FindFirstChild("Rendered") or workspace

    for _, obj in ipairs(searchRoot:GetDescendants()) do
        local cf = nil

        if (obj:IsA("BasePart") or obj:IsA("MeshPart")) and not seen[obj] then
            if EASTER_MAIN_NAMES[obj.Name] then
                seen[obj] = true
                cf = obj.CFrame
            end
        elseif obj:IsA("Model") and EASTER_MAIN_NAMES[obj.Name] and not seen[obj] then
            seen[obj] = true
            if obj.PrimaryPart then
                cf = obj.PrimaryPart.CFrame
            else
                local ok, pivot = pcall(function() return obj:GetPivot() end)
                if ok and pivot then
                    cf = pivot
                else
                    for _, child in ipairs(obj:GetDescendants()) do
                        if child:IsA("BasePart") then cf = child.CFrame; break end
                    end
                end
            end
        end

        if cf then table.insert(found, cf) end
    end

    return found
end

-- Easter Island collectibles: ANY object (Part/Model) with name matching any GUID, and Y > 10000
local function getEasterIslandItems()
    local found = {}
    local seen  = {}
    local searchRoot = workspace

    for _, obj in ipairs(searchRoot:GetDescendants()) do
        if not seen[obj] and (obj:IsA("BasePart") or obj:IsA("MeshPart") or obj:IsA("Model")) then
            if ISLAND_GUID_SET[obj.Name] then
                seen[obj] = true
                local cf = nil
                if obj:IsA("BasePart") then
                    cf = obj.CFrame
                elseif obj:IsA("Model") then
                    if obj.PrimaryPart then
                        cf = obj.PrimaryPart.CFrame
                    else
                        local ok, pivot = pcall(function() return obj:GetPivot() end)
                        if ok and pivot then
                            cf = pivot
                        else
                            for _, child in ipairs(obj:GetDescendants()) do
                                if child:IsA("BasePart") then cf = child.CFrame; break end
                            end
                        end
                    end
                end

                if cf and cf.Y > 10000 then
                    table.insert(found, cf)
                end
            end
        end
    end

    return found
end

