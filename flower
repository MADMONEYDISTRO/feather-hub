    local function getSessionHatches() local cur = getRealHatchCount(); if cur then return math.max(0, cur - fortuneHatchSnapshot) end; return nil end
    local function updateCounter()
        local real = getSessionHatches()
        if real then fortuneCountLbl.Text = ("Session hatches: %d  |  Attempts: %d"):format(real, fortuneAttempts); fortuneCountLbl.TextColor3 = greenAccent
        else fortuneCountLbl.Text = ("Attempts: %d  (leaderboard unreadable)"):format(fortuneAttempts); fortuneCountLbl.TextColor3 = Color3.fromRGB(200,200,100) end
    end
    fortuneLockConn = RunService.Heartbeat:Connect(function()
        if not fortuneEnabled then return end
        local root = getRoot()
        if root and (root.Position - FORTUNE_EGG_CF.Position).Magnitude > 10 then root.CFrame = FORTUNE_EGG_CF; fortuneStatusLbl.Text = "⚠️ Out of range — snapping back..."; fortuneStatusLbl.TextColor3 = Color3.fromRGB(255,200,50) end
    end)
    while fortuneEnabled and sg.Parent do
