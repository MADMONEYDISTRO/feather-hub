local function getRoot()
    local char = player.Character
    return char and char:FindFirstChild("HumanoidRootPart")
end

local function getHumanoid()
    local char = player.Character
    return char and char:FindFirstChildOfClass("Humanoid")
end

local function saveOrigin()
    local root = getRoot()
    return root and root.CFrame or nil
end

local function teleportTo(cf)
    local root = getRoot()
    if root then root.CFrame = cf end
end

-- Smooth tween with humanoid control and distance‑based duration
local function tweenTo(targetCF, duration)
    local root = getRoot()
    local hum = getHumanoid()
    if not root or not hum then return false end

    -- Store original settings
    local originalWalkSpeed = hum.WalkSpeed
    local originalAutoRotate = hum.AutoRotate
    local originalPlatform = hum.PlatformStand

    -- Disable humanoid movement
    hum.WalkSpeed = 0
    hum.AutoRotate = false
    hum.PlatformStand = true
    root.Anchored = false

    -- If no duration given, compute based on distance (0.3s per 100 studs, min 0.2s)
    if not duration then
        local dist = (root.Position - targetCF.Position).Magnitude
        duration = math.max(0.2, dist / 100 * 0.3)
    end

    local tween = TweenService:Create(root, TweenInfo.new(duration, Enum.EasingStyle.Linear), {CFrame = targetCF})
    tween:Play()
    tween.Completed:Wait()

    -- Restore settings
    hum.WalkSpeed = originalWalkSpeed
    hum.AutoRotate = originalAutoRotate
    hum.PlatformStand = originalPlatform

    return true
end

-- ════════════════════════════════════════════════════════
--  GLOBAL ANTI-TELEPORT SYSTEM (with tolerance)
-- ════════════════════════════════════════════════════════

local FORBIDDEN_ZONE   = Vector3.new(-40.88, 2902.75, 0.68)
local FORBIDDEN_RADIUS = 200

local function getSnapTarget()
    if easterMainEnabled  and easterMainLockCF   then return easterMainLockCF   end
    if easterIslandEnabled and easterIslandPathCF then return easterIslandPathCF end
    return nil
end

local function isInForbiddenZone(pos)
    return (pos - FORBIDDEN_ZONE).Magnitude < FORBIDDEN_RADIUS
end

local function snapBackIfForbidden()
    local root   = getRoot()
    local target = getSnapTarget()
    if not root or not target then return end

    local dist = (root.Position - target.Position).Magnitude
    -- Only snap if we're far away (>15 studs) AND in forbidden zone
    -- This allows tweens to run without interruption
    if isInForbiddenZone(root.Position) and dist > 15 then
        root.CFrame = target
    end
end

RunService.Heartbeat:Connect(function()
    if not (easterMainEnabled or easterIslandEnabled) then return end
    snapBackIfForbidden()
end)

local rootChangedConn = nil

local function hookRootChanged(char)
    if rootChangedConn then rootChangedConn:Disconnect(); rootChangedConn = nil end
    local root = char and char:WaitForChild("HumanoidRootPart", 5)
    if not root then return end
    rootChangedConn = root:GetPropertyChangedSignal("CFrame"):Connect(function()
        if not (easterMainEnabled or easterIslandEnabled) then return end
        task.defer(snapBackIfForbidden)
    end)
end

if player.Character then
    hookRootChanged(player.Character)
end

player.CharacterAdded:Connect(function(char)
    task.wait(0.1)
    hookRootChanged(char)
    local target = getSnapTarget()
    if target then
        local root = char:WaitForChild("HumanoidRootPart", 5)
        if root then
            task.wait(0.2)
            root.CFrame = target
        end
    end
end)

task.spawn(function()
    while true do
        task.wait(0.1)
        if easterMainEnabled or easterIslandEnabled then
            snapBackIfForbidden()
        end
    end
end)

