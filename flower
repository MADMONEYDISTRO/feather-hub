local currentWaypointIndex = 1

-- Main roaming loop (tween between waypoints, and also tween to GUID items)
local function startRoaming()
    while easterIslandEnabled and sg.Parent do
        -- Check for GUID collectibles and tween to them
        local guidItems = getEasterIslandItems()
        if #guidItems > 0 then
            islandStatusLbl.Text = "✨ Collecting GUID items..."
            for _, cf in ipairs(guidItems) do
                if not easterIslandEnabled then break end
                easterIslandPathCF = cf
                tweenTo(cf, 0.15)  -- tween fast to the item
                islandCollected = islandCollected + 1
                islandCountLbl.Text = ("Collected: %d"):format(islandCollected)
                task.wait(0.1)
            end
            task.wait(0.2)
            -- After collecting, resume waypoint path from current index
            easterIslandPathCF = WAYPOINTS[currentWaypointIndex]
            continue
        end

        -- Follow the waypoint path
        if not easterIslandEnabled then break end

        local targetCF = WAYPOINTS[currentWaypointIndex]
        easterIslandPathCF = targetCF

        islandStatusLbl.Text = string.format("🏝️ Waypoint %d/%d", currentWaypointIndex, #WAYPOINTS)
        tweenTo(targetCF)  -- distance‑based duration

        -- Move to next waypoint, loop back to start at the end
        currentWaypointIndex = currentWaypointIndex + 1
        if currentWaypointIndex > #WAYPOINTS then
            currentWaypointIndex = 1
        end

        task.wait(0.05)  -- small pause between moves
    end
end

local function startIslandRoam()
    currentWaypointIndex = 1
    islandCollected = 0
    islandCountLbl.Text = "Collected: 0"
    islandStatusLbl.Text = "🏝️ Starting waypoint path..."

    -- Tween to first waypoint
    local firstCF = WAYPOINTS[1]
    easterIslandPathCF = firstCF
    tweenTo(firstCF)

    -- Start the roaming loop
    startRoaming()
end

