local function highlightStep(idx)
    for i, obj in ipairs(stepObjs) do
        local on = (i == idx)
        TweenService:Create(obj.frame, tw(0.15), {BackgroundColor3 = on and C.accentD or C.panel}):Play()
        TweenService:Create(obj.num,   tw(0.15), {TextColor3 = on and C.text or C.muted}):Play()
        TweenService:Create(obj.name,  tw(0.15), {TextColor3 = on and C.text or C.muted}):Play()
    end
end

