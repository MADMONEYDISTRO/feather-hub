-- Helper: check if any ancestor of obj has a name in the skip table
local function hasSkippedAncestor(obj)
    local ancestor = obj.Parent
    while ancestor and ancestor ~= workspace do
        if DEFAULT_SKIP_ANCESTORS[ancestor.Name] then
            return true
        end
        ancestor = ancestor.Parent
    end
    return false
end

local function getCoins()
    local found = {}
    local seen  = {}
    local searchRoot = workspace:FindFirstChild("Rendered") or workspace

    for _, obj in ipairs(searchRoot:GetDescendants()) do
        local cf = nil

        if (obj:IsA("BasePart") or obj:IsA("MeshPart")) and not seen[obj] then
            if STPATRICK_NAMES[obj.Name] then
                -- For "default" parts, skip if under Lucky Trophy or Lucky Token
                local skip = false
                if obj.Name == "default" then
                    skip = hasSkippedAncestor(obj)
                end

                if not skip then
                    -- St. Patrick — collect at any elevation
                    seen[obj] = true
                    cf = obj.CFrame
                end
            elseif GENIE_NAMES[obj.Name] and obj.Position.Y > GENIE_MIN_Y then
                seen[obj] = true
                cf = obj.CFrame
            end

        elseif obj:IsA("Model") and COLLECTIBLE_MODELS[obj.Name] and not seen[obj] then
            seen[obj] = true
            if obj.PrimaryPart then
                cf = obj.PrimaryPart.CFrame
            else
                local ok, pivot = pcall(function() return obj:GetPivot() end)
                if ok and pivot then
                    cf = pivot
                else
                    for _, child in ipairs(obj:GetDescendants()) do
                        if child:IsA("BasePart") then cf = child.CFrame; break end
                    end
                end
            end
        end

        if cf then table.insert(found, cf) end
    end

    return found
end

