-- ════════════════════════════════════════════════════════

local function setStatus(txt, col)
    if statusText then
        statusText.Text = txt
        if col then
            statusText.TextColor3 = col
        end
    end
end

local function highlightRoute(id)
    for i, card in ipairs(routeCards) do
        card.frame.BackgroundColor3 = (i == id) and accentGrey or darkGrey
    end
end

local function updateUI()
    for i in ipairs(ROUTES) do
        if routeCards[i] and routeCards[i].count then
            routeCards[i].count.Text = routeCounts[i] .. "x"
        end
    end
    if cyclesLabel then cyclesLabel.Text = "Total runs: " .. totalCycles end
    if modeLabel then modeLabel.Text = "Mode: " .. speedMode end
    if retryInfo then retryInfo.Text = string.format("Retry Queue: %d spots", #RetrySystem.retryQueue) end
    if wheelCountLbl then wheelCountLbl.Text = "Spins this session: " .. wheelSpins end
    
    if staffListLbl then
        if #currentServerStaff > 0 then
            staffListLbl.Text = "Staff in server: " .. table.concat(currentServerStaff, ", ")
            staffListLbl.TextColor3 = Color3.fromRGB(255, 100, 100)
            staffIndicator.BackgroundColor3 = staffWatchEnabled and Color3.fromRGB(255, 0, 0) or Color3.fromRGB(100, 100, 100)
        else
            staffListLbl.Text = "Staff in server: None"
            staffListLbl.TextColor3 = Color3.fromRGB(100, 255, 100)
            staffIndicator.BackgroundColor3 = staffWatchEnabled and Color3.fromRGB(0, 255, 0) or Color3.fromRGB(100, 100, 100)
        end
    end
end

-- ════════════════════════════════════════════════════════
--  MOVEMENT
-- ════════════════════════════════════════════════════════

local function moveToPosition(targetCF, duration)
    local root = getRoot()
    if not root then return end
    
    if speedMode == "INSTANT" then
        root.CFrame = targetCF
        task.wait(0.1)
    elseif speedMode == "FAST" then
        local t = TweenService:Create(root, TweenInfo.new(duration or 0.5, Enum.EasingStyle.Linear), {CFrame = targetCF})
        t:Play()
        t.Completed:Wait()
        task.wait(interactionDelay)
    else
        local t = TweenService:Create(root, TweenInfo.new(duration or 1.5, Enum.EasingStyle.Linear), {CFrame = targetCF})
        t:Play()
        t.Completed:Wait()
        task.wait(interactionDelay + 0.2)
    end
end

-- ════════════════════════════════════════════════════════
--  ROUTE EXECUTION
-- ════════════════════════════════════════════════════════

local function runRoute(route)
    if not farmEnabled then return end
    highlightRoute(route.id)
    setStatus(" Farming " .. route.name .. "...", route.color)
    nextReadyAt[route.id] = tick() + route.cooldown

    for i, wp in ipairs(route.waypoints) do
        if not farmEnabled then break end
        setStatus(string.format("%s: point %d/%d", route.name, i, #route.waypoints), route.color)
        moveToPosition(wp, speedMode == "SAFE" and 1.5 or 0.5)
        task.wait(0.2)
        if not verifySpot(wp) then
            markForRetry(wp, route.id)
            setStatus(string.format(" %s pt %d → retry", route.name, i), Color3.fromRGB(255, 200, 100))
        else
            markSuccessful(wp)
        end
        updateUI()
    end

    routeCounts[route.id] = routeCounts[route.id] + 1
    totalCycles = totalCycles + 1
    updateUI()
    highlightRoute(0)
end

-- ════════════════════════════════════════════════════════
--  RETRY LOOP
-- ════════════════════════════════════════════════════════

local function retryLoop()
    while farmEnabled do
        if #RetrySystem.retryQueue > 0 and currentRoute == nil then
            local spot = getNextRetrySpot()
            if spot then
                setStatus(string.format("Retry attempt %d/%d", spot.failCount, RetrySystem.maxRetries),
                    Color3.fromRGB(255, 200, 100))
                local ok = retrySpot(spot)
                setStatus(ok and " Retry OK!" or "Retry failed – queued again",
                    ok and Color3.fromRGB(100, 255, 100) or Color3.fromRGB(255, 150, 50))
                updateUI()
                task.wait(1)
            end
        end
        task.wait(0.5)
    end
end

-- ════════════════════════════════════════════════════════
--  WHEEL SPIN LOOP
-- ════════════════════════════════════════════════════════

local function wheelLoop()
    while farmEnabled do
        if autoWheelValue then
            pcall(function()
                if FunctionHandler then
                    FunctionHandler:InvokeServer("SpringWheelSpin")
                end
                task.wait(0.5)
                if EventHandler then
                    EventHandler:FireServer("ClaimSpringWheelSpinQueue")
                end
                wheelSpins = wheelSpins + 1
                updateUI()
            end)
            task.wait(1)
        else
            task.wait(0.5)
        end
    end
end

-- ════════════════════════════════════════════════════════
--  PRIORITY QUEUE
-- ════════════════════════════════════════════════════════

local function getNextRoute()
    local now = tick()
    for _, route in ipairs(ROUTES) do
        if now >= (nextReadyAt[route.id] or 0) then
            return route, 0
        end
    end
    local soonest, soonestTime = nil, math.huge
    for _, route in ipairs(ROUTES) do
        local ra = nextReadyAt[route.id] or 0
        if ra < soonestTime then
            soonestTime = ra
            soonest = route
        end
    end
    return soonest, soonestTime - now
end

-- ════════════════════════════════════════════════════════
--  MAIN FARM LOOP
-- ════════════════════════════════════════════════════════

local function farmLoop()
    for _, route in ipairs(ROUTES) do
        nextReadyAt[route.id] = 0
    end
    while farmEnabled do
        local route, waitTime = getNextRoute()
        if waitTime > 0 then
            setStatus(string.format("Idle %.1fs (%d retry)", waitTime, #RetrySystem.retryQueue),
                Color3.fromRGB(255, 200, 100))
            currentRoute = nil
            local deadline = tick() + waitTime
            while farmEnabled and tick() < deadline do
                local cr = getNextRoute()
                if cr and cr.id ~= route.id and (nextReadyAt[cr.id] or 0) <= tick() then
                    break
                end
                task.wait(0.1)
            end
        end
        if farmEnabled then
            local nextRoute = getNextRoute()
            if nextRoute then
                currentRoute = nextRoute
                runRoute(nextRoute)
                currentRoute = nil
            end
        end
    end
    currentRoute = nil
    setStatus("⏸ Idle – Press Start", Color3.fromRGB(200, 200, 200))
    highlightRoute(0)
end

