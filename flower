-- Restore normal walking after stopping
local function restoreWalking()
    local hum = getHumanoid()
    if hum then
        hum.WalkSpeed = 16
        hum.AutoRotate = true
        hum.PlatformStand = false
    end
end

local function tweenTo(targetCF, duration)
    local root = getRoot()
    local hum  = getHumanoid()
    if not root or not hum then return false end
    local origWalk = hum.WalkSpeed; local origRotate = hum.AutoRotate; local origPlatform = hum.PlatformStand
    hum.WalkSpeed = 0; hum.AutoRotate = false; hum.PlatformStand = true; root.Anchored = false
    if not duration then local dist = (root.Position - targetCF.Position).Magnitude duration = math.max(0.2, dist / 100 * 0.3) end
    local tween = TweenService:Create(root, TweenInfo.new(duration, Enum.EasingStyle.Linear), {CFrame = targetCF})
    tween:Play(); tween.Completed:Wait()
    hum.WalkSpeed = origWalk; hum.AutoRotate = origRotate; hum.PlatformStand = origPlatform
    return true
end

local function orbitPoint(centerCF, radius, steps, stepTime)
    local root = getRoot(); local hum = getHumanoid()
    if not root or not hum then return end
    local origWalk = hum.WalkSpeed; hum.WalkSpeed = 0
    for i = 1, steps do
        if not metalEnabled then break end
        local angle = (i / steps) * math.pi * 2
        local offset = Vector3.new(math.cos(angle) * radius, 0, math.sin(angle) * radius)
        local target = centerCF + offset
        local tween = TweenService:Create(root, TweenInfo.new(stepTime, Enum.EasingStyle.Linear), {CFrame = target})
        tween:Play(); tween.Completed:Wait()
    end
    hum.WalkSpeed = origWalk
end

