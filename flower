    Instance.new("UICorner", sf).CornerRadius = UDim.new(0, 8)

    local numL = Instance.new("TextLabel")
    numL.Size               = UDim2.new(1, 0, 0, 18)
    numL.Position           = UDim2.new(0, 0, 0, 5)
    numL.Text               = s.short
    numL.Font               = Enum.Font.GothamBold
    numL.TextSize           = 13
    numL.TextColor3         = C.muted
    numL.BackgroundTransparency = 1
    numL.ZIndex             = 5
    numL.Parent             = sf

    local nameL = Instance.new("TextLabel")
    nameL.Size               = UDim2.new(1, -4, 0, 12)
    nameL.Position           = UDim2.new(0, 2, 0, 26)
    nameL.Text               = s.label
    nameL.Font               = Enum.Font.Gotham
    nameL.TextSize           = 9
    nameL.TextColor3         = C.muted
