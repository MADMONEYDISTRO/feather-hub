local function mkToggle(parent, yOff, label, default)
    local rowH = isMobile and 32 or 24
    local row = Instance.new("Frame")
    row.Size                = UDim2.new(1,-16,0,rowH)
    row.Position            = UDim2.new(0,8,0,yOff)
    row.BackgroundTransparency = 1
    row.Parent              = parent

    local lbl = Instance.new("TextLabel")
    lbl.Size              = UDim2.new(1,-44,1,0)
    lbl.BackgroundTransparency = 1
    lbl.Font              = Enum.Font.Gotham
    lbl.TextSize          = 11
    lbl.TextColor3        = textGrey
    lbl.TextXAlignment    = Enum.TextXAlignment.Left
    lbl.Text              = label
    lbl.TextTruncate      = Enum.TextTruncate.AtEnd
    lbl.Parent            = row

    local track = Instance.new("Frame")
    track.Size             = UDim2.new(0,32,0,18)
    track.Position         = UDim2.new(1,-32,0.5,-9)
    track.BackgroundColor3 = default and accentGrey or darkGrey
    track.BorderSizePixel  = 0
    track.Parent           = row
    mkCorner(track,9)

    local knob = Instance.new("Frame")
    knob.Size             = UDim2.new(0,14,0,14)
    knob.Position         = default and UDim2.new(0,16,0.5,-7) or UDim2.new(0,2,0.5,-7)
    knob.BackgroundColor3 = default and Color3.new(1,1,1) or textGrey
    knob.BorderSizePixel  = 0
    knob.Parent           = track
    mkCorner(knob,7)

    local state = default or false
    local cbs   = {}

    local hit = Instance.new("TextButton")
    hit.Size               = UDim2.new(1,0,1,0)
    hit.BackgroundTransparency = 1
    hit.Text               = ""
    hit.Parent             = track
    hit.MouseButton1Click:Connect(function()
        state = not state
        track.BackgroundColor3 = state and accentGrey or darkGrey
        knob.Position          = state and UDim2.new(0,16,0.5,-7) or UDim2.new(0,2,0.5,-7)
        knob.BackgroundColor3  = state and Color3.new(1,1,1) or textGrey
        for _, cb in ipairs(cbs) do pcall(cb,state) end
    end)

    return {
        onChanged = function(_, cb) table.insert(cbs,cb) end,
        getState  = function() return state end,
        setState  = function(_, v)
            if state==v then return end
            state = v
            track.BackgroundColor3 = state and accentGrey or darkGrey
            knob.Position          = state and UDim2.new(0,16,0.5,-7) or UDim2.new(0,2,0.5,-7)
            knob.BackgroundColor3  = state and Color3.new(1,1,1) or textGrey
            for _, cb in ipairs(cbs) do pcall(cb,state) end
        end,
    }
end

