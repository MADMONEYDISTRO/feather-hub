local function getServers()
    local ok, res = pcall(function()
        local url = ("https://games.roblox.com/v1/games/%d/servers/Public?limit=100"):format(currentPlaceId)
        return HttpService:JSONDecode(game:HttpGetAsync(url))
    end)
    return (ok and res and res.data) or {}
end

local function serverHop()
    task.wait(0.5)
    local servers = getServers()
    local avail   = {}
    for _, s in ipairs(servers) do
        if s.id ~= game.JobId and s.playing < s.maxPlayers then
            table.insert(avail, s)
        end
    end
    if #avail > 0 then
        TeleportService:TeleportToPlaceInstance(currentPlaceId, avail[math.random(1,#avail)].id, player)
    end
end

local function rejoin()
    task.wait(0.5)
    TeleportService:Teleport(currentPlaceId, player)
end

