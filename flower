-- Helpers
local function getRoot() local char = player.Character return char and char:FindFirstChild("HumanoidRootPart") end
local function getHumanoid() local char = player.Character return char and char:FindFirstChildOfClass("Humanoid") end
local function saveOrigin() local root = getRoot() return root and root.CFrame or nil end
