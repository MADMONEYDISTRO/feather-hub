-- ════════════════════════════════════════════════════════
--  RETRY SYSTEM
-- ════════════════════════════════════════════════════════

local RetrySystem = {
    retryQueue = {},
    successfulSpots = {},
    failedSpots = {},
    maxRetries = 3,
    retryCooldown = 2,
    lastRetryTime = {},
}

local function getRoot()
    local char = player.Character or player.CharacterAdded:Wait()
    return char:WaitForChild("HumanoidRootPart")
end

local function verifySpot(wp)
    local char = player.Character
    if not char then return false end
    local root = char:FindFirstChild("HumanoidRootPart")
    return root and (root.Position - wp.Position).Magnitude < 8
end

local function markForRetry(wp, routeId)
    local key = tostring(wp)
    RetrySystem.failedSpots[key] = (RetrySystem.failedSpots[key] or 0) + 1
    if RetrySystem.failedSpots[key] > RetrySystem.maxRetries then return end
    for _, item in ipairs(RetrySystem.retryQueue) do
        if tostring(item.waypoint) == key then return end
    end
    table.insert(RetrySystem.retryQueue, {
        waypoint = wp, routeId = routeId,
        failCount = RetrySystem.failedSpots[key], addedTime = tick()
    })
end

local function markSuccessful(wp)
    local key = tostring(wp)
    RetrySystem.failedSpots[key] = nil
    for i = #RetrySystem.retryQueue, 1, -1 do
        if tostring(RetrySystem.retryQueue[i].waypoint) == key then
            table.remove(RetrySystem.retryQueue, i)
        end
    end
end

local function getNextRetrySpot()
    local now = tick()
    for i, spot in ipairs(RetrySystem.retryQueue) do
        local last = RetrySystem.lastRetryTime[tostring(spot.waypoint)] or 0
        if now - last >= RetrySystem.retryCooldown then
            table.remove(RetrySystem.retryQueue, i)
            if verifySpot(spot.waypoint) then
                markSuccessful(spot.waypoint)
                return nil
            end
            return spot
        end
    end
end

local function retrySpot(spot)
    RetrySystem.lastRetryTime[tostring(spot.waypoint)] = tick()
    getRoot().CFrame = spot.waypoint
    task.wait(0.2)
    if verifySpot(spot.waypoint) then
        markSuccessful(spot.waypoint)
        return true
    end
    return false
end

