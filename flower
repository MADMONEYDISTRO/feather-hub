--  STAFF WATCH SYSTEM
-- ════════════════════════════════════════════════════════

local function isStaffUser(username)
    username = username:lower()
    for _, s in ipairs(STAFF_LIST) do
        if s:lower()==username then return true end
    end
    for _, kw in ipairs(BANNED_KEYWORDS) do
        if username:find(kw,1,true) then return true end
    end
    return false
end

function checkForStaff()
    local now = tick()
    if now - lastStaffCheck < checkInterval then return currentServerStaff end
    lastStaffCheck = now

    local found = {}
    for _, plr in ipairs(Players:GetPlayers()) do
        if plr~=player and isStaffUser(plr.Name) then
            table.insert(found, plr.Name)
        end
    end
    currentServerStaff = found

    if staffListLbl then
        if #found > 0 then
            staffListLbl.Text      = "Staff in server:\n"..table.concat(found,", ")
            staffListLbl.TextColor3 = Color3.fromRGB(255,100,100)
            staffIndicator.BackgroundColor3 = staffWatchEnabled and Color3.fromRGB(255,0,0) or Color3.fromRGB(100,100,100)
        else
            staffListLbl.Text      = "Staff in server: None"
            staffListLbl.TextColor3 = Color3.fromRGB(100,255,100)
            staffIndicator.BackgroundColor3 = staffWatchEnabled and Color3.fromRGB(0,255,0) or Color3.fromRGB(100,100,100)
        end
    end

    if #found>0 and autoServerHop and not notificationShown then
        staffDetected     = true
        notificationShown = true

        local notif = Instance.new("Frame")
        notif.Size             = UDim2.new(0,300,0,120)
        notif.Position         = UDim2.new(0.5,-150,0.2,0)
        notif.BackgroundColor3 = Color3.fromRGB(200,50,50)
        notif.BackgroundTransparency = 0.1
        notif.BorderSizePixel  = 0
        notif.Parent           = sg
        notif.ZIndex           = 100
        mkCorner(notif,8)

        local notifText = Instance.new("TextLabel")
        notifText.Size               = UDim2.new(1,-20,1,-40)
        notifText.Position           = UDim2.new(0,10,0,10)
        notifText.BackgroundTransparency = 1
        notifText.Text               = ("⚠️ STAFF DETECTED ⚠️\n%s\nHopping in %d..."):format(table.concat(found,", "),hopDelay)
        notifText.TextColor3         = Color3.new(1,1,1)
        notifText.TextSize           = 13
        notifText.Font               = Enum.Font.GothamBold
        notifText.TextWrapped        = true
        notifText.Parent             = notif
        notifText.ZIndex             = 101

        local cancelB = Instance.new("TextButton")
        cancelB.Size             = UDim2.new(0,70,0,26)
        cancelB.Position         = UDim2.new(0.5,-35,1,-32)
        cancelB.BackgroundColor3 = Color3.fromRGB(90,90,90)
        cancelB.Text             = "Cancel"
        cancelB.TextColor3       = Color3.new(1,1,1)
        cancelB.Font             = Enum.Font.GothamBold
        cancelB.TextSize         = 11
        cancelB.Parent           = notif
        cancelB.ZIndex           = 101
        mkCorner(cancelB,4)
        cancelB.MouseButton1Click:Connect(function()
            notif:Destroy()
            notificationShown = false
            staffDetected     = false
        end)

        task.spawn(function()
            for i = hopDelay,1,-1 do
                if not notificationShown then break end
                notifText.Text = ("⚠️ STAFF DETECTED ⚠️\n%s\nHopping in %d..."):format(table.concat(found,", "),i)
                task.wait(1)
            end
            if notificationShown then
                notif:Destroy()
                serverHop()
            end
        end)
    elseif #found==0 then
        staffDetected     = false
        notificationShown = false
    end

    return found
end

