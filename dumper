-- COMPAT TAB BUILD
-- ═══════════════════════════════════════════════════════════════════════════════
local function buildCompatUI()
    local hdr = Instance.new("TextLabel")
    hdr.Size             = UDim2.new(1, -8, 0, 26)
    hdr.BackgroundColor3 = Color3.fromRGB(22, 22, 36)
    hdr.BorderSizePixel  = 0
    hdr.Font             = Enum.Font.GothamBold
    hdr.TextSize         = 11
    hdr.TextColor3       = Color3.fromRGB(200, 160, 60)
    hdr.Text             = "  Executor: " .. executorName
    hdr.TextXAlignment   = Enum.TextXAlignment.Left
    hdr.LayoutOrder      = 0
    hdr.Parent           = CompatScroll
    Instance.new("UICorner", hdr).CornerRadius = UDim.new(0, 5)

    local cats, catOrder = {}, {}
    for _, check in ipairs(COMPAT_CHECKS) do
        if not cats[check.category] then
            cats[check.category] = {}
            table.insert(catOrder, check.category)
        end
        table.insert(cats[check.category], check)
    end

    local order = 1
    for _, cat in ipairs(catOrder) do
        local catLbl = Instance.new("TextLabel")
        catLbl.Size              = UDim2.new(1, -8, 0, 16)
        catLbl.BackgroundTransparency = 1
        catLbl.Font              = Enum.Font.GothamBold
        catLbl.TextSize          = 9
        catLbl.TextColor3        = Color3.fromRGB(140, 140, 160)
        catLbl.TextXAlignment    = Enum.TextXAlignment.Left
        catLbl.Text              = "  ── " .. cat:upper() .. " ──"
        catLbl.LayoutOrder       = order
        catLbl.Parent            = CompatScroll
        order = order + 1

        for _, check in ipairs(cats[cat]) do
            local supported = compatResults[check.name]
            local row = Instance.new("Frame")
            row.Size             = UDim2.new(1, -8, 0, 22)
            row.BackgroundColor3 = Color3.fromRGB(22, 22, 34)
            row.BorderSizePixel  = 0
            row.LayoutOrder      = order
            row.Parent           = CompatScroll
            Instance.new("UICorner", row).CornerRadius = UDim.new(0, 4)
            order = order + 1

            local icon = Instance.new("TextLabel")
            icon.Size = UDim2.new(0, 18, 1, 0)
            icon.Position = UDim2.new(0, 4, 0, 0)
            icon.BackgroundTransparency = 1
            icon.Font = Enum.Font.GothamBold
            icon.TextSize = 13
            icon.TextColor3 = supported and Color3.fromRGB(80, 220, 100) or Color3.fromRGB(255, 70, 70)
            icon.Text = supported and "✓" or "✗"
            icon.Parent = row

            local nameLbl = Instance.new("TextLabel")
            nameLbl.Size = UDim2.new(1, -90, 1, 0)
            nameLbl.Position = UDim2.new(0, 24, 0, 0)
            nameLbl.BackgroundTransparency = 1
            nameLbl.Font = Enum.Font.RobotoMono
            nameLbl.TextSize = 10
            nameLbl.TextColor3 = Color3.fromRGB(200, 200, 210)
            nameLbl.TextXAlignment = Enum.TextXAlignment.Left
            nameLbl.Text = check.name
            nameLbl.Parent = row

            local badge = Instance.new("TextLabel")
            badge.Size = UDim2.new(0, 70, 0, 14)
            badge.Position = UDim2.new(1, -76, 0.5, -7)
            badge.BackgroundColor3 = supported and Color3.fromRGB(30, 70, 30)
                or (check.critical and Color3.fromRGB(80, 20, 20) or Color3.fromRGB(50, 40, 20))
            badge.BorderSizePixel = 0
            badge.Font = Enum.Font.GothamBold
            badge.TextSize = 8
            badge.TextColor3 = supported and Color3.fromRGB(100, 255, 100)
                or (check.critical and Color3.fromRGB(255, 80, 80) or Color3.fromRGB(200, 160, 60))
            badge.Text = supported and "OK" or (check.critical and "MISSING!" or "N/A")
            badge.Parent = row
            Instance.new("UICorner", badge).CornerRadius = UDim.new(0, 3)
        end
    end
end

buildCompatUI()

