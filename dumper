local function batchedDump(title, items, formatFn)
	if isDumping then
		addDumpEntry("a dump is already running, hit cancel first", c.yellow)
		return
	end
	setDumpState(true)
	switchTab("dumper")
	addDumpHeader(title .. "  [" .. os.date("%H:%M:%S") .. "]  (" .. #items .. " items)")
	if #items == 0 then
		addDumpEntry("  (nothing found)", c.textDim)
		setDumpState(false)
		return
	end
	local index, total = 0, #items
	local function processBatch()
		if cancelFlag then
			addDumpEntry("cancelled at " .. index .. "/" .. total, c.orange)
			setDumpState(false)
			flashStatus("cancelled", c.orange)
			return
		end
		local stop = math.min(index + batchSize, total)
		for i = index + 1, stop do
			if items[i] ~= nil then
				local ok, text, color = pcall(formatFn, items[i], i)
				if ok and text then addDumpEntry(text, color) end
			end
		end
		index = stop
		statusLbl.Text = math.floor((index / total) * 100) .. "%"
		statusLbl.TextColor3 = Color3.fromRGB(180, 180, 255)
		if index < total then
			task.wait()
			processBatch()
		else
			addDumpEntry("done - " .. total .. " items", c.green)
			setDumpState(false)
			flashStatus("done", c.green)
		end
	end
	task.spawn(processBatch)
end

local function batchedCollect(root, predicate, onDone)
	task.spawn(function()
		local results, all = {}, {}
		pcall(function() all = root:GetDescendants() end)
		local i = 0
		while i < #all do
			local stop = math.min(i + 50, #all)
			for j = i + 1, stop do
				local ok, passes = pcall(predicate, all[j])
				if ok and passes then table.insert(results, all[j]) end
			end
			i = stop
			task.wait()
		end
		onDone(results)
	end)
end

local function flattenTree(root, maxDepth, useFilter)
	local flat = {}
	maxDepth = maxDepth or filterConfig.MaxDepth
	local skipped = 0

	local function recurse(obj, depth)
		if depth > maxDepth then return end
		local cn = obj.ClassName
		local filtered = useFilter and shouldFilter(obj)
		if not filtered then
			local indent = string.rep("  ", depth)
			local info = indent .. obj.Name .. "  <font color='rgb(120,120,150)'>(" .. cn .. ")</font>"
			if obj:IsA("ValueBase") then
				local ok, val = pcall(function() return tostring(obj.Value) end)
				if ok then
					if #val > 80 then val = val:sub(1, 80) .. "..." end
					info = info .. "  <font color='rgb(100,200,100)'>= " .. val .. "</font>"
				end
			end
			local attrOk, attrs = pcall(function() return obj:GetAttributes() end)
			if attrOk and attrs then
				local parts = {}
				for k, v in pairs(attrs) do table.insert(parts, k .. "=" .. tostring(v)) end
				if #parts > 0 then
					local s = table.concat(parts, ", ")
					if #s > 100 then s = s:sub(1, 100) .. "..." end
					info = info .. "  <font color='rgb(180,160,255)'>[attr: " .. s .. "]</font>"
				end
			end
			table.insert(flat, { text = info, depth = depth, color = classColor(cn) })
		else
			skipped = skipped + 1
		end
		if cn ~= "Terrain" then
			local children = {}
			pcall(function() children = obj:GetChildren() end)
			for _, child in ipairs(children) do recurse(child, depth + 1) end
		end
	end

	local children = {}
	pcall(function() children = root:GetChildren() end)
	for _, child in ipairs(children) do recurse(child, 0) end

	if useFilter and skipped > 0 then
		table.insert(flat, {
			text = "<font color='rgb(100,100,130)'>  -- " .. skipped .. " noise instances filtered (change it in the config before dumping) --</font>",
			depth = 0, color = c.textDim,
		})
	end
	return flat
end

