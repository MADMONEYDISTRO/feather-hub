local function makeLabel(scroll, count, text, color, visible)
    local lbl = Instance.new("TextLabel")
    lbl.Name              = "Entry_" .. count
    lbl.Size              = UDim2.new(1, -4, 0, 0)
    lbl.AutomaticSize     = Enum.AutomaticSize.Y
    lbl.BackgroundTransparency = (count % 2 == 0) and 0.92 or 1
    lbl.BackgroundColor3  = Color3.fromRGB(35, 35, 50)
    lbl.Font              = Enum.Font.RobotoMono
    lbl.TextSize          = 11
    lbl.TextColor3        = color or Color3.fromRGB(200, 200, 200)
    lbl.TextXAlignment    = Enum.TextXAlignment.Left
    lbl.TextYAlignment    = Enum.TextYAlignment.Top
    lbl.TextWrapped       = true
    lbl.RichText          = true
    lbl.Text              = text
    lbl.LayoutOrder       = count
    lbl.Visible           = (visible ~= false)
    lbl.Parent            = scroll
    local pad = Instance.new("UIPadding")
    pad.PaddingLeft   = UDim.new(0, 4)
    pad.PaddingTop    = UDim.new(0, 2)
    pad.PaddingBottom = UDim.new(0, 2)
    pad.Parent        = lbl
    return lbl
end

local consolePausedRef = {false}
ConsoleScroll:GetPropertyChangedSignal("CanvasPosition"):Connect(function()
    local atBottom = ConsoleScroll.CanvasPosition.Y
        >= (ConsoleScroll.AbsoluteCanvasSize.Y - ConsoleScroll.AbsoluteSize.Y - 5)
    consolePausedRef[1] = not atBottom
end)

local function addConsoleEntry(message, messageType)
    consoleCount = consoleCount + 1
    local color  = TYPE_COLORS[messageType] or Color3.fromRGB(200, 200, 200)
    local prefix = TYPE_PREFIX[messageType] or ""
    local ts     = os.date("%H:%M:%S")
    local text   = ts .. "  " .. prefix .. tostring(message)
    table.insert(consoleEntries, text)

    if consoleCount > MAX_ENTRIES then
        local oldest = ConsoleScroll:FindFirstChild("Entry_" .. (consoleCount - MAX_ENTRIES))
        if oldest then oldest:Destroy() end
        table.remove(consoleEntries, 1)
    end

    makeLabel(ConsoleScroll, consoleCount, text, color)

    if not consolePausedRef[1] then
        task.defer(function()
            ConsoleScroll.CanvasPosition = Vector2.new(0, ConsoleScroll.AbsoluteCanvasSize.Y)
        end)
    end
end

local function addDumpEntry(text, color)
    dumpCount = dumpCount + 1
    table.insert(dumpEntries, text)
    local show = (filterText == "") or (text:lower():find(filterText:lower(), 1, true) ~= nil)
    local lbl = makeLabel(DumpScroll, dumpCount, text, color or Color3.fromRGB(190, 190, 200), show)
    table.insert(dumpLabels, lbl)
    task.defer(function()
        DumpScroll.CanvasPosition = Vector2.new(0, DumpScroll.AbsoluteCanvasSize.Y)
    end)
end

local function addDumpHeader(text)
    addDumpEntry("━━━ " .. text .. " ━━━", Color3.fromRGB(200, 160, 60))
end

-- Filter
FilterBox:GetPropertyChangedSignal("Text"):Connect(function()
    filterText = FilterBox.Text
    local lower = filterText:lower()
    for i, lbl in ipairs(dumpLabels) do
        if lbl and lbl.Parent then
            local entryText = dumpEntries[i] or ""
            lbl.Visible = (lower == "") or (entryText:lower():find(lower, 1, true) ~= nil)
        end
    end
end)

-- Hook console
pcall(function()
    LogService.MessageOut:Connect(function(message, messageType)
        addConsoleEntry(message, messageType)
    end)
end)

-- Copy & Clear
copyBtn.MouseButton1Click:Connect(function()
    local entries = (activeTab == "console") and consoleEntries or dumpEntries
    local fullLog = table.concat(entries, "\n")
    if #fullLog > CLIP_MAX_BYTES then
        statusLbl.Text = "Too big!"
        statusLbl.TextColor3 = Color3.fromRGB(255, 100, 100)
        task.delay(2, function() statusLbl.Text = "" end)
        return
    end
    local ok = tryClipboard(fullLog)
    statusLbl.Text = ok and "Copied!" or "No clip"
    statusLbl.TextColor3 = ok and Color3.fromRGB(100, 255, 100) or Color3.fromRGB(255, 100, 100)
    task.delay(2, function() statusLbl.Text = "" end)
end)

clearBtn.MouseButton1Click:Connect(function()
    if activeTab == "console" then
        for _, c in ipairs(ConsoleScroll:GetChildren()) do if c:IsA("TextLabel") then c:Destroy() end end
        consoleEntries = {}; consoleCount = 0
    elseif activeTab == "dumper" then
        for _, c in ipairs(DumpScroll:GetChildren()) do if c:IsA("TextLabel") then c:Destroy() end end
        dumpEntries = {}; dumpLabels = {}; dumpCount = 0
    end
    statusLbl.Text = "Cleared"
    task.delay(1.5, function() statusLbl.Text = "" end)
end)

