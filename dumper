local function spyArgs(...)
	local n = select("#", ...)
	if n == 0 then return "no args" end
	local parts = {}
	for i = 1, n do
		local v = select(i, ...)
		local ok, s = pcall(function() return tostring(v) end)
		s = ok and s or "?"
		if #s > 40 then s = s:sub(1, 40) .. "..." end
		table.insert(parts, typeof(v) .. ": " .. s)
	end
	return table.concat(parts, ", ")
end

local function setupSpy()
	if spyHooked then return true end
	local ok = pcall(function()
		local getMethod = getnamecallmethod
		if type(hookmetamethod) == "function" then
			local old
			old = hookmetamethod(game, "__namecall", function(self, ...)
				if spying then
					local method = getMethod and getMethod() or ""
					if method == "FireServer" or method == "InvokeServer" then
						local path = "?"
						pcall(function() path = self:GetFullName() end)
						table.insert(spyQueue, {
							text = os.date("%H:%M:%S") .. "  " .. method .. "  " .. path .. "  (" .. spyArgs(...) .. ")",
							color = c.blue,
						})
					end
				end
				return old(self, ...)
			end)
		elseif type(getrawmetatable) == "function" then
			local mt = getrawmetatable(game)
			local old = mt.__namecall
			if type(setreadonly) == "function" then setreadonly(mt, false) end
			local function hooked(self, ...)
				if spying then
					local method = getMethod and getMethod() or ""
					if method == "FireServer" or method == "InvokeServer" then
						local path = "?"
						pcall(function() path = self:GetFullName() end)
						table.insert(spyQueue, {
							text = os.date("%H:%M:%S") .. "  " .. method .. "  " .. path .. "  (" .. spyArgs(...) .. ")",
							color = c.blue,
						})
					end
				end
				return old(self, ...)
			end
			mt.__namecall = (type(newcclosure) == "function") and newcclosure(hooked) or hooked
		else
			error("no namecall hook available")
		end
	end)
	spyHooked = ok
	return ok
end

