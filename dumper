local function setDumpState(running)
    isDumping = running
    cancelFlag = false
    cancelBtn.Visible = running
end

local function batchedDump(title, items, formatFn)
    if isDumping then
        addDumpEntry("⚠ A dump is already running. Press Cancel first.", Color3.fromRGB(255, 200, 60))
        return
    end
    setDumpState(true)
    switchTab("dumper")

    local ts = os.date("%H:%M:%S")
    addDumpHeader(title .. "  [" .. ts .. "]  (" .. #items .. " items)")

    local total = #items
    if total == 0 then
        addDumpEntry("  (no items found)", Color3.fromRGB(160, 160, 160))
        setDumpState(false)
        return
    end

    local index = 0
    local function processBatch()
        if cancelFlag then
            addDumpEntry("✗ Cancelled at " .. index .. "/" .. total, Color3.fromRGB(255, 120, 60))
            setDumpState(false)
            statusLbl.Text = "Cancelled"
            statusLbl.TextColor3 = Color3.fromRGB(255, 140, 60)
            task.delay(2, function() statusLbl.Text = "" end)
            return
        end

        local batchEnd = math.min(index + BATCH_SIZE, total)
        for i = index + 1, batchEnd do
            if items[i] ~= nil then
                local ok, text, color = pcall(formatFn, items[i], i)
                if ok and text then
                    addDumpEntry(text, color)
                end
            end
        end
        index = batchEnd
        statusLbl.Text = math.floor((index / total) * 100) .. "%"
        statusLbl.TextColor3 = Color3.fromRGB(180, 180, 255)

        if index < total then
            task.wait()
            processBatch()
        else
            addDumpEntry("✓ Done — " .. total .. " items", Color3.fromRGB(100, 255, 100))
            setDumpState(false)
            statusLbl.Text = "Done"
            statusLbl.TextColor3 = Color3.fromRGB(100, 255, 100)
            task.delay(2, function() statusLbl.Text = "" end)
        end
    end
    task.spawn(processBatch)
end

local function batchedCollect(root, predicate, onDone)
    task.spawn(function()
        local results = {}
        local all = {}
        pcall(function() all = root:GetDescendants() end)
        local i = 0
        while i < #all do
            local bEnd = math.min(i + 50, #all)
            for j = i + 1, bEnd do
                local ok, passes = pcall(predicate, all[j])
                if ok and passes then table.insert(results, all[j]) end
            end
            i = bEnd
            task.wait()
        end
        onDone(results)
    end)
end

