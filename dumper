local function shouldFilter(inst)
	local cn = inst.ClassName
	if alwaysKeep[cn] then return false end

	local ok, attrs = pcall(function() return inst:GetAttributes() end)
	if ok and attrs then
		for _ in pairs(attrs) do return false end
	end

	if filterConfig.BaseParts and baseParts[cn] then return true end
	if filterConfig.Constraints and constraints[cn] then return true end
	if filterConfig.Decorators and decorators[cn] then return true end
	if filterConfig.Effects and effects[cn] then return true end
	if filterConfig.Lights and lights[cn] then return true end
	if filterConfig.BodyMovers and bodyMovers[cn] then return true end
	if filterConfig.Attachments and attachments[cn] then return true end
	if filterConfig.ClickDetectors and cn == "ClickDetector" then return true end
	if filterConfig.Animations and anims[cn] then return true end
	if filterConfig.LocalizationTbl and cn == "LocalizationTable" then return true end
	if filterConfig.WireframeAdorn and wireframe[cn] then return true end
	return false
end

