    { name = "gethiddenproperty",    fn = function() return type(gethiddenproperty) == "function" end, category = "Instance", critical = false },
    { name = "sethiddenproperty",    fn = function() return type(sethiddenproperty) == "function" end, category = "Instance", critical = false },
    { name = "getrawmetatable",      fn = function() return type(getrawmetatable) == "function" end, category = "Instance", critical = false },
    { name = "setrawmetatable",      fn = function() return type(setrawmetatable) == "function" end, category = "Instance", critical = false },
    { name = "game:GetDescendants",  fn = function() return type(game.GetDescendants) == "function" end, category = "Scanning", critical = true },
    { name = "Instance:GetChildren", fn = function() return type(game.GetChildren) == "function" end, category = "Scanning", critical = true },
    { name = "GetAttributes (inst)", fn = function()
        local ok = pcall(function() workspace:GetAttributes() end)
        return ok
    end, category = "Scanning", critical = false },
    { name = "LogService.MessageOut", fn = function() return LogService ~= nil end, category = "Logging", critical = true },
    { name = "ScreenGui parenting",  fn = function()
        local ok = pcall(function() LocalPlayer:WaitForChild("PlayerGui", 1) end)
        return ok
    end, category = "UI", critical = true },
    { name = "identifyexecutor",     fn = function() return type(identifyexecutor) == "function" end, category = "Identity", critical = false },
    { name = "getexecutorname",      fn = function() return type(getexecutorname) == "function" end, category = "Identity", critical = false },
    { name = "syn.request / http",   fn = function()
        return type(syn) == "table" or type(http) == "table" or type(request) == "function"
    end, category = "Network", critical = false },
}

local compatResults = {}
local executorName  = "Unknown"
pcall(function()
    if type(identifyexecutor) == "function" then
        executorName = identifyexecutor()
    elseif type(getexecutorname) == "function" then
        executorName = getexecutorname()
    end
end)
for _, check in ipairs(COMPAT_CHECKS) do
    local ok, result = pcall(check.fn)
    compatResults[check.name] = (ok and result == true)
end

local function tryClipboard(text)
    if type(setclipboard) == "function" then
        local ok = pcall(setclipboard, text); if ok then return true end
    end
    if type(toclipboard) == "function" then
        local ok = pcall(toclipboard, text); if ok then return true end
    end
    return false
end

