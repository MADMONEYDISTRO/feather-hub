local function addConsoleEntry(message, messageType)
	consoleCount = consoleCount + 1
	local color = typeColors[messageType] or c.text
	local prefix = typePrefix[messageType] or ""
	local text = os.date("%H:%M:%S") .. "  " .. prefix .. tostring(message)
	table.insert(consoleEntries, text)
	if consoleCount > maxEntries then
		local removeOrder = consoleCount - maxEntries
		for _, child in ipairs(consoleScroll:GetChildren()) do
			if child:IsA("TextLabel") and child.LayoutOrder == removeOrder then
				child:Destroy()
				break
			end
		end
		table.remove(consoleEntries, 1)
	end
	local lbl = makeLabel(consoleScroll, consoleCount, text, color)
	bindLineCopy(lbl, text)
	if not consolePaused then scrollToBottom(consoleScroll) end
end

