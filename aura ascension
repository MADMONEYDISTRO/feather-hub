            local capturedTab = e.tab
            hitbox.MouseButton1Click:Connect(function()
                searchBox.Text = ""; srPanel.Visible = false
                for i = 1, #tabBtns do
                    if tabBtns[i].Text == TAB_NAMES[capturedTab] then tabBtns[i].MouseButton1Click:Fire(); break end
                end
            end)
        end
    end
    local absPos = searchFrame.AbsolutePosition; local absSize = searchFrame.AbsoluteSize
    srPanel.Position = UDim2.new(0, absPos.X, 0, absPos.Y + absSize.Y + 4)
    srPanel.Size = UDim2.new(0, absSize.X, 0, math.min(#matches, 5) * 36 + 8)
