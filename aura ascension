            nameLbl.TextColor3 = Theme.text; nameLbl.TextXAlignment = Enum.TextXAlignment.Left; nameLbl.BackgroundTransparency = 1; nameLbl.ZIndex = 43
            local badge = Instance.new("TextLabel", row)
            badge.Size = UDim2.new(0, 64, 0, 18); badge.Position = UDim2.new(1, -70, 0.5, -9)
            badge.Text = tabName; badge.Font = Enum.Font.GothamBold; badge.TextSize = 8
