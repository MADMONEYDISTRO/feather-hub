-- Stats update loop (every 2 seconds)
task.spawn(function()
    while task.wait(2) do
        pcall(function()
            local a = getAura()
            local rb = getRebirths()
            local rank = getRank(a)
            local prog = getProgress(a)
            local idx = getRankIdx(a)
            local zones = loadZones()
            local nz = nextUnlock(a, zones)
            local up = os.clock() - Settings.sessStart
            local ut = string.format("%02d:%02d:%02d", math.floor(up/3600), math.floor(up%3600/60), math.floor(up%60))

            local labels = _G.StatLabels
            if labels then
                labels[1].Text = fmt(a)
                labels[2].Text = rank.n .. "  (x" .. fmt(rank.m) .. ")"
                if idx < #Ranks then
                    labels[3].Text = Ranks[idx+1].n .. "  [" .. math.floor(prog*100) .. "%]"
                else
                    labels[3].Text = "MAX RANK"
                end
                labels[4].Text = fmt(rb)
                labels[5].Text = Settings.curZone
                labels[6].Text = "+" .. fmt(Settings.tickAmt)

                if nz then
                    if Settings.tickAmt > 0 then
                        local need = nz.req - a
                        if need > 0 then
                            local sec = need / Settings.tickAmt
                            local eta
                            if sec > 86400 then eta = string.format("%.1fd", sec/86400)
                            elseif sec > 3600 then eta = string.format("%.1fh", sec/3600)
                            else eta = string.format("%.0fm", sec/60) end
                            labels[7].Text = nz.name .. " in " .. eta
                        else
                            labels[7].Text = nz.name .. " - READY!"
                        end
                    else
                        labels[7].Text = nz.name .. " [" .. fmt(nz.req) .. "]"
                    end
                else
                    labels[7].Text = "All unlocked!"
                end

                if a >= 1000 then
                    labels[8].Text = "READY NOW"
                elseif Settings.tickAmt > 0 then
                    labels[8].Text = string.format("%.0fs", (1000-a)/Settings.tickAmt)
                else
                    labels[8].Text = "Waiting ticks..."
                end

                labels[9].Text = fmt(Settings.sessAura)
                labels[10].Text = tostring(Settings.sessRebirths)
                labels[11].Text = (up > 60) and tostring(math.floor(Settings.sessRebirths / (up/3600))) or "0"
                labels[12].Text = ut
            end
        end)
    end
end)

