-- ═══ GAME LOGIC ═══
local placeId = 94845773826960
local autoEnter  = false
local autoStart  = false
local autoClear  = false
local autoRestart = false
local killAura   = false

local selectedDungeon = nil
local diffLevel  = 1
local partySize  = 1
local tweenSpeed = 50
local orbitSpeed = 1
local orbitRadius = 30

local mobsFolder = WS:FindFirstChild("Mobs")
local mobList    = {}

local function tweenToPos(targetPos)
    local char = Player.Character
    if not char then return end
    local hrp = char:FindFirstChild("HumanoidRootPart")
    if not hrp then return end
    local distance = (hrp.Position - targetPos).Magnitude
    local start = tick(); local startPos = hrp.Position
    local conn
    conn = RS.Heartbeat:Connect(function()
        if not (char and char.Parent) then conn:Disconnect() return end
        local t = math.min((tick()-start) / math.max(distance/tweenSpeed, 0.01), 1)
        hrp.CFrame = CFrame.new(startPos:Lerp(targetPos, t))
        if t >= 1 then conn:Disconnect() end
    end)
end

local function updateMobList()
    mobList = {}
    if mobsFolder then
        for _, mob in ipairs(mobsFolder:GetChildren()) do
            if mob:FindFirstChild("HumanoidRootPart") and mob:FindFirstChild("Healthbar") then
                table.insert(mobList, mob)
            end
        end
    end
end

local function setDungeonSettings()
    ReplicatedStorage:WaitForChild("Systems"):WaitForChild("Parties"):WaitForChild("SetSettings"):FireServer(
        tostring(selectedDungeon), tonumber(diffLevel), tonumber(partySize), true
    )
end
local function startDungeon()
    ReplicatedStorage:WaitForChild("Systems"):WaitForChild("Dungeons"):WaitForChild("TriggerStartDungeon"):FireServer()
end
local function chooseExit()
    ReplicatedStorage:WaitForChild("Systems"):WaitForChild("Dungeons"):WaitForChild("SetExitChoice"):FireServer("GoAgain")
end

task.spawn(function() while task.wait(10) do if game.PlaceId == placeId and autoEnter and selectedDungeon then setDungeonSettings() end end end)
task.spawn(function() while task.wait(60) do if game.PlaceId ~= placeId and autoStart then startDungeon() end end end)
task.spawn(function() while task.wait(5)  do if game.PlaceId ~= placeId and autoRestart then chooseExit() end end end)

task.spawn(function()
    while task.wait(0.25) do
        updateMobList()
        if killAura and game.PlaceId ~= placeId and #mobList > 0 then
            local targets = {}
            for _, mob in ipairs(mobList) do
                if mob:FindFirstChild("Healthbar") and mob:FindFirstChild("HumanoidRootPart") then table.insert(targets, mob) end
            end
            if #targets > 0 then
                ReplicatedStorage:WaitForChild("Systems"):WaitForChild("Combat"):WaitForChild("PlayerAttack"):FireServer(targets)
            end
        end
    end
end)

local orbitConn, orbitMob = nil, nil
local function stopOrbit()
    if orbitConn then orbitConn:Disconnect(); orbitConn = nil end
    orbitMob = nil
end
local function startOrbit(mob)
    stopOrbit()
    if not mob or not mob:FindFirstChild("HumanoidRootPart") then return end
    orbitMob = mob
    local angle = 0
    orbitConn = RS.Heartbeat:Connect(function(dt)
        if not orbitMob or not orbitMob.Parent or not orbitMob:FindFirstChild("HumanoidRootPart") then stopOrbit() return end
        local char = Player.Character
        if not char then return end
        local hrp = char:FindFirstChild("HumanoidRootPart")
        if not hrp then return end
        angle = (angle + orbitSpeed * dt * 5) % (2*math.pi)
        local offset = Vector3.new(math.cos(angle)*orbitRadius, 20, math.sin(angle)*orbitRadius)
        hrp.CFrame = CFrame.new(orbitMob.HumanoidRootPart.Position + offset, orbitMob.HumanoidRootPart.Position)
    end)
end

