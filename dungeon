local function makeSlider(parent, label, min, max, default, callback)
    local row = Instance.new("Frame")
    row.Size = UDim2.new(1,0,0,48)
    row.BackgroundColor3 = cardCol
    row.BorderSizePixel = 0
    row.Parent = parent
    mkC(row,8)

    local lbl = Instance.new("TextLabel")
    lbl.Size = UDim2.new(1,-70,0,20)
    lbl.Position = UDim2.new(0,12,0,6)
    lbl.Text = label
    lbl.Font = Enum.Font.GothamSemibold
    lbl.TextSize = 9
    lbl.TextColor3 = txtCol
    lbl.TextXAlignment = Enum.TextXAlignment.Left
    lbl.BackgroundTransparency = 1
    lbl.Parent = row

    local valLabel = Instance.new("TextLabel")
    valLabel.Size = UDim2.new(0,60,0,20)
    valLabel.Position = UDim2.new(1,-68,0,6)
    valLabel.Text = tostring(default)
    valLabel.Font = Enum.Font.GothamBold
    valLabel.TextSize = 9
    valLabel.TextColor3 = accent
    valLabel.TextXAlignment = Enum.TextXAlignment.Right
    valLabel.BackgroundTransparency = 1
    valLabel.Parent = row

    local track = Instance.new("Frame")
    track.Size = UDim2.new(1,-24,0,6)
    track.Position = UDim2.new(0,12,0,30)
    track.BackgroundColor3 = dimCol
    track.BorderSizePixel = 0
    track.Parent = row
    mkC(track,3)

    local fill = Instance.new("Frame")
    fill.Size = UDim2.new((default-min)/(max-min),0,1,0)
    fill.BackgroundColor3 = accent
    fill.BorderSizePixel = 0
    fill.Parent = track
    mkC(fill,3)

    local dragBegan = false
    local function updateSlider(input)
        local relX = math.clamp((input.Position.X - track.AbsolutePosition.X) / track.AbsoluteSize.X, 0, 1)
        local value = math.floor(min + relX*(max-min) + 0.5)
        fill.Size = UDim2.new(relX,0,1,0)
        valLabel.Text = tostring(value)
        pcall(callback, value)
    end
    track.InputBegan:Connect(function(i)
        if i.UserInputType == Enum.UserInputType.MouseButton1 or i.UserInputType == Enum.UserInputType.Touch then
            dragBegan = true; updateSlider(i)
        end
    end)
    UIS.InputChanged:Connect(function(i)
        if dragBegan and (i.UserInputType == Enum.UserInputType.MouseMovement or i.UserInputType == Enum.UserInputType.Touch) then
            updateSlider(i)
        end
    end)
    UIS.InputEnded:Connect(function(i)
        if i.UserInputType == Enum.UserInputType.MouseButton1 or i.UserInputType == Enum.UserInputType.Touch then
            dragBegan = false
        end
    end)
    return row
end

