    btn.BorderSizePixel = 0
    btn.LayoutOrder = order
    btn.Parent = tabButtonsFrame
    mkC(btn,6)
    return btn
end

local function switchTab(tabName)
    if selectedTab == tabName then return end
    selectedTab = tabName
    for _, t in pairs(tabs) do
        if t.content then t.content.Visible = false end
        if t.button  then
            TS:Create(t.button, tw(0.12), {BackgroundColor3 = dimCol, TextColor3 = txtCol}):Play()
        end
    end
    local t = tabs[tabName]
    if t then
        if t.content then t.content.Visible = true end
        if t.button  then
            TS:Create(t.button, tw(0.12), {BackgroundColor3 = accent, TextColor3 = Color3.new(1,1,1)}):Play()
        end
    end
end

