        if autoClear and game.PlaceId ~= placeId then
            updateMobList()
            if #mobList > 0 then
                table.sort(mobList, function(a,b)
                    local charPos = Player.Character and Player.Character:FindFirstChild("HumanoidRootPart") and Player.Character.HumanoidRootPart.Position
                    if charPos then return (a.HumanoidRootPart.Position - charPos).Magnitude < (b.HumanoidRootPart.Position - charPos).Magnitude end
                    return false
                end)
                local nearest = mobList[1]
                if nearest and nearest:FindFirstChild("HumanoidRootPart") and not orbitConn then
                    tweenToPos(nearest.HumanoidRootPart.Position)
                    task.wait(0.2)
                    startOrbit(nearest)
                end
            else
                stopOrbit()
            end
        else
            stopOrbit()
        end
    end
end)

