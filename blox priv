function EquipWeapon(name)
    if not name then return end
    local bp = Player.Backpack
    local tool = bp and bp:FindFirstChild(name)
    if tool then
        local hum = getChar() and getChar():FindFirstChildOfClass("Humanoid")
        if hum then hum:EquipTool(tool) end
    end
end

function AutoHaki()
    pcall(function()
        local char = getChar()
        if char and char:FindFirstChild("Services") and char.Services:FindFirstChild("Haki") and char.Services.Haki.Value == 0 then
            Player.PlayerStats.BusoShopValue.Value = "BusoHaki"
            ReplicatedStorage.Chest.Remotes.Events.Armament:FireServer()
        end
    end)
end

function StopTween(v) end
function Hop()
    pcall(function()
        local servers = {}
        local data = HttpService:JSONDecode(game:HttpGet("https://games.roblox.com/v1/games/"..game.PlaceId.."/servers/Public?sortOrder=Asc&limit=100"))
        if data and data.data then
            for _, s in pairs(data.data) do
                if s.playing < s.maxPlayers and s.id ~= game.JobId then
                    table.insert(servers, s.id)
                end
            end
        end
        if #servers > 0 then TeleportService:TeleportToPlaceInstance(game.PlaceId, servers[math.random(1,#servers)], Player) end
    end)
end

