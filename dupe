--  DRAG  (Mouse + Touch unified)
-- ══════════════════════════════════════════════════════════════

local dragging      = false
local dragInput     = nil
local dragStart     = nil
local dragStartPos  = nil

local function onDragBegan(input)
    local t = input.UserInputType
    if t == Enum.UserInputType.MouseButton1 or t == Enum.UserInputType.Touch then
        dragging     = true
        dragStart    = input.Position
        dragStartPos = win.Position
    end
end

local function onDragChanged(input)
    local t = input.UserInputType
    if t == Enum.UserInputType.MouseMovement or t == Enum.UserInputType.Touch then
        dragInput = input
    end
end

topBar.InputBegan:Connect(onDragBegan)
topBar.InputChanged:Connect(onDragChanged)

UserInputService.InputChanged:Connect(function(input)
    if not dragging or input ~= dragInput then return end
    local d = input.Position - dragStart

    -- Clamp to screen so the window can't be dragged offscreen
    local vp       = workspace.CurrentCamera.ViewportSize
    local newX     = math.clamp(dragStartPos.X.Offset + d.X, 0, vp.X - W)
    local newY     = math.clamp(dragStartPos.Y.Offset + d.Y, 0, vp.Y - H)
    win.Position   = UDim2.new(0, newX, 0, newY)
end)

UserInputService.InputEnded:Connect(function(input)
    local t = input.UserInputType
    if t == Enum.UserInputType.MouseButton1 or t == Enum.UserInputType.Touch then
        dragging = false
    end
end)

