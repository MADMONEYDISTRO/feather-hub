-- ══════════════════════════════════════════════════════════════
--  PING MEASUREMENT
-- ══════════════════════════════════════════════════════════════

local function getPing()
    if typeof(Player.GetNetworkPing) == "function" then
        local ok, result = pcall(function()
            return tonumber(string.match(Player:GetNetworkPing(), "%d+"))
        end)
        if ok and result then return result end
    end

    local ok2, pingStat = pcall(function()
        return Player:FindFirstChild("PlayerGui") and Player.PlayerGui:FindFirstChild("Ping")
            or Player:FindFirstChild("PlayerScripts") and Player.PlayerScripts:FindFirstChild("Ping")
    end)
    if ok2 and pingStat and pingStat:IsA("TextLabel") then
        local num = tonumber(string.match(pingStat.Text, "%d+"))
        if num then return num end
    end

    local t0   = tick()
    local temp = Instance.new("BoolValue", ReplicatedStorage)
    temp.Name  = "PingTest_" .. tostring(math.random(10000, 99999))
    task.wait(0.1)
    local t1 = tick()
    temp:Destroy()
    return math.clamp((t1 - t0) * 1000, 50, 300)
end

-- ══════════════════════════════════════════════════════════════
--  CORE DUPE FUNCTION
-- ══════════════════════════════════════════════════════════════

local dupeRunning = false

local function runDupe()
    if dupeRunning then return end

    local Tool = Character:FindFirstChildOfClass("Tool")
    if not Tool then
        setStatus("No tool equipped — equip one first", C.red)
        return
    end

    local ToolName = Tool.Name
    toolNameLbl.Text = ToolName
    dupeRunning = true
    setDupeEnabled(false)

    setStatus("Measuring ping...", C.yellow)
    local ping  = getPing()
    pingLbl.Text       = ping .. " ms"
    pingLbl.TextColor3 = ping < 100 and C.green or ping < 200 and C.yellow or C.red

    local delay = 0.25 + ((math.clamp(ping, 0, 300) / 300) * 0.03)

    setStatus("Unequipping tool...", C.yellow)
    Tool.Parent = Backpack
    task.wait(0.5)

    local ToolId           = nil
    local marketConnection = ReplicatedStorage.MarketItems.ChildAdded:Connect(function(item)
        if item.Name == ToolName then
            local owner = item:WaitForChild("owner", 2)
            if owner and owner.Value == Player.Name then
                ToolId = item:GetAttribute("SpecialId")
            end
        end
    end)

    setStatus("Listing on market...", C.yellow)
    task.spawn(function()
        ReplicatedStorage.ListWeaponRemote:FireServer(ToolName, 99999)
    end)
    task.wait(delay)

    setStatus("Storing to backpack...", C.yellow)
    task.spawn(function()
        ReplicatedStorage.BackpackRemote:InvokeServer("Store", ToolName)
    end)
    task.wait(3)

    if ToolId then
        setStatus("Removing market listing...", C.yellow)
        task.spawn(function()
            ReplicatedStorage.BuyItemRemote:FireServer(ToolName, "Remove", ToolId)
        end)
    else
        setStatus("Warning: ToolId not found — listing may remain", C.yellow)
    end

    setStatus("Grabbing tool back...", C.yellow)
    task.spawn(function()
        ReplicatedStorage.BackpackRemote:InvokeServer("Grab", ToolName)
    end)

    marketConnection:Disconnect()
    task.wait(0.5)
    setStatus("Done  —  " .. ToolName .. " duped!", C.green)
    toolNameLbl.Text = ToolName .. " (duped)"
    dupeRunning = false
    setDupeEnabled(true)
end

