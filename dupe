-- ═══ DUPER LOGIC ═══
local dupeRunning = false

local function getPing()
    local ok, p = pcall(function() return math.round(Player:GetNetworkPing() * 1000) end)
    if ok and p then return p end
    return 100
end

local function runDupe(statusLbl, toolLbl, pingLbl)
    if dupeRunning then return end
    Character = Player.Character or Player.CharacterAdded:Wait()
    local Tool = Character:FindFirstChildOfClass("Tool")
    if not Tool then
        statusLbl.Text = "No tool equipped!"; statusLbl.TextColor3 = red
        return
    end
    local ToolName = Tool.Name
    toolLbl.Text = ToolName; toolLbl.TextColor3 = accent
    dupeRunning = true

    statusLbl.Text = "Measuring ping..."; statusLbl.TextColor3 = yellow
    local ping = getPing()
    pingLbl.Text = ping.." ms"; pingLbl.TextColor3 = ping < 100 and green or ping < 200 and yellow or red
    local delay = 0.25 + ((math.clamp(ping, 0, 300) / 300) * 0.03)

    statusLbl.Text = "Unequipping..."; statusLbl.TextColor3 = yellow
    Tool.Parent = Backpack; task.wait(0.5)

    local ToolId = nil
    local conn = ReplicatedStorage.MarketItems.ChildAdded:Connect(function(item)
        if item.Name == ToolName then
            local owner = item:WaitForChild("owner", 2)
            if owner and owner.Value == Player.Name then ToolId = item:GetAttribute("SpecialId") end
        end
    end)

    statusLbl.Text = "Listing on market..."; statusLbl.TextColor3 = yellow
    task.spawn(function() ReplicatedStorage.ListWeaponRemote:FireServer(ToolName, 99999) end)
    task.wait(delay)

    statusLbl.Text = "Storing to backpack..."; statusLbl.TextColor3 = yellow
    task.spawn(function() ReplicatedStorage.BackpackRemote:InvokeServer("Store", ToolName) end)
    task.wait(3)

    if ToolId then
        statusLbl.Text = "Removing listing..."; statusLbl.TextColor3 = yellow
        task.spawn(function() ReplicatedStorage.BuyItemRemote:FireServer(ToolName, "Remove", ToolId) end)
    end

    statusLbl.Text = "Grabbing tool back..."; statusLbl.TextColor3 = yellow
    task.spawn(function() ReplicatedStorage.BackpackRemote:InvokeServer("Grab", ToolName) end)

    conn:Disconnect(); task.wait(0.5)
    statusLbl.Text = ToolName.." duped!"; statusLbl.TextColor3 = green
    toolLbl.Text = ToolName.." (duped)"; toolLbl.TextColor3 = green
    dupeRunning = false
end

-- ═══ JOB FARM LOGIC ═══
local farming = false
local farmThread = nil

local function tp(cf)
    pcall(function()
        local char = Player.Character
        if not char then return end
        local hum = char:FindFirstChild("Humanoid")
        local hrp = char:FindFirstChild("HumanoidRootPart")
        if not hum or not hrp then return end
        hum:ChangeState(0)
        while Player:GetAttribute("LastACPos") do task.wait() end
        hrp.CFrame = cf; task.wait(); hum:ChangeState(2)
    end)
end

local function getWallSpot()
    local ok, result = pcall(function()
        for _, v in pairs(workspace.ConstructionStuff:GetChildren()) do
            if v:IsA("Part") and v.Name:find("Wall") then
                local prompt = v:FindFirstChild("Prompt")
                if prompt and prompt.Enabled then return v end
            end
        end
    end)
    return ok and result or nil
end

local function farmLoop(statusLbl)
    while farming do
        pcall(function()
            local char = Player.Character
            if not char then task.wait(); return end
            local hum = char:FindFirstChild("Humanoid")
            local hrp = char:FindFirstChild("HumanoidRootPart")
            if not hum or not hrp or hum.Health <= 0 then task.wait(); return end

            -- Start job if not working
            if not Player:GetAttribute("WorkingJob") then
                statusLbl.Text = "Starting job..."; statusLbl.TextColor3 = yellow
                tp(CFrame.new(-1729, 371, -1171)); task.wait(0.35)
                pcall(function() fireproximityprompt(workspace.ConstructionStuff["Start Job"].Prompt) end)
                repeat task.wait() until Player:GetAttribute("WorkingJob") or not farming
            end
            if not farming then return end

            -- Grab wood
            local hasWood = Player.Backpack:FindFirstChild("PlyWood") or char:FindFirstChild("PlyWood")
            if not hasWood then
                statusLbl.Text = "Grabbing wood..."; statusLbl.TextColor3 = yellow
                tp(CFrame.new(-1728, 371, -1178))
                repeat
                    task.wait()
                    pcall(function() fireproximityprompt(workspace.ConstructionStuff["Grab Wood"].Prompt) end)
                    hasWood = Player.Backpack:FindFirstChild("PlyWood") or char:FindFirstChild("PlyWood")
                until hasWood or not farming
            end
            if not farming then return end

            -- Equip wood
            local tool = Player.Backpack:FindFirstChild("PlyWood")
            if tool then pcall(function() hum:EquipTool(tool) end) end

            local spot = getWallSpot()
            if not spot then statusLbl.Text = "No wall spot found..."; statusLbl.TextColor3 = mutedCol; task.wait(1); return end

            -- Place wood
            statusLbl.Text = "Placing wood..."; statusLbl.TextColor3 = green
            tp(spot.CFrame)
            repeat
                task.wait()
                pcall(function() fireproximityprompt(spot.Prompt) end)
            until not char:FindFirstChild("PlyWood") or not spot.Prompt.Enabled or not farming

            task.wait(0.12)
        end)
        task.wait()
    end
end

