--// Helper Functions
local function randomId()
	return tostring(math.random(100000, 999999))
end

local function getHRP(plr)
	local char = plr.Character
	if char then
		return char:FindFirstChild("HumanoidRootPart")
	end
end

local function getNearestPlayerInRange()
	local myHRP = getHRP(player)
	if not myHRP then return end
	
	local closestHRP
	local closestDist = settings.targetSpike.maxDistance
	
	for _, plr in ipairs(Players:GetPlayers()) do
		if plr ~= player then
			local hrp = getHRP(plr)
			if hrp then
				local dist = (myHRP.Position - hrp.Position).Magnitude
				if dist < closestDist then
					closestDist = dist
					closestHRP = hrp
				end
			end
		end
	end
	
	return closestHRP
end

--// Object Search Functions
local function findObjects()
	local objects = {}
	
	-- Find all players
	for _, plr in ipairs(Players:GetPlayers()) do
		if plr ~= player then
			local hrp = getHRP(plr)
			if hrp then
				table.insert(objects, {
					Name = plr.Name,
					Type = "Player",
					Part = hrp,
					Color = Color3.fromRGB(255, 100, 100)
				})
			end
		end
	end
	
	-- Find chests if enabled
	if settings.compass.showChests then
		local treasureFolder = Workspace:FindFirstChild("Treasure")
		if treasureFolder then
			for _, chest in ipairs(treasureFolder:GetChildren()) do
				if chest:IsA("Model") and chest.Name == "Chest" then
					local primaryPart = chest.PrimaryPart or chest:FindFirstChildWhichIsA("BasePart")
					if primaryPart then
						table.insert(objects, {
							Name = "Chest",
							Type = "Chest",
							Part = primaryPart,
							Color = Color3.fromRGB(255, 215, 0) -- Gold color
						})
					end
				end
			end
		end
	end
	
	-- Find cows if enabled
	if settings.compass.showCows then
		local charactersFolder = Workspace:FindFirstChild("Characters")
		if charactersFolder then
			for _, cow in ipairs(charactersFolder:GetChildren()) do
				if cow:IsA("Model") and cow.Name == "Cow" then
					local primaryPart = cow.PrimaryPart or cow:FindFirstChildWhichIsA("BasePart")
					if primaryPart then
						table.insert(objects, {
							Name = "Cow",
							Type = "Cow",
							Part = primaryPart,
							Color = Color3.fromRGB(139, 69, 19) -- Brown color
						})
					end
				end
			end
		end
	end
	
	return objects
end

local function getNearestObject()
	local myChar = player.Character
	if not myChar then return nil, nil, nil, nil end
	local myHRP = myChar:FindFirstChild("HumanoidRootPart")
	if not myHRP then return nil, nil, nil, nil end
	
	local allObjects = findObjects()
	local nearestObject = nil
	local nearestPart = nil
	local nearestDist = math.huge
	local nearestType = nil
	
	for _, obj in ipairs(allObjects) do
		-- Team check for players
		if obj.Type == "Player" then
			local targetPlayer = Players:FindFirstChild(obj.Name)
			if targetPlayer and settings.compass.teamCheck and targetPlayer.Team == player.Team then
				continue
			end
			
			-- Search filter
			if settings.compass.searchEnabled and settings.compass.searchQuery ~= "" then
				local lowerName = string.lower(obj.Name)
				local lowerQuery = string.lower(settings.compass.searchQuery)
				if not string.find(lowerName, lowerQuery) then
					continue
				end
			end
		else
			-- Search filter for objects
			if settings.compass.searchEnabled and settings.compass.searchQuery ~= "" then
				local lowerName = string.lower(obj.Name)
				local lowerQuery = string.lower(settings.compass.searchQuery)
				if not string.find(lowerName, lowerQuery) then
					continue
				end
			end
		end
		
		local dist = (myHRP.Position - obj.Part.Position).Magnitude
		if dist < nearestDist then
			nearestDist = dist
			nearestObject = obj
			nearestPart = obj.Part
			nearestType = obj.Type
		end
	end
	
	return nearestObject, nearestPart, nearestDist, nearestType
end

--// Spike Functions
local function placeSelfSpikeCircle()
	if not settings.selfSpike.enabled then return end
	
	local char = player.Character
	if not char then return end
	local root = char:FindFirstChild("HumanoidRootPart")
	if not root then return end
	
	local spikesTool = player.Backpack:FindFirstChild("Super Spikes")
	if not spikesTool then return end
	
	local buildRemote = spikesTool:WaitForChild("StructureScripts"):WaitForChild("Build")
	
	for i = 1, settings.selfSpike.spikeCount do
		local angle = math.rad((i - 1) * (360 / settings.selfSpike.spikeCount))
		local offset = Vector3.new(
			math.cos(angle) * settings.selfSpike.radius,
			settings.selfSpike.height,
			math.sin(angle) * settings.selfSpike.radius
		)
		
		local spikeCFrame = CFrame.new(root.Position + offset)
		spikeCFrame = spikeCFrame * CFrame.Angles(0, math.rad(math.random(0,360)), 0)
		
		local args = {
			spikesTool,
			spikeCFrame,
			randomId(),
			randomId(),
			math.random(200, 300)
		}
		
		buildRemote:InvokeServer(unpack(args))
		
		if settings.selfSpike.placeDelay > 0 then
			task.wait(settings.selfSpike.placeDelay)
		end
	end
end

local function placeTargetSpikeCircle()
	if not settings.targetSpike.enabled then return end
	
	local spikesTool = player.Backpack:FindFirstChild("Super Spikes")
	if not spikesTool then return end
	
	local buildRemote = spikesTool:WaitForChild("StructureScripts"):WaitForChild("Build")
	local targetHRP = getNearestPlayerInRange()
	if not targetHRP then return end
	
	local rayParams = RaycastParams.new()
	rayParams.FilterDescendantsInstances = { player.Character }
	rayParams.FilterType = Enum.RaycastFilterType.Blacklist
	
	for i = 1, settings.targetSpike.spikeCount do
		local angle = math.rad((i - 1) * (360 / settings.targetSpike.spikeCount))
		local offset = Vector3.new(
			math.cos(angle) * settings.targetSpike.radius,
			0,
			math.sin(angle) * settings.targetSpike.radius
		)
		
		local testPos = targetHRP.Position + offset
		local rayResult = workspace:Raycast(
			testPos + Vector3.new(0, 5, 0),
			Vector3.new(0, -15, 0),
			rayParams
		)
		
		if rayResult then
			local spikeCFrame = CFrame.new(rayResult.Position + Vector3.new(0, settings.targetSpike.groundOffset, 0))
			spikeCFrame = spikeCFrame * CFrame.Angles(0, math.rad(math.random(0, 360)), 0)
			
			local args = {
				spikesTool,
				spikeCFrame,
				randomId(),
				randomId(),
				math.random(200, 300)
			}
			
			buildRemote:InvokeServer(unpack(args))
		end
		
		if settings.targetSpike.placeDelay > 0 then
			task.wait(settings.targetSpike.placeDelay)
		end
	end
end

