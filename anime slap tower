-- Helper to make cards
local function makeCard(order)
    local c = Instance.new("Frame")
    c.Size = UDim2.new(1, 0, 0, 0)
    c.AutomaticSize = Enum.AutomaticSize.Y
    c.BackgroundColor3 = T.card
    c.BorderSizePixel = 0
    c.LayoutOrder = order
    c.ZIndex = 3
    c.Parent = page
    Instance.new("UICorner", c).CornerRadius = UDim.new(0, 11)

    local s = Instance.new("UIStroke")
    s.Color = T.border
    s.Thickness = 1
    s.Parent = c

    local ll = Instance.new("UIListLayout")
    ll.SortOrder = Enum.SortOrder.LayoutOrder
    ll.HorizontalAlignment = Enum.HorizontalAlignment.Center
    ll.Parent = c

    return c
end

local function makeRow(card, order, isLast, h)
    local row = Instance.new("Frame")
    row.Size = UDim2.new(1, 0, 0, h or 46)
    row.BackgroundTransparency = 1
    row.BorderSizePixel = 0
    row.LayoutOrder = order
    row.ZIndex = 4
    row.Parent = card

    if not isLast then
        local sep = Instance.new("Frame")
        sep.Size = UDim2.new(1, -28, 0, 1)
        sep.Position = UDim2.new(0, 14, 1, -1)
        sep.BackgroundColor3 = T.sep
        sep.BorderSizePixel = 0
        sep.ZIndex = 4
        sep.Parent = row
    end
    return row
end

-- ================== FEATURES ==================
local autoWinEnabled = false
local autoWinLoop = nil

local function startAutoWin()
    if autoWinLoop then return end
    autoWinLoop = task.spawn(function()
        while autoWinEnabled and sg.Parent do
            local char = LocalPlayer.Character
            local fin = workspace:FindFirstChild("Fin")
            if char and char:FindFirstChild("HumanoidRootPart") and fin then
                char:MoveTo(fin.Position + Vector3.new(0, 3, 0))
            end
            task.wait(0.2)
        end
        autoWinLoop = nil
    end)
end

local function stopAutoWin()
    autoWinEnabled = false
end

