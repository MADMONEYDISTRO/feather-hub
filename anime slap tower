local function giveTools(list)
    task.spawn(function()
        for _, toolName in ipairs(list) do
            pcall(function()
                ReplicatedStorage:WaitForChild("Remotes"):WaitForChild("GiveFree"):FireServer(toolName)
            end)
            task.wait(0.15)
        end
        notify("Tools", "All tools requested!", "success")
    end)
end

