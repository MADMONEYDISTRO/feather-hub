function SeatCustomers()
    for _, group in ipairs(getgenv().PlayerPlot.Customers:GetChildren()) do
        task.wait(0.05)
        local groupnumber = group.Name
        if group:FindFirstChild("Data") and group.Data.SeatedAt ~= "" and group:FindFirstChild("Customers") then
            for _, customer in ipairs(group.Customers:GetChildren()) do
                task.wait(0.05)
                local customernumber = customer.Name
                for _, surface in ipairs(getgenv().PlayerPlot.Items.OftenFiltered.Surface:GetChildren()) do
                    task.wait(0.05)
                    if surface:FindFirstChild("InUse") and surface.InUse.Value == false then
                        local args = {
                            name = "SendToTable",
                            obj = surface,
                            group = groupnumber,
                            tycoon = workspace.Tycoons.Tycoon,
                            customer = customernumber,
                        }
                        game:GetService("ReplicatedStorage").Events.ClientTycoonInput:FireServer(getgenv().PlayerPlot, args)
                    end
                end
            end
        end
    end
end

function DeliverDrinks()
    for _, tableObj in ipairs(getgenv().PlayerPlot.Customers:GetChildren()) do
        task.wait(0.05)
        local tablenumber = tableObj.Name
        if tableObj:FindFirstChild("Customers") then
            for _, customer in ipairs(tableObj.Customers:GetChildren()) do
                task.wait(0.05)
                local customernumber = customer.Name
                local mealChoice = customer:FindFirstChild("MealChoice")
                if mealChoice then
                    local drinkName = mealChoice.Value
                    local fridge = getgenv().PlayerPlot.Items.OftenFiltered.Kitchen:FindFirstChild("68")
                    if fridge then
                        game:GetService("ReplicatedStorage").Events.RequestGrab:InvokeServer("Fridge", fridge, getgenv().PlayerPlot)
                    end
                    for _, drink in ipairs(getgenv().PlayerPlot.Resources.Drinks:GetChildren()) do
                        task.wait(0.05)
                        if drink.Name == drinkName then
                            local args = {
                                models = {},
                                name = "ManageFood",
                                model = drink,
                                customer = customernumber,
                                tycoon = getgenv().PlayerPlot,
                                group = tablenumber,
                            }
                            game:GetService("ReplicatedStorage").Events.ClientTycoonInput:FireServer(getgenv().PlayerPlot, args)
                        end
                    end
                end
            end
        end
    end
end

function DeliverFood()
    for _, tableObj in ipairs(getgenv().PlayerPlot.Customers:GetChildren()) do
        task.wait(0.05)
        local tablenumber = tableObj.Name
        if tableObj:FindFirstChild("Customers") then
            for _, customer in ipairs(tableObj.Customers:GetChildren()) do
                task.wait(0.05)
                local customernumber = customer.Name
                local mealChoice = customer:FindFirstChild("MealChoice")
                if mealChoice then
                    local meal = mealChoice.Value
                    for _, surface in ipairs(getgenv().PlayerPlot.Items.OftenFiltered.Surface:GetChildren()) do
                        task.wait(0.05)
                        if surface:FindFirstChild("OrderedFoods") and surface.OrderedFoods:FindFirstChild(meal) then
                            local args = {
                                models = { surface.OrderedFoods[meal] },
                                name = "ManageFood",
                                model = surface.OrderedFoods[meal],
                                customer = customernumber,
                                tycoon = getgenv().PlayerPlot,
                                group = tablenumber,
                            }
                            game:GetService("ReplicatedStorage").Events.ClientTycoonInput:FireServer(getgenv().PlayerPlot, args)
                        end
                    end
                end
            end
        end
    end
end

function TakeOrders()
    for _, group in ipairs(getgenv().PlayerPlot.Customers:GetChildren()) do
        task.wait(0.05)
        local groupnumber = group.Name
        if group:FindFirstChild("Customers") then
            for _, customer in ipairs(group.Customers:GetChildren()) do
                task.wait(0.05)
                local args = {
                    customer = customer.Name,
                    tycoon = getgenv().PlayerPlot,
                    name = "ManageCustomers",
                    group = groupnumber,
                }
                game:GetService("ReplicatedStorage").Events.ClientTycoonInput:FireServer(getgenv().PlayerPlot, args)
            end
        end
    end
end

function GetBills()
    for _, surface in ipairs(getgenv().PlayerPlot.Items.OftenFiltered.Surface:GetChildren()) do
        if surface:FindFirstChild("Bill") then
            game:GetService("ReplicatedStorage").Events.ClientTycoonInput:FireServer(getgenv().PlayerPlot, {
                name = "CollectBill",
                model = surface,
            })
        end
    end
    for _, furniture in ipairs(getgenv().PlayerPlot.Items.AlwaysFiltered.Furniture:GetChildren()) do
        if furniture:FindFirstChild("Jar") and furniture.Jar.BillboardGui.Frame.Amt.Text ~= "0 Cash" then
            game:GetService("ReplicatedStorage").Events.ClientTycoonInput:FireServer(getgenv().PlayerPlot, {
                name = "CollectTip",
            })
        end
    end
    for _, drop in ipairs(workspace.DropFolder:GetChildren()) do
        if drop:FindFirstChild("TouchInterest") then
            firetouchinterest(rootPart, drop, 0)
            task.wait(0.25)
            firetouchinterest(rootPart, drop, 1)
        end
    end
end

function CollectDishes()
    for _, surface in ipairs(getgenv().PlayerPlot.Items.OftenFiltered.Surface:GetChildren()) do
        if surface:FindFirstChild("Trash") then
            game:GetService("ReplicatedStorage").Events.ClientTycoonInput:FireServer(getgenv().PlayerPlot, {
                name = "ClearTrash",
                model = surface,
            })
        end
    end
end

