        UI.rotationStatus.Text = "Status: Active"
        UI.rotationStatus.TextColor3 = UI_THEMES[currentTheme].Success
        UI.rotationToggle.Text = "DISABLE ROTATION"
        UI.rotationToggle.BackgroundColor3 = UI_THEMES[currentTheme].Danger
        
        connection = game:GetService("RunService").Heartbeat:Connect(function()
            local character = player.Character
            local closestPlayer = getClosestPlayer()
            
            if character and closestPlayer and closestPlayer.Character then
                rotateAroundTarget(closestPlayer.Character, character)
            end
        end)
        
        local lastClick = tick()
        clickConnection = game:GetService("RunService").Heartbeat:Connect(function()
            local now = tick()
            if now - lastClick >= CLICK_INTERVAL then
                sendMouseInput()
                lastClick = now
            end
        end)
        
    else
        UI.rotationStatus.Text = "Status: Disabled"
        UI.rotationStatus.TextColor3 = UI_THEMES[currentTheme].Danger
        UI.rotationToggle.Text = "ENABLE ROTATION"
        UI.rotationToggle.BackgroundColor3 = UI_THEMES[currentTheme].Secondary
        
        if connection then
            connection:Disconnect()
            connection = nil
        end
        
        if clickConnection then
            clickConnection:Disconnect()
            clickConnection = nil
        end
    end
end

-- Safezone Functions
function getPlayerHealth()
    local character = player.Character
    if not character then return nil end
    
    local humanoid = character:FindFirstChildOfClass("Humanoid")
    if not humanoid then return nil end
    
    return humanoid.Health, humanoid.MaxHealth
end

function teleportToSafezone()
    local character = player.Character
    if not character then return false end
    
    local humanoidRootPart = character:FindFirstChild("HumanoidRootPart")
    if not humanoidRootPart then return false end
    
    humanoidRootPart.CFrame = TELEPORT_CFRAME
    return true
end

function updateHealthStatus()
    local health, maxHealth = getPlayerHealth()
    if not health or not maxHealth then
        UI.healthStatus.Text = "Health: No character"
        UI.healthStatus.TextColor3 = UI_THEMES[currentTheme].Warning
        return
    end
    
    local percent = (health / maxHealth) * 100
    
    if percent >= 75 then
        UI.healthStatus.Text = string.format("Health: Full (%.0f%%)", percent)
        UI.healthStatus.TextColor3 = UI_THEMES[currentTheme].Success
    elseif percent > 25 then
        UI.healthStatus.Text = string.format("Health: Moderate (%.0f%%)", percent)
        UI.healthStatus.TextColor3 = UI_THEMES[currentTheme].Warning
    else
        UI.healthStatus.Text = string.format("Health: Low (%.0f%%)", percent)
        UI.healthStatus.TextColor3 = UI_THEMES[currentTheme].Danger
    end
    
    if safezoneToggle and health <= LOW_HP_THRESHOLD then
        local success = teleportToSafezone()
        if success then
            UI.healthStatus.Text = "SAFE ZONE TELEPORTED!"
            UI.healthStatus.TextColor3 = UI_THEMES[currentTheme].Accent
            
            task.wait(1)
        end
    end
end

function toggleSafezone()
    safezoneToggle = not safezoneToggle
    
    if safezoneToggle then
        UI.safezoneToggleBtn.Text = "DISABLE SAFEZONE"
        UI.safezoneToggleBtn.BackgroundColor3 = UI_THEMES[currentTheme].Success
        
        if not safezoneConnection then
            safezoneConnection = game:GetService("RunService").Heartbeat:Connect(function()
                updateHealthStatus()
            end)
        end
    else
        UI.safezoneToggleBtn.Text = "ENABLE SAFEZONE"
        UI.safezoneToggleBtn.BackgroundColor3 = UI_THEMES[currentTheme].Secondary
        
        if safezoneConnection then
            safezoneConnection:Disconnect()
            safezoneConnection = nil
        end
    end
end

UI.safezoneToggleBtn.MouseButton1Click:Connect(toggleSafezone)

-- Handle player respawns to maintain UI
player.CharacterAdded:Connect(function(character)
    task.wait(1) -- Wait for character to fully load
    updateHealthStatus()
    
    -- The UI persists automatically due to ResetOnSpawn = false
    -- But we need to make sure all connections are still working
    print("Character respawned - UI maintained")
end)

