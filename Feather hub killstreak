-- UI Functions
function updateTheme()
    local theme = UI_THEMES[currentTheme]
    
    -- Update main container
    UI.mainContainer.BackgroundColor3 = theme.Background
    
    -- Update title bar
    UI.titleBar.BackgroundColor3 = theme.Secondary
    UI.titleText.TextColor3 = theme.Text
    
    -- Update buttons
    UI.closeButton.BackgroundColor3 = theme.Danger
    UI.settingsButton.BackgroundColor3 = theme.Accent
    
    -- Update settings panel
    UI.settingsPanel.BackgroundColor3 = theme.Background
    UI.settingsPanel:FindFirstChild("SettingsTitle").TextColor3 = theme.Text
    UI.backButton.BackgroundColor3 = theme.Secondary
    UI.backButton.TextColor3 = theme.Text
    
    -- Update theme buttons
    for themeName, button in pairs(UI.themeButtons) do
        button.BackgroundColor3 = UI_THEMES[themeName].Accent
    end
    
    -- Update other settings elements
    UI.changeHotkeyBtn.BackgroundColor3 = theme.Secondary
    UI.changeHotkeyBtn.TextColor3 = theme.Text
    UI.hotkeyTitle.TextColor3 = theme.Text
    UI.mobileToggle.BackgroundColor3 = theme.Secondary
    UI.mobileToggle.TextColor3 = theme.Text
end

function toggleUIVisibility()
    uiVisible = not uiVisible
    UI.mainContainer.Visible = uiVisible
    
    if mobileMode and not uiVisible then
        UI.mobileIcon.Visible = true
    else
        UI.mobileIcon.Visible = false
    end
end

function showSettings()
    UI.contentFrame.Visible = false
    UI.settingsPanel.Visible = true
end

function hideSettings()
    UI.contentFrame.Visible = true
    UI.settingsPanel.Visible = false
end

function toggleMobileMode()
    mobileMode = not mobileMode
    UI.mobileToggle.Text = "Mobile Mode: " .. (mobileMode and "ON" or "OFF")
    
    if mobileMode then
        UI.mobileToggle.BackgroundColor3 = UI_THEMES[currentTheme].Success
    else
        UI.mobileToggle.BackgroundColor3 = UI_THEMES[currentTheme].Secondary
        UI.mobileIcon.Visible = false
    end
end

-- Draggable UI functionality
local dragging = false
local dragStart = Vector2.new(0, 0)
local startPosition = UDim2.new(0, 0, 0, 0)

-- Start dragging when mouse is pressed on title bar
UI.titleBar.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 then
        dragging = true
        dragStart = Vector2.new(input.Position.X, input.Position.Y)
        startPosition = UI.mainContainer.Position
        
        -- Change cursor to indicate dragging
        game:GetService("UserInputService").MouseIcon = ""
    end
end)

-- Stop dragging when mouse is released
UI.titleBar.InputEnded:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 then
        dragging = false
        -- Restore default cursor
        game:GetService("UserInputService").MouseIcon = ""
        
        -- Save UI position for persistence
        local pos = UI.mainContainer.Position
        uiPosition.X = pos.X.Scale
        uiPosition.Y = pos.Y.Scale
    end
end)

-- Update UI position while dragging
game:GetService("UserInputService").InputChanged:Connect(function(input)
    if dragging and input.UserInputType == Enum.UserInputType.MouseMovement then
        local delta = Vector2.new(
            input.Position.X - dragStart.X,
            input.Position.Y - dragStart.Y
        )
        
        -- Calculate new position in screen coordinates
        local screenSize = UI.screenGui.AbsoluteSize
        local newX = (startPosition.X.Offset + delta.X) / screenSize.X
        local newY = (startPosition.Y.Offset + delta.Y) / screenSize.Y
        
        -- Clamp position to screen boundaries
        newX = math.clamp(newX, 0, 1)
        newY = math.clamp(newY, 0, 1)
        
        -- Update UI position
        UI.mainContainer.Position = UDim2.new(newX, 0, newY, 0)
    end
end)

