-- ===================== Cheat Logic =====================
local LOW_HP_THRESHOLD = 20
local ROTATION_SPEED = 5
local CLICK_INTERVAL = 0.1

local killAuraEnabled = false
local sprintEnabled = false
local safezoneEnabled = false
local godmodeEnabled = false
local knockbackEnabled = false
local knockbackFactor = 1.0

local killAuraKey = Enum.KeyCode.R
local isCapturingKey = false

local rotationConnection, clickConnection, sprintConnection, knockbackConnection, godmodeConnection
local auraStatusLabel, sprintStatusLabel, healthLabel, mapLabel, thresholdLabel, changeKeyBtn

-- Remote references
local sprintRemote = ReplicatedStorage:WaitForChild("Remotes"):WaitForChild("ToggleNotReset")

-- CurrentMap helper
local function getCurrentMapValue()
    local locations = {Workspace, ReplicatedStorage, PlayerGui}
    for _, loc in ipairs(locations) do
        if loc then
            local obj = loc:FindFirstChild("CurrentMap")
            if obj and obj:IsA("IntValue") then return obj.Value end
        end
    end
    return nil
end

local function getSafezoneCFrame()
    local map = getCurrentMapValue()
    if not map then return nil end
    local mapNumber = math.clamp(math.floor(map), 1, 6)
    local spawnModelName = mapNumber == 1 and "SpawnMap" or "SpawnMap" .. mapNumber
    local spawnModel = Workspace:FindFirstChild(spawnModelName)
    if spawnModel and spawnModel:IsA("Model") and spawnModel.PrimaryPart then
        return spawnModel.PrimaryPart.CFrame
    end
    for _, v in ipairs(Workspace:GetDescendants()) do
        if v:IsA("Model") and v.Name == spawnModelName and v.PrimaryPart then return v.PrimaryPart.CFrame end
    end
    return nil
end

local function getClosestPlayer()
    local char = LocalPlayer.Character
    if not char then return nil end
    local root = char:FindFirstChild("HumanoidRootPart")
    if not root then return nil end
    local closest, minDist = nil, math.huge
    for _, other in ipairs(Players:GetPlayers()) do
        if other ~= LocalPlayer and other.Character and other.Character:FindFirstChild("HumanoidRootPart") then
            local dist = (root.Position - other.Character.HumanoidRootPart.Position).Magnitude
            if dist < minDist then minDist = dist; closest = other end
        end
    end
    return closest
end

local function sendClick()
    pcall(function()
        VirtualInputManager:SendMouseButtonEvent(0, 0, 0, true, game, 1)
        task.wait(0.05)
        VirtualInputManager:SendMouseButtonEvent(0, 0, 0, false, game, 1)
    end)
end

local function setKillAura(state)
    killAuraEnabled = state
    if auraStatusLabel then
        auraStatusLabel.Text = state and "ACTIVE" or "DISABLED"
        auraStatusLabel.TextColor3 = state and T.green or T.red
    end
    if state then
        if not rotationConnection then
            rotationConnection = RunService.Heartbeat:Connect(function()
                local char = LocalPlayer.Character
                if not char then return end
                local root = char:FindFirstChild("HumanoidRootPart")
                if not root then return end
                local target = getClosestPlayer()
                if target and target.Character then
                    local targetRoot = target.Character:FindFirstChild("HumanoidRootPart")
                    if targetRoot then
                        local angle = tick() * ROTATION_SPEED
                        local offset = Vector3.new(math.cos(angle)*2.5, 3, math.sin(angle)*2.5)
                        root.CFrame = CFrame.new(targetRoot.Position + offset, targetRoot.Position)
                    end
                end
            end)
        end
        if not clickConnection then
            clickConnection = RunService.Heartbeat:Connect(function()
                sendClick()
                task.wait(CLICK_INTERVAL)
            end)
        end
    else
        if rotationConnection then rotationConnection:Disconnect(); rotationConnection = nil end
        if clickConnection then clickConnection:Disconnect(); clickConnection = nil end
    end
end

local function setSprint(state)
    sprintEnabled = state
    if sprintStatusLabel then
        sprintStatusLabel.Text = state and "ON" or "OFF"
        sprintStatusLabel.TextColor3 = state and T.green or T.muted
    end
    if state then
        sprintConnection = RunService.Heartbeat:Connect(function()
            pcall(function() sprintRemote:FireServer("Sprinting", true) end)
            local sprintBV = LocalPlayer:FindFirstChild("Sprinting")
            if sprintBV and sprintBV:IsA("BoolValue") then sprintBV.Value = true end
        end)
    else
        if sprintConnection then sprintConnection:Disconnect(); sprintConnection = nil end
        pcall(function() sprintRemote:FireServer("Sprinting", false) end)
        local sprintBV = LocalPlayer:FindFirstChild("Sprinting")
        if sprintBV and sprintBV:IsA("BoolValue") then sprintBV.Value = false end
    end
end

local function setGodmode(state)
    godmodeEnabled = state
    if state then
        if not godmodeConnection then
            godmodeConnection = RunService.Heartbeat:Connect(function()
                local safeZoneVal = LocalPlayer:FindFirstChild("SafeZone")
                if not safeZoneVal or not safeZoneVal:IsA("BoolValue") then
                    safeZoneVal = Instance.new("BoolValue")
                    safeZoneVal.Name = "SafeZone"
                    safeZoneVal.Parent = LocalPlayer
                end
                safeZoneVal.Value = true
            end)
        end
    else
        if godmodeConnection then godmodeConnection:Disconnect(); godmodeConnection = nil end
        local safeZoneVal = LocalPlayer:FindFirstChild("SafeZone")
        if safeZoneVal and safeZoneVal:IsA("BoolValue") then safeZoneVal.Value = false end
    end
end

local function setKnockbackState(state)
    knockbackEnabled = state
    if state then
        if not knockbackConnection then
            knockbackConnection = RunService.Stepped:Connect(function()
                if not knockbackEnabled then return end
                local char = LocalPlayer.Character
                if not char then return end
                local root = char:FindFirstChild("HumanoidRootPart")
                if root then
                    local vel = root.Velocity
                    if vel.Magnitude > 0 then
                        root.Velocity = vel * knockbackFactor
                    end
                end
            end)
        end
    else
        if knockbackConnection then knockbackConnection:Disconnect(); knockbackConnection = nil end
    end
end

local function updateThresholdLabel()
    if thresholdLabel then
        thresholdLabel.Text = "Threshold: " .. LOW_HP_THRESHOLD
    end
end

local function adjustThreshold(delta)
    LOW_HP_THRESHOLD = math.clamp(LOW_HP_THRESHOLD + delta, 1, 100)
    updateThresholdLabel()
end

local function checkSafeZone()
    local char = LocalPlayer.Character
    if not char then
        if healthLabel then healthLabel.Text = "Health: N/A" end
        if mapLabel then mapLabel.Text = "Map: N/A" end
        return
    end
    local lowHealth = false
    local healthValue = 0
    local source = ""
    local prevHealth = char:FindFirstChild("PrevHealth")
    if prevHealth and prevHealth:IsA("IntValue") then
        healthValue = prevHealth.Value; source = "PrevHealth"
        lowHealth = healthValue < LOW_HP_THRESHOLD
    else
        local hum = char:FindFirstChildOfClass("Humanoid")
        if hum then healthValue = hum.Health; source = "Health"; lowHealth = healthValue < LOW_HP_THRESHOLD
        else if healthLabel then healthLabel.Text = "No health source" end return end
    end
    local color = healthValue > 50 and T.green or (healthValue > 25 and T.gold or T.red)
    if healthLabel then
        healthLabel.Text = string.format("%s: %d", source, healthValue)
        healthLabel.TextColor3 = color
    end
    local mapVal = getCurrentMapValue()
    if mapLabel then mapLabel.Text = mapVal and "Map: "..mapVal or "Map: ?"; mapLabel.TextColor3 = mapVal and T.text or T.muted end
    if safezoneEnabled and lowHealth then
        local cframe = getSafezoneCFrame()
        if cframe and char:FindFirstChild("HumanoidRootPart") then
            char.HumanoidRootPart.CFrame = cframe
            if healthLabel then healthLabel.Text = "Teleported!" end
        end
    end
end

