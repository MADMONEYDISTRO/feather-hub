-- Global Input
UserInputService.InputBegan:Connect(function(input, gameProcessed)
    if gameProcessed then return end
    if isCapturingKey then
        if input.KeyCode ~= Enum.KeyCode.Unknown then
            killAuraKey = input.KeyCode
            changeKeyBtn.Text = "Bind: " .. tostring(killAuraKey):gsub("Enum.KeyCode.", "")
            changeKeyBtn.BackgroundColor3 = T.accent
            isCapturingKey = false
        end
    else
        if input.KeyCode == killAuraKey then setKillAura(not killAuraEnabled)
        elseif input.KeyCode == Enum.KeyCode.F3 then sg.Enabled = not sg.Enabled end
    end
end)

