-- =================== Bypass Logic ===================
local spoofedKey = "FEATHER-KEY-" .. tostring(math.random(100000, 999999))
local bypassActive = false
local logLabel

local function addLog(text, color)
    if logLabel and logLabel.Parent then
        logLabel.Text = logLabel.Text .. "\n" .. text
        logLabel.TextColor3 = color or T.text
        local scroll = logLabel.Parent.Parent
        if scroll and scroll:IsA("ScrollingFrame") then
            scroll.CanvasPosition = Vector2.new(0, scroll.CanvasSize.Y.Offset)
        end
    end
end

local function enableBypass()
    if bypassActive then return end
    bypassActive = true

    -- Overwrite common key check globals
    local keyFunctions = {
        "is_key_valid","check_key","verify_key","get_key","key_check",
        "validate_key","is_executor_whitelisted","is_whitelisted",
        "check_whitelist","is_key","key_verify","getkey","checkkey","validatekey",
    }
    for _, fnName in ipairs(keyFunctions) do
        if not _G[fnName] or type(_G[fnName]) ~= "function" then
            _G[fnName] = function() return true end
        end
    end
    _G.get_key = function() return spoofedKey end
    _G.getkey = _G.get_key

    -- Hook game.HttpGet
    local originalHttpGet = game.HttpGet
    if type(originalHttpGet) == "function" then
        local hooked = function(url)
            local lowerUrl = url:lower()
            if lowerUrl:find("key") or lowerUrl:find("whitelist") then
                addLog("🌐 Intercepted: " .. url, T.muted)
                return [[{"success":true,"key":"]], spoofedKey, [["}]]
            end
            return originalHttpGet(url)
        end
        local ok = pcall(function() game.HttpGet = hooked end)
        if ok then
            addLog("🔗 HttpGet hooked for key requests.", T.green)
        else
            addLog("⚠ Could not hook HttpGet (global bypass still active)", T.red)
        end
    end

    _G.whitelist_status = true
    _G.executor_whitelisted = true
    _G.script_key = spoofedKey
    _G.GLOBAL_KEY = spoofedKey
    addLog("✅ Bypass enabled – all key functions mocked.", T.green)
end

