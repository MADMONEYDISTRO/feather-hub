local function getRoot()
    local char = Player.Character or Player.CharacterAdded:Wait()
    return char:WaitForChild("HumanoidRootPart")
end

local function getCurrentCash()
    local stats = Player:FindFirstChild("leaderstats")
    local cash = stats and stats:FindFirstChild("Cash")
    return cash and cash.Value or 0
end

local function findPlayerTycoon()
    local ok, result = pcall(function()
        for _, tycoon in ipairs(workspace.Tycoon.Tycoons:GetChildren()) do
            if tycoon:FindFirstChild("Owner") and tycoon.Owner.Value == Player then
                return tycoon
            end
        end
    end)
    return ok and result or nil
end

local function storeSellPosition()
    local tycoon = findPlayerTycoon()
    if not tycoon then return false end
    local ok = pcall(function()
        local oilCollector = tycoon.Essentials:FindFirstChild("Oil Collector")
        if oilCollector then
            local plane = oilCollector.Collector:FindFirstChild("Plane")
            if plane then
                Config.SellPosition = plane.CFrame * CFrame.new(0, 3, 0)
            end
        end
    end)
    return Config.SellPosition ~= nil
end

local function isGreenButton(btn)
    local neon = btn:FindFirstChild("Neon") or btn:FindFirstChild("Button")
    if neon and neon:IsA("BasePart") then
        local c = neon.Color
        return (c.G > c.R and c.G > c.B)
    end
    return false
end

local function pressE(duration)
    VIM:SendKeyEvent(true, Enum.KeyCode.E, false, game)
    task.wait(duration)
    VIM:SendKeyEvent(false, Enum.KeyCode.E, false, game)
end

local function collectAndSellCrate()
    if isProcessing then return end
    isProcessing = true

    local found = false
    pcall(function()
        local crates = workspace:FindFirstChild("Game Systems") and workspace["Game Systems"]:FindFirstChild("Crate Workspace")
        if crates then
            for _, crate in ipairs(crates:GetChildren()) do
                if crate.Name:find("Crate") and crate:IsA("BasePart") then
                    local owner = crate:GetAttribute("Owner")
                    if owner and tostring(owner) == Player.Name then continue end

                    getRoot().CFrame = crate.CFrame * CFrame.new(3, 0, 0)
                    task.wait(2)
                    pressE(Config.RecupCrate)
                    task.wait(2)

                    if not Config.SellPosition then storeSellPosition() end
                    if Config.SellPosition then
                        getRoot().CFrame = Config.SellPosition
                        task.wait(2)
                        pressE(Config.SellCrate)
                        task.wait(2)
                    end
                    found = true
                    break
                end
            end
        end
    end)

    if not found and Config.FallbackTeleports then
        for _, pos in ipairs(Config.FallbackTeleports) do
            if not isFarming then break end
            pcall(function() getRoot().CFrame = pos end)
            task.wait(Config.TeleportDelay)
        end
    end
    isProcessing = false
end

local function collectBarrelsLoop()
    while collectingBarrels do
        for _, pos in ipairs(Config.OilBarrels) do
            if not collectingBarrels then break end
            pcall(function()
                getRoot().CFrame = CFrame.new(pos)
                task.wait(Config.TeleportDelay)
                pressE(Config.RecupCrate)
                task.wait(1)

                if not Config.SellPosition then storeSellPosition() end
                if Config.SellPosition then
                    getRoot().CFrame = Config.SellPosition
                    task.wait(Config.TeleportDelay)
                    pressE(Config.SellCrate)
                    task.wait(1)
                end
            end)
        end
        task.wait(1)
    end
end

local function startAutoFarm()
    if farmingConnection then return end
    isFarming = true
    pcall(function() originalPosition = getRoot().CFrame end)
    storeSellPosition()

    farmingConnection = RS.Heartbeat:Connect(function()
        if not isFarming then
            if farmingConnection then farmingConnection:Disconnect(); farmingConnection = nil end
            return
        end
        if isProcessing or collectingBarrels then return end

        local currentMoney = getCurrentCash()

        if Config.AutoBuy and currentMoney >= Config.CashTarget then
            local tycoon = findPlayerTycoon()
            local buttons = tycoon and tycoon:FindFirstChild("UnpurchasedButtons")
            if buttons then
                local targetButton = nil
                for _, btn in ipairs(buttons:GetChildren()) do
                    if isGreenButton(btn) then targetButton = btn; break end
                end
                if targetButton then
                    local neon = targetButton:FindFirstChild("Neon") or targetButton:FindFirstChild("Button")
                    if neon then pcall(function() getRoot().CFrame = neon.CFrame + Vector3.new(0, 5, 0) end) end
                    task.wait(Config.TeleportDelay)
                else
                    collectAndSellCrate()
                end
            else
                collectAndSellCrate()
            end
        elseif Config.RecupMonay then
            collectAndSellCrate()
        end
    end)
end

local function stopAutoFarm()
    isFarming = false
    if farmingConnection then farmingConnection:Disconnect(); farmingConnection = nil end
    if originalPosition then pcall(function() getRoot().CFrame = originalPosition end) end
end

