local function makeSlider(card, order, label, min, max, default, cb, isLast)
    local row=makeRow(card,order,isLast,48)
    local lbl=Instance.new("TextLabel"); lbl.Size=UDim2.new(0.5,0,0,16); lbl.Position=UDim2.new(0,14,0,4)
    lbl.Text=label; lbl.Font=Enum.Font.GothamSemibold; lbl.TextSize=isMobile and 11 or 10
    lbl.TextColor3=T.muted; lbl.TextXAlignment=Enum.TextXAlignment.Left; lbl.BackgroundTransparency=1; lbl.ZIndex=5; lbl.Parent=row
    reg(lbl,"TextColor3",LIGHT.muted,DARK.muted)

    local valLbl=Instance.new("TextLabel"); valLbl.Size=UDim2.new(0.3,0,0,16); valLbl.Position=UDim2.new(0.7,-14,0,4)
    valLbl.Text=tostring(default); valLbl.Font=Enum.Font.GothamBold; valLbl.TextSize=isMobile and 11 or 10
    valLbl.TextColor3=accent; valLbl.TextXAlignment=Enum.TextXAlignment.Right; valLbl.BackgroundTransparency=1; valLbl.ZIndex=5; valLbl.Parent=row
    Instance.new("UIPadding",valLbl).PaddingRight=UDim.new(0,14)

    local track=Instance.new("Frame"); track.Size=UDim2.new(1,-28,0,5); track.Position=UDim2.new(0,14,0,28)
    track.BackgroundColor3=T.dim; track.BorderSizePixel=0; track.ZIndex=5; track.Parent=row
    Instance.new("UICorner",track).CornerRadius=UDim.new(1,0)
    reg(track,"BackgroundColor3",LIGHT.dim,DARK.dim)

    local fill=Instance.new("Frame"); fill.Size=UDim2.new((default-min)/(max-min),0,1,0)
    fill.BackgroundColor3=accent; fill.BorderSizePixel=0; fill.ZIndex=6; fill.Parent=track
    Instance.new("UICorner",fill).CornerRadius=UDim.new(1,0)

    local knob=Instance.new("Frame"); knob.Size=UDim2.new(0,12,0,12)
    knob.Position=UDim2.new((default-min)/(max-min),-6,0.5,-6)
    knob.BackgroundColor3=Color3.new(1,1,1); knob.ZIndex=7; knob.Parent=track
    Instance.new("UICorner",knob).CornerRadius=UDim.new(1,0)
    local ks=Instance.new("UIStroke",knob); ks.Color=accent; ks.Thickness=2; ks.Transparency=0.4

    local sdrag = false
    local function updSlider(posX)
        local tAbs = track.AbsolutePosition.X
        local tSz  = track.AbsoluteSize.X
        local rel  = math.clamp((posX - tAbs) / tSz, 0, 1)
        local val  = math.floor(min + (max - min) * rel)
        fill.Size = UDim2.new(rel, 0, 1, 0)
        knob.Position = UDim2.new(rel, -6, 0.5, -6)
        valLbl.Text = tostring(val)
        cb(val)
    end
    track.InputBegan:Connect(function(i)
        if i.UserInputType==Enum.UserInputType.MouseButton1 or i.UserInputType==Enum.UserInputType.Touch then
            sdrag=true; updSlider(i.Position.X) end
    end)
    UserInputService.InputChanged:Connect(function(i)
        if sdrag and (i.UserInputType==Enum.UserInputType.MouseMovement or i.UserInputType==Enum.UserInputType.Touch) then
            updSlider(i.Position.X) end
    end)
    UserInputService.InputEnded:Connect(function(i)
        if i.UserInputType==Enum.UserInputType.MouseButton1 or i.UserInputType==Enum.UserInputType.Touch then sdrag=false end
    end)
    return row
end

