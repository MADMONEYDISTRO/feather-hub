-- ══════════════════════════════════════════
--  TOGGLE LOGIC
-- ══════════════════════════════════════════

local function setParry(enabled)
    getgenv().autoparry = enabled

    -- pill animation
    TweenService:Create(pill, ti(), {
        BackgroundColor3 = enabled and C.success or C.dim,
    }):Play()
    TweenService:Create(knob, ti(), {
        Position         = enabled and UDim2.new(1, -19, 0.5, -8) or UDim2.new(0, 3, 0.5, -8),
        BackgroundColor3 = enabled and Color3.new(1, 1, 1) or C.muted,
    }):Play()

    -- status card
    TweenService:Create(statusStrip, ti(), {
        BackgroundColor3 = enabled and C.success or C.error,
    }):Play()
    statusLbl.Text       = enabled and "Parry is active" or "Parry is disabled"
    statusLbl.TextColor3 = enabled and C.success or C.error

    -- icon bg
    TweenService:Create(iconBg, ti(), {
        BackgroundColor3 = enabled and C.success or C.error,
    }):Play()

    -- sub text
    toggleSub.Text = enabled and "Click to disable" or "Click to enable"
end

