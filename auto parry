local function GetPing()
    local ok, p = pcall(function() return Stats.Network.ServerStatsItem["Data Ping"]:GetValue()/1000 end)
    return ok and p or 0.1
end

local function Parry()
    VirtualInputManager:SendKeyEvent(true, CFG.KEY, false, game)
    VirtualInputManager:SendKeyEvent(false, CFG.KEY, false, game)
end

local function FindBall()
    local folder = workspace:FindFirstChild("Balls")
    if not folder then return nil end
    local best, dist = nil, math.huge
    for _, b in ipairs(folder:GetChildren()) do
        if b:IsA("BasePart") then
            local t = b:GetAttribute("target")
            local d = (b.Position - root.Position).Magnitude
            local me = (t == Player.Name)
            if me then
                if not best or best:GetAttribute("target") ~= Player.Name or d < dist then best, dist = b, d end
            elseif not best or (best:GetAttribute("target") ~= Player.Name and d < dist) then
                best, dist = b, d
            end
        end
    end
    return best
end

-- ══════════════════════════════════════════
--  VISUAL SYSTEMS
-- ══════════════════════════════════════════
local function UpdateVis(targeted, dynRange)
    if not root or not root.Parent then return end
    if not S.rangeVis then if visPart then visPart:Destroy() visPart = nil end return end
    if not visPart then
        visPart = Instance.new("Part")
        visPart.Name = "FBVis"; visPart.Shape = Enum.PartType.Cylinder
        visPart.Anchored, visPart.CanCollide, visPart.CastShadow = true, false, false
        visPart.Parent = workspace
    end
    visPart.Color = targeted and Color3.fromRGB(255,60,60) or Color3.fromRGB(80,200,255)
    visPart.Transparency = targeted and 0.35 or 0.8
    visPart.Material = targeted and Enum.Material.Neon or Enum.Material.ForceField
    local sz = math.clamp(dynRange or S.range, 5, 300) * 2
    visPart.Size = Vector3.new(0.5, sz, sz)
    visPart.CFrame = root.CFrame * CFrame.Angles(0,0,math.rad(90)) - Vector3.new(0,2.5,0)
end

local function ClearPred()
    for _,p in ipairs(predParts) do if p and p.Parent then p:Destroy() end end
    predParts = {}
end

local function UpdatePred()
    ClearPred()
    if not S.ballPred or not S.ball or not S.ball.Parent then return end
    local pos, vel = S.ball.Position, S.ball.AssemblyLinearVelocity
    for i = 1, CFG.PRED_STEPS do
        local d = Instance.new("Part")
        d.Shape = Enum.PartType.Ball; d.Size = Vector3.new(0.6,0.6,0.6)
        d.Material = Enum.Material.Neon
        d.Color = Color3.fromHSV(0.75 + (i/CFG.PRED_STEPS)*0.15, 0.8, 1)
        d.Transparency = 0.15 + (i/CFG.PRED_STEPS)*0.6
        d.Anchored, d.CanCollide, d.CastShadow = true, false, false
        d.Position = pos + vel * (0.05 * i)
        d.Parent = workspace
        predParts[#predParts+1] = d
    end
end

local function ClearBeam()
    if beamObj then beamObj:Destroy() beamObj = nil end
    if att0 then att0:Destroy() att0 = nil end
    if att1 then att1:Destroy() att1 = nil end
end

local function UpdateBeam()
    if not S.targetBeam or not S.ball or not S.ball.Parent then ClearBeam() return end
    local tn = S.ball:GetAttribute("target")
    if not tn then ClearBeam() return end
    local tp = Players:FindFirstChild(tn)
    if not tp or not tp.Character then ClearBeam() return end
    local tr = tp.Character:FindFirstChild("HumanoidRootPart")
    if not tr then ClearBeam() return end
    if not beamObj then
        att0 = Instance.new("Attachment"); att0.Parent = S.ball
        att1 = Instance.new("Attachment"); att1.Parent = tr
        beamObj = Instance.new("Beam")
        beamObj.Attachment0, beamObj.Attachment1 = att0, att1
        beamObj.Width0, beamObj.Width1 = 0.25, 0.25
        beamObj.FaceCamera, beamObj.Segments = true, 1
        beamObj.Transparency = NumberSequence.new(0.3)
        beamObj.Parent = S.ball
    end
    beamObj.Color = ColorSequence.new(tn == Player.Name and Color3.fromRGB(255,60,60) or Color3.fromRGB(80,200,255))
    pcall(function()
        if att0.Parent ~= S.ball then att0.Parent = S.ball end
        if att1.Parent ~= tr then att1.Parent = tr end
    end)
end

local function Dodge(ball)
    if not root then return end
    S.lastDodge = tick(); S.dodges = S.dodges + 1
    local dir = (ball.Position - root.Position).Unit
    local r = dir:Cross(Vector3.new(0,1,0)).Unit
    local rp = RaycastParams.new()
    rp.FilterDescendantsInstances = {Player.Character}
    rp.FilterType = Enum.RaycastFilterType.Exclude
    local hr, hl = workspace:Raycast(root.Position, r*10, rp), workspace:Raycast(root.Position, -r*10, rp)
    local chosen = (hr and not hl) and -r or (hr and hl) and -dir or r
    local old = root:FindFirstChild("FBDodge"); if old then old:Destroy() end
    local bv = Instance.new("BodyVelocity")
    bv.Name = "FBDodge"; bv.Velocity = chosen * CFG.DODGE_PWR
    bv.MaxForce = Vector3.new(15000,0,15000); bv.P = 300; bv.Parent = root
    Debris:AddItem(bv, CFG.DODGE_DUR)
end

