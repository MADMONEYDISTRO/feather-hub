-- ══════════════════════════════════════════
--  MAIN GAME LOOP
-- ══════════════════════════════════════════
RunService.PreSimulation:Connect(function()
    if not char or not char.Parent then
        char = Player.Character
        if char then root = char:FindFirstChild("HumanoidRootPart"); humanoid = char:FindFirstChild("Humanoid") end
        return
    end
    if not root or not root.Parent then return end

    S.ball = FindBall()

    local isTargetingMe = false
    local finalRange = S.range

    if S.ball and S.ball.Parent then
        local targetName = S.ball:GetAttribute("target")
        isTargetingMe = (targetName == Player.Name)
        S.speed = math.floor(S.ball.AssemblyLinearVelocity.Magnitude + 0.5)

        if isTargetingMe then
            local vel = S.ball.AssemblyLinearVelocity
            local rel = S.ball.Position - root.Position
            local spd = -rel.Unit:Dot(vel)
            if CFG.DYN_SCALE and spd > 0 then
                finalRange = S.range + math.clamp(spd / CFG.SCALE_F, 0, CFG.SCALE_CAP)
            end
        end
    end

    -- update stats labels
    pcall(function()
        valParries.Text = tostring(S.parries)
        valDodges.Text  = tostring(S.dodges)
        valSpeed.Text   = tostring(S.speed)
        valPing.Text    = math.floor(GetPing()*1000).."ms"
    end)

    -- visuals
    if S.rangeVis then UpdateVis(isTargetingMe, finalRange) end
    if S.ballPred then UpdatePred() end
    if S.targetBeam then UpdateBeam() end

    if not S.ball or not S.ball.Parent then return end
    if not isTargetingMe then S.parriedCurrent = false; ClearBeam() end

    -- auto walk
    if S.autoWalk and isTargetingMe and humanoid then
        local d = Vector3.new((S.ball.Position-root.Position).X, 0, (S.ball.Position-root.Position).Z)
        humanoid:Move(d.Magnitude > 5 and d.Unit or Vector3.zero)
    end

    -- combat
    if isTargetingMe then
        if not S.ball or not S.ball.Parent or not root or not root.Parent then return end
        local vel = S.ball.AssemblyLinearVelocity
        local relPos = S.ball.Position - root.Position
        if math.abs(relPos.Y) > CFG.Y_LIMIT then return end

        local spd = -relPos.Unit:Dot(vel)
        local ping = GetPing()
        local off = spd * ping
        local rad = math.max(S.ball.Size.X, S.ball.Size.Z) / 2
        local hDist = Vector3.new(relPos.X,0,relPos.Z).Magnitude
        local eDist = (hDist - rad - S.pad) - off
        local d3D = relPos.Magnitude

        if S.autoParry and spd > 0 then
            if d3D <= (CFG.PANIC * 1.2) then Parry(); S.parries=S.parries+1 end
            if d3D <= (CFG.LAST_LAYER * 1.2) then Parry() end
            if eDist <= finalRange and not S.parriedCurrent then
                Parry(); S.parriedCurrent=true; S.parries=S.parries+1
            end
        end

        if S.spamParry and d3D <= (CFG.PANIC * 1.5) and spd > 0 then Parry() end

        if S.autoDodge then
            local cd = spd > 0 and 0.2 or 0.4
            local tti = eDist / math.max(1, spd)
            if tti <= (CFG.REACT + 0.3) and eDist > 10 and tick() - S.lastDodge > cd then
                Dodge(S.ball)
            end
        end
    end
end)

