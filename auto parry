-- ══════════════════════════════════════════
--  AUTO PARRY LOOP
-- ══════════════════════════════════════════

task.spawn(function()
    RunService.PreRender:Connect(function()
        if not getgenv().autoparry then return end

        local par = parry_helper.FindTargetBall()
        if not par then return end

        local hat = par.AssemblyLinearVelocity
        if par:FindFirstChild("zoomies") then
            hat = par.zoomies.VectorVelocity
        end

        local i = par.Position
        local j = Player.Character and Player.Character.PrimaryPart
        if not j then return end
        j = j.Position

        local kil = (j - i).Unit
        local l   = Player:DistanceFromCharacter(i)
        local m   = kil:Dot(hat.Unit)
        local n   = hat.Magnitude

        if m > 0 then
            local o = l - 5
            local p = o / n

            if parry_helper.IsPlayerTarget(par) and p <= 0.55 and not ero then
                VirtualManager:SendMouseButtonEvent(0, 0, 0, true, game, 0)
                task.wait(0.01)
                ero = true

                -- increment counter
                parryCount = parryCount + 1
                countLbl.Text = tostring(parryCount)

                -- flash accent on count label
                TweenService:Create(countLbl, ti(0.1), {TextColor3 = C.success}):Play()
                task.delay(0.4, function()
                    TweenService:Create(countLbl, ti(), {TextColor3 = C.accent}):Play()
                end)
            end
        else
            ero = false
        end
    end)
end)

