-- ====================== ORIGINAL HELPERS ======================
local function _nameHasGodRock(nm)
    local s = string.lower(tostring(nm))
    return s:find("god") and s:find("rock") and not s:find("axe") and not s:find("pick")
end
local function isGodRockEquipped()
    local char = LocalPlayer.Character
    if char then
        for _, ch in ipairs(char:GetChildren()) do
            if ch:IsA("Tool") and _nameHasGodRock(ch.Name) then return true end
        end
    end
    if _GameUtil and _GameUtil.Data then
        local idx = _GameUtil.Data.equipped
        local toolbar = _GameUtil.Data.toolbar
        if idx and toolbar and toolbar[idx] then
            local slot = toolbar[idx]
            if slot and slot.name and _nameHasGodRock(slot.name) then return true end
        end
    end
    return false
end
local function getPlayerTribeColor(player)
    if not _GameUtil then return nil end
    local ok, color = pcall(function()
        local c, _ = _GameUtil.isInATribe(player.UserId)
        return c
    end)
    if ok and color and color ~= "" then return tostring(color) end
    return nil
end
local function getLocalTribeColor() return getPlayerTribeColor(LocalPlayer) end
local function isEnemy(player)
    if player == LocalPlayer then return false end
    if not Settings.ka_teamCheck then return true end
    local myTribe = getLocalTribeColor()
    if myTribe == nil then return true end
    local theirTribe = getPlayerTribeColor(player)
    if theirTribe == nil then return true end
    return myTribe ~= theirTribe
end
local function isPichEnemy(player)
    if player == LocalPlayer then return false end
    if not Settings.pich_teamCheck then return true end
    local myTribe = getLocalTribeColor()
    if myTribe == nil then return true end
    local theirTribe = getPlayerTribeColor(player)
    if theirTribe == nil then return true end
    return myTribe ~= theirTribe
end

local SlashAnim = ReplicatedStorage:WaitForChild("Animations"):WaitForChild("Slash")
local AnimTrack, CurrentAnimator, lastSlashTime = nil, nil, 0
local function playSlash()
    if not Settings.ka_animToggle then return end
    if not isGodRockEquipped() then return end
    local char = LocalPlayer.Character
    if not char then return end
    local now = os.clock()
    if now - lastSlashTime < 0.45 then return end
    lastSlashTime = now
    local hum = char:FindFirstChild("Humanoid")
    if not hum then return end
    local animator = hum:FindFirstChildOfClass("Animator")
    if not animator then
        animator = Instance.new("Animator")
        animator.Parent = hum
    end
    if CurrentAnimator ~= animator then
        if AnimTrack then AnimTrack:Stop() end
        CurrentAnimator = animator
        AnimTrack = nil
    end
    if not AnimTrack then
        AnimTrack = animator:LoadAnimation(SlashAnim)
        AnimTrack.Priority = Enum.AnimationPriority.Action4
        AnimTrack.Looped = false
    end
    AnimTrack:Play(0.05, 1, 0.45)
    AnimTrack:AdjustSpeed(1)
end

-- Packet encoding utilities
local function decode(str)
    local b1, b2, b3 = string.byte(str, -4, -2)
    return b1 + b2*256 + b3*65536
end
local function to_half(value)
    local bits = string.unpack("<I4", string.pack("<f", value))
    local sign = bit32.rshift(bits, 31)
    local exp  = bit32.band(bit32.rshift(bits, 23), 0xFF)
    local mant = bit32.band(bits, 0x7FFFFF)
    if exp == 0xFF then
        if mant == 0 then return bit32.bor(bit32.lshift(sign, 15), 0x7C00)
        else return bit32.bor(bit32.lshift(sign, 15), 0x7E00, bit32.rshift(mant, 13)) end
    end
    exp = exp - 127
    if exp <= -15 then return bit32.lshift(sign, 15) end
    if exp >=  16 then return bit32.bor(bit32.lshift(sign, 15), 0x7C00) end
    exp = exp + 15
    local half = bit32.bor(bit32.lshift(sign, 15), bit32.lshift(exp, 10), bit32.rshift(mant, 13))
    if bit32.band(mant, 0x1000) ~= 0 then half = half + 1 end
    return half
end
local SWING_FOOTER = string.char(0x8C, 0x7D, 0xDA, 0x41)
local function getHRP()
    local char = LocalPlayer.Character
    if char then return char:FindFirstChild("HumanoidRootPart") end
    return nil
end
local function swingencode(ids)
    if typeof(ids) ~= "table" then ids = {ids} end
    local count = #ids
    local hrp = getHRP()
    local pos, cf
    if hrp then
        pos = hrp.Position
        cf = hrp.CFrame
    else
        pos = Vector3.new()
        cf = CFrame.new()
    end
    local out = {string.char(0x00, 0x13, count, 0x00)}
    for i = 1, count do
        local num = ids[i]
        out[#out+1] = string.char(
            num % 256,
            math.floor(num / 256)      % 256,
            math.floor(num / 65536)    % 256,
            math.floor(num / 16777216) % 256,
            0x00
        )
    end
    out[#out+1] = string.pack("<f", pos.X)
    out[#out+1] = string.pack("<f", pos.Y)
    out[#out+1] = string.pack("<f", pos.Z)
    local ex, ey, ez = cf:ToEulerAnglesXYZ()
    local rx, ry, rz = to_half(ex), to_half(ey), to_half(ez)
    out[#out+1] = string.char(rx % 256, math.floor(rx / 256))
    out[#out+1] = string.char(ry % 256, math.floor(ry / 256))
    out[#out+1] = string.char(rz % 256, math.floor(rz / 256))
    out[#out+1] = string.pack("<f", os.clock() % 1000)
    out[#out+1] = SWING_FOOTER
    return table.concat(out)
end
local function sendSwing(ids) ByteNetReliable:FireServer(buffer.fromstring(swingencode(ids))) end
local function healencode(slot) return string.char(0x00, 0x32, slot, 0x00) end
local function pickupencode(eid) return string.char(0x00, 0xE7, eid%256, math.floor(eid/256)%256, math.floor(eid/65536)%256, 0x00) end
local function harvestencode(eid) return string.char(0x00, 0xE7, eid%256, math.floor(eid/256)%256, math.floor(eid/65536)%256, 0x00) end
local function dropencode(slot) return string.char(0x00, 0x5D, slot, 0x00) end
local function toggledoorencode(eid) return string.char(0x00, 0x07, eid%256, math.floor(eid/256)%256, math.floor(eid/65536)%256, 0x00) end
local function interactstructureencode(eid, itemid) return string.char(0x00, 0xC9, eid%256, math.floor(eid/256)%256, math.floor(eid/65536)%256, 0x00, itemid%256, math.floor(itemid/256)%256) end
local function placeencode(name, x, y, z, rx, ry, rz)
    local len = #name
    local out = {string.char(0x00, 0xE1, len%256, math.floor(len/256))}
    out[#out+1] = name
    out[#out+1] = string.pack("<f", x)
    out[#out+1] = string.pack("<f", y)
    out[#out+1] = string.pack("<f", z)
    local hrx, hry, hrz = to_half(rx), to_half(ry), to_half(rz)
    out[#out+1] = string.char(hrx%256, math.floor(hrx/256))
    out[#out+1] = string.char(hry%256, math.floor(hry/256))
    out[#out+1] = string.char(hrz%256, math.floor(hrz/256))
    return table.concat(out)
end
local function sendPacket(packet) ByteNetReliable:FireServer(buffer.fromstring(packet)) end

-- Ground detection (raycast)
local _rayParams = RaycastParams.new()
_rayParams.FilterType = Enum.RaycastFilterType.Exclude
_rayParams.FilterDescendantsInstances = {LocalPlayer.Character or Instance.new("Folder")}
LocalPlayer.CharacterAdded:Connect(function(c) _rayParams.FilterDescendantsInstances = {c} end)

local function groundAt(pos)
    local origin = pos + Vector3.new(0, 60, 0)
    local result = Workspace:Raycast(origin, Vector3.new(0, -120, 0), _rayParams)
    if result then
        return Vector3.new(pos.X, result.Position.Y + 0.1, pos.Z)
    end
    return Vector3.new(pos.X, pos.Y + 0.1, pos.Z)
end

