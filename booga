    makeSection(pg5, "Quick Place Plantboxes", 5)
    local qpCard = makeCard(pg5, 6)
    local function placeplants(size)
        local startPos = HumanoidRootPart.Position - Vector3.new(0, 3, 0)
        local spacing = 6.04
        local count = 0
        local ry = math.rad(45)
        for x = 0, size-1 do
            for z = 0, size-1 do
                local pos = startPos + Vector3.new(x*spacing, 0, z*spacing)
                local g = groundAt(pos)
                sendPacket(placeencode("Plant Box", g.X, g.Y, g.Z, 0, ry, 0))
                count = count + 1
                task.wait(0.3)
            end
        end
        Notify("Plantboxes", "Placed "..count.." boxes ("..size.."x"..size..")")
    end
