-- ================== Brookhaven Features ==================
local selectedPlayer = ""
local killMode = "Bus"
local pullMode = "Bus"
local flingMode = "Bus"

local function getCharacter(player)
    return player and player.Character
end

local function getRoot(player)
    local char = getCharacter(player)
    return char and char:FindFirstChild("HumanoidRootPart")
end

local function getHumanoid(player)
    local char = getCharacter(player)
    return char and char:FindFirstChild("Humanoid")
end

-- Remote functions
local function fireRemote(name, ...)
    local remote = ReplicatedStorage.RE:FindFirstChild(name)
    if remote then
        remote:FireServer(...)
    end
end

local function invokeRemote(name, ...)
    local remote = ReplicatedStorage.RE:FindFirstChild(name)
    if remote then
        return remote:InvokeServer(...)
    end
end

-- Kill with Bus
local function killWithBus(targetName, toggleCallback)
    local target = Players:FindFirstChild(targetName)
    if not target then return end
    
    local function loop()
        local root = getRoot(target)
        local myRoot = getRoot(Player)
        if root and myRoot then
            local bus = Workspace.Vehicles:FindFirstChild("Bus") or Instance.new("Model")
            -- Simplified: Use remote to kill (Brookhaven specific)
            fireRemote("1Player1sCa1r", "Kill", targetName)
        end
        task.wait(0.1)
    end
    
    while toggleCallback and toggleCallback() do
        loop()
    end
end

-- Pull with Bus
local function pullWithBus(targetName, toggleCallback)
    local target = Players:FindFirstChild(targetName)
    if not target then return end
    
    while toggleCallback and toggleCallback() do
        local root = getRoot(target)
        local myRoot = getRoot(Player)
        if root and myRoot then
            root.CFrame = myRoot.CFrame + Vector3.new(0, 0, -5)
        end
        task.wait(0.1)
    end
end

-- Fling with Bus
local function flingWithBus(targetName, toggleCallback)
    local target = Players:FindFirstChild(targetName)
    if not target then return end
    
    while toggleCallback and toggleCallback() do
        local root = getRoot(target)
        if root then
            root.Velocity = Vector3.new(99999, 99999, 99999)
        end
        task.wait(0.1)
    end
end

