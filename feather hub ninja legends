local function getRootPart()
    local char = LocalPlayer.Character
    return char and char:FindFirstChild("HumanoidRootPart")
end

-- Refresh hoop list - finds all hoops
local function refreshHoops()
    local newList = {}
    -- Look for any part/model named "Hoop" or containing "hoop"
    for _, obj in ipairs(workspace:GetDescendants()) do
        if obj:IsA("BasePart") and obj.Name:lower():find("hoop") then
            table.insert(newList, obj)
        elseif obj:IsA("Model") and obj.Name:lower():find("hoop") then
            local primary = obj.PrimaryPart or obj:FindFirstChildWhichIsA("BasePart")
            if primary then
                table.insert(newList, primary)
            end
        end
    end
    -- Also check Hoops folder
    local hoopFolder = workspace:FindFirstChild("Hoops")
    if hoopFolder then
        for _, child in ipairs(hoopFolder:GetChildren()) do
            if child:IsA("BasePart") then
                table.insert(newList, child)
            elseif child:IsA("Model") then
                local primary = child.PrimaryPart or child:FindFirstChildWhichIsA("BasePart")
                if primary then
                    table.insert(newList, primary)
                end
            end
        end
    end
    -- Remove duplicates (by reference)
    local unique = {}
    for _, v in ipairs(newList) do
        if not unique[v] then
            unique[v] = true
            table.insert(allHoops, v)
        end
    end
    allHoops = newList
    return #allHoops
end

