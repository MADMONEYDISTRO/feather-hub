local function makeSlider(card, order, text, min, max, default, callback)
    local row = makeRow(card, order, true, 70)
    local lbl = Instance.new("TextLabel")
    lbl.Size = UDim2.new(0.5, 0, 0, 20)
    lbl.Position = UDim2.new(0, 16, 0, 8)
    lbl.Text = text
    lbl.Font = Enum.Font.GothamSemibold
    lbl.TextSize = 10
    lbl.TextColor3 = T.text
    lbl.TextXAlignment = Enum.TextXAlignment.Left
    lbl.BackgroundTransparency = 1
    lbl.Parent = row
    local valLbl = Instance.new("TextLabel")
    valLbl.Size = UDim2.new(0.4, 0, 0, 20)
    valLbl.Position = UDim2.new(0.6, 0, 0, 8)
    valLbl.Text = tostring(default)
    valLbl.Font = Enum.Font.GothamBold
    valLbl.TextSize = 9
    valLbl.TextColor3 = T.accent
    valLbl.TextXAlignment = Enum.TextXAlignment.Right
    valLbl.BackgroundTransparency = 1
    valLbl.Parent = row
    local track = Instance.new("Frame")
    track.Size = UDim2.new(1, -32, 0, 6)
    track.Position = UDim2.new(0, 16, 0, 44)
    track.BackgroundColor3 = T.dim
    track.BorderSizePixel = 0
    track.Parent = row
    Instance.new("UICorner", track).CornerRadius = UDim.new(1, 0)
    local fill = Instance.new("Frame")
    fill.Size = UDim2.new((default-min)/(max-min), 0, 1, 0)
    fill.BackgroundColor3 = T.accent
    fill.BorderSizePixel = 0
    fill.Parent = track
    Instance.new("UICorner", fill).CornerRadius = UDim.new(1, 0)
    local knob = Instance.new("TextButton")
    knob.Size = UDim2.new(0, 14, 0, 14)
    knob.Position = UDim2.new((default-min)/(max-min), -7, 0.5, -7)
    knob.BackgroundColor3 = Color3.new(1,1,1)
    knob.BorderSizePixel = 0
    knob.AutoButtonColor = false
    knob.Text = ""
    knob.Parent = track
    Instance.new("UICorner", knob).CornerRadius = UDim.new(1, 0)
    local dragging = false
    knob.InputBegan:Connect(function(i)
        if i.UserInputType == Enum.UserInputType.MouseButton1 then dragging = true end
    end)
    UserInputService.InputEnded:Connect(function(i)
        if i.UserInputType == Enum.UserInputType.MouseButton1 then dragging = false end
    end)
    UserInputService.InputChanged:Connect(function(i)
        if dragging and (i.UserInputType == Enum.UserInputType.MouseMovement) then
            local ap = track.AbsolutePosition
            local az = track.AbsoluteSize
            local r = math.clamp((i.Position.X - ap.X) / az.X, 0, 1)
            local val = min + r * (max - min)
            val = math.floor(val)
            fill.Size = UDim2.new(r, 0, 1, 0)
            knob.Position = UDim2.new(r, -7, 0.5, -7)
            valLbl.Text = tostring(val)
            callback(val)
        end
    end)
    return row
end

-- Dropdown that appears on top (parented to screen gui)
local function makeDropdown(card, order, text, options, default, callback)
    local row = makeRow(card, order, false, 54)
    local lbl = Instance.new("TextLabel")
    lbl.Size = UDim2.new(0.5, 0, 1, 0)
    lbl.Position = UDim2.new(0, 16, 0, 0)
    lbl.Text = text
    lbl.Font = Enum.Font.GothamSemibold
    lbl.TextSize = 10
    lbl.TextColor3 = T.text
    lbl.TextXAlignment = Enum.TextXAlignment.Left
    lbl.BackgroundTransparency = 1
    lbl.Parent = row

    local dropdownBtn = Instance.new("TextButton")
    dropdownBtn.Size = UDim2.new(0, 130, 0, 28)
    dropdownBtn.Position = UDim2.new(1, -142, 0.5, -14)
    dropdownBtn.Text = default
    dropdownBtn.Font = Enum.Font.GothamMedium
    dropdownBtn.TextSize = 9
    dropdownBtn.TextColor3 = T.text
    dropdownBtn.BackgroundColor3 = T.inputBg
    dropdownBtn.BorderSizePixel = 0
    dropdownBtn.AutoButtonColor = false
    dropdownBtn.Parent = row
    Instance.new("UICorner", dropdownBtn).CornerRadius = UDim.new(0, 7)

    -- Menu placed in screen gui (topmost)
    local menu = Instance.new("Frame")
    menu.Size = UDim2.new(0, 130, 0, 0)
    menu.BackgroundColor3 = T.card
    menu.BorderSizePixel = 0
    menu.Visible = false
    menu.ZIndex = 50
    menu.Parent = sg
    Instance.new("UICorner", menu).CornerRadius = UDim.new(0, 7)
    local menuLayout = Instance.new("UIListLayout", menu)
    menuLayout.SortOrder = Enum.SortOrder.LayoutOrder
    menuLayout.Padding = UDim.new(0, 2)

    local function updateMenu()
        for _, child in pairs(menu:GetChildren()) do if child:IsA("TextButton") then child:Destroy() end end
        for _, opt in ipairs(options) do
            local btn = Instance.new("TextButton")
            btn.Size = UDim2.new(1, 0, 0, 24)
            btn.Text = opt
            btn.Font = Enum.Font.GothamMedium
            btn.TextSize = 8
            btn.TextColor3 = T.text
            btn.BackgroundColor3 = T.dim
            btn.BorderSizePixel = 0
            btn.AutoButtonColor = false
            btn.Parent = menu
            btn.MouseButton1Click:Connect(function()
                dropdownBtn.Text = opt
                menu.Visible = false
                callback(opt)
            end)
        end
        menu.Size = UDim2.new(0, 130, 0, #options * 26)
        -- Position menu below the button
        local absPos = dropdownBtn.AbsolutePosition
        menu.Position = UDim2.new(0, absPos.X, 0, absPos.Y + 28)
    end

    dropdownBtn.MouseButton1Click:Connect(function()
        if menu.Visible then
            menu.Visible = false
        else
            updateMenu()
            menu.Visible = true
        end
    end)

    -- Hide menu when clicking outside
    UserInputService.InputBegan:Connect(function(input)
        if menu.Visible then
            task.wait(0.05)
            local mousePos = UserInputService:GetMouseLocation()
            local menuAbs = menu.AbsolutePosition
            local menuSize = menu.AbsoluteSize
            if not (mousePos.X >= menuAbs.X and mousePos.X <= menuAbs.X + menuSize.X and
                    mousePos.Y >= menuAbs.Y and mousePos.Y <= menuAbs.Y + menuSize.Y) then
                menu.Visible = false
            end
        end
    end)

    return row
end

