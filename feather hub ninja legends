local katanaConn = nil
local function startKatana()
    if katanaConn then return end
    katanaConn = RunService.Heartbeat:Connect(function()
        if Settings.autoKatana then
            pcall(function()
                LocalPlayer:WaitForChild("ninjaEvent"):FireServer("swingKatana")
            end)
        end
    end)
end
local function stopKatana()
    if katanaConn then katanaConn:Disconnect(); katanaConn = nil end
end

-- ══════════════════════════════════════════
--  AUTO HOOP FARM (FIXED)
-- ══════════════════════════════════════════
local hoopConn = nil

local function farmNextHoop()
    if not Settings.autoHoop then return end
    
    local now = tick()
    if now - lastHoopTime < Settings.hoopDelay then return end
    
    -- Refresh hoop list each cycle
    local count = refreshHoops()
    if count == 0 then
        Notify("Hoop Farm", "No hoops found!", "warning")
        return
    end
    
    -- Reset index if needed
    if currentHoopIndex > count then
        currentHoopIndex = 1
        Notify("Hoop Farm", "Completed all hoops! Starting over.", "success")
    end
    
    local target = allHoops[currentHoopIndex]
    if target then
        local root = getRootPart()
        if root then
            local pos = target.Position
            root.CFrame = CFrame.new(pos + Vector3.new(0, 3, 0))
            Notify("Hoop Farm", "Teleported to " .. target.Name .. " (" .. currentHoopIndex .. "/" .. count .. ")", "success")
            lastHoopTime = now
        else
            Notify("Hoop Farm", "Character not ready", "error")
        end
    end
    
    -- Move to next hoop
    currentHoopIndex = currentHoopIndex + 1
end

local function startHoopFarm()
    if hoopConn then return end
    refreshHoops()
    currentHoopIndex = 1
    lastHoopTime = 0
    hoopConn = RunService.Heartbeat:Connect(farmNextHoop)
    Notify("Hoop Farm", "Started! Found " .. #allHoops .. " hoops.", #allHoops > 0 and "success" or "warning")
end

local function stopHoopFarm()
    if hoopConn then
        hoopConn:Disconnect()
        hoopConn = nil
        Notify("Hoop Farm", "Stopped.", nil)
    end
end

