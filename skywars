    while State.belowAuraEnabled do
        local teamCheck = getSetting("BelowAura","TeamCheck")
        local radius    = getSetting("BelowAura","Radius") or 8
        local cps       = getSetting("BelowAura","CPS") or 12
        local orbitSpeed = getSetting("BelowAura","OrbitSpeed") or 2.0
        local heightOffset = getSetting("BelowAura","Height") or -3
        local doAttack  = getSetting("BelowAura","Attack")

        local root = getRoot()
        if root then
            local best, bd = nil, radius
            for _,plr in ipairs(Players:GetPlayers()) do
                local skip = (plr==LocalPlayer) or (teamCheck and sameTeam(plr))
                if not skip and plr.Character then
                    local ph = plr.Character:FindFirstChild("HumanoidRootPart")
                    local pu = plr.Character:FindFirstChild("Humanoid")
                    if ph and pu and pu.Health>0 then
                        local d = (root.Position - ph.Position).Magnitude
                        if d < bd then best = plr; bd = d end
                    end
                end
            end

            if best and best.Character then
                local targetRoot = best.Character:FindFirstChild("HumanoidRootPart")
                if targetRoot then
                    angle = angle + orbitSpeed * 0.1
                    local offset = Vector3.new(math.cos(angle) * radius, heightOffset, math.sin(angle) * radius)
                    local tpPos = targetRoot.Position + offset

                    local char = LocalPlayer.Character
                    if char then
                        for _,v in ipairs(char:GetDescendants()) do
                            if v:IsA("BasePart") then pcall(function() v.CanCollide = false end) end
                        end
                    end
                    root.CFrame = CFrame.new(tpPos, targetRoot.Position)

                    if doAttack then
                        facePlayer(best)
                        fireLeftClick()
                    end
                end
            end
        end
        wait(1 / math.max(cps, 1))
    end
    State.belowAuraRunning = false
end

