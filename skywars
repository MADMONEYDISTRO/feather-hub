-- ============================================================
-- TPAURA — teleport around enemy + fire clicks
-- Works by finding nearest enemy and repeatedly teleporting
-- just behind them, then firing a left click attack
-- ============================================================
local function tpauraLoop()
    State.tpauraRunning=true
    while State.tpauraEnabled do
        local teamCheck  = getSetting("TPAura","TeamCheck")
        local radius     = getSetting("TPAura","Radius") or 8
        local cps        = getSetting("TPAura","CPS") or 10
        local doAttack   = getSetting("TPAura","AttackOnTP")

        local root=getRoot()
        if root then
            local best, bd = nil, radius
            for _,plr in ipairs(Players:GetPlayers()) do
                local skip = (plr==LocalPlayer) or (teamCheck and sameTeam(plr))
                if not skip and plr.Character then
                    local ph=plr.Character:FindFirstChild("HumanoidRootPart")
                    local pu=plr.Character:FindFirstChild("Humanoid")
                    if ph and pu and pu.Health>0 then
                        local d=(root.Position-ph.Position).Magnitude
                        if d<bd then best=plr; bd=d end
                    end
                end
            end

            -- If no enemy in range, find nearest regardless and close in
            if not best then
                for _,plr in ipairs(Players:GetPlayers()) do
                    local skip = (plr==LocalPlayer) or (teamCheck and sameTeam(plr))
                    if not skip and plr.Character then
                        local ph=plr.Character:FindFirstChild("HumanoidRootPart")
                        local pu=plr.Character:FindFirstChild("Humanoid")
                        if ph and pu and pu.Health>0 then
                            local d=(root.Position-ph.Position).Magnitude
                            if not best or d < bd then best=plr; bd=d end
                        end
                    end
                end
            end

            if best and best.Character then
                local ph=best.Character:FindFirstChild("HumanoidRootPart")
                if ph then
                    -- Teleport to just behind the target (relative to their look direction)
                    local targetCF = ph.CFrame
                    -- Place ourselves slightly behind and to the side of target
                    local offset = targetCF.LookVector * -2 + Vector3.new(0, 0, 0)
                    local newPos = ph.Position + offset

                    -- Disable our collisions briefly so we don't get stuck
                    local char=LocalPlayer.Character
                    if char then
                        for _,d in ipairs(char:GetDescendants()) do
                            if d:IsA("BasePart") then pcall(function() d.CanCollide=false end) end
                        end
                    end

                    root.CFrame = CFrame.new(newPos, ph.Position)

                    -- Fire attack if setting is on
                    if doAttack then
                        facePlayer(best)
                        fireLeftClick()
                    end
                end
            end
        end
        wait(1/math.max(cps,1))
    end
    State.tpauraRunning=false
end

-- ============================================================
-- INF AURA (teleport around target, attack multiple times, return)
-- ============================================================
local function infAuraLoop()
    State.infAuraRunning = true
    while State.infAuraEnabled do
        local teamCheck = getSetting("InfAura","TeamCheck")
        local range     = getSetting("InfAura","Range") or 15
        local cps       = getSetting("InfAura","CPS") or 15
        local rotations = getSetting("InfAura","Rotations") or 1
        local returnSpeed = getSetting("InfAura","ReturnSpeed") or 1.0

        local root = getRoot()
        if root then
            local best, bd = nil, range
            for _,plr in ipairs(Players:GetPlayers()) do
                local skip = (plr==LocalPlayer) or (teamCheck and sameTeam(plr))
                if not skip and plr.Character then
                    local ph = plr.Character:FindFirstChild("HumanoidRootPart")
                    local pu = plr.Character:FindFirstChild("Humanoid")
                    if ph and pu and pu.Health>0 then
                        local d = (root.Position - ph.Position).Magnitude
                        if d < bd then best = plr; bd = d end
                    end
                end
            end

            if best and best.Character then
                local targetRoot = best.Character:FindFirstChild("HumanoidRootPart")
                if targetRoot then
                    local startPos = root.Position
                    local targetPos = targetRoot.Position
                    -- Disable collisions
                    local char = LocalPlayer.Character
                    if char then
                        for _,v in ipairs(char:GetDescendants()) do
                            if v:IsA("BasePart") then pcall(function() v.CanCollide = false end) end
                        end
                    end
                    for i = 1, rotations do
                        local angle = (i / rotations) * math.pi * 2
                        local offset = Vector3.new(math.cos(angle) * 3, 0, math.sin(angle) * 3)
                        local tpPos = targetPos + offset
                        root.CFrame = CFrame.new(tpPos, targetPos)
                        facePlayer(best)
                        fireLeftClick()
                        wait(0.05)
                    end
                    -- Return to start
                    root.CFrame = CFrame.new(startPos)
                end
            end
        end
        wait(1 / math.max(cps, 1))
    end
    State.infAuraRunning = false
end

