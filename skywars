-- ============================================================
-- HELPERS
-- ============================================================
local function getRoot()
    local c=LocalPlayer.Character; return c and c:FindFirstChild("HumanoidRootPart")
end
local function getHum()
    local c=LocalPlayer.Character; return c and c:FindFirstChild("Humanoid")
end
local function keyName(kc)
    local s=tostring(kc); return s:match("Enum%.KeyCode%.(.+)") or s
end
local function getNearestEnemy(range)
    local root=getRoot(); if not root then return nil end
    local best, bd = nil, range
    for _,plr in ipairs(Players:GetPlayers()) do
        if isValidTarget(plr) then
            local ph = plr.Character:FindFirstChild("HumanoidRootPart")
            if ph then
                local d = (root.Position - ph.Position).Magnitude
                if d < bd then best=plr; bd=d end
            end
        end
    end
    return best
end
local function facePlayer(target)
    local root=getRoot()
    if not (root and target and target.Character) then return end
    local ph = target.Character:FindFirstChild("HumanoidRootPart")
    if ph then
        local dir = Vector3.new(ph.Position.X-root.Position.X, 0, ph.Position.Z-root.Position.Z)
        if dir.Magnitude > 0 then
            root.CFrame = CFrame.new(root.Position, root.Position + dir.Unit)
        end
    end
end

