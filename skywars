    accent.BackgroundColor3=sameTeam(plr) and Color3.fromRGB(60,200,255) or Color3.fromRGB(255,60,80)
    accent.BorderSizePixel=0
    local ac=Instance.new("UICorner",accent); ac.CornerRadius=UDim.new(0,7)

    -- Player name
    local nameL=Instance.new("TextLabel",bg)
    nameL.Size=UDim2.new(1,-10,0,18)
    nameL.Position=UDim2.new(0,5,0,4)
    nameL.Text=plr.Name
    nameL.Font=Enum.Font.GothamBold; nameL.TextSize=13
    nameL.TextColor3=Color3.fromRGB(240,240,255)
    nameL.BackgroundTransparency=1
    nameL.TextXAlignment=Enum.TextXAlignment.Left

    -- HP bar background
    local hpBG=Instance.new("Frame",bg)
    hpBG.Size=UDim2.new(1,-10,0,5)
    hpBG.Position=UDim2.new(0,5,0,25)
    hpBG.BackgroundColor3=Color3.fromRGB(40,40,40)
    hpBG.BorderSizePixel=0
    local hbc=Instance.new("UICorner",hpBG); hbc.CornerRadius=UDim.new(1,0)

    -- HP bar fill
    local hpFill=Instance.new("Frame",hpBG)
    hpFill.Size=UDim2.new(1,0,1,0)
    hpFill.BackgroundColor3=Color3.fromRGB(80,255,100)
    hpFill.BorderSizePixel=0
    local hfc=Instance.new("UICorner",hpFill); hfc.CornerRadius=UDim.new(1,0)

    -- HP text + distance
    local infoL=Instance.new("TextLabel",bg)
    infoL.Size=UDim2.new(1,-10,0,14)
    infoL.Position=UDim2.new(0,5,0,33)
    infoL.Text="100 HP  •  0m"
    infoL.Font=Enum.Font.Gotham; infoL.TextSize=10
    infoL.TextColor3=Color3.fromRGB(160,160,180)
    infoL.BackgroundTransparency=1
    infoL.TextXAlignment=Enum.TextXAlignment.Left

    ESPTags[plr] = bb

    -- Update loop
    spawn(function()
        while bb.Parent and plr.Parent do
            local show = getSetting("ESP","ShowHP") or getSetting("ESP","ShowName")
            bb.Enabled = State.espEnabled and show ~= nil

            local hum=plr.Character and plr.Character:FindFirstChild("Humanoid")
            local maxHP = hum and hum.MaxHealth or 100
            local curHP = hum and hum.Health or 0
            local ratio = math.clamp(curHP/(maxHP>0 and maxHP or 1), 0, 1)

            hpFill.Size=UDim2.new(ratio,0,1,0)
            -- Color: green->yellow->red
            if ratio>0.5 then
                hpFill.BackgroundColor3=Color3.fromRGB(
                    math.floor(255*(1-ratio)*2),255,80)
            else
                hpFill.BackgroundColor3=Color3.fromRGB(
                    255,math.floor(255*ratio*2),80)
            end

            -- distance
            local root=getRoot()
            local ph=plr.Character and plr.Character:FindFirstChild("HumanoidRootPart")
            local dist=0
            if root and ph then dist=math.floor((root.Position-ph.Position).Magnitude) end

            local parts={}
            if getSetting("ESP","ShowHP")   then table.insert(parts, math.floor(curHP).." HP") end
            if getSetting("ESP","ShowDist") then table.insert(parts, dist.."m")               end
            infoL.Text=table.concat(parts,"  •  ")

            -- Name visibility
            nameL.Visible = getSetting("ESP","ShowName") == true
            hpBG.Visible  = getSetting("ESP","ShowHP")   == true

            wait(0.1)
        end
        bb:Destroy()
        ESPTags[plr]=nil
    end)
