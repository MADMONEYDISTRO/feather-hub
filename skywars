local function killauraLoop()
    State.killauraRunning=true
    while State.killauraEnabled do
        local teamCheck = getSetting("KillAura","TeamCheck")
        local range     = getSetting("KillAura","Range") or 10
        local cps       = getSetting("KillAura","CPS")   or 12

        local root=getRoot()
        if root then
            local best, bd = nil, range
            for _,plr in ipairs(Players:GetPlayers()) do
                local skip = (plr==LocalPlayer) or (teamCheck and sameTeam(plr))
                if not skip and plr.Character then
                    local ph=plr.Character:FindFirstChild("HumanoidRootPart")
                    local pu=plr.Character:FindFirstChild("Humanoid")
                    if ph and pu and pu.Health>0 then
                        local d=(root.Position-ph.Position).Magnitude
                        if d<bd then best=plr; bd=d end
                    end
                end
            end
            if best then
                facePlayer(best)
                fireLeftClick()
            end
        end
        wait(1/math.max(cps,1))
    end
    State.killauraRunning=false
end

