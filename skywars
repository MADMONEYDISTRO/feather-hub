-- Flat lookup
local ModByName = {}
for _, cat in ipairs(Modules) do
    for _, mod in ipairs(cat.mods) do ModByName[mod.name] = mod end
end

local function getSetting(modName, key)
    local mod = ModByName[modName]; if not mod then return nil end
    for _, s in ipairs(mod.settings) do if s.key == key then return s.value end end
    return nil
end

