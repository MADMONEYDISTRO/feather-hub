UserInputService.InputBegan:Connect(function(inp, gp)
    if gp then return end
    local k = inp.KeyCode
    if k==Enum.KeyCode.W     then State.flyKeys.W=true end
    if k==Enum.KeyCode.S     then State.flyKeys.S=true end
    if k==Enum.KeyCode.A     then State.flyKeys.A=true end
    if k==Enum.KeyCode.D     then State.flyKeys.D=true end
    if k==Enum.KeyCode.Space     then State.flyKeys.Space=true     end
    if k==Enum.KeyCode.LeftShift then State.flyKeys.LeftShift=true end
end)
UserInputService.InputEnded:Connect(function(inp)
    local k = inp.KeyCode
    if k==Enum.KeyCode.W     then State.flyKeys.W=false end
    if k==Enum.KeyCode.S     then State.flyKeys.S=false end
    if k==Enum.KeyCode.A     then State.flyKeys.A=false end
    if k==Enum.KeyCode.D     then State.flyKeys.D=false end
    if k==Enum.KeyCode.Space     then State.flyKeys.Space=false     end
    if k==Enum.KeyCode.LeftShift then State.flyKeys.LeftShift=false end
end)

local function flyDirVec()
    local v=Vector3.zero
    if State.flyKeys.W then v=v+Vector3.new(0,0,-1) end
    if State.flyKeys.S then v=v+Vector3.new(0,0,1)  end
    if State.flyKeys.A then v=v+Vector3.new(-1,0,0) end
    if State.flyKeys.D then v=v+Vector3.new(1,0,0)  end
    if State.flyKeys.Space     then v=v+Vector3.new(0,1,0)  end
    if State.flyKeys.LeftShift then v=v+Vector3.new(0,-1,0) end
    return v
end

-- ============================================================
-- FLY METHODS
-- ============================================================
local function stopFly()
    State.flyEnabled = false
    if State.flyConn      then State.flyConn:Disconnect();      State.flyConn=nil      end
    if State.flyNoclipConn then State.flyNoclipConn:Disconnect(); State.flyNoclipConn=nil end
    if State.flyPart      then State.flyPart:Destroy();         State.flyPart=nil       end
    -- restore gravity if gravity method
    workspace.Gravity = 196.2
    -- restore collision if noclip
    local char = LocalPlayer.Character
    if char then
        for _,d in ipairs(char:GetDescendants()) do
            if d:IsA("BasePart") then pcall(function() d.CanCollide=true end) end
        end
    end
    -- restore walkspeed
    local hum = getHum()
    if hum then hum.WalkSpeed = 16 end
end

local function startFly()
    stopFly()
    State.flyEnabled = true
    local method = getSetting("Fly","Method") or "Part"
    State.flyMethod = method

    if method == "Part" then
        -- Classic: invisible platform under feet
        local p = Instance.new("Part")
        p.Size=Vector3.new(5,1,5); p.Anchored=true; p.CanCollide=true
        p.Transparency=1; p.Parent=workspace
        State.flyPart = p
        State.flyConn = RunService.RenderStepped:Connect(function(dt)
            local root=getRoot()
            if not (State.flyEnabled and root) then return end
            local dir=flyDirVec()
            if dir.Magnitude>0 then
                local cam=workspace.CurrentCamera.CFrame
                local world=(cam:VectorToWorldSpace(dir)).Unit
                root.CFrame = root.CFrame + world*State.flySpeed*dt
            end
            p.Position = root.Position - Vector3.new(0, 3.2, 0)
        end)

    elseif method == "Noclip" then
        -- No gravity, move camera-relative, pass through walls
        workspace.Gravity = 0
        local char = LocalPlayer.Character
        if char then
            for _,d in ipairs(char:GetDescendants()) do
                if d:IsA("BasePart") then pcall(function() d.CanCollide=false end) end
            end
        end
        State.flyNoclipConn = RunService.RenderStepped:Connect(function()
            local c=LocalPlayer.Character
            if c then
                for _,d in ipairs(c:GetDescendants()) do
                    if d:IsA("BasePart") then pcall(function() d.CanCollide=false end) end
                end
            end
        end)
        State.flyConn = RunService.RenderStepped:Connect(function(dt)
            local root=getRoot()
            if not (State.flyEnabled and root) then return end
            local dir=flyDirVec()
            if dir.Magnitude>0 then
                local world=workspace.CurrentCamera.CFrame:VectorToWorldSpace(dir).Unit
                root.CFrame=root.CFrame+world*State.flySpeed*dt
            end
        end)

    elseif method == "Gravity" then
        -- Set very low gravity, player floats and can boost upward
        workspace.Gravity = 5
        local hum = getHum()
        if hum then hum.WalkSpeed = State.flySpeed * 0.8 end
        State.flyConn = RunService.RenderStepped:Connect(function(dt)
            local root=getRoot()
            if not (State.flyEnabled and root) then return end
            if State.flyKeys.Space then
                root.CFrame = root.CFrame + Vector3.new(0, State.flySpeed * dt, 0)
            end
            if State.flyKeys.LeftShift then
                root.CFrame = root.CFrame - Vector3.new(0, State.flySpeed * dt, 0)
            end
        end)

    elseif method == "Glide" then
        -- Slow fall + horizontal speed, like gliding
        State.flyConn = RunService.RenderStepped:Connect(function(dt)
            local root=getRoot()
            if not (State.flyEnabled and root) then return end
            local dir=flyDirVec()
            -- Horizontal movement
            if dir.Magnitude>0 then
                local cam=workspace.CurrentCamera.CFrame
                local world=cam:VectorToWorldSpace(dir).Unit
                root.CFrame=root.CFrame+Vector3.new(world.X,0,world.Z)*State.flySpeed*dt
            end
            -- Slow the fall
            local vel=root.AssemblyLinearVelocity
            if vel.Y < -5 then
                root.AssemblyLinearVelocity=Vector3.new(vel.X, -5, vel.Z)
            end
            -- Up/down
            if State.flyKeys.Space then
                root.CFrame=root.CFrame+Vector3.new(0,State.flySpeed*0.5*dt,0)
            end
            if State.flyKeys.LeftShift then
                root.CFrame=root.CFrame-Vector3.new(0,State.flySpeed*0.5*dt,0)
            end
        end)
    end
end

-- ============================================================
-- SPEED
-- ============================================================
local function doSpeed()
    if not (State.speedEnabled and State.isAlive) then return end
    local root=getRoot(); if not root then return end
    if State.speedMode=="WalkSpeed" then
        local hum=getHum(); if hum then hum.WalkSpeed=State.speedMult*100 end
        return
    end
    -- CFrame mode
    local zero=Vector3.zero
    local look=root.CFrame.LookVector; local right=root.CFrame.RightVector
    if UserInputService:IsKeyDown(Enum.KeyCode.W) then zero=zero+look*State.speedMult  end
    if UserInputService:IsKeyDown(Enum.KeyCode.S) then zero=zero-look*State.speedMult  end
    if UserInputService:IsKeyDown(Enum.KeyCode.A) then zero=zero-right*State.speedMult end
    if UserInputService:IsKeyDown(Enum.KeyCode.D) then zero=zero+right*State.speedMult end
    if zero.Magnitude>0 then root.CFrame=root.CFrame+zero end
end

