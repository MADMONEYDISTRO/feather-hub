-- ============================================================
-- TEAM CHECK HELPER
-- Returns true if 'plr' is on the same team as local player
-- ============================================================
local function sameTeam(plr)
    if plr == LocalPlayer then return true end
    local lt = LocalPlayer.Team
    local pt = plr.Team
    if lt and pt and lt == pt then return true end
    return false
end

local function isValidTarget(plr)
    if plr == LocalPlayer then return false end
    if sameTeam(plr) then return false end
    if not plr.Character then return false end
    local hum = plr.Character:FindFirstChild("Humanoid")
    if not hum or hum.Health <= 0 then return false end
    local hrp = plr.Character:FindFirstChild("HumanoidRootPart")
    if not hrp then return false end
    return true
end

-- ============================================================
-- SIMULATE LEFT CLICK (fires a real VirtualInput mouse click)
-- ============================================================
local function fireLeftClick()
    -- Method 1: VirtualInputManager (most reliable in exploit context)
    pcall(function()
        VirtualInputManager:SendMouseButtonEvent(0, 0, 0, true,  game, 1)
        VirtualInputManager:SendMouseButtonEvent(0, 0, 0, false, game, 1)
    end)
    -- Method 2: Tool activate as fallback
    pcall(function()
        local tool = LocalPlayer.Character and LocalPlayer.Character:FindFirstChildOfClass("Tool")
        if tool then tool:Activate() end
    end)
end

