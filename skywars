-- ---- Settings box height ----
local function settingsH(mod)
    return (#mod.settings+1)*(ROW_H+ROW_GAP)+4
end

-- ---- Full panel height ----
local function panelH(mods)
    local h=HEADER_H+PAD
    for _,mod in ipairs(mods) do
        h=h+BTN_H+BTN_GAP
        if mod.settingsOpen and (#mod.settings>0 or true) then
            h=h+settingsH(mod)+BTN_GAP
        end
    end
    return h+PAD
end

-- ---- Rebuild panel ----
rebuildPanel = function(catName, mods, panel)
    for _,ch in ipairs(panel:GetChildren()) do
        if ch.Name=="_Row" or ch.Name=="_SBox" or ch.Name=="_Accent" then ch:Destroy() end
    end
    panel.Size=UDim2.new(0,PANEL_W,0,panelH(mods))
    local y=HEADER_H+PAD

    for _,mod in ipairs(mods) do
        local btn=Instance.new("TextButton",panel)
        btn.Name="_Row"
        btn.Size=UDim2.new(1,-10,0,BTN_H)
        btn.Position=UDim2.new(0,5,0,y)
        btn.Text=mod.name
        btn.TextColor3=mod.enabled and Color3.fromRGB(80,255,80) or Color3.fromRGB(210,210,210)
        btn.BackgroundColor3=mod.enabled and Color3.fromRGB(14,44,14) or Color3.fromRGB(22,22,34)
        btn.BorderSizePixel=0; btn.Font=Enum.Font.Gotham; btn.TextSize=11
        btn.TextXAlignment=Enum.TextXAlignment.Left; btn.ZIndex=7

        local bc=Instance.new("UICorner",btn); bc.CornerRadius=UDim.new(0,5)
        local bs=Instance.new("UIStroke",btn)
        bs.Color=mod.settingsOpen and Color3.fromRGB(88,88,195) or Color3.fromRGB(40,40,62)
        bs.Thickness=1

        local tp=Instance.new("UIPadding",btn); tp.PaddingLeft=UDim.new(0,8)

        -- dot
        local dot=Instance.new("Frame",btn); dot.Name="Dot"
        dot.Size=UDim2.new(0,6,0,6); dot.Position=UDim2.new(1,-10,0.5,-3)
        dot.BackgroundColor3=mod.enabled and Color3.fromRGB(80,255,80) or Color3.fromRGB(60,60,60)
        dot.BorderSizePixel=0; dot.ZIndex=8
        local dc=Instance.new("UICorner",dot); dc.CornerRadius=UDim.new(1,0)

        -- keybind hint
        local kh=Instance.new("TextLabel",btn)
        kh.Size=UDim2.new(0,28,1,0); kh.Position=UDim2.new(1,-40,0,0)
        kh.Text=keyName(mod.keybind)
        kh.TextColor3=Color3.fromRGB(80,80,115)
        kh.BackgroundTransparency=1; kh.Font=Enum.Font.Gotham; kh.TextSize=9
        kh.TextXAlignment=Enum.TextXAlignment.Right; kh.ZIndex=8

        -- arrow
        local arr=Instance.new("TextLabel",btn)
        arr.Size=UDim2.new(0,10,1,0); arr.Position=UDim2.new(1,-52,0,0)
        arr.Text=mod.settingsOpen and "▼" or "▶"
        arr.TextColor3=Color3.fromRGB(95,95,160)
        arr.BackgroundTransparency=1; arr.Font=Enum.Font.GothamBold; arr.TextSize=9
        arr.TextXAlignment=Enum.TextXAlignment.Right; arr.ZIndex=8

        -- LEFT: toggle
        btn.MouseButton1Click:Connect(function()
            mod.enabled=not mod.enabled
            applyToggle(mod)
            rebuildPanel(catName,mods,panel)
        end)
        -- RIGHT: settings
        btn.MouseButton2Click:Connect(function()
            mod.settingsOpen=not mod.settingsOpen
            rebuildPanel(catName,mods,panel)
        end)
        btn.MouseEnter:Connect(function()
            if not mod.enabled then btn.BackgroundColor3=Color3.fromRGB(28,28,44) end
        end)
        btn.MouseLeave:Connect(function()
            btn.BackgroundColor3=mod.enabled and Color3.fromRGB(14,44,14) or Color3.fromRGB(22,22,34)
        end)

        y=y+BTN_H+BTN_GAP

        -- Settings box
        if mod.settingsOpen then
            local sh=settingsH(mod)
            local box=Instance.new("Frame",panel)
            box.Name="_SBox"
            box.Size=UDim2.new(1,-12,0,sh)
            box.Position=UDim2.new(0,6,0,y)
            box.BackgroundColor3=Color3.fromRGB(12,12,20)
            box.BorderSizePixel=0; box.ZIndex=6
            local bxc=Instance.new("UICorner",box); bxc.CornerRadius=UDim.new(0,5)
            local bxs=Instance.new("UIStroke",box); bxs.Color=Color3.fromRGB(50,50,100); bxs.Thickness=1

            local ll=Instance.new("UIListLayout",box)
            ll.Padding=UDim.new(0,ROW_GAP)
            ll.FillDirection=Enum.FillDirection.Vertical
            ll.SortOrder=Enum.SortOrder.LayoutOrder
            local lp=Instance.new("UIPadding",box)
            lp.PaddingTop=UDim.new(0,2); lp.PaddingBottom=UDim.new(0,2)
            lp.PaddingLeft=UDim.new(0,2); lp.PaddingRight=UDim.new(0,2)

            for si,setting in ipairs(mod.settings) do
                local row=makeSettingRow(box,mod,setting,8)
                row.LayoutOrder=si
            end
            local kr=makeKeybindRow(box,mod,catName,mods,8)
            kr.LayoutOrder=999

            y=y+sh+BTN_GAP
        end
    end

    -- accent bar
    local ab=Instance.new("Frame",panel); ab.Name="_Accent"
    ab.Size=UDim2.new(0,2,1,-HEADER_H); ab.Position=UDim2.new(0,0,0,HEADER_H)
    ab.BackgroundColor3=Color3.fromRGB(70,70,210); ab.BorderSizePixel=0; ab.ZIndex=4
end

