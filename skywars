-- HITBOX
-- ============================================================
local function applyHitbox()
    local sz=Vector3.new(State.hitboxSize,5,State.hitboxSize)
    for _,plr in ipairs(Players:GetPlayers()) do
        if plr~=LocalPlayer and plr.Character then
            local hrp=plr.Character:FindFirstChild("HumanoidRootPart")
            if hrp then
                if not State.hitboxSaved[plr] then
                    State.hitboxSaved[plr]={Size=hrp.Size,Transparency=hrp.Transparency,Color=hrp.Color}
                end
                hrp.Size=sz; hrp.Transparency=0.5; hrp.Color=Color3.new(1,0,0)
            end
        end
    end
end
local function removeHitbox()
    for plr,saved in pairs(State.hitboxSaved) do
        if plr.Character then
            local hrp=plr.Character:FindFirstChild("HumanoidRootPart")
            if hrp then hrp.Size=saved.Size; hrp.Transparency=saved.Transparency; hrp.Color=saved.Color end
        end
    end
    State.hitboxSaved={}
end

