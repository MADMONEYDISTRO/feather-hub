-- GLOBAL INPUT (keybinds + rebind)
-- ============================================================
UserInputService.InputBegan:Connect(function(inp, gp)
    if gp then return end
    if inp.UserInputType ~= Enum.UserInputType.Keyboard then return end

    -- Rebind
    if rebindTarget then
        if inp.KeyCode ~= Enum.KeyCode.Escape then
            rebindTarget.mod.keybind=inp.KeyCode
        end
        rebindTarget.lbl.Text="["..keyName(rebindTarget.mod.keybind).."]"
        rebindTarget.lbl.TextColor3=Color3.fromRGB(195,155,250)
        local cn=rebindTarget.catName; local ms=rebindTarget.mods
        rebindTarget=nil
        rebuildPanel(cn,ms,PanelRefs[cn])
        return
    end

    if inp.KeyCode==Enum.KeyCode.RightAlt then
        ScreenGui.Enabled=not ScreenGui.Enabled; return
    end

    for _,cat in ipairs(Modules) do
        for _,mod in ipairs(cat.mods) do
            if inp.KeyCode==mod.keybind then
                mod.enabled=not mod.enabled
                applyToggle(mod)
                rebuildPanel(cat.category,cat.mods,PanelRefs[cat.category])
            end
        end
    end
end)

