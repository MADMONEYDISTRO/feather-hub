-- APPLY TOGGLE
-- ============================================================
local PanelRefs = {}
local rebuildPanel  -- forward declare

local function applyToggle(mod)
    local n=mod.name; local on=mod.enabled

    if n=="Fly" then
        if on then startFly() else stopFly() end
        State.flyEnabled=on

    elseif n=="Speed" then
        State.speedEnabled=on
        if not on and State.speedMode=="WalkSpeed" then
            local hum=getHum(); if hum then hum.WalkSpeed=16 end
        end

    elseif n=="Fast Fall" then
        State.fastfallEnabled=on

    elseif n=="Hitbox" then
        State.hitboxEnabled=on
        if not on then removeHitbox() end

    elseif n=="KillAura" then
        State.killauraEnabled=on
        if on and not State.killauraRunning then coroutine.wrap(killauraLoop)() end

    elseif n=="AutoClicker" then
        State.acEnabled=on
        if on and not State.acRunning then coroutine.wrap(autoClickerLoop)() end

    elseif n=="TPAura" then
        State.tpauraEnabled=on
        if on and not State.tpauraRunning then coroutine.wrap(tpauraLoop)() end

    elseif n=="InfAura" then
        State.infAuraEnabled = on
        if on and not State.infAuraRunning then coroutine.wrap(infAuraLoop)() end

    elseif n=="BelowAura" then
        State.belowAuraEnabled = on
        if on and not State.belowAuraRunning then coroutine.wrap(belowAuraLoop)() end

    elseif n=="NoClip" then
        State.noclipEnabled = on
        local char = LocalPlayer.Character
        if char then
            for _,v in ipairs(char:GetDescendants()) do
                if v:IsA("BasePart") then pcall(function() v.CanCollide = not on end) end
            end
        end

    elseif n=="HighJump" then
        State.highJumpEnabled = on
        local hum = getHum()
        if hum then
            hum.JumpPower = on and State.highJumpPower or 50
        end

    elseif n=="InfJump" then
        State.infJumpEnabled = on
        State.infJumpCount = 0
        setupInfJump()

    elseif n=="NoFall" then
        State.noFallEnabled = on
        local hum = getHum()
        if hum and on then
            hum.StateChanged:Connect(noFallHandler)
        end

    elseif n=="ESP" then
        State.espEnabled=on; refreshESP()

    elseif n=="Chams" then
        State.chamsEnabled=on; refreshChams()

    elseif n=="FOV" then
        State.fovEnabled=on
        workspace.CurrentCamera.FieldOfView=on and State.fovAmount or 70

    elseif n=="NoRender" then
        State.norenderEnabled=on

    elseif n=="Tracers" then
        State.tracersEnabled = on
        if on then
            updateTracers()
        else
            for _, line in pairs(State.tracersLines) do
                pcall(function() line:Destroy() end)
            end
            State.tracersLines = {}
        end
    end
end

-- ============================================================
-- propagate setting value → State
-- ============================================================
local function propagate(mod, setting)
    local n,k,v=mod.name,setting.key,setting.value
    if n=="Fly" then
        if k=="Speed"  then State.flySpeed=v end
        if k=="Method" then
            State.flyMethod=v
            if State.flyEnabled then startFly() end -- restart with new method
        end
    end
    if n=="Speed" then
        if k=="Multiplier" then State.speedMult=v end
        if k=="Mode"       then
            State.speedMode=v
            if not mod.enabled then
                local hum=getHum(); if hum then hum.WalkSpeed=16 end
            end
        end
    end
    if n=="Fast Fall" and k=="Strength" then State.fastfallStr=v end
    if n=="Hitbox"    and k=="Size"     then State.hitboxSize=v  end
    if n=="FOV"       and k=="Amount"   then
        State.fovAmount=v
        if State.fovEnabled then workspace.CurrentCamera.FieldOfView=v end
    end
    if n=="Chams" and k=="FillAlpha" then refreshChams() end
    if n=="ESP" then refreshESP() end
    if n=="HighJump" and k=="Power" then
        State.highJumpPower = v
        if State.highJumpEnabled then
            local hum = getHum()
            if hum then hum.JumpPower = v end
        end
    end
    if n=="InfJump" and k=="MaxJumps" then
        State.infJumpMax = v
    end
    if n=="Tracers" then
        if State.tracersEnabled then updateTracers() end
    end
end

