-- ============================================================
local function updateTracers()
    -- Remove old lines
    for _, line in pairs(State.tracersLines) do
        if line then pcall(function() line:Destroy() end) end
    end
    State.tracersLines = {}
    if not State.tracersEnabled then return end

    local colorMap = {
        Red = Color3.new(1,0,0),
        Green = Color3.new(0,1,0),
        Blue = Color3.new(0,0,1),
        Yellow = Color3.new(1,1,0),
        White = Color3.new(1,1,1),
    }
    local enemyColor = colorMap[getSetting("Tracers","ColorEnemy")] or Color3.new(1,0,0)
    local allyColor  = colorMap[getSetting("Tracers","ColorAlly")] or Color3.new(0,0,1)
    local thickness  = getSetting("Tracers","Thickness") or 1

    local myRoot = getRoot()
    if not myRoot then return end

    for _, plr in ipairs(Players:GetPlayers()) do
        if plr ~= LocalPlayer and plr.Character then
            local targetRoot = plr.Character:FindFirstChild("HumanoidRootPart")
            if targetRoot then
                local isAlly = sameTeam(plr)
                local color = isAlly and allyColor or enemyColor
                local line = Instance.new("Part")
                line.Name = "TracerLine"
                line.Anchored = true
                line.CanCollide = false
                line.Size = Vector3.new(thickness/10, thickness/10, 1)
                line.Color = color
                line.Material = Enum.Material.Neon
                line.Parent = workspace
                table.insert(State.tracersLines, line)
                
                spawn(function()
                    while line and line.Parent and State.tracersEnabled and myRoot and targetRoot and targetRoot.Parent do
                        local startPos = myRoot.Position
                        local endPos = targetRoot.Position
                        local distance = (startPos - endPos).Magnitude
                        line.Size = Vector3.new(thickness/10, thickness/10, distance)
                        line.CFrame = CFrame.new(startPos, endPos) * CFrame.new(0, 0, -distance/2)
                        wait()
                    end
                    pcall(function() line:Destroy() end)
                end)
            end
        end
    end
end

