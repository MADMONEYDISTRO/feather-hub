-- ---- Setting row ----
local function makeSettingRow(parent, mod, setting, zo)
    local f=Instance.new("Frame",parent)
    f.BackgroundColor3=Color3.fromRGB(17,17,28)
    f.BorderSizePixel=0; f.ZIndex=zo
    f.Size=UDim2.new(1,0,0,ROW_H)
    local fc=Instance.new("UICorner",f); fc.CornerRadius=UDim.new(0,3)

    local nl=Instance.new("TextLabel",f)
    nl.Size=UDim2.new(0.45,0,1,0); nl.Position=UDim2.new(0,5,0,0)
    nl.Text=setting.key; nl.TextColor3=Color3.fromRGB(165,165,195)
    nl.BackgroundTransparency=1; nl.Font=Enum.Font.Gotham; nl.TextSize=10
    nl.TextXAlignment=Enum.TextXAlignment.Left; nl.ZIndex=zo+1

    if setting.type=="number" then
        local vl=Instance.new("TextLabel",f)
        vl.Size=UDim2.new(0,24,1,0); vl.Position=UDim2.new(0.45,0,0,0)
        vl.Text=tostring(setting.value)
        vl.TextColor3=Color3.fromRGB(90,215,125)
        vl.BackgroundTransparency=1; vl.Font=Enum.Font.GothamBold; vl.TextSize=10
        vl.TextXAlignment=Enum.TextXAlignment.Center; vl.ZIndex=zo+1

        local function mkBtn(parent2, txt, col, bgCol, xOff)
            local b=Instance.new("TextButton",parent2)
            b.Size=UDim2.new(0,15,0,15); b.Position=UDim2.new(0.72,xOff,0.5,-7)
            b.Text=txt; b.Font=Enum.Font.GothamBold; b.TextSize=14
            b.TextColor3=col; b.BackgroundColor3=bgCol; b.BorderSizePixel=0; b.ZIndex=zo+2
            local c=Instance.new("UICorner",b); c.CornerRadius=UDim.new(0,3)
            return b
        end
        local mn=mkBtn(f,"-",Color3.fromRGB(255,80,80),Color3.fromRGB(40,12,12),0)
        local pl=mkBtn(f,"+",Color3.fromRGB(80,255,80),Color3.fromRGB(12,40,12),18)

        local rng=(setting.max or 10)-(setting.min or 0)
        local step=math.max(0.01,rng/20)
        local function upd(d)
            setting.value=math.clamp(
                math.floor((setting.value+d)*1000+0.5)/1000,
                setting.min or -1e9, setting.max or 1e9)
            vl.Text=tostring(math.floor(setting.value*100+0.5)/100)
            propagate(mod,setting)
        end
        mn.MouseButton1Click:Connect(function() upd(-step) end)
        pl.MouseButton1Click:Connect(function()  upd( step) end)

    elseif setting.type=="bool" then
        local tb=Instance.new("TextButton",f)
        tb.Size=UDim2.new(0,34,0,14); tb.Position=UDim2.new(0.5,2,0.5,-7)
        tb.Text=setting.value and "ON" or "OFF"
        tb.TextColor3=setting.value and Color3.fromRGB(80,255,80) or Color3.fromRGB(255,80,80)
        tb.BackgroundColor3=Color3.fromRGB(24,24,40); tb.BorderSizePixel=0
        tb.Font=Enum.Font.GothamBold; tb.TextSize=10; tb.ZIndex=zo+2
        local tc=Instance.new("UICorner",tb); tc.CornerRadius=UDim.new(0,3)
        tb.MouseButton1Click:Connect(function()
            setting.value=not setting.value
            tb.Text=setting.value and "ON" or "OFF"
            tb.TextColor3=setting.value and Color3.fromRGB(80,255,80) or Color3.fromRGB(255,80,80)
            propagate(mod,setting)
        end)

    elseif setting.type=="select" then
        local idx=1
        for i,opt in ipairs(setting.options) do if opt==setting.value then idx=i end end
        local sb=Instance.new("TextButton",f)
        sb.Size=UDim2.new(0.5,0,0,14); sb.Position=UDim2.new(0.49,0,0.5,-7)
        sb.Text=setting.value; sb.TextColor3=Color3.fromRGB(155,155,255)
        sb.BackgroundColor3=Color3.fromRGB(24,24,46); sb.BorderSizePixel=0
        sb.Font=Enum.Font.Gotham; sb.TextSize=10; sb.ZIndex=zo+2
        local sc=Instance.new("UICorner",sb); sc.CornerRadius=UDim.new(0,3)
        sb.MouseButton1Click:Connect(function()
            idx=(idx%#setting.options)+1
            setting.value=setting.options[idx]; sb.Text=setting.value
            propagate(mod,setting)
        end)
    end
    return f
end

