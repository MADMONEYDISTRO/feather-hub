-- =============================================
-- UTILITY FUNCTIONS
-- =============================================
local function isWithinField(pos, fieldPos)
    return (pos - fieldPos).Magnitude <= farmRadius
end

local function findNearestCollectible(pos)
    local best, bestDist = nil, math.huge
    for _, c in ipairs(Workspace.Collectibles:GetChildren()) do
        if c.Transparency == 0 then
            local d = (c.Position - pos).Magnitude
            if d < bestDist then best, bestDist = c, d end
        end
    end
    return best
end

local function findPriorityTarget(pos, fieldPos)
    local best, bestDist = nil, math.huge
    local function check(tbl, name)
        for _, obj in ipairs(tbl) do
            local part = obj
            if name == "Balloon" then
                part = obj:FindFirstChild("BalloonBody")
                if not part then continue end
            end
            if isWithinField(part.Position, fieldPos.Position) then
                local d = (part.Position - pos).Magnitude
                if d < bestDist then best, bestDist = part, d end
            end
        end
    end
    if farmCoconuts then check(Workspace.Particles:GetChildren(), "WarningDisk") end
    if farmFlames then check(Workspace.PlayerFlames:GetChildren(), "Flame") end
    if farmBubbles then
        for _, b in ipairs(Workspace.Particles:GetChildren()) do
            if b.Name == "Bubble" and isWithinField(b.Position, fieldPos.Position) then
                local d = (b.Position - pos).Magnitude
                if d < bestDist then best, bestDist = b, d end
            end
        end
    end
    if farmBalloons then check(Workspace.Balloons.FieldBalloons:GetChildren(), "Balloon") end
    return best
end

local function randomFieldTarget(fieldPos)
    local angle = math.random() * math.pi * 2
    local dist = math.random(5, farmRadius)
    local offset = Vector3.new(math.cos(angle)*dist, 0, math.sin(angle)*dist)
    local target = fieldPos.Position + offset
    local ray = RaycastParams.new()
    ray.FilterType = Enum.RaycastFilterType.Blacklist
    ray.FilterDescendantsInstances = {Player.Character or nil}
    local hit = Workspace:Raycast(target + Vector3.new(0,20,0), Vector3.new(0,-100,0), ray)
    if hit then target = hit.Position + Vector3.new(0,3,0) end
    return target
end

local function moveTo(targetPos)
    local char = Player.Character
    if not char then return end
    local hrp = char:FindFirstChild("HumanoidRootPart")
    if not hrp then return end
    if selectedFarmMode == "Walk" then
        local hum = char:FindFirstChildOfClass("Humanoid")
        if hum then
            hum:MoveTo(Vector3.new(targetPos.X, hrp.Position.Y, targetPos.Z))
            repeat task.wait() until (hrp.Position - Vector3.new(targetPos.X, hrp.Position.Y, targetPos.Z)).Magnitude < 3 or not autoFarmActive
        end
    else
        local tween = TweenService:Create(hrp,
            TweenInfo.new(selectedFarmMode == "Tween" and 0.5 or 0.2),
            {CFrame = CFrame.new(targetPos.X, hrp.Position.Y, targetPos.Z)})
        tween:Play()
        tween.Completed:Wait()
    end
end

