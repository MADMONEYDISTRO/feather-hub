local function slider(c, order, text, min, max, default, round, cb)
    local r = row(c, order, false, 64)
    local lbl = Instance.new("TextLabel", r)
    lbl.Size = UDim2.new(1,-24,0,22)
    lbl.Position = UDim2.new(0,14,0,6)
    lbl.Text = text..": "..default
    lbl.Font = Enum.Font.GothamSemibold; lbl.TextSize = 10; lbl.TextColor3 = T.text
    lbl.TextXAlignment = Enum.TextXAlignment.Left; lbl.BackgroundTransparency = 1
    local track = Instance.new("Frame", r)
    track.Size = UDim2.new(1,-28,0,6)
    track.Position = UDim2.new(0,14,0,34)
    track.BackgroundColor3 = T.dim; track.Active = true
    Instance.new("UICorner", track).CornerRadius = UDim.new(1,0)
    local fill = Instance.new("Frame", track)
    fill.Size = UDim2.new((default-min)/(max-min),0,1,0)
    fill.BackgroundColor3 = T.accent
    Instance.new("UICorner", fill).CornerRadius = UDim.new(1,0)
    local knob = Instance.new("TextButton", track)
    knob.Size = UDim2.new(0,18,0,18)
    knob.Position = UDim2.new((default-min)/(max-min),-9,0.5,-9)
    knob.BackgroundColor3 = Color3.new(1,1,1); knob.Text = ""; knob.AutoButtonColor = false
    Instance.new("UICorner", knob).CornerRadius = UDim.new(1,0)
    local drag = false
    local function upd(input)
        local rel = math.clamp((input.Position.X - track.AbsolutePosition.X) / track.AbsoluteSize.X, 0, 1)
        local val = min + (max-min)*rel
        if round>0 then val = math.floor(val/round+0.5)*round end
        lbl.Text = text..": "..val
        fill.Size = UDim2.new(rel,0,1,0)
        knob.Position = UDim2.new(rel,-9,0.5,-9)
        cb(val)
    end
    local function hookTouch(input)
        drag = true; upd(input)
        input.Changed:Connect(function()
            if input.UserInputState == Enum.UserInputState.Change then upd(input)
            elseif input.UserInputState == Enum.UserInputState.End or input.UserInputState == Enum.UserInputState.Cancel then drag=false end
        end)
    end
    knob.InputBegan:Connect(function(i) if i.UserInputType==Enum.UserInputType.Touch then hookTouch(i) elseif i.UserInputType==Enum.UserInputType.MouseButton1 then drag=true end end)
    track.InputBegan:Connect(function(i) if i.UserInputType==Enum.UserInputType.Touch then hookTouch(i) elseif i.UserInputType==Enum.UserInputType.MouseButton1 then upd(i) drag=true end end)
    UserInputService.InputChanged:Connect(function(i) if drag and i.UserInputType==Enum.UserInputType.MouseMovement then upd(i) end end)
    UserInputService.InputEnded:Connect(function(i) if i.UserInputType==Enum.UserInputType.MouseButton1 then drag=false end end)
    return r
end
local function dropdown(c, order, text, opts, default, cb)
    local r = row(c, order, false, 52)
    local lbl = Instance.new("TextLabel", r)
    lbl.Size = UDim2.new(0.5,0,1,0); lbl.Position = UDim2.new(0,14,0,0)
    lbl.Text = text; lbl.Font = Enum.Font.GothamSemibold; lbl.TextSize = 10
    lbl.TextColor3 = T.text; lbl.TextXAlignment = Enum.TextXAlignment.Left; lbl.BackgroundTransparency = 1
    local btn = Instance.new("TextButton", r)
    btn.Size = UDim2.new(0,130,0,28); btn.Position = UDim2.new(1,-142,0.5,-14)
    btn.Text = default; btn.Font = Enum.Font.GothamMedium; btn.TextSize = 9
    btn.TextColor3 = T.text; btn.BackgroundColor3 = T.inputBg; btn.AutoButtonColor = false
    Instance.new("UICorner", btn).CornerRadius = UDim.new(0,6)
    local menu = Instance.new("Frame", sg)
    menu.Size = UDim2.new(0,130,0,0); menu.BackgroundColor3 = T.card
    menu.Visible = false; menu.ZIndex = 50
    Instance.new("UICorner", menu).CornerRadius = UDim.new(0,6)
    local menuList = Instance.new("UIListLayout", menu)
    menuList.SortOrder = Enum.SortOrder.LayoutOrder; menuList.Padding = UDim.new(0,2)
    local function buildMenu()
        for _,c in pairs(menu:GetChildren()) do if c:IsA("TextButton") then c:Destroy() end end
        for _,opt in ipairs(opts) do
            local b = Instance.new("TextButton", menu)
            b.Size = UDim2.new(1,0,0,28); b.Text = opt; b.Font = Enum.Font.GothamMedium; b.TextSize = 9
            b.TextColor3 = T.text; b.BackgroundColor3 = T.dim; b.AutoButtonColor = false
            b.MouseButton1Click:Connect(function() btn.Text = opt; menu.Visible = false; cb(opt) end)
        end
        menu.Size = UDim2.new(0,130,0,#opts*30)
        local abs = btn.AbsolutePosition; local h = #opts*30
        local vs = Workspace.CurrentCamera.ViewportSize
        local y = abs.Y + btn.AbsoluteSize.Y + 2
        if y+h > vs.Y-20 then y = abs.Y - h - 2 end
        menu.Position = UDim2.new(0, abs.X, 0, y)
    end
    btn.MouseButton1Click:Connect(function() if menu.Visible then menu.Visible = false else buildMenu(); menu.Visible = true end end)
    UserInputService.InputBegan:Connect(function(i)
        if menu.Visible and (i.UserInputType==Enum.UserInputType.MouseButton1 or i.UserInputType==Enum.UserInputType.Touch) then
            task.wait()
            local pos = i.Position
            local a = menu.AbsolutePosition; local s = menu.AbsoluteSize
            if not (pos.X>=a.X and pos.X<=a.X+s.X and pos.Y>=a.Y and pos.Y<=a.Y+s.Y) then menu.Visible = false end
        end
    end)
    return r
end
