-- Auto Farm (pauses during sell)
spawn(function()
    while true do
        if autoFarmActive then
            while sellInProgress do task.wait(0.1) end
            local char = Player.Character
            if char then
                local hrp = char:FindFirstChild("HumanoidRootPart")
                if hrp then
                    local pos = hrp.Position
                    local fieldPos = fieldPositions[selectedField]
                    if fieldPos then
                        if not isWithinField(pos, fieldPos.Position) then
                            hrp.CFrame = fieldPos
                            pos = hrp.Position
                        end
                        local target = findPriorityTarget(pos, fieldPos) or findNearestCollectible(pos)
                        if target and isWithinField(target.Position, fieldPos.Position) then
                            moveTo(target.Position)
                        else
                            moveTo(randomFieldTarget(fieldPos))
                        end
                    end
                end
            end
            task.wait(0.1)
        else
            task.wait(0.5)
        end
    end
end)

-- Auto Sell (finds player's hive by Owner.UserId)
spawn(function()
    while true do
        if autoSell then
            local capacity = Player.CoreStats.Capacity.Value
            local pollen = Player.CoreStats.Pollen.Value
            if pollen >= capacity * 0.99 then
                sellInProgress = true
                local char = Player.Character
                if char then
                    local hrp = char:FindFirstChild("HumanoidRootPart")
                    if hrp then
                        local originalPos = hrp.CFrame
                        local myHive = nil
                        for _, hive in ipairs(Workspace.Honeycombs:GetChildren()) do
                            local owner = hive:FindFirstChild("Owner")
                            if owner and owner.Value == Player.UserId then
                                myHive = hive
                                break
                            end
                        end
                        if myHive then
                            local lightHolder = myHive:FindFirstChild("LightHolder")
                            if lightHolder then
                                local sellCF = lightHolder.CFrame * CFrame.new(0, -5, -5)
                                hrp.CFrame = sellCF
                                local conn; conn = RunService.Heartbeat:Connect(function()
                                    if autoSell and Player.CoreStats.Pollen.Value > 0 then
                                        hrp.CFrame = sellCF
                                    else
                                        conn:Disconnect()
                                    end
                                end)
                                repeat
                                    local btnText = Player.PlayerGui.ScreenGui.ActivateButton.TextBox.Text
                                    if btnText == 'Make Honey' then
                                        PlayerHiveCommand:FireServer("ToggleHoneyMaking")
                                    end
                                    task.wait()
                                until Player.CoreStats.Pollen.Value == 0 or not autoSell
                                task.wait(8)
                            end
                        end
                        hrp.CFrame = originalPos
                    end
                end
                sellInProgress = false
            end
        end
        task.wait(0)
    end
end)

