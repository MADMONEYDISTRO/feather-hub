    makeToggle(page, 3, "Show FOV Circle", false, function(v) ShowFOV = v end)
    makeSlider(page, 4, "FOV Radius", 10, 500, 100, "px", function(v) FOV_Radius = v end)
    makeSlider(page, 5, "Aimbot Smoothing", 1, 10, 3, "", function(v) Smoothing = v end)

    -- TriggerBot
    local TriggerBotEnabled, TriggerBotDelay = false, 0
