local function makeDropdown(parent, order, title, values, defaultIndex, callback)
    local row = makeRow(parent, order, false, 52)
    local lbl = Instance.new("TextLabel", row)
    lbl.Size = UDim2.new(0.4, 0, 0, 20)
    lbl.Position = UDim2.new(0, 16, 0, 8)
    lbl.Text = title
    lbl.Font = Enum.Font.GothamSemibold
    lbl.TextSize = 10
    lbl.TextColor3 = T.text
    lbl.TextXAlignment = Enum.TextXAlignment.Left
    lbl.BackgroundTransparency = 1
    lbl.ZIndex = 5

    local selected = values[defaultIndex] or values[1]
    local btn = Instance.new("TextButton", row)
    btn.Size = UDim2.new(0.55, -20, 0, 30)
    btn.Position = UDim2.new(1, -btn.Size.X.Offset - 16, 0.5, -15)
    btn.Text = selected
    btn.Font = Enum.Font.GothamMedium
    btn.TextSize = 10
    btn.TextColor3 = T.text
    btn.BackgroundColor3 = T.inputBg
    btn.BorderSizePixel = 0
    btn.AutoButtonColor = false
    btn.ZIndex = 5
    Instance.new("UICorner", btn).CornerRadius = UDim.new(0, 6)
    local stroke = Instance.new("UIStroke", btn)
    stroke.Color = T.border
    stroke.Thickness = 1

    local dropdownOpen = false
    local dropdownFrame
    local closeConnection

    local function closeDropdown()
        if dropdownFrame then dropdownFrame:Destroy(); dropdownFrame = nil end
        if closeConnection then closeConnection:Disconnect(); closeConnection = nil end
        dropdownOpen = false
    end

    btn.MouseButton1Click:Connect(function()
        if dropdownOpen then closeDropdown(); return end
        dropdownOpen = true
        dropdownFrame = Instance.new("Frame")
        dropdownFrame.Size = UDim2.new(0, btn.AbsoluteSize.X, 0, #values * 30)
        dropdownFrame.Position = UDim2.new(0, btn.AbsolutePosition.X, 0, btn.AbsolutePosition.Y + btn.AbsoluteSize.Y)
        dropdownFrame.BackgroundColor3 = T.card
        dropdownFrame.BorderSizePixel = 0
        dropdownFrame.ZIndex = 100
        dropdownFrame.Parent = ScreenGui
        Instance.new("UICorner", dropdownFrame).CornerRadius = UDim.new(0, 6)
        Instance.new("UIStroke", dropdownFrame).Color = T.border
        local ddLayout = Instance.new("UIListLayout", dropdownFrame)
        ddLayout.SortOrder = Enum.SortOrder.LayoutOrder

        for _, v in ipairs(values) do
            local opt = Instance.new("TextButton", dropdownFrame)
            opt.Size = UDim2.new(1, 0, 0, 30)
            opt.Text = v
            opt.Font = Enum.Font.GothamMedium
            opt.TextSize = 10
            opt.TextColor3 = T.text
            opt.BackgroundColor3 = T.card
            opt.BorderSizePixel = 0
            opt.ZIndex = 101
            opt.AutoButtonColor = false
            opt.MouseEnter:Connect(function() createTween(opt, {BackgroundColor3 = T.dim}):Play() end)
            opt.MouseLeave:Connect(function() createTween(opt, {BackgroundColor3 = T.card}):Play() end)
            opt.MouseButton1Click:Connect(function()
                btn.Text = v
                selected = v
                closeDropdown()
                callback(v)
            end)
        end
        task.wait(0.05)
        closeConnection = UserInputService.InputBegan:Connect(function(input)
            if input.UserInputType == Enum.UserInputType.MouseButton1 then
                local mousePos = UserInputService:GetMouseLocation()
                local inDropdown = false
                if dropdownFrame then
                    local ap, as = dropdownFrame.AbsolutePosition, dropdownFrame.AbsoluteSize
                    if mousePos.X >= ap.X and mousePos.X <= ap.X + as.X and mousePos.Y >= ap.Y and mousePos.Y <= ap.Y + as.Y then inDropdown = true end
                end
                local bap, bas = btn.AbsolutePosition, btn.AbsoluteSize
                if mousePos.X >= bap.X and mousePos.X <= bap.X + bas.X and mousePos.Y >= bap.Y and mousePos.Y <= bap.Y + bas.Y then inDropdown = true end
                if not inDropdown then closeDropdown() end
            end
        end)
    end)
    return {
        SetValues = function(self, newVals)
            values = newVals
            btn.Text = values[1] or ""
            if dropdownOpen then closeDropdown() end
        end,
        SetValue = function(self, val)
            btn.Text = val
            selected = val
        end,
        Value = selected
    }
end

