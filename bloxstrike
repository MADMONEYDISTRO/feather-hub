            if suffix == "px" or not string.find(suffix or "", "%.") then val = math.floor(val) end
            fill.Size = UDim2.new(relX, 0, 1, 0)
            knob.Position = UDim2.new(relX, -7, 0.5, -7)
            valLabel.Text = tostring(val) .. (suffix or "")
            callback(val)
        end
    end)
    return {SetValue = function(_, v)
        local relX = (v - min) / (max - min)
        fill.Size = UDim2.new(relX, 0, 1, 0)
        knob.Position = UDim2.new(relX, -7, 0.5, -7)
        valLabel.Text = tostring(v) .. (suffix or "")
