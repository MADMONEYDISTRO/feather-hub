--// ─── AUTO FARM LOGIC ─────────────────────────────────────────────────────────

local AutoFarm        = false
local AutoFarmRunning = false
local AntiAFK         = true

local FarmStartTime   = 0
local MoneyStart      = 0
local MoneyEarned     = 0

local StartPos = Vector3.new(811.013184,  27.3421249, 2203.55542)
local EndPos   = Vector3.new(-76.4760208, 27.7194824, 1993.84229)

local function GetVehicle()
    local char = LocalPlayer.Character
    if not char then return nil end
    local hum = char:FindFirstChildOfClass("Humanoid")
    if not hum or not hum.SeatPart then return nil end
    return hum.SeatPart.Parent
end

local function GetCarHeight(car)
    if not car or not car.PrimaryPart then return 1 end
    return car.PrimaryPart.Size.Y / 2 + 0.5
end

local function GetMoney()
    local holder = LocalPlayer:FindFirstChild("Holder")
    if not holder then return 0 end
    local money = holder:FindFirstChild("Money")
    if not money then return 0 end
    return tonumber(money.Value) or 0
end

local function TPWithFacing(fromPos, toPos, car)
    if not car or not car.PrimaryPart then return end
    local height = GetCarHeight(car)
    car:SetPrimaryPartCFrame(CFrame.new(fromPos + Vector3.new(0, height, 0), toPos))
end

local function VelocityTPWithFacing(fromPos, toPos, car)
    if not car or not car.PrimaryPart then return end
    local primary = car.PrimaryPart
    local height  = GetCarHeight(car)
    local speed   = math.random(200, 600)

    primary.CFrame = CFrame.new(fromPos + Vector3.new(0, height, 0), toPos)

    local gyro = Instance.new("BodyGyro", primary)
    gyro.P          = 5000
    gyro.MaxTorque  = Vector3.new(9e9, 9e9, 9e9)
    gyro.CFrame     = CFrame.new(primary.Position, toPos)

    local vel = Instance.new("BodyVelocity", primary)
    vel.MaxForce = Vector3.new(9e9, 9e9, 9e9)
    vel.Velocity = (toPos - primary.Position).Unit * speed

    task.wait((primary.Position - toPos).Magnitude / speed)
    vel.Velocity = Vector3.new()
    task.wait(0.1)
    vel:Destroy()
    gyro:Destroy()
end

LocalPlayer.Idled:Connect(function()
    if not AntiAFK then return end
    VirtualUser:CaptureController()
    VirtualUser:ClickButton2(Vector2.new(), Camera.CFrame)
end)

task.spawn(function()
    while true do
        task.wait(0.5)
        if not AutoFarm then
            AutoFarmRunning = false
            continue
        end

        AutoFarmRunning = true
        local car = GetVehicle()
        if not car then
            Notify("FeatherHub", "Enter a vehicle to AutoFarm.", 2)
            task.wait(2)
            continue
        end

        TPWithFacing(StartPos, EndPos, car)
        VelocityTPWithFacing(StartPos, EndPos, car)
        TPWithFacing(EndPos, StartPos, car)
        VelocityTPWithFacing(EndPos, StartPos, car)
    end
end)

--// ─── BUILD & CONNECT EVERYTHING ─────────────────────────────────────────────

local refs = BuildUI()

local callbacks = {
    OnAutoFarmToggle = function(state)
        AutoFarm = state
        if state then
            FarmStartTime = tick()
            MoneyStart    = GetMoney()
        end
    end,
    OnAntiAfkToggle = function(state)
        AntiAFK = state
    end,
}

local mainUIRefs = BuildMainPage(refs.MainPage, callbacks)
BuildOtherPage(refs.OtherPage, refs.Main)
BuildATMPage(refs.ATMPage)

RunService.RenderStepped:Connect(function()
    if not AutoFarmRunning then return end

    local tf = tick() - FarmStartTime
    mainUIRefs.TimeLabel.Text = string.format("Time Farmed:  %ds", math.floor(tf))

    local me = GetMoney() - MoneyStart
    mainUIRefs.MoneyLabel.Text = "Money Earned: $" .. me

    local mph = tf > 0 and math.floor((me / tf) * 3600) or 0
    mainUIRefs.EstLabel.Text = "Estimated:    $" .. mph .. " / hr"
end)

task.spawn(function()
    while true do
        task.wait(4)
        if refs.ATMPage.Visible then
            BuildATMPage(refs.ATMPage)
        end
    end
end)

Notify("FeatherHub v1", "Loaded. Press RightShift to toggle.", 4)
