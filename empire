local function MakeLabel(parent, text, yOffset, textSize)
    local lbl = Instance.new("TextLabel", parent)
    lbl.Size               = UDim2.new(1, -16, 0, 22)
    lbl.Position           = UDim2.new(0, 8, 0, yOffset)
    lbl.BackgroundTransparency = 1
    lbl.Font               = Enum.Font.GothamSemibold
    lbl.TextSize           = textSize or 12
    lbl.TextColor3         = Color3.fromRGB(200, 195, 240)
    lbl.TextXAlignment     = Enum.TextXAlignment.Left
    lbl.Text               = text
    return lbl
end

local function MakeToggle(parent, label, yOffset, onToggle)
    local isOn = false
    local ON_COLOR  = Color3.fromRGB(80, 60, 180)
    local OFF_COLOR = Color3.fromRGB(30, 24, 60)

    local row = Instance.new("Frame", parent)
    row.Size                   = UDim2.new(1, -16, 0, 30)
    row.Position               = UDim2.new(0, 8, 0, yOffset)
    row.BackgroundColor3       = OFF_COLOR
    row.BorderSizePixel        = 0
    Instance.new("UICorner", row).CornerRadius = UDim.new(0, 8)

    local lbl = Instance.new("TextLabel", row)
    lbl.Size               = UDim2.new(1, -60, 1, 0)
    lbl.Position           = UDim2.new(0, 10, 0, 0)
    lbl.BackgroundTransparency = 1
    lbl.Font               = Enum.Font.GothamSemibold
    lbl.TextSize           = 12
    lbl.TextColor3         = Color3.fromRGB(200, 195, 240)
    lbl.TextXAlignment     = Enum.TextXAlignment.Left
    lbl.Text               = label

    local btn = Instance.new("TextButton", row)
    btn.Size               = UDim2.new(0, 48, 0, 22)
    btn.Position           = UDim2.new(1, -54, 0.5, -11)
    btn.BackgroundColor3   = OFF_COLOR
    btn.Font               = Enum.Font.GothamBold
    btn.TextSize           = 11
    btn.TextColor3         = Color3.fromRGB(180, 170, 230)
    btn.Text               = "OFF"
    Instance.new("UICorner", btn).CornerRadius = UDim.new(0, 6)
    AnimateButton(btn)

    btn.MouseButton1Click:Connect(function()
        isOn = not isOn
        btn.Text             = isOn and "ON" or "OFF"
        btn.BackgroundColor3 = isOn and ON_COLOR or OFF_COLOR
        if onToggle then onToggle(isOn) end
    end)

    return btn, function() return isOn end
end

