local function isInsideSpawner(obj)
    local cur = obj.Parent
    while cur and cur ~= workspace do
        if cur.Name == "CriminalATMSpawner" or cur.Name == "CriminalATMSpawners" then
            return true
        end
        cur = cur.Parent
    end
    return false
end

