--// ─── ANIMATION HELPERS ──────────────────────────────────────────────────────

local function Ripple(btn)
    btn.ClipsDescendants = true
    btn.MouseButton1Click:Connect(function(x, y)
        local absPos  = btn.AbsolutePosition
        local absSize = btn.AbsoluteSize
        local circle  = Instance.new("Frame")
        circle.BackgroundColor3    = Color3.fromRGB(255, 255, 255)
        circle.BackgroundTransparency = 0.7
        circle.BorderSizePixel     = 0
        circle.ZIndex              = btn.ZIndex + 1
        circle.AnchorPoint         = Vector2.new(0.5, 0.5)
        circle.Position            = UDim2.new(0, x - absPos.X, 0, y - absPos.Y)
        circle.Size                = UDim2.new(0, 0, 0, 0)
        circle.Parent              = btn
        Instance.new("UICorner", circle).CornerRadius = UDim.new(1, 0)
        local finalSize = math.max(absSize.X, absSize.Y) * 2
        TweenService:Create(circle, TweenInfo.new(0.4, Enum.EasingStyle.Quad), {
            Size = UDim2.new(0, finalSize, 0, finalSize),
            BackgroundTransparency = 1
        }):Play()
        task.delay(0.4, function() if circle then circle:Destroy() end end)
    end)
end

local function AnimateButton(btn)
    local defaultColor = btn.BackgroundColor3
    local hoverColor   = defaultColor:Lerp(Color3.fromRGB(120, 100, 220), 0.4)
    local pressColor   = defaultColor:Lerp(Color3.fromRGB(150, 120, 240), 0.6)
    btn.MouseEnter:Connect(function()
        TweenService:Create(btn, TweenInfo.new(0.15, Enum.EasingStyle.Quad), { BackgroundColor3 = hoverColor }):Play()
    end)
    btn.MouseLeave:Connect(function()
        TweenService:Create(btn, TweenInfo.new(0.15, Enum.EasingStyle.Quad), { BackgroundColor3 = defaultColor }):Play()
    end)
    btn.MouseButton1Down:Connect(function()
        TweenService:Create(btn, TweenInfo.new(0.08, Enum.EasingStyle.Quad), { BackgroundColor3 = pressColor }):Play()
    end)
    btn.MouseButton1Up:Connect(function()
        TweenService:Create(btn, TweenInfo.new(0.08, Enum.EasingStyle.Quad), { BackgroundColor3 = hoverColor }):Play()
    end)
    Ripple(btn)
end

local function InertiaDrag(frame)
    local dragging, dragStart, startPos = false, Vector2.new(), UDim2.new()
    local velocity, lastPos, lastTime   = Vector2.new(), Vector2.new(), tick()
    frame.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            dragging  = true
            dragStart = input.Position
            startPos  = frame.Position
            velocity  = Vector2.new()
            lastPos   = input.Position
            lastTime  = tick()
        end
    end)
    UserInputService.InputChanged:Connect(function(input)
        if dragging and input.UserInputType == Enum.UserInputType.MouseMovement then
            local delta = input.Position - dragStart
            frame.Position = UDim2.new(
                startPos.X.Scale, startPos.X.Offset + delta.X,
                startPos.Y.Scale, startPos.Y.Offset + delta.Y
            )
            local dt = tick() - lastTime
            if dt > 0 then velocity = (input.Position - lastPos) / dt end
            lastPos  = input.Position
            lastTime = tick()
        end
    end)
    UserInputService.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 and dragging then
            dragging = false
            local speed = velocity.Magnitude
            if speed > 0 then
                local offset = velocity.Unit * math.clamp(speed * 0.03, 20, 120)
                TweenService:Create(frame, TweenInfo.new(0.35, Enum.EasingStyle.Quart), {
                    Position = frame.Position + UDim2.new(0, offset.X, 0, offset.Y)
                }):Play()
            end
        end
    end)
end

