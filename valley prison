-- ESP
local espEnabled = false
local espPlayers = {}
local function updateESP()
    for _, p in ipairs(Players:GetPlayers()) do
        if p == LocalPlayer then continue end
        local char = p.Character
        if not char then
            if espPlayers[p] then
                if espPlayers[p].highlight then espPlayers[p].highlight:Destroy() end
                if espPlayers[p].billboard then espPlayers[p].billboard:Destroy() end
                espPlayers[p] = nil
            end
            continue
        end
        if not espPlayers[p] then
            local hl = Instance.new("Highlight")
            hl.FillColor = Color3.fromRGB(0, 170, 255)
            hl.OutlineColor = Color3.fromRGB(255,255,255)
            hl.FillTransparency = 0.5
            hl.OutlineTransparency = 0
            hl.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
            hl.Enabled = false
            hl.Parent = char
            local bb = nil
            local head = char:FindFirstChild("Head")
            if head then
                bb = Instance.new("BillboardGui")
                bb.Size = UDim2.new(0,90,0,18)
                bb.StudsOffset = Vector3.new(0,3,0)
                bb.AlwaysOnTop = true
                bb.Enabled = false
                bb.Parent = head
                bb.Adornee = head
                local name = Instance.new("TextLabel")
                name.Size = UDim2.new(1,0,1,0)
                name.BackgroundTransparency = 1
                name.Font = Enum.Font.GothamSemibold
                name.TextSize = 10
                name.TextColor3 = Color3.new(1,1,1)
                name.TextStrokeTransparency = 0.8
                name.Text = p.Name
                name.Parent = bb
            end
            espPlayers[p] = {highlight=hl, billboard=bb}
        end
        local d = espPlayers[p]
        if d.highlight then d.highlight.Enabled = espEnabled end
        if d.billboard then d.billboard.Enabled = espEnabled end
    end
end
RunService.RenderStepped:Connect(updateESP)

