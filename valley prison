    if not invESP then
        for _, g in pairs(invGuis) do g:Destroy() end
        invGuis = {}
        return
    end
    for _, p in ipairs(Players:GetPlayers()) do
        if p == LocalPlayer then continue end
        local char = p.Character
        if not char then continue end
        local head = char:FindFirstChild("Head")
        if not head then continue end
        local gui = invGuis[p]
        if not gui then
            gui = Instance.new("BillboardGui")
            gui.Size = UDim2.new(5,0,1.8,0)
            gui.StudsOffset = Vector3.new(0,4.5,0)
            gui.AlwaysOnTop = true
            gui.Parent = head
            gui.Adornee = head
            local txt = Instance.new("TextLabel")
            txt.Size = UDim2.new(1,0,1,0)
            txt.BackgroundTransparency = 1
            txt.TextScaled = true
            txt.TextColor3 = Color3.new(1,1,1)
            txt.TextStrokeTransparency = 0
            txt.Font = Enum.Font.SourceSansBold
            txt.Parent = gui
            invGuis[p] = gui
        end
        local items = {}
        local bp = p:FindFirstChild("Backpack")
        if bp then for _, t in ipairs(bp:GetChildren()) do if t:IsA("Tool") then table.insert(items, t.Name) end end end
        if char then for _, obj in ipairs(char:GetChildren()) do if obj:IsA("Tool") then table.insert(items, obj.Name) end end end
        invGuis[p].TextLabel.Text = table.concat(items, "\n")
    end
end)

-- Dropped Items ESP
local dropESP = false
local dropHL = {}
RunService.RenderStepped:Connect(function()
    local folder = Workspace:FindFirstChild("DroppedTools")
    if not folder then
        for _, list in pairs(dropHL) do for _, h in ipairs(list) do h:Destroy() end end
        table.clear(dropHL)
        return
    end
    local processed = {}
    for _, tool in ipairs(folder:GetChildren()) do
        if tool:IsA("Tool") then
            if not dropHL[tool] then
                local hlList = {}
                for _, part in ipairs(tool:GetDescendants()) do
                    if part:IsA("BasePart") then
                        local h = Instance.new("Highlight")
                        h.FillColor = Color3.fromRGB(255,100,0)
                        h.OutlineColor = Color3.fromRGB(255,255,0)
                        h.FillTransparency = 0.3
                        h.OutlineTransparency = 0
                        h.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
                        h.Enabled = dropESP
                        h.Parent = part
                        table.insert(hlList, h)
                    end
                end
                dropHL[tool] = hlList
            else
                for _, h in ipairs(dropHL[tool]) do h.Enabled = dropESP end
            end
            processed[tool] = true
        end
    end
    for tool, hlList in pairs(dropHL) do
        if not processed[tool] then
            for _, h in ipairs(hlList) do h:Destroy() end
            dropHL[tool] = nil
        end
    end
end)

-- Keycard ESP
local keycardESP = false
local keycards = {}
RunService.RenderStepped:Connect(function()
    if not keycardESP then
        for _, d in pairs(keycards) do d:Remove() end
        keycards = {}
        return
    end
    for _, obj in ipairs(Workspace:GetDescendants()) do
        if obj:IsA("BasePart") and obj.Name:lower():find("card") then
            local prompt = obj:FindFirstChildWhichIsA("ProximityPrompt")
            if prompt and (not prompt.ObjectText or prompt.ObjectText=="") and (not prompt.ActionText or prompt.ActionText=="") then
                if not keycards[obj] then
                    local c = Drawing.new("Circle")
                    c.Thickness = 2
                    c.Filled = false
                    c.Color = Color3.new(0,255,0)
                    c.Radius = 10
                    c.Visible = true
                    keycards[obj] = c
                end
                local pos = Camera:WorldToViewportPoint(obj.Position)
                keycards[obj].Position = Vector2.new(pos.X, pos.Y)
                keycards[obj].Visible = pos.Z > 0
            end
        end
    end
end)

-- Aimbot
local aimbot = false
local aimFOV = 80
local aimSmooth = 0.2
local aimTeam = true
local aimKey = Enum.KeyCode.Q
local fovCircle
local function getTarget()
    local closest, minDist = nil, aimFOV
    local mouse = UserInputService:GetMouseLocation()
    for _, p in ipairs(Players:GetPlayers()) do
        if p == LocalPlayer then continue end
        if aimTeam and p.Team == LocalPlayer.Team then continue end
        local head = p.Character and p.Character:FindFirstChild("Head")
        if not head then continue end
        local pos, scr = Camera:WorldToViewportPoint(head.Position)
        if scr then
            local d = (Vector2.new(pos.X, pos.Y) - mouse).Magnitude
            if d < minDist then minDist = d; closest = p end
        end
    end
    return closest
end
RunService.RenderStepped:Connect(function()
    if aimbot and UserInputService:IsKeyDown(aimKey) then
        local t = getTarget()
        if t and t.Character and t.Character:FindFirstChild("Head") then
            Camera.CFrame = Camera.CFrame:Lerp(CFrame.lookAt(Camera.CFrame.Position, t.Character.Head.Position), aimSmooth)
        end
    end
end)
if Drawing then
    fovCircle = Drawing.new("Circle")
    fovCircle.Visible = false
    fovCircle.Thickness = 2
    fovCircle.Filled = false
    fovCircle.Radius = aimFOV
    fovCircle.Color = Color3.fromRGB(255,255,255)
    fovCircle.Position = Camera.ViewportSize/2
    RunService:BindToRenderStep("AimFOV", 1, function()
        if aimbot then
            fovCircle.Radius = aimFOV
            fovCircle.Position = Camera.ViewportSize/2
            fovCircle.Visible = true
        else
            fovCircle.Visible = false
        end
    end)
end

