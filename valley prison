-- Gun Mods
local gunMods = false
local function applyMods(tool)
    if not gunMods then return end
    local cfg = tool:FindFirstChild("LocalConfig")
    if cfg then cfg = cfg:FindFirstChild("Configuration") end
    if cfg then
        for _, v in ipairs(cfg:GetChildren()) do
            if v.Name=="Accuracy" then v.Value=0
            elseif v.Name=="RecoilMin" then v.Value=0
            elseif v.Name=="RecoilMax" then v.Value=0
            elseif v.Name=="MaximumRange" then v.Value=9999 end
        end
    end
end
LocalPlayer.Backpack.ChildAdded:Connect(function(c) if c:IsA("Tool") then applyMods(c) end end)
LocalPlayer.CharacterAdded:Connect(function(c)
    c.ChildAdded:Connect(function(ch) if ch:IsA("Tool") then applyMods(ch) end end)
end)

