local function notify(title, msg, nType)
    local col = ({success=Color3.fromRGB(40,200,130), error=red, warning=gold})[nType] or accent
    local n = Instance.new("Frame")
    n.Size = UDim2.new(0,0,0,58); n.Position = UDim2.new(1,-10,1,-70)
    n.AnchorPoint = Vector2.new(1,1); n.BackgroundColor3 = T.bg
