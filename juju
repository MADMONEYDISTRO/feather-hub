--  AIMBOT SYSTEM
-- ══════════════════════════════════════════
local aimbotActive = false
local aimbotDistance = 50
local aimbotTilt = false
local aimbotConnection

local function getAimbotTarget()
    local char = Player.Character
    if not char then return nil end
    local playerRoot = char:FindFirstChild("HumanoidRootPart")
    if not playerRoot then return nil end
    local closest = nil
    local shortest = math.huge
    for _, obj in ipairs(char.Parent:GetChildren()) do
        if obj ~= char and obj:FindFirstChild("HumanoidRootPart") and obj:FindFirstChild("Humanoid") then
            local dist = (playerRoot.Position - obj.HumanoidRootPart.Position).Magnitude
            if dist < shortest and dist <= aimbotDistance then
                shortest = dist
                closest = obj
            end
        end
    end
    return closest
end

local function aimAtTarget(target)
    local char = Player.Character
    if not char then return end
    local playerRoot = char:FindFirstChild("HumanoidRootPart")
    if not playerRoot or not target or not target:FindFirstChild("HumanoidRootPart") then return end
    local targetPos = target.HumanoidRootPart.Position
    local direction
    if aimbotTilt then
        direction = (targetPos - playerRoot.Position).Unit
    else
        direction = Vector3.new(
            targetPos.X - playerRoot.Position.X, 0,
            targetPos.Z - playerRoot.Position.Z
        ).Unit
    end
    playerRoot.CFrame = CFrame.new(playerRoot.Position, playerRoot.Position + direction)
end

local function toggleAimbot(state)
    aimbotActive = state
    if aimbotConnection then aimbotConnection:Disconnect(); aimbotConnection = nil end
    if not state then return end
    aimbotConnection = RunService.RenderStepped:Connect(function()
        if not aimbotActive then return end
        local target = getAimbotTarget()
        if target then aimAtTarget(target) end
    end)
end

local function toggleAimbotTilt(state)
    aimbotTilt = state
end

local function setAimbotDistance(val)
    local n = tonumber(val)
    if n and n > 0 then
        aimbotDistance = n
        notify("Aimbot", "Range set to " .. n, "success")
    else
        notify("Error", "Invalid distance", "error")
    end
end

-- ══════════════════════════════════════════
--  BLACK FLASH SYSTEM
-- ══════════════════════════════════════════
local blackFlashActive = false
local blackFlashCount = 1

local function getNearestCombatTarget()
    local char = Player.Character
    if not char then return nil, math.huge end
    local rootPart = char:FindFirstChild("HumanoidRootPart")
    if not rootPart then return nil, math.huge end
    local nearestRoot = nil
    local nearestDist = math.huge

    for _, p in ipairs(Players:GetPlayers()) do
        if p == Player then continue end
        local c = p.Character
        if not c then continue end
        local r = c:FindFirstChild("HumanoidRootPart")
        if not r then continue end
        local dist = (rootPart.Position - r.Position).Magnitude
        if dist < nearestDist then
            nearestDist = dist
            nearestRoot = r
        end
    end

    for _, obj in ipairs(Workspace:GetDescendants()) do
        if obj:IsA("Model") and obj ~= char then
            local hum = obj:FindFirstChildWhichIsA("Humanoid")
            local r = obj:FindFirstChild("HumanoidRootPart")
            if hum and r and hum.Health > 0 then
                local isPlr = false
                for _, p in ipairs(Players:GetPlayers()) do
                    if p.Character == obj then isPlr = true; break end
                end
                if not isPlr then
                    local dist = (rootPart.Position - r.Position).Magnitude
                    if dist < nearestDist then
                        nearestDist = dist
                        nearestRoot = r
                    end
                end
            end
        end
    end

    return nearestRoot, nearestDist
end

local function fireDivergentFist()
    local char = Player.Character
    if not char then return end
    local moveset = char:FindFirstChild("Moveset")
    if not moveset then return end
    local df = moveset:FindFirstChild("Divergent Fist")
    if not df then return end
    pcall(function()
        ReplicatedStorage.Knit.Knit.Services.DivergentFistService.RE.Activated:FireServer(df)
    end)
end

local function teleportBehindTarget(targetRoot)
    local char = Player.Character
    if not char then return end
    local rootPart = char:FindFirstChild("HumanoidRootPart")
    if not rootPart then return end
    rootPart.CFrame = targetRoot.CFrame * CFrame.new(0, 0, 3)
end

local function executeBlackFlash()
    if blackFlashActive then return end
    blackFlashActive = true
    local count = math.clamp(blackFlashCount, 1, 4)

    local nearestRoot, nearestDist = getNearestCombatTarget()
    if nearestRoot and nearestDist > 20 then
        teleportBehindTarget(nearestRoot)
        task.wait(0.1)
    end

    for i = 1, count do
        fireDivergentFist()
        task.wait(0.3)
        fireDivergentFist()
        nearestRoot = getNearestCombatTarget()
        if nearestRoot then
            teleportBehindTarget(nearestRoot)
        end
        task.wait(0.5)
    end

    blackFlashActive = false
    notify("Black Flash", "Completed " .. count .. " hit(s)", "success")
end

local function setBlackFlashCount(val)
    local n = tonumber(val)
    if n then
        blackFlashCount = math.clamp(math.floor(n), 1, 4)
        notify("Black Flash", "Hit count set to " .. blackFlashCount, "success")
    else
        notify("Error", "Enter a number 1-4", "error")
    end
end

