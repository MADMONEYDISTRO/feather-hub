--  THEME REGISTRY
-- ══════════════════════════════════════════
local themeReg = {}
local function reg(obj, prop, lv, dv)
    table.insert(themeReg, {o=obj, p=prop, l=lv, d=dv})
end
local function applyReg()
    for _, e in ipairs(themeReg) do
        if e.o and e.o.Parent then e.o[e.p] = isDark and e.d or e.l end
    end
end

