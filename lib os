--  THEME SWITCHER
-- ══════════════════════════════════════════
local tabContents = {}
local tabButtonsList = {}
local allThemeApplyButtons = {}  -- track all apply buttons for reset

local function switchTheme(themeName)
    currentTheme = themeName
    colors = colorSchemes[themeName]
    settings.accentColor = colors.accent

    local tweenInfo = getAnimInfo()
    TweenService:Create(mainFrame, tweenInfo, {BackgroundColor3 = colors.background}):Play()
    TweenService:Create(dragBar, tweenInfo, {BackgroundColor3 = colors.dragBar}):Play()
    TweenService:Create(dragCover, tweenInfo, {BackgroundColor3 = colors.dragBar}):Play()
    TweenService:Create(dragTitle, tweenInfo, {TextColor3 = colors.text}):Play()
    TweenService:Create(versionBadge, tweenInfo, {TextColor3 = colors.text, BackgroundColor3 = colors.tabInactive}):Play()
    TweenService:Create(closeButton, tweenInfo, {BackgroundColor3 = colors.tabInactive, TextColor3 = colors.text}):Play()
    TweenService:Create(contentFrame, tweenInfo, {BackgroundColor3 = colors.contentBg}):Play()
    TweenService:Create(logoFrame, tweenInfo, {BackgroundColor3 = colors.accent}):Play()

    for i, tabButton in ipairs(tabButtonsList) do
        if tabContents[i] and tabContents[i].Visible then
            TweenService:Create(tabButton, tweenInfo, {BackgroundColor3 = colors.tabActive, TextColor3 = colors.textActive}):Play()
        else
            TweenService:Create(tabButton, tweenInfo, {BackgroundColor3 = colors.tabInactive, TextColor3 = colors.text}):Play()
        end
    end

    -- Update all apply buttons
    for tName, applyBtn in pairs(allThemeApplyButtons) do
        if tName == themeName then
            applyBtn.Text = "✓ Active"
            applyBtn.BackgroundColor3 = Color3.fromRGB(46, 204, 113)
        else
            applyBtn.Text = "Apply"
            applyBtn.BackgroundColor3 = colorSchemes[tName].accent
        end
    end

    sendNotification("Theme", themeName .. " applied!", colorSchemes[themeName].preview or "")
end

