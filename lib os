        scrollFrame.BorderSizePixel = 0
        scrollFrame.Parent = contentContainer

        local settingsLayout = Instance.new("UIListLayout")
        settingsLayout.Padding = UDim.new(0, 10)
        settingsLayout.Parent = scrollFrame
        settingsLayout:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(function()
            scrollFrame.CanvasSize = UDim2.new(0, 0, 0, settingsLayout.AbsoluteContentSize.Y + 16)
        end)

        local function createToggle(name, desc, defaultState, callback)
            local toggleFrame = Instance.new("Frame")
            toggleFrame.Size = UDim2.new(1, 0, 0, 55)
            toggleFrame.BackgroundColor3 = colors.statsBg
            toggleFrame.BorderSizePixel = 0
            toggleFrame.Parent = scrollFrame
            Instance.new("UICorner", toggleFrame).CornerRadius = UDim.new(0, 8)

            local titleL = Instance.new("TextLabel")
            titleL.Size = UDim2.new(1, -70, 0, 20)
            titleL.Position = UDim2.new(0, 12, 0, 8)
            titleL.Text = name
            titleL.Font = Enum.Font.GothamSemibold
            titleL.TextSize = 13
            titleL.TextColor3 = colors.text
            titleL.TextXAlignment = Enum.TextXAlignment.Left
            titleL.BackgroundTransparency = 1
            titleL.Parent = toggleFrame

            local descL = Instance.new("TextLabel")
            descL.Size = UDim2.new(1, -70, 0, 16)
            descL.Position = UDim2.new(0, 12, 0, 30)
            descL.Text = desc
            descL.Font = Enum.Font.Gotham
            descL.TextSize = 10
            descL.TextColor3 = colors.text
            descL.TextTransparency = 0.5
            descL.TextXAlignment = Enum.TextXAlignment.Left
            descL.BackgroundTransparency = 1
            descL.TextWrapped = true
            descL.Parent = toggleFrame

            local toggleBtn = Instance.new("TextButton")
            toggleBtn.Size = UDim2.new(0, 46, 0, 24)
            toggleBtn.Position = UDim2.new(1, -56, 0, 16)
            toggleBtn.Text = ""
            toggleBtn.BackgroundColor3 = defaultState and colors.accent or colors.border
            toggleBtn.BorderSizePixel = 0
            toggleBtn.AutoButtonColor = false
            toggleBtn.Parent = toggleFrame
            Instance.new("UICorner", toggleBtn).CornerRadius = UDim.new(1, 0)

            local toggleCircle = Instance.new("Frame")
            toggleCircle.Size = UDim2.new(0, 18, 0, 18)
            toggleCircle.Position = defaultState and UDim2.new(0, 25, 0, 3) or UDim2.new(0, 3, 0, 3)
            toggleCircle.BackgroundColor3 = Color3.new(1, 1, 1)
            toggleCircle.BorderSizePixel = 0
            toggleCircle.Parent = toggleBtn
            Instance.new("UICorner", toggleCircle).CornerRadius = UDim.new(1, 0)

            local state = defaultState
            toggleBtn.MouseButton1Click:Connect(function()
                state = not state
                TweenService:Create(toggleBtn, getAnimInfo(), {BackgroundColor3 = state and colors.accent or colors.border}):Play()
                TweenService:Create(toggleCircle, getAnimInfo(), {Position = state and UDim2.new(0, 25, 0, 3) or UDim2.new(0, 3, 0, 3)}):Play()
                if callback then callback(state) end
            end)
            return toggleFrame
        end

        local function createDropdown(name, desc, options, defaultVal, callback)
            local frame = Instance.new("Frame")
            frame.Size = UDim2.new(1, 0, 0, 55)
            frame.BackgroundColor3 = colors.statsBg
            frame.BorderSizePixel = 0
            frame.Parent = scrollFrame
            Instance.new("UICorner", frame).CornerRadius = UDim.new(0, 8)

            local titleL = Instance.new("TextLabel")
            titleL.Size = UDim2.new(1, -120, 0, 20)
            titleL.Position = UDim2.new(0, 12, 0, 8)
            titleL.Text = name
            titleL.Font = Enum.Font.GothamSemibold
            titleL.TextSize = 13
            titleL.TextColor3 = colors.text
            titleL.TextXAlignment = Enum.TextXAlignment.Left
            titleL.BackgroundTransparency = 1
            titleL.Parent = frame

            local descL = Instance.new("TextLabel")
            descL.Size = UDim2.new(1, -120, 0, 16)
            descL.Position = UDim2.new(0, 12, 0, 30)
            descL.Text = desc
            descL.Font = Enum.Font.Gotham
            descL.TextSize = 10
            descL.TextColor3 = colors.text
            descL.TextTransparency = 0.5
            descL.TextXAlignment = Enum.TextXAlignment.Left
            descL.BackgroundTransparency = 1
            descL.Parent = frame

            local dropdown = Instance.new("TextButton")
            dropdown.Size = UDim2.new(0, 105, 0, 30)
            dropdown.Position = UDim2.new(1, -115, 0, 12)
            dropdown.Text = defaultVal
            dropdown.Font = Enum.Font.GothamMedium
            dropdown.TextSize = 11
            dropdown.TextColor3 = colors.text
            dropdown.BackgroundColor3 = colors.buttonBg
            dropdown.BorderSizePixel = 0
            dropdown.AutoButtonColor = false
            dropdown.Parent = frame
            Instance.new("UICorner", dropdown).CornerRadius = UDim.new(0, 6)

            local idx = 1
            for j, v in ipairs(options) do
                if v == defaultVal then idx = j break end
            end

            dropdown.MouseButton1Click:Connect(function()
                idx = (idx % #options) + 1
                dropdown.Text = options[idx]
                if callback then callback(options[idx]) end
            end)
        end

        -- Animation style dropdown
        createDropdown("Animation Style", "Choose UI transition style",
            {"Smooth", "Bounce", "Elastic", "Quick", "Sine", "Back"},
            settings.animationStyle, function(val)
                settings.animationStyle = val
                sendNotification("Animation", "Style: " .. val, "")
            end)

        -- All toggles
        createToggle("Notifications", "Show in-game notifications", settings.notifications, function(state)
            settings.notifications = state
        end)
        createToggle("UI Animations", "Enable smooth UI transitions", settings.animations, function(state)
            settings.animations = state
        end)
        createToggle("Auto-Save Config", "Automatically save settings", settings.autoSave, function(state)
            settings.autoSave = state
        end)
        createToggle("FPS Unlocker", "Unlock frame rate limit", fpsUnlockerEnabled, function(state)
            fpsUnlockerEnabled = state
            setFPSCap(state and 999 or 60)
        end)
        createToggle("FPS Boost (Low GFX)", "Reduce graphics quality for better FPS", lowGfxEnabled, function(state)
            lowGfxEnabled = state
            toggleLowGFX()
        end)
        createToggle("Anti-AFK", "Prevent auto-kick from idling", false, function(state)
            if state then
                local VirtualUser = game:GetService("VirtualUser")
                player.Idled:Connect(function()
                    VirtualUser:CaptureController()
                    VirtualUser:ClickButton2(Vector2.new())
                end)
                sendNotification("Anti-AFK", "Protection enabled", "")
            end
        end)
        createToggle("Rainbow Accent", "Cycle accent color through rainbow", settings.rainbowAccent, function(state)
            settings.rainbowAccent = state
            if state then
                task.spawn(function()
                    local hue = 0
                    while settings.rainbowAccent do
                        hue = (hue + 0.002) % 1
                        local rainbow = Color3.fromHSV(hue, 1, 1)
                        colors.accent = rainbow
                        logoFrame.BackgroundColor3 = rainbow
                        sendNotification("Rainbow", "Mode Active!", "")
                        task.wait(0.03)
                    end
                end)
            end
        end)

    -- ──────────────────────────────────────
    --  THEMES TAB  (massively expanded)
    -- ──────────────────────────────────────
    elseif tab.Name == "Themes" then
        local scrollFrame = Instance.new("ScrollingFrame")
        scrollFrame.Size = UDim2.new(1, -16, 1, -16)
        scrollFrame.Position = UDim2.new(0, 8, 0, 8)
        scrollFrame.BackgroundTransparency = 1
        scrollFrame.ScrollBarThickness = 4
        scrollFrame.ScrollBarImageColor3 = colors.accent
        scrollFrame.BorderSizePixel = 0
        scrollFrame.CanvasSize = UDim2.new(0, 0, 0, 0)
        scrollFrame.Parent = contentContainer

        local themesLayout = Instance.new("UIListLayout")
        themesLayout.Padding = UDim.new(0, 10)
        themesLayout.SortOrder = Enum.SortOrder.LayoutOrder
        themesLayout.Parent = scrollFrame
        themesLayout:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(function()
            scrollFrame.CanvasSize = UDim2.new(0, 0, 0, themesLayout.AbsoluteContentSize.Y + 16)
        end)

        -- ---- Header ----
        local headerFrame = Instance.new("Frame")
        headerFrame.Size = UDim2.new(1, 0, 0, 48)
        headerFrame.BackgroundColor3 = colors.statsBg
        headerFrame.BorderSizePixel = 0
        headerFrame.LayoutOrder = 0
        headerFrame.Parent = scrollFrame
        Instance.new("UICorner", headerFrame).CornerRadius = UDim.new(0, 8)

        local headerTitle = Instance.new("TextLabel")
        headerTitle.Size = UDim2.new(0.65, 0, 0, 26)
        headerTitle.Position = UDim2.new(0, 12, 0, 6)
        headerTitle.Text = "Theme Gallery"
        headerTitle.Font = Enum.Font.GothamBold
        headerTitle.TextSize = 16
        headerTitle.TextColor3 = colors.accent
        headerTitle.TextXAlignment = Enum.TextXAlignment.Left
        headerTitle.BackgroundTransparency = 1
        headerTitle.Parent = headerFrame

        local headerSub = Instance.new("TextLabel")
        headerSub.Size = UDim2.new(0.65, 0, 0, 16)
        headerSub.Position = UDim2.new(0, 12, 0, 28)
        headerSub.Text = "15 themes — click Apply to preview live"
        headerSub.Font = Enum.Font.Gotham
        headerSub.TextSize = 10
        headerSub.TextColor3 = colors.text
        headerSub.TextTransparency = 0.4
        headerSub.TextXAlignment = Enum.TextXAlignment.Left
        headerSub.BackgroundTransparency = 1
        headerSub.Parent = headerFrame

        -- Active theme badge
        local activeBadge = Instance.new("TextLabel")
        activeBadge.Size = UDim2.new(0, 110, 0, 26)
        activeBadge.Position = UDim2.new(1, -118, 0, 11)
        activeBadge.Text = "Active: " .. currentTheme
        activeBadge.Font = Enum.Font.GothamSemibold
        activeBadge.TextSize = 11
        activeBadge.TextColor3 = Color3.new(1, 1, 1)
        activeBadge.BackgroundColor3 = colors.accent
        activeBadge.BorderSizePixel = 0
        activeBadge.Parent = headerFrame
        Instance.new("UICorner", activeBadge).CornerRadius = UDim.new(0, 6)

        -- ---- Category Filter Buttons ----
        local catFrame = Instance.new("Frame")
        catFrame.Size = UDim2.new(1, 0, 0, 32)
        catFrame.BackgroundTransparency = 1
        catFrame.LayoutOrder = 1
        catFrame.Parent = scrollFrame

        local catLayout = Instance.new("UIListLayout")
        catLayout.FillDirection = Enum.FillDirection.Horizontal
        catLayout.Padding = UDim.new(0, 6)
        catLayout.Parent = catFrame

        local categories = {"All", "Dark", "Light", "Neon", "Warm", "Nature"}
        local selectedCategory = "All"
        local catButtons = {}
        local themeCards = {}  -- {card, themeName}

        local function filterCards()
            for _, entry in ipairs(themeCards) do
                local card, tname = entry[1], entry[2]
                local cat = colorSchemes[tname].category
                local show = (selectedCategory == "All") or (cat == selectedCategory)
                card.Visible = show
                if show then
                    card.Size = UDim2.new(1, 0, 0, 145)
                else
                    card.Size = UDim2.new(1, 0, 0, 0)
                end
            end
        end

        for _, catName in ipairs(categories) do
            local catBtn = Instance.new("TextButton")
            catBtn.Size = UDim2.new(0, 62, 1, 0)
            catBtn.Text = catName
            catBtn.Font = Enum.Font.GothamMedium
            catBtn.TextSize = 11
            catBtn.BackgroundColor3 = catName == "All" and colors.tabActive or colors.tabInactive
            catBtn.TextColor3 = catName == "All" and colors.textActive or colors.text
            catBtn.BorderSizePixel = 0
            catBtn.AutoButtonColor = false
            catBtn.Parent = catFrame
            Instance.new("UICorner", catBtn).CornerRadius = UDim.new(0, 6)
            catButtons[catName] = catBtn

            catBtn.MouseButton1Click:Connect(function()
                selectedCategory = catName
                for _, cb in pairs(catButtons) do
                    TweenService:Create(cb, getAnimInfo(), {
                        BackgroundColor3 = colors.tabInactive,
                        TextColor3 = colors.text
                    }):Play()
                end
                TweenService:Create(catBtn, getAnimInfo(), {
                    BackgroundColor3 = colors.tabActive,
                    TextColor3 = colors.textActive
                }):Play()
                filterCards()
            end)
        end

        -- ---- Theme Cards ----
        local themeOrder = {
            "Dark", "Light", "Obsidian", "MidnightBlue", "ArcticIce",
            "DeepPurple", "VaporWave", "Cyberpunk", "MatrixGreen", "NeonRed",
            "ForestGreen", "OceanBreeze", "RoseGold", "SunsetOrange", "GoldenHour"
        }

        for layoutOrder, themeName in ipairs(themeOrder) do
            local theme = colorSchemes[themeName]

            local themeCard = Instance.new("Frame")
            themeCard.Size = UDim2.new(1, 0, 0, 145)
            themeCard.BackgroundColor3 = colors.statsBg
            themeCard.BorderSizePixel = 0
            themeCard.LayoutOrder = layoutOrder + 10
            themeCard.Parent = scrollFrame
            Instance.new("UICorner", themeCard).CornerRadius = UDim.new(0, 8)

            table.insert(themeCards, {themeCard, themeName})

            -- === LEFT: LIVE PREVIEW PANEL ===
            local previewContainer = Instance.new("Frame")
            previewContainer.Size = UDim2.new(0, 155, 1, -16)
            previewContainer.Position = UDim2.new(0, 8, 0, 8)
            previewContainer.BackgroundTransparency = 1
            previewContainer.Parent = themeCard
            previewContainer.ClipsDescendants = true

            createThemePreview(themeName, previewContainer)

            -- === RIGHT: INFO + CONTROLS ===
            local infoPanel = Instance.new("Frame")
            infoPanel.Size = UDim2.new(1, -175, 1, -16)
            infoPanel.Position = UDim2.new(0, 168, 0, 8)
            infoPanel.BackgroundTransparency = 1
            infoPanel.Parent = themeCard

            -- Theme name
            local nameLabel = Instance.new("TextLabel")
            nameLabel.Size = UDim2.new(1, 0, 0, 22)
            nameLabel.Position = UDim2.new(0, 0, 0, 0)
            nameLabel.Text = theme.preview .. "  " .. themeName
            nameLabel.Font = Enum.Font.GothamBold
            nameLabel.TextSize = 14
            nameLabel.TextColor3 = theme.accent
            nameLabel.TextXAlignment = Enum.TextXAlignment.Left
            nameLabel.BackgroundTransparency = 1
            nameLabel.Parent = infoPanel

            -- Category pill
            local catPill = Instance.new("TextLabel")
            catPill.Size = UDim2.new(0, 48, 0, 16)
            catPill.Position = UDim2.new(0, 0, 0, 24)
            catPill.Text = theme.category
            catPill.Font = Enum.Font.GothamMedium
            catPill.TextSize = 9
            catPill.TextColor3 = Color3.new(1, 1, 1)
            catPill.BackgroundColor3 = theme.accent
            catPill.BackgroundTransparency = 0.3
            catPill.BorderSizePixel = 0
            catPill.Parent = infoPanel
            Instance.new("UICorner", catPill).CornerRadius = UDim.new(1, 0)

            -- Color swatches row
            local swatchRow = Instance.new("Frame")
            swatchRow.Size = UDim2.new(1, 0, 0, 18)
            swatchRow.Position = UDim2.new(0, 0, 0, 44)
            swatchRow.BackgroundTransparency = 1
            swatchRow.Parent = infoPanel

            local swatchLayout = Instance.new("UIListLayout")
            swatchLayout.FillDirection = Enum.FillDirection.Horizontal
            swatchLayout.Padding = UDim.new(0, 4)
            swatchLayout.Parent = swatchRow

            local swatchColors = {
                theme.background, theme.accent, theme.tabActive,
                theme.buttonBg, theme.text
            }
            local swatchLabels = {"BG", "Accent", "Tab", "Button", "Text"}

            for si, sc in ipairs(swatchColors) do
                local swatch = Instance.new("Frame")
                swatch.Size = UDim2.new(0, 16, 0, 16)
                swatch.BackgroundColor3 = sc
                swatch.BorderSizePixel = 0
                swatch.Parent = swatchRow
                Instance.new("UICorner", swatch).CornerRadius = UDim.new(0, 4)

                -- Tooltip on hover
                local tip = Instance.new("TextLabel")
                tip.Size = UDim2.new(0, 42, 0, 14)
                tip.Position = UDim2.new(0, -13, 1, 2)
                tip.Text = swatchLabels[si]
                tip.Font = Enum.Font.Gotham
                tip.TextSize = 8
                tip.TextColor3 = colors.text
                tip.BackgroundColor3 = colors.statsBg
                tip.BorderSizePixel = 0
                tip.Visible = false
                tip.ZIndex = 10
                tip.Parent = swatch
                Instance.new("UICorner", tip).CornerRadius = UDim.new(0, 3)

                swatch.MouseEnter:Connect(function() tip.Visible = true end)
                swatch.MouseLeave:Connect(function() tip.Visible = false end)
            end

            -- Apply Button
            local applyBtn = Instance.new("TextButton")
            applyBtn.Size = UDim2.new(1, 0, 0, 30)
            applyBtn.Position = UDim2.new(0, 0, 1, -34)
            applyBtn.Text = currentTheme == themeName and "✓  Active" or "Apply Theme"
            applyBtn.Font = Enum.Font.GothamSemibold
            applyBtn.TextSize = 12
            applyBtn.TextColor3 = Color3.new(1, 1, 1)
            applyBtn.BackgroundColor3 = currentTheme == themeName and Color3.fromRGB(46, 204, 113) or theme.accent
            applyBtn.BorderSizePixel = 0
            applyBtn.AutoButtonColor = false
            applyBtn.Parent = infoPanel
            Instance.new("UICorner", applyBtn).CornerRadius = UDim.new(0, 6)

            -- Store reference for theme switcher
            allThemeApplyButtons[themeName] = applyBtn

            -- Hover pulse on apply button
            applyBtn.MouseEnter:Connect(function()
                if currentTheme ~= themeName then
                    TweenService:Create(applyBtn, getAnimInfo(), {
                        Size = UDim2.new(1, 0, 0, 32),
                        Position = UDim2.new(0, 0, 1, -36)
                    }):Play()
                end
            end)
            applyBtn.MouseLeave:Connect(function()
                TweenService:Create(applyBtn, getAnimInfo(), {
                    Size = UDim2.new(1, 0, 0, 30),
                    Position = UDim2.new(0, 0, 1, -34)
                }):Play()
            end)

            applyBtn.MouseButton1Click:Connect(function()
                switchTheme(themeName)
                -- Update active badge
                activeBadge.Text = "Active: " .. themeName
                activeBadge.BackgroundColor3 = colorSchemes[themeName].accent
            end)
        end

        -- ---- Quick Randomize Button ----
        local randomFrame = Instance.new("Frame")
        randomFrame.Size = UDim2.new(1, 0, 0, 48)
        randomFrame.BackgroundColor3 = colors.statsBg
        randomFrame.BorderSizePixel = 0
        randomFrame.LayoutOrder = 200
        randomFrame.Parent = scrollFrame
        Instance.new("UICorner", randomFrame).CornerRadius = UDim.new(0, 8)

        local randomBtn = Instance.new("TextButton")
        randomBtn.Size = UDim2.new(1, -16, 0, 34)
        randomBtn.Position = UDim2.new(0, 8, 0, 7)
        randomBtn.Text = "Randomize Theme"
        randomBtn.Font = Enum.Font.GothamBold
        randomBtn.TextSize = 13
        randomBtn.TextColor3 = Color3.new(1, 1, 1)
        randomBtn.BackgroundColor3 = colors.accent
        randomBtn.BorderSizePixel = 0
        randomBtn.AutoButtonColor = false
        randomBtn.Parent = randomFrame
        Instance.new("UICorner", randomBtn).CornerRadius = UDim.new(0, 8)

        randomBtn.MouseEnter:Connect(function()
            TweenService:Create(randomBtn, getAnimInfo(), {BackgroundTransparency = 0.2}):Play()
        end)
        randomBtn.MouseLeave:Connect(function()
            TweenService:Create(randomBtn, getAnimInfo(), {BackgroundTransparency = 0}):Play()
        end)
        randomBtn.MouseButton1Click:Connect(function()
            local randomTheme = themeOrder[math.random(1, #themeOrder)]
            switchTheme(randomTheme)
            activeBadge.Text = "Active: " .. randomTheme
            activeBadge.BackgroundColor3 = colorSchemes[randomTheme].accent
        end)
    end

    tabContents[i] = contentContainer
    tabButtonsList[i] = tabButton

    tabButton.MouseEnter:Connect(function()
        if not contentContainer.Visible and settings.animations then
            TweenService:Create(tabButton, getAnimInfo(), {BackgroundColor3 = colors.buttonHover}):Play()
        end
    end)
    tabButton.MouseLeave:Connect(function()
        if not contentContainer.Visible and settings.animations then
            TweenService:Create(tabButton, getAnimInfo(), {BackgroundColor3 = colors.tabInactive}):Play()
        end
    end)
    tabButton.MouseButton1Click:Connect(function()
        for _, c in ipairs(tabContents) do c.Visible = false end
        contentContainer.Visible = true
        for _, btn in ipairs(tabButtonsList) do
            if btn ~= tabButton then
                TweenService:Create(btn, getAnimInfo(), {BackgroundColor3 = colors.tabInactive, TextColor3 = colors.text}):Play()
            end
        end
        TweenService:Create(tabButton, getAnimInfo(), {BackgroundColor3 = colors.tabActive, TextColor3 = colors.textActive}):Play()
    end)
end

