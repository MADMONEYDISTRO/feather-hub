local espContainer = ESP.new({ArrowEdgePadding=50, ArrowShowDistanceText=false, Parent=Player:WaitForChild("PlayerGui")})
local ftf = {players=false, pcs=false, pods=false, exits=false}

local function getBeast()
    for _,p in ipairs(Players:GetPlayers()) do
        local ok, ch = pcall(function() return p.Character end)
        if ok and ch and ch:FindFirstChild("BeastPowers") then return p end
    end
    return nil
end

local function reloadESP()
    espContainer:ClearAllGroups()
    if ftf.players then
        for _,p in ipairs(Players:GetPlayers()) do
            if p ~= Player then
                local ch = p.Character
                if ch then
                    if p == getBeast() then
                        espContainer:Add(ch, {AccentColor=Color3.new(1,0,0), ArrowShow=true, ArrowMinDistance=999999, ArrowSize=UDim2.new(0,40,0,40), LabelText="Beast", ShowLabel=true, GroupName="players"})
                    else
                        espContainer:Add(ch, {AccentColor=Color3.new(0,1,0), ArrowShow=false, ShowLabel=false, GroupName="players"})
                    end
                end
            end
        end
    end
    if ftf.pcs then
        for _,obj in ipairs(workspace:GetDescendants()) do
            pcall(function()
                if obj.Name == "ComputerTable" and obj:FindFirstChild("Screen") then
                    if obj.Screen.Color == Color3.fromRGB(40,127,71) then
                        espContainer:Add(obj, {AccentColor=Color3.new(0.133,0.333,0.008), ArrowShow=false, ShowLabel=false, GroupName="pcs"})
                    else
                        espContainer:Add(obj, {AccentColor=Color3.new(0,0.37,1), ArrowShow=true, ArrowMinDistance=99999, ArrowSize=UDim2.new(0,10,0,10), ShowLabel=false, GroupName="pcs"})
                    end
                end
            end)
        end
    end
    if ftf.pods then
        for _,obj in ipairs(workspace:GetDescendants()) do
            if obj.Name == "FreezePod" then
                espContainer:Add(obj, {AccentColor=Color3.new(0,1,1), ArrowShow=false, ShowLabel=false, GroupName="pods"})
            end
        end
    end
    if ftf.exits then
        for _,obj in ipairs(workspace:GetDescendants()) do
            if obj.Name == "ExitDoor" then
                espContainer:Add(obj, {AccentColor=Color3.new(1,1,0), ArrowShow=false, ShowLabel=false, GroupName="exits"})
            end
        end
    end
end

