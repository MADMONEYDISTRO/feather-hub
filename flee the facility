local ESP = {}
ESP.__index = ESP
ESP.Groups = {}
ESP.TargetIndex = {}

function ESP.new(opts)
    local self = setmetatable({}, ESP)
    opts = opts or {}
    self.ScreenGui = Instance.new("ScreenGui")
    self.ScreenGui.Name = "FeatherESP"
    self.ScreenGui.IgnoreGuiInset = true
    self.ScreenGui.ResetOnSpawn = false
    self.ScreenGui.Parent = opts.Parent or Player:WaitForChild("PlayerGui")
    self.Indicators = {}
    self.Settings = {
        ArrowEdgePadding = opts.ArrowEdgePadding or 50,
        ArrowSize = opts.ArrowSize or UDim2.new(0,30,0,30),
        ArrowImage = opts.ArrowImage or "rbxassetid://97136202386756",
        ArrowShowDistanceText = opts.ArrowShowDistanceText ~= false,
        FillTransparency = opts.FillTransparency or 0.7,
    }
    -- Arrow template
    self.ArrowTemplate = Instance.new("ImageLabel")
    self.ArrowTemplate.Name = "ArrowTpl"
    self.ArrowTemplate.Size = self.Settings.ArrowSize
    self.ArrowTemplate.AnchorPoint = Vector2.new(0.5,0.5)
    self.ArrowTemplate.BackgroundTransparency = 1
    self.ArrowTemplate.Image = self.Settings.ArrowImage
    self.ArrowTemplate.Visible = false
    self.ArrowTemplate.Parent = self.ScreenGui
    local sc = Instance.new("UIScale"); sc.Scale = 0; sc.Name = "Scaler"; sc.Parent = self.ArrowTemplate

    self._conn = RS.RenderStepped:Connect(function() pcall(function() self:_update() end) end)
    return self
end

function ESP:AddGroup(n)
    if not ESP.Groups[n] then ESP.Groups[n] = {enabled=true, targets={}} end
    return ESP.Groups[n]
end

function ESP:RemoveGroup(n)
    local g = ESP.Groups[n]
    if not g then return end
    for _,t in ipairs(g.targets) do
        self:Remove(t)
    end
    ESP.Groups[n] = nil
end

function ESP:ClearAllGroups()
    local names = {}
    for n in pairs(ESP.Groups) do table.insert(names, n) end
    for _, n in ipairs(names) do self:RemoveGroup(n) end
end

function ESP:Add(target, opts)
    if not target then return end
    opts = opts or {}
    -- Remove existing first
    if self.Indicators[target] then self:Remove(target) end

    local hl = Instance.new("Highlight")
    hl.Adornee = target
    hl.FillTransparency = opts.FillTransparency or self.Settings.FillTransparency
    hl.FillColor = opts.AccentColor or Color3.new(1,1,0)
    hl.OutlineColor = opts.AccentColor or Color3.new(1,1,0)
    hl.OutlineTransparency = 0
    hl.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
    hl.Parent = self.ScreenGui

    local arrow, scaler, distLabel
    if opts.ArrowShow then
        arrow = self.ArrowTemplate:Clone()
        arrow.ImageColor3 = opts.AccentColor or Color3.new(1,1,0)
        arrow.Visible = true
        arrow.Parent = self.ScreenGui
        scaler = arrow:FindFirstChild("Scaler")
        if self.Settings.ArrowShowDistanceText then
            distLabel = Instance.new("TextLabel")
            distLabel.Name = "Dist"
            distLabel.AnchorPoint = Vector2.new(0.5,0)
            distLabel.BackgroundTransparency = 1
            distLabel.Font = Enum.Font.Montserrat
            distLabel.TextSize = 18
            distLabel.TextColor3 = opts.AccentColor or Color3.new(1,1,0)
            distLabel.Size = UDim2.new(0,60,0,20)
            distLabel.Parent = arrow
        end
    end

    local label
    if opts.ShowLabel then
        label = Instance.new("BillboardGui")
        label.AlwaysOnTop = true
        label.MaxDistance = 99999
        label.Size = UDim2.new(0,70,0,70)
        label.StudsOffset = Vector3.new(0,2,0)
        label.Adornee = target
        label.Parent = self.ScreenGui
        local tl = Instance.new("TextLabel")
        tl.Size = UDim2.new(1,0,1,0)
        tl.AnchorPoint = Vector2.new(0.5,0.5)
        tl.Position = UDim2.new(0.5,0,0.5,0)
        tl.BackgroundTransparency = 1
        tl.Font = Enum.Font.SourceSansBold
        tl.TextScaled = true
        tl.TextColor3 = opts.AccentColor or Color3.new(1,1,0)
        tl.Text = opts.LabelText or "?"
        tl.Parent = label
        Instance.new("UIStroke", tl)
    end

    self.Indicators[target] = {Highlight=hl, Arrow=arrow, Scaler=scaler, DistanceLabel=distLabel, Label=label, Options=opts}

    if opts.GroupName then
        local g = self:AddGroup(opts.GroupName)
        if not table.find(g.targets, target) then table.insert(g.targets, target) end
    end
end

function ESP:Remove(t)
    local ind = self.Indicators[t]
    if not ind then return end
    pcall(function() if ind.Highlight then ind.Highlight.Adornee = nil; ind.Highlight:Destroy() end end)
    pcall(function() if ind.Arrow then ind.Arrow:Destroy() end end)
    pcall(function() if ind.Label then ind.Label.Adornee = nil; ind.Label:Destroy() end end)
    self.Indicators[t] = nil
end

function ESP:_update()
    local cam = workspace.CurrentCamera
    if not cam then return end
    local vp = cam.ViewportSize
    local vpX, vpY = vp.X, vp.Y
    local pad = self.Settings.ArrowEdgePadding
    local toRemove = {}

    for target, ind in pairs(self.Indicators) do
        local ok = pcall(function()
            local arrow = ind.Arrow
            local scaler = ind.Scaler
            if not arrow or not scaler then return end

            -- Check target still exists
            if not target or not target.Parent then table.insert(toRemove, target); return end

            -- Get position
            local pos3
            if target:IsA("Model") then
                local pp = target.PrimaryPart
                if pp then pos3 = pp.Position else local bp = target:FindFirstChildWhichIsA("BasePart"); if bp then pos3 = bp.Position end end
            elseif target:IsA("BasePart") then
                pos3 = target.Position
            end
            if not pos3 then return end

            local sp, onScreen = cam:WorldToViewportPoint(pos3)
            local dist = (cam.CFrame.Position - pos3).Magnitude
            local minDist = ind.Options.ArrowMinDistance or 0

            -- If on screen, hide arrow
            if onScreen and dist > minDist then
                scaler.Scale = 0; return
            end

            -- Off screen — position arrow at edge
            scaler.Scale = 1
            local hW, hH = (vpX-pad*2)/2, (vpY-pad*2)/2
            local objLocal = cam.CFrame:VectorToObjectSpace(pos3 - cam.CFrame.Position)
            local r2 = Vector2.new(objLocal.X, objLocal.Y)
            if r2.Magnitude < 0.001 then scaler.Scale = 0; return end
            local d2 = r2.Unit

            local cX = math.clamp(sp.X, pad, vpX-pad)
            local cY = math.clamp(sp.Y, pad, vpY-pad)
            if cX == sp.X and cY == sp.Y and onScreen then scaler.Scale = 0; return end

            local ev
            local absX, absY = math.max(math.abs(d2.X), 0.001), math.max(math.abs(d2.Y), 0.001)
            if absY * hW > absX * hH then ev = d2 * (hH / absY) else ev = d2 * (hW / absX) end

            arrow.Position = UDim2.fromOffset(vpX/2 + ev.X, vpY/2 - ev.Y)
            arrow.Rotation = math.deg(math.atan2(d2.X, d2.Y))

            if ind.DistanceLabel then
                ind.DistanceLabel.Text = string.format("%dm", math.round(dist))
                ind.DistanceLabel.Position = UDim2.new(0.5, 0, 0, (ind.Options.ArrowSize and ind.Options.ArrowSize.Y.Offset or 30) + 16)
            end
        end)
        if not ok then table.insert(toRemove, target) end
    end

    for _, t in ipairs(toRemove) do self:Remove(t) end
end

function ESP:Destroy()
    if self._conn then self._conn:Disconnect() end
    self:ClearAllGroups()
    for t in pairs(self.Indicators) do self:Remove(t) end
    pcall(function() self.ScreenGui:Destroy() end)
end

