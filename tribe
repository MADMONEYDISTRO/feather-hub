local function SetTracer(state, parent, color)
    local origin = eu.Character.HumanoidRootPart:FindFirstChild("Origin")
    if not origin then
        origin = Instance.new("Attachment")
        origin.Name = "Origin"
        origin.Parent = eu.Character.HumanoidRootPart
    end
    
    local beam = parent:FindFirstChild("Tracer")
    if beam then
        if beam.Enabled ~= state then beam.Enabled = state end
        local seq = ColorSequence.new(color)
        if beam.Color ~= seq then beam.Color = seq end
        if beam.Attachment0 ~= origin then beam.Attachment0 = origin end
        return
    end
    
    local attachment1 = Instance.new("Attachment", parent)
    beam = Instance.new("Beam")
    beam.Name = "Tracer"
    beam.Attachment0 = origin
    beam.Attachment1 = attachment1
    beam.Color = ColorSequence.new(color)
    beam.FaceCamera = true
    beam.Width0 = 0.15
    beam.Width1 = 0.15
    beam.Enabled = state
    beam.Parent = parent
end

local function SetHighlight(state, parent)
    local name = "Triangulare_Highlight"
    local color = Color3.fromRGB(255, 0, 0)
    
    local existing = parent:FindFirstChild(name)
    if existing and existing.Enabled ~= state then
        existing.Enabled = state
        return
    end

    local highlight = parent:FindFirstChild(name) or Instance.new("Highlight")
    highlight.Name = name
    highlight.Parent = parent
    highlight.FillColor = color
    highlight.OutlineColor = Color3.new(1, 1, 1)
    highlight.FillTransparency = 0.5
    highlight.OutlineTransparency = 0.6
    highlight.Adornee = parent
end

local function SetEat(char)
    Gokka:Connect({
        Name = "AutoEat",
        Signal = eu.Character.Humanoid.HealthChanged,
        Callback = function(vidaAtual)
            local SafeMode = not Settings.Blatant
            if not getgenv().AutoEat or vidaAtual == 1 or (SafeMode and Settings.Eating) then return end
            
            char = char or eu.Character
            local humanoid = char and char:FindFirstChild("Humanoid")
            if not humanoid then return end
            if vidaAtual >= humanoid.MaxHealth then return end
            
            local function ScanFoodIn(where)
                for _, f in ipairs(eu[where]:GetChildren()) do
                    if f:FindFirstChild("FoodScripts") and f:FindFirstChild("Stats") then
                        return f
                    end
                end
            end
            
            local food = eu.Backpack:FindFirstChild(Settings.Food) or eu.Character:FindFirstChild(Settings.Food)
            if not food then
                local f = ScanFoodIn("Backpack") or ScanFoodIn("Character")
                if not f then return end
                Settings.Food, food = f.Name, f
            end
            
            if char.Resources:GetAttribute("Food") < food.Stats:GetAttribute("FoodCost") then return end
            
            if SafeMode then Settings.Eating = true end
            food.FoodScripts.Eat:InvokeServer()
            if SafeMode then
                task.wait(0.01)
                Settings.Eating = false
            end
        end
    })
end

-- AutoSwipe (unchanged)
local function AutoSwipe()
    task.spawn(function()
        local IsDescendantOf = game.IsDescendantOf
        local hooks = {}
        hooks.__namecall = hookmetamethod(game, "__namecall", function(self, ...)
            if getnamecallmethod() ~= "FireServer" or not (self.ClassName == "RemoteEvent" and self.Name == "Swing") then
                return hooks.__namecall(self, ...)
            end
            
            local arg1, arg2 = ...
            if not arg1 or not arg2 or typeof(arg1) ~= "CFrame" or type(arg2) ~= "table" then
                return hooks.__namecall(self, ...)
            end
        
            local firstObj = arg2[1]
            if not firstObj then return hooks.__namecall(self, ...) end
            
            if IsDescendantOf(firstObj, workspace.Characters) or IsDescendantOf(firstObj, workspace.Resources) then
                ReplicatedStorage.Remotes.Hats.EquipHat:FireServer("Dark Hood")
                return hooks.__namecall(self, ...)
            end
            
            return hooks.__namecall(self, ...)
        end)
    end)
end

