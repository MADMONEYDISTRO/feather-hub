    lbl.TextSize = 9
    lbl.TextColor3 = T.text
    lbl.TextXAlignment = Enum.TextXAlignment.Left
    lbl.BackgroundTransparency = 1
    lbl.Parent = row

    local dropdownBtn = Instance.new("TextButton")
    dropdownBtn.Size = UDim2.new(0, 120, 0, 26)
    dropdownBtn.Position = UDim2.new(1, -130, 0.5, -13)
    dropdownBtn.Text = default
    dropdownBtn.Font = Enum.Font.GothamMedium
    dropdownBtn.TextSize = 8
    dropdownBtn.TextColor3 = T.text
    dropdownBtn.BackgroundColor3 = T.inputBg or T.dim
    dropdownBtn.BorderSizePixel = 0
    dropdownBtn.AutoButtonColor = false
    dropdownBtn.Parent = row
    Instance.new("UICorner", dropdownBtn).CornerRadius = UDim.new(0, 6)

    local menu = Instance.new("Frame")
    menu.Size = UDim2.new(0, 120, 0, 0)
    menu.BackgroundColor3 = T.card
    menu.BorderSizePixel = 0
    menu.Visible = false
    menu.ZIndex = 50
    menu.Parent = sg
    Instance.new("UICorner", menu).CornerRadius = UDim.new(0, 6)
    local menuLayout = Instance.new("UIListLayout", menu)
    menuLayout.SortOrder = Enum.SortOrder.LayoutOrder
    menuLayout.Padding = UDim.new(0, 2)

    local function updateMenu()
        for _, child in pairs(menu:GetChildren()) do if child:IsA("TextButton") then child:Destroy() end end
        for _, opt in ipairs(options) do
            local btn = Instance.new("TextButton")
            btn.Size = UDim2.new(1, 0, 0, 22)
            btn.Text = opt
            btn.Font = Enum.Font.GothamMedium
            btn.TextSize = 7
            btn.TextColor3 = T.text
            btn.BackgroundColor3 = T.dim
            btn.BorderSizePixel = 0
            btn.AutoButtonColor = false
            btn.Parent = menu
            btn.MouseButton1Click:Connect(function()
                dropdownBtn.Text = opt
                menu.Visible = false
                callback(opt)
            end)
        end
        menu.Size = UDim2.new(0, 120, 0, #options * 24)
        local btnAbs = dropdownBtn.AbsolutePosition
        local btnSize = dropdownBtn.AbsoluteSize
        local menuHeight = #options * 24
        local screenSize = Workspace.CurrentCamera.ViewportSize
        local posX = btnAbs.X
        local posY = btnAbs.Y + btnSize.Y + 2
        if posY + menuHeight > screenSize.Y - 20 then
            posY = btnAbs.Y - menuHeight - 2
        end
        if posX + 120 > screenSize.X then
            posX = screenSize.X - 120 - 5
        end
        menu.Position = UDim2.new(0, posX, 0, posY)
    end

    dropdownBtn.MouseButton1Click:Connect(function()
        if menu.Visible then menu.Visible = false else updateMenu(); menu.Visible = true end
    end)
    UserInputService.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 and menu.Visible then
            task.wait(0.05)
            local mousePos = UserInputService:GetMouseLocation()
            local menuAbs = menu.AbsolutePosition
            local menuSize = menu.AbsoluteSize
            if not (mousePos.X >= menuAbs.X and mousePos.X <= menuAbs.X + menuSize.X and
                    mousePos.Y >= menuAbs.Y and mousePos.Y <= menuAbs.Y + menuSize.Y) then
                menu.Visible = false
            end
        end
    end)
    return row
end

local function makeSlider(card, order, text, minVal, maxVal, default, rounding, callback)
    local row = makeRow(card, order, false, 60)
    local lbl = Instance.new("TextLabel")
    lbl.Size = UDim2.new(1, -24, 0, 20)
    lbl.Position = UDim2.new(0, 14, 0, 6)
    lbl.Text = text .. ": " .. default
    lbl.Font = Enum.Font.GothamSemibold
    lbl.TextSize = 9
    lbl.TextColor3 = T.text
    lbl.TextXAlignment = Enum.TextXAlignment.Left
    lbl.BackgroundTransparency = 1
    lbl.Parent = row

    local sliderFrame = Instance.new("Frame")
    sliderFrame.Size = UDim2.new(1, -28, 0, 4)
    sliderFrame.Position = UDim2.new(0, 14, 0, 32)
    sliderFrame.BackgroundColor3 = T.dim
    sliderFrame.BorderSizePixel = 0
    sliderFrame.Parent = row
    Instance.new("UICorner", sliderFrame).CornerRadius = UDim.new(1, 0)

    local fill = Instance.new("Frame")
    fill.Size = UDim2.new((default - minVal) / (maxVal - minVal), 0, 1, 0)
    fill.BackgroundColor3 = T.accent
    fill.BorderSizePixel = 0
    fill.Parent = sliderFrame
    Instance.new("UICorner", fill).CornerRadius = UDim.new(1, 0)

    local knob = Instance.new("TextButton")
    knob.Size = UDim2.new(0, 14, 0, 14)
    knob.Position = UDim2.new((default - minVal) / (maxVal - minVal), -7, 0.5, -7)
    knob.BackgroundColor3 = Color3.new(1,1,1)
    knob.BorderSizePixel = 0
    knob.Text = ""
    knob.AutoButtonColor = false
    knob.Parent = sliderFrame
    Instance.new("UICorner", knob).CornerRadius = UDim.new(1, 0)

    local draggingSlider = false
    local function updateSlider(input)
        local relativeX = math.clamp((input.Position.X - sliderFrame.AbsolutePosition.X) / sliderFrame.AbsoluteSize.X, 0, 1)
        local val = minVal + (maxVal - minVal) * relativeX
        if rounding and rounding > 0 then val = math.floor(val / rounding + 0.5) * rounding end
        lbl.Text = text .. ": " .. val
        fill.Size = UDim2.new(relativeX, 0, 1, 0)
        knob.Position = UDim2.new(relativeX, -7, 0.5, -7)
        callback(val)
    end

    knob.MouseButton1Down:Connect(function()
        draggingSlider = true
    end)
    UserInputService.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then draggingSlider = false end
    end)
    UserInputService.InputChanged:Connect(function(input)
        if draggingSlider and input.UserInputType == Enum.UserInputType.MouseMovement then
            updateSlider(input)
        end
    end)
    sliderFrame.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            updateSlider(input)
            draggingSlider = true
        end
    end)
    return row
end

