-- Unicorn ESP (Drawings)
local unicornESPActive = false
local unicornESPList = {}
local unicornESPConn = nil
local function createUnicornDrawings(model)
    local hrp = model:FindFirstChild("HumanoidRootPart")
    if not hrp then return end
    local circle = Drawing.new("Circle")
    circle.Color = Color3.fromRGB(255,0,0)
    circle.Radius = 10
    circle.Thickness = 2
    circle.Filled = false
    circle.Visible = true
    local txt = Drawing.new("Text")
    txt.Text = "Unicorn"
    txt.Size = 16
    txt.Color = Color3.fromRGB(255,255,255)
    txt.Center = true
    txt.Outline = true
    txt.OutlineColor = Color3.fromRGB(0,0,0)
    txt.Font = 2
    txt.Visible = true
    table.insert(unicornESPList, {model = model, circle = circle, text = txt})
end
local function refreshUnicornESP()
    for _, entry in ipairs(unicornESPList) do
        entry.circle:Remove()
        entry.text:Remove()
    end
    unicornESPList = {}
    for _, obj in ipairs(Workspace:GetDescendants()) do
        if obj.Name == "Unicorn" and obj:IsA("Model") and obj:FindFirstChild("HumanoidRootPart") then
            createUnicornDrawings(obj)
        end
    end
end
local function startUnicornESP()
    refreshUnicornESP()
    if unicornESPConn then unicornESPConn:Disconnect() end
    unicornESPConn = RunService.RenderStepped:Connect(function()
        for _, entry in ipairs(unicornESPList) do
            local hrp = entry.model:FindFirstChild("HumanoidRootPart")
            if hrp then
                local pos, onScreen = Camera:WorldToViewportPoint(hrp.Position)
                if onScreen then
                    entry.circle.Position = Vector2.new(pos.X, pos.Y)
                    entry.circle.Visible = true
                    entry.text.Position = Vector2.new(pos.X, pos.Y - 15)
                    entry.text.Visible = true
                else
                    entry.circle.Visible = false
                    entry.text.Visible = false
                end
            else
                entry.circle.Visible = false
                entry.text.Visible = false
            end
        end
    end)
    unicornESPActive = true
end
local function stopUnicornESP()
    if unicornESPConn then unicornESPConn:Disconnect() end
    for _, entry in ipairs(unicornESPList) do
        entry.circle:Remove()
        entry.text:Remove()
    end
    unicornESPList = {}
    unicornESPActive = false
end
local function setUnicornESP(state)
    if state then
        startUnicornESP()
        -- refresh periodically
        task.spawn(function()
            while unicornESPActive do
                task.wait(2)
                refreshUnicornESP()
            end
        end)
    else
        stopUnicornESP()
    end
end

