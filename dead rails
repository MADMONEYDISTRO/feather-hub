-- ESP Items/Mods/Zombies/Train
getgenv().espEntity = false
getgenv().esptrain = false
local espObjects = {}

local function addESP(model, color)
    if model and model.PrimaryPart and not espObjects[model] then
        local hl = Instance.new("Highlight")
        hl.Name = "ESP_Highlight"
        hl.Adornee = model
        hl.FillColor = color
        hl.OutlineColor = color
        hl.Parent = model
        local bill = Instance.new("BillboardGui")
        bill.Name = "ESP_Billboard"
        bill.Adornee = model.PrimaryPart
        bill.Size = UDim2.new(0, 200, 0, 50)
        bill.StudsOffset = Vector3.new(0, 5, 0)
        bill.AlwaysOnTop = true
        bill.Parent = model
        local label = Instance.new("TextLabel", bill)
        label.Text = model.Name
        label.Size = UDim2.new(1,0,1,0)
        label.TextColor3 = color
        label.BackgroundTransparency = 1
        label.TextSize = 7
        espObjects[model] = {Highlight = hl, Billboard = bill}
    end
end

local function clearESP()
    for model, data in pairs(espObjects) do
        if data.Highlight then data.Highlight:Destroy() end
        if data.Billboard then data.Billboard:Destroy() end
    end
    espObjects = {}
end

local function scanForESPEntities()
    clearESP()
    -- RuntimeItems
    local runtime = Workspace:FindFirstChild("RuntimeItems")
    if runtime then
        for _, obj in ipairs(runtime:GetDescendants()) do
            if obj:IsA("Model") then addESP(obj, Color3.new(1,0,0)) end
        end
    end
    -- Animals
    local baseplates = Workspace:FindFirstChild("Baseplates")
    if baseplates and #baseplates:GetChildren() >= 2 then
        local center = baseplates:GetChildren()[2]
        local animals = center and center:FindFirstChild("CenterBaseplate") and center.CenterBaseplate:FindFirstChild("Animals")
        if animals then
            for _, obj in ipairs(animals:GetDescendants()) do
                if obj:IsA("Model") then addESP(obj, Color3.new(1,0,1)) end
            end
        end
    end
    -- NightEnemies
    local night = Workspace:FindFirstChild("NightEnemies")
    if night then
        for _, obj in ipairs(night:GetDescendants()) do
            if obj:IsA("Model") then addESP(obj, Color3.new(0,0,1)) end
        end
    end
    -- DestroyedHouse Zombies
    local randBuild = Workspace:FindFirstChild("RandomBuildings")
    if randBuild then
        local house = randBuild:FindFirstChild("DestroyedHouse")
        local zombiePart = house and house:FindFirstChild("StandaloneZombiePart")
        local zombies = zombiePart and zombiePart:FindFirstChild("Zombies")
        if zombies then
            for _, obj in ipairs(zombies:GetChildren()) do
                if obj:IsA("Model") then addESP(obj, Color3.new(0,1,0)) end
            end
        end
    end
end

task.spawn(function()
    while getgenv().espEntity do
        scanForESPEntities()
        task.wait(0.5)
    end
end)

