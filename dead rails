-- Aimbot Variables
getgenv().aimbotEnabled = false
getgenv().aimbotFOV = 20
getgenv().aimbotFOVColor = Color3.fromRGB(255, 0, 0)
getgenv().aimbotPart = "Head"

-- Aimbot Logic
local aimbotTargets = {}
local aimbotCircle = Drawing.new("Circle")
aimbotCircle.Radius = getgenv().aimbotFOV
aimbotCircle.Thickness = 2
aimbotCircle.Filled = false
aimbotCircle.Transparency = 1
aimbotCircle.Color = getgenv().aimbotFOVColor
aimbotCircle.Visible = false

local function isValidTarget(model)
    if model:IsA("Model") and model:FindFirstChild("Humanoid") and model.Humanoid.Health > 0 then
        local part = model:FindFirstChild(getgenv().aimbotPart)
        if part then
            return not Players:GetPlayerFromCharacter(model)
        end
    end
    return false
end

local function updateTargetList()
    aimbotTargets = {}
    for _, obj in ipairs(Workspace:GetDescendants()) do
        if isValidTarget(obj) then
            table.insert(aimbotTargets, obj)
        end
    end
end

local function getClosestTarget()
    if not getgenv().aimbotEnabled then return nil end
    local center = Vector2.new(Camera.ViewportSize.X / 2, Camera.ViewportSize.Y / 2)
    local closestDist = math.huge
    local closestTarget = nil
    for _, target in ipairs(aimbotTargets) do
        local part = target:FindFirstChild(getgenv().aimbotPart)
        if part then
            local screenPos, onScreen = Camera:WorldToViewportPoint(part.Position)
            if onScreen then
                local dist = (Vector2.new(screenPos.X, screenPos.Y) - center).Magnitude
                if dist < getgenv().aimbotFOV and dist < closestDist then
                    closestDist = dist
                    closestTarget = target
                end
            end
        end
    end
    return closestTarget
end

RunService.RenderStepped:Connect(function()
    aimbotCircle.Visible = getgenv().aimbotEnabled
    aimbotCircle.Position = Vector2.new(Camera.ViewportSize.X / 2, Camera.ViewportSize.Y / 2)
    aimbotCircle.Radius = getgenv().aimbotFOV
    if getgenv().aimbotEnabled then
        local target = getClosestTarget()
        if target then
            local part = target:FindFirstChild(getgenv().aimbotPart)
            if part then
                local camPos = Camera.CFrame.Position
                local dir = (part.Position - camPos).Unit
                Camera.CFrame = CFrame.new(camPos, camPos + dir)
            end
        end
    end
end)

Workspace.DescendantAdded:Connect(function(obj)
    if isValidTarget(obj) then table.insert(aimbotTargets, obj) end
end)
Workspace.DescendantRemoving:Connect(function(obj)
    for i = #aimbotTargets, 1, -1 do
        if aimbotTargets[i] == obj then table.remove(aimbotTargets, i) break end
    end
end)
updateTargetList()

-- Hitbox Variables
getgenv().hitboxNPC = false
getgenv().hitboxValue = 7
getgenv().hitboxColor = Color3.new(1, 0, 0)

local hitboxTargets = {}
local function isValidHitboxTarget(model)
    if model:IsA("Model") and model:FindFirstChild("Humanoid") and model.Humanoid.Health > 0 and model:FindFirstChild("HumanoidRootPart") then
        return not Players:GetPlayerFromCharacter(model)
    end
    return false
end

local function updateHitboxList()
    hitboxTargets = {}
    for _, obj in ipairs(Workspace:GetDescendants()) do
        if isValidHitboxTarget(obj) then
            table.insert(hitboxTargets, obj)
        end
    end
end

local function applyHitbox()
    for _, target in ipairs(hitboxTargets) do
        local hrp = target:FindFirstChild("HumanoidRootPart")
        if hrp then
            if getgenv().hitboxNPC then
                hrp.Size = Vector3.new(getgenv().hitboxValue, getgenv().hitboxValue, getgenv().hitboxValue)
                hrp.Transparency = 0.5
                hrp.Color = getgenv().hitboxColor
                hrp.Material = Enum.Material.Neon
            else
                hrp.Size = Vector3.new(2, 2, 1)
                hrp.Transparency = 0
                hrp.Material = Enum.Material.Plastic
            end
        end
    end
end

Workspace.DescendantAdded:Connect(function(obj)
    if isValidHitboxTarget(obj) then
        table.insert(hitboxTargets, obj)
        applyHitbox()
    end
end)
Workspace.DescendantRemoving:Connect(function(obj)
    for i = #hitboxTargets, 1, -1 do
        if hitboxTargets[i] == obj then table.remove(hitboxTargets, i) break end
    end
end)
RunService.RenderStepped:Connect(applyHitbox)
updateHitboxList()

