    bg.Parent = CoreGui
    itemsESPTable[part] = bg
end
local function clearItemsESP()
    for _, gui in pairs(itemsESPTable) do
        gui:Destroy()
    end
    itemsESPTable = {}
end
local function refreshItemsESP()
    clearItemsESP()
    for _, item in ipairs(Workspace.RuntimeItems:GetChildren()) do
        if item:IsA("Model") and item.PrimaryPart then
            createItemESP(item.PrimaryPart, item.Name)
        elseif item:IsA("BasePart") then
            createItemESP(item, item.Name)
        end
    end
end
local function setItemsESP(state)
    itemsESPActive = state
    if itemsESPThread then task.cancel(itemsESPThread) end
    if state then
        refreshItemsESP()
        itemsESPThread = task.spawn(function()
            while itemsESPActive do
                task.wait(2)
                refreshItemsESP()
            end
        end)
    else
        clearItemsESP()
    end
end

