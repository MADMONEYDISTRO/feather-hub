-- Noclip (collision group method)
local noclipActive = false
local noclipConn = nil
local noclipGroupCreated = false
local function ensureNoclipGroup()
    if noclipGroupCreated then return true end
    local PhysicsService = game:GetService("PhysicsService")
    local success, err = pcall(function()
        if not PhysicsService:GetCollisionGroups():FindFirstChild("NoCollide") then
            PhysicsService:CreateCollisionGroup("NoCollide", 1)
        end
        PhysicsService:SetGroupCollisionEnabled(0, 1, false)
        PhysicsService:SetGroupCollisionEnabled(1, 1, false)
    end)
    noclipGroupCreated = success
    return success
end
local function setNoclip(state)
    noclipActive = state
    if noclipConn then noclipConn:Disconnect() end
    if not state then
        local char = Player.Character
        if char then
            for _, part in ipairs(char:GetDescendants()) do
                if part:IsA("BasePart") and part.CollisionGroupId == 1 then
                    pcall(function() part.CollisionGroupId = 0 end)
                end
            end
        end
        return
    end
    if not ensureNoclipGroup() then
        notify("Noclip","Failed to create collision group","error")
        return
    end
    noclipConn = RunService.Heartbeat:Connect(function()
        local char = Player.Character
        if not char then return end
        for _, part in ipairs(char:GetDescendants()) do
            if part:IsA("BasePart") and part.CollisionGroupId ~= 1 then
                pcall(function() part.CollisionGroupId = 1 end)
            end
        end
    end)
end

-- Teleport helpers
local function teleportLoop(targetCF, conditionFn, maxTime)
    local char = Player.Character
    if not char then return end
    local root = char:FindFirstChild("HumanoidRootPart")
    local hum = char:FindFirstChildOfClass("Humanoid")
    if not root or not hum then return end
    local startTime = tick()
    while tick() - startTime < (maxTime or 3) do
        if conditionFn and conditionFn() then break end
        root.CFrame = targetCF
        task.wait()
    end
end

