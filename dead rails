-- Weapon hack (modify gun stats)
local weaponHackActive = false
local weaponHackHook = nil
local function setWeaponHack(state)
    weaponHackActive = state
    if state then
        if not weaponHackHook then
            weaponHackHook = hookmetamethod(game, "__index", function(self, key)
                if not checkcaller() then
                    local class = tostring(self)
                    if class == "FireDelay" and key == "Value" then return 0 end
                    if class == "MagazineSize" and key == "Value" then return math.huge end
                    if class == "ReloadDuration" and key == "Value" then return 0 end
                    if class == "SpreadAngle" and key == "Value" then return 0 end
                end
                return weaponHackHook(self, key)
            end)
        end
    else
        if weaponHackHook then
            hookmetamethod(game, "__index", weaponHackHook)
            weaponHackHook = nil
        end
    end
end

-- Items ESP (Billboard)
local itemsESPActive = false
local itemsESPTable = {}
local itemsESPThread = nil
local function createItemESP(part, name)
    if itemsESPTable[part] then return end
    local bg = Instance.new("BillboardGui")
    bg.Name = "ESP"
    bg.Adornee = part
    bg.Size = UDim2.new(0,100,0,30)
    bg.StudsOffset = Vector3.new(0,2,0)
    bg.AlwaysOnTop = true
