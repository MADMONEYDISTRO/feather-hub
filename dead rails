-- Gun Aura (auto-shoot mobs)
local gunAuraActive = false
local gunAuraThread = nil
local function setGunAura(state)
    gunAuraActive = state
    if gunAuraThread then task.cancel(gunAuraThread) end
    if state then
        gunAuraThread = task.spawn(function()
            while gunAuraActive do
                task.wait(0.2)
                pcall(function()
                    local closest = nil
                    local minDist = math.huge
                    for _, obj in ipairs(Workspace:GetDescendants()) do
                        if obj.Name == "HumanoidRootPart" and (obj.Parent:GetAttribute("EntityName") or obj.Parent:GetAttribute("Bounty")) then
                            local hum = obj.Parent:FindFirstChild("Humanoid")
                            if hum and hum.Health > 0 then
                                local dist = Player:DistanceFromCharacter(obj.Position)
                                if dist < minDist then
                                    minDist = dist
                                    closest = obj
                                end
                            end
                        end
                    end
                    if closest then
                        local tool = Player.Character and Player.Character:FindFirstChildOfClass("Tool")
                        if not tool then return end
                        local args = {
                            Workspace:GetServerTimeNow(),
                            tool,
                            closest.CFrame * CFrame.Angles(-1.79, 0.23, 2.36),
                            { [4] = closest.Parent:FindFirstChild("Humanoid"), [2] = closest.Parent:FindFirstChild("Humanoid") }
                        }
                        ReplicatedStorage.Remotes.Weapon.Shoot:FireServer(unpack(args))
                        task.wait(0.1)
                        local reloadArgs = { Workspace:GetServerTimeNow(), tool }
                        ReplicatedStorage.Remotes.Weapon.Reload:FireServer(unpack(reloadArgs))
                    end
                end)
            end
        end)
    end
end

