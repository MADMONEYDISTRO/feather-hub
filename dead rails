-- Server Hop
local hopCursor = ""
function Hop()
    local placeId = game.PlaceId
    local serverList = {}
    local function fetchServers()
        local url = "https://games.roblox.com/v1/games/"..placeId.."/servers/Public?sortOrder=Asc&limit=100"
        if hopCursor ~= "" then url = url .. "&cursor=" .. hopCursor end
        local data = HttpService:JSONDecode(game:HttpGet(url))
        if data.nextPageCursor and data.nextPageCursor ~= "null" then hopCursor = data.nextPageCursor end
        for _, s in ipairs(data.data) do
            if s.playing < s.maxPlayers then
                table.insert(serverList, s.id)
            end
        end
    end
    task.spawn(function()
        while true do
            fetchServers()
            if #serverList > 0 then
                TeleportService:TeleportToPlaceInstance(placeId, serverList[math.random(1,#serverList)], Player)
                break
            end
            task.wait(1)
        end
    end)
end

-- FPS Boost
local function fpsBoost()
    local ter = Workspace.Terrain
    ter.WaterWaveSize = 0
    ter.WaterWaveSpeed = 0
    ter.WaterReflectance = 0
    ter.WaterTransparency = 0
    Lighting.GlobalShadows = false
    Lighting.FogEnd = 9e9
    Lighting.Brightness = 0
    settings().Rendering.QualityLevel = "Level01"
    for _, obj in ipairs(game:GetDescendants()) do
        if obj:IsA("Part") or obj:IsA("Union") or obj:IsA("MeshPart") then
            obj.Material = "Plastic"
            obj.Reflectance = 0
        elseif obj:IsA("Decal") or obj:IsA("Texture") then
            obj.Transparency = 1
        elseif obj:IsA("ParticleEmitter") or obj:IsA("Trail") then
            obj.Lifetime = NumberRange.new(0)
        elseif obj:IsA("Explosion") then
            obj.BlastPressure = 1
            obj.BlastRadius = 1
        elseif obj:IsA("Fire") or obj:IsA("SpotLight") or obj:IsA("Smoke") or obj:IsA("Sparkles") then
            obj.Enabled = false
        end
    end
    for _, effect in ipairs(Lighting:GetChildren()) do
        if effect:IsA("PostEffect") then effect.Enabled = false end
    end
    notify("FPS Boost", "Applied", "success")
end

-- Bring Items
local function bringItems()
    local runtime = Workspace:FindFirstChild("RuntimeItems")
    if runtime and Player.Character then
        local hrp = Player.Character:WaitForChild("HumanoidRootPart")
        for _, obj in ipairs(runtime:GetDescendants()) do
            if obj:IsA("Model") and obj.PrimaryPart then
                obj:SetPrimaryPartCFrame(hrp.CFrame + hrp.CFrame.LookVector * 5)
            end
        end
    end
end

