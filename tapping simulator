-- Save/Load settings
local function saveSettings()
    local success, encoded = pcall(HttpService.JSONEncode, HttpService, Settings)
    if success then
        pcall(function() writefile("FeatherHubSettings.json", encoded) end)
    end
end

local function loadSettings()
    pcall(function()
        if isfile and isfile("FeatherHubSettings.json") then
            local success, decoded = pcall(HttpService.JSONDecode, HttpService, readfile("FeatherHubSettings.json"))
            if success and type(decoded) == "table" then
                for k, v in pairs(decoded) do
                    Settings[k] = v
                end
            end
        end
    end)
end

-- ========== REMOTE SCANNING ==========
local function ScanFarmRemotes()
    table.clear(CachedRemotes.Farm)
    for _, remote in pairs(ReplicatedStorage:GetDescendants()) do
        if remote:IsA("RemoteEvent") then
            local name = remote.Name:lower()
            if name:find("tap") or name:find("click") or name:find("collect") or name:find("farm") then
                table.insert(CachedRemotes.Farm, remote)
            end
        end
    end
end

local function FindHatchRemotes()
    if #CachedRemotes.Hatch > 0 then return CachedRemotes.Hatch end
    local remotes = ReplicatedStorage:FindFirstChild("Remotes") or 
                   ReplicatedStorage:FindFirstChild("Events") or 
                   ReplicatedStorage:FindFirstChild("Network") or 
                   ReplicatedStorage
    for _, remote in pairs(remotes:GetDescendants()) do
        if remote:IsA("RemoteEvent") or remote:IsA("RemoteFunction") then
            local rName = remote.Name:lower()
            if rName:find("hatch") or rName:find("open") or (rName:find("buy") and rName:find("egg")) then
                table.insert(CachedRemotes.Hatch, remote)
            end
        end
    end
    local network = ReplicatedStorage:FindFirstChild("Packages") or ReplicatedStorage:FindFirstChild("Shared")
    if network then
        for _, child in pairs(network:GetDescendants()) do
            if child:IsA("RemoteEvent") and child.Name:lower():find("egg") then
                table.insert(CachedRemotes.Hatch, child)
            end
        end
    end
    return CachedRemotes.Hatch
end

local function FindBuyEggRemote()
    if CachedRemotes.BuyEgg then return CachedRemotes.BuyEgg end
    for _, remote in pairs(ReplicatedStorage:GetDescendants()) do
        if remote:IsA("RemoteEvent") or remote:IsA("RemoteFunction") then
            local rName = remote.Name:lower()
            if rName:find("buy") or rName:find("purchase") or rName:find("unlock") then
                CachedRemotes.BuyEgg = remote
                return remote
            end
        end
    end
    return nil
end

local function FindEggPart(eggName)
    if CachedEggPart and CachedEggPart.Name == eggName then return CachedEggPart end
    for _, obj in pairs(workspace:GetDescendants()) do
        if obj:IsA("BasePart") and (obj.Name == eggName or (obj.Name:find(eggName) and obj.Name:lower():find("egg"))) then
            CachedEggPart = obj
            return obj
        end
    end
    return nil
end

local function getRebirthRemote()
    if CachedRemotes.Rebirth then return CachedRemotes.Rebirth end
    for _, r in pairs(ReplicatedStorage:GetDescendants()) do
        if r.Name == "Rebirth" and (r:IsA("RemoteFunction") or r:IsA("RemoteEvent")) then
            CachedRemotes.Rebirth = r
            return r
        end
    end
    return nil
end

