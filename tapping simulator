        knob.BorderSizePixel = 0
        knob.ZIndex = 7
        knob.Parent = track
        Instance.new("UICorner", knob).CornerRadius = UDim.new(1, 0)
        local knobStroke = Instance.new("UIStroke")
        knobStroke.Color = T.accentLt
        knobStroke.Thickness = 1.5
        knobStroke.Parent = knob

        local sliding = false
        local function updateFromMouse(x)
            local relative = (x - track.AbsolutePosition.X) / track.AbsoluteSize.X
            local newVal = math.clamp(minVal + (maxVal - minVal) * relative, minVal, maxVal)
            if isInt then newVal = math.floor(newVal) end
            setter(newVal)
            local pct = (newVal - minVal) / (maxVal - minVal)
            fill.Size = UDim2.new(pct, 0, 1, 0)
            knob.Position = UDim2.new(pct, -7, 0.5, -7)
            valueBox.Text = tostring(newVal)
            saveSettings()
        end
        knob.MouseButton1Down:Connect(function()
            sliding = true
            updateFromMouse(UserInputService:GetMouseLocation().X)
        end)
        UserInputService.InputChanged:Connect(function(input)
            if sliding and input.UserInputType == Enum.UserInputType.MouseMovement then
                updateFromMouse(input.Position.X)
            end
        end)
        UserInputService.InputEnded:Connect(function(input)
            if input.UserInputType == Enum.UserInputType.MouseButton1 then sliding = false end
        end)
        valueBox.FocusLost:Connect(function()
            local num = tonumber(valueBox.Text)
            if num then
                num = math.clamp(num, minVal, maxVal)
                if isInt then num = math.floor(num) end
                setter(num)
                local pct = (num - minVal) / (maxVal - minVal)
                fill.Size = UDim2.new(pct, 0, 1, 0)
                knob.Position = UDim2.new(pct, -7, 0.5, -7)
                valueBox.Text = tostring(num)
                saveSettings()
            else
                valueBox.Text = tostring(getter())
            end
        end)
        return row
    end

