-- ESP
local function updateESP()
    for _, player in pairs(Players:GetPlayers()) do
        if player ~= LocalPlayer then
            if Settings.ESPEnabled then
                if player.Character and not player.Character:FindFirstChild("FeatherESP") then
                    local hl = Instance.new("Highlight")
                    hl.Name = "FeatherESP"
                    hl.FillColor = Color3.fromRGB(195, 160, 60)
                    hl.FillTransparency = 0.5
                    hl.OutlineColor = Color3.fromRGB(225, 190, 90)
                    hl.OutlineTransparency = 0
                    hl.Parent = player.Character
                end
            else
                if player.Character then
                    local hl = player.Character:FindFirstChild("FeatherESP")
                    if hl then hl:Destroy() end
                end
            end
        end
    end
end
Players.PlayerAdded:Connect(function(p) p.CharacterAdded:Connect(function() updateESP() end) end)
Players.PlayerRemoving:Connect(function(p)
    if p.Character then
        local hl = p.Character:FindFirstChild("FeatherESP")
        if hl then hl:Destroy() end
    end
end)

-- Fly handler
local flyBV, flyBG
RunService.Stepped:Connect(function()
    pcall(function()
        local humanoid = getHumanoid()
        if humanoid then
            if not Settings.Fly then humanoid.WalkSpeed = Settings.WalkSpeed end
            humanoid.JumpPower = Settings.JumpPower
        end
        if Settings.Noclip then
            local char = getCharacter()
            for _, part in pairs(char:GetDescendants()) do
                if part:IsA("BasePart") then part.CanCollide = false end
            end
        end
        if Settings.Fly then
            local root = getRootPart()
            if root then
                if not flyBV or not flyBV.Parent then
                    flyBV = Instance.new("BodyVelocity")
                    flyBV.Name = "FeatherFlyVelocity"
                    flyBV.MaxForce = Vector3.new(math.huge, math.huge, math.huge)
                    flyBV.Parent = root
                    flyBG = Instance.new("BodyGyro")
                    flyBG.Name = "FeatherFlyGyro"
                    flyBG.MaxTorque = Vector3.new(math.huge, math.huge, math.huge)
                    flyBG.P = 9000
                    flyBG.D = 500
                    flyBG.Parent = root
                end
                local cam = workspace.CurrentCamera
                flyBV.Velocity = cam.CFrame.LookVector * Settings.FlySpeed
                flyBG.CFrame = cam.CFrame
            end
        else
            if flyBV then flyBV:Destroy() end
            if flyBG then flyBG:Destroy() end
        end
