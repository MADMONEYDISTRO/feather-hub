    titleLbl.Font = Enum.Font.GothamSemibold
    titleLbl.TextSize = 11
    titleLbl.TextXAlignment = Enum.TextXAlignment.Left
    titleLbl.ZIndex = 5
    local valueBox = Instance.new("TextBox", row)
    valueBox.Size = UDim2.new(0, 55, 0, 22)
    valueBox.Position = UDim2.new(1, -70, 0, 8)
    valueBox.BackgroundColor3 = Theme.inputBg
    valueBox.Text = tostring(initial)
    valueBox.TextColor3 = Theme.gold
    valueBox.Font = Enum.Font.GothamBold
    valueBox.TextSize = 10
    valueBox.BorderSizePixel = 0
    valueBox.ZIndex = 5
    Instance.new("UICorner", valueBox).CornerRadius = UDim.new(0, 5)
    local track = Instance.new("Frame", row)
    track.Size = UDim2.new(1, -32, 0, 4)
    track.Position = UDim2.new(0, 16, 0, 50)
    track.BackgroundColor3 = Theme.dim
    track.BorderSizePixel = 0
    track.ZIndex = 5
    Instance.new("UICorner", track).CornerRadius = UDim.new(1, 0)
    local fill = Instance.new("Frame", track)
    fill.Size = UDim2.new((initial - min) / (max - min), 0, 1, 0)
    fill.BackgroundColor3 = Theme.accent
    fill.BorderSizePixel = 0
    fill.ZIndex = 6
    Instance.new("UICorner", fill).CornerRadius = UDim.new(1, 0)
    local knob = Instance.new("TextButton", track)
    knob.Size = UDim2.new(0, 14, 0, 14)
    knob.Position = UDim2.new((initial - min) / (max - min), -7, 0.5, -7)
    knob.BackgroundColor3 = Theme.gold
    knob.Text = ""
    knob.BorderSizePixel = 0
    knob.ZIndex = 7
    Instance.new("UICorner", knob).CornerRadius = UDim.new(1, 0)
    local ds = false
    knob.InputBegan:Connect(function(i) if i.UserInputType == Enum.UserInputType.MouseButton1 then ds = true end end)
    UserInputService.InputEnded:Connect(function(i) if i.UserInputType == Enum.UserInputType.MouseButton1 then ds = false end end)
    UserInputService.InputChanged:Connect(function(i)
        if ds and i.UserInputType == Enum.UserInputType.MouseMovement then
            local ap = track.AbsolutePosition
            local sz = track.AbsoluteSize
            local ratio = math.clamp((i.Position.X - ap.X) / sz.X, 0, 1)
            local val = math.floor(min + ratio * (max - min))
            valueBox.Text = tostring(val)
            fill.Size = UDim2.new(ratio, 0, 1, 0)
            knob.Position = UDim2.new(ratio, -7, 0.5, -7)
            onChanged(val)
        end
    end)
    return row
end

local function makeDropdownRow(card, order, label, options, default, isLast, onSelect, tabIdx)
    registerFeature(label, tabIdx or 1)
    local row = makeRow(card, order, isLast, 48)
    local titleLbl = Instance.new("TextLabel", row)
    titleLbl.Size = UDim2.new(0.55, -16, 0, 16)
    titleLbl.Position = UDim2.new(0, 16, 0, 8)
    titleLbl.BackgroundTransparency = 1
    titleLbl.Text = label
    titleLbl.TextColor3 = Theme.text
    titleLbl.Font = Enum.Font.GothamSemibold
    titleLbl.TextSize = 11
    titleLbl.TextXAlignment = Enum.TextXAlignment.Left
    titleLbl.ZIndex = 5
    local selected = default
    if selected == nil then
        if options[1] and options[1].Title then
            selected = options[1].Title
        else
            selected = ""
        end
    end
    local btn = Instance.new("TextButton", row)
    btn.Size = UDim2.new(0, 140, 0, 28)
    btn.Position = UDim2.new(1, -156, 0.5, -14)
    btn.BackgroundColor3 = Theme.inputBg
    btn.Text = selected
    btn.TextColor3 = Theme.gold
    btn.Font = Enum.Font.GothamSemibold
    btn.TextSize = 9
    btn.BorderSizePixel = 0
    btn.AutoButtonColor = false
    btn.ZIndex = 5
    Instance.new("UICorner", btn).CornerRadius = UDim.new(0, 6)
    local drop = Instance.new("Frame", gui)
    drop.Size = UDim2.new(0, 140, 0, #options * 24)
    drop.Position = UDim2.new(1, -156, 0, 42)
    drop.BackgroundColor3 = Theme.card
    drop.BorderSizePixel = 0
    drop.Visible = false
    drop.ZIndex = 20
    Instance.new("UICorner", drop).CornerRadius = UDim.new(0, 6)
    local scroll = Instance.new("ScrollingFrame", drop)
    scroll.Size = UDim2.new(1, 0, 1, 0)
    scroll.BackgroundTransparency = 1
    scroll.ScrollBarThickness = 3
    scroll.ScrollBarImageColor3 = Theme.accent
    scroll.CanvasSize = UDim2.new(0, 0, 0, #options * 24)
    scroll.ZIndex = 21
    local listLayout = Instance.new("UIListLayout", scroll)
    listLayout.Padding = UDim.new(0, 1)
    listLayout.SortOrder = Enum.SortOrder.LayoutOrder
    for i = 1, #options do
        local opt = options[i]
        local ob = Instance.new("TextButton", scroll)
        ob.Size = UDim2.new(1, 0, 0, 23)
        ob.BackgroundColor3 = Theme.dim
        ob.BackgroundTransparency = 0.5
        ob.Text = opt.Title
        ob.TextColor3 = Theme.text
        ob.Font = Enum.Font.Gotham
        ob.TextSize = 9
        ob.BorderSizePixel = 0
        ob.ZIndex = 22
        ob.MouseEnter:Connect(function() TweenService:Create(ob, tw(0.1), {BackgroundTransparency = 0}):Play() end)
        ob.MouseLeave:Connect(function() TweenService:Create(ob, tw(0.1), {BackgroundTransparency = 0.5}):Play() end)
        ob.MouseButton1Click:Connect(function()
            selected = opt.Title
            btn.Text = opt.Title
            drop.Visible = false
            if onSelect then onSelect(opt.Title) end
        end)
    end
    btn.MouseButton1Click:Connect(function() drop.Visible = not drop.Visible end)
    UserInputService.InputBegan:Connect(function(inp)
        if inp.UserInputType == Enum.UserInputType.MouseButton1 and drop.Visible then
            local mp = UserInputService:GetMouseLocation()
            local dp = drop.AbsolutePosition
            local ds2 = drop.AbsoluteSize
            if mp.X < dp.X or mp.X > dp.X + ds2.X or mp.Y < dp.Y or mp.Y > dp.Y + ds2.Y then
                drop.Visible = false
            end
        end
    end)
    return row
end

