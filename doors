local function tw(d)
    local dur = d
    if dur == nil then
        dur = 0.2
    end
    return TweenInfo.new(dur, Enum.EasingStyle.Quart, Enum.EasingDirection.Out)
end

-- Notify (safe if-elseif-else)
local function Notify(title, msg, level)
    local col
    if level == "error" then
        col = Theme.red
    elseif level == "warning" then
        col = Theme.orange
    else
        col = Theme.accent
    end
    local n = Instance.new("Frame", gui)
    n.Size = UDim2.new(0, 240, 0, 52)
    n.Position = UDim2.new(1, -260, 0, 100)
    n.BackgroundColor3 = Theme.card
    n.BorderSizePixel = 0
    n.ZIndex = 50
    Instance.new("UICorner", n).CornerRadius = UDim.new(0, 8)
    local st = Instance.new("UIStroke", n)
    st.Color = col
    st.Thickness = 1.5
    local t = Instance.new("TextLabel", n)
    t.Size = UDim2.new(1, -16, 0, 22)
    t.Position = UDim2.new(0, 8, 0, 6)
    t.Text = title
    t.Font = Enum.Font.GothamBold
    t.TextSize = 11
    t.TextColor3 = col
    t.BackgroundTransparency = 1
    local m = Instance.new("TextLabel", n)
    m.Size = UDim2.new(1, -16, 0, 18)
    m.Position = UDim2.new(0, 8, 0, 28)
    m.Text = msg
    m.Font = Enum.Font.Gotham
