local function makeSliderRow(card, order, label, min, max, initial, isLast, onChanged, tabIdx)
    registerFeature(label, tabIdx or 1)
    local row = makeRow(card, order, isLast, 68)
    local titleLbl = Instance.new("TextLabel", row)
    titleLbl.Size = UDim2.new(0.65, -16, 0, 16)
    titleLbl.Position = UDim2.new(0, 16, 0, 8)
    titleLbl.BackgroundTransparency = 1
    titleLbl.Text = label
