        if n.Parent then
            TweenService:Create(n, TweenInfo.new(0.4), {BackgroundTransparency = 1, Size = UDim2.new(0, 0, 0, 0)}):Play()
            task.wait(0.4)
            n:Destroy()
        end
    end)
end

