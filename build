-- ══════════════════════════════════════════
--  SIZING
-- ══════════════════════════════════════════
local WIN_W  = 520
local WIN_H  = 460
local SIDE_W = 115
local HDR_H  = 48

local function tw(t, s, d)
    return TweenInfo.new(t or 0.22, s or Enum.EasingStyle.Quart, d or Enum.EasingDirection.Out)
end

-- ══════════════════════════════════════════
--  UTILITIES
-- ══════════════════════════════════════════
local function getCharacter()
    return LocalPlayer.Character or LocalPlayer.CharacterAdded:Wait()
end

local function getRootPart()
    local char = getCharacter()
    return char and char:FindFirstChild("HumanoidRootPart")
end

local function getHumanoid()
    local char = getCharacter()
    return char and char:FindFirstChildOfClass("Humanoid")
end

-- ══════════════════════════════════════════
--  ANTI AFK
-- ══════════════════════════════════════════
local function startAntiAfk()
    task.spawn(function()
        while Settings.antiAfk do
            pcall(function()
                VirtualUser:CaptureController()
                VirtualUser:ClickButton1(Vector2.new())
            end)
            task.wait(55)
        end
    end)
end

-- ══════════════════════════════════════════
--  CORE FARM LOGIC
-- ══════════════════════════════════════════
local function doRun()
    local char = LocalPlayer.Character
    if not char then
        LocalPlayer.CharacterAdded:Wait()
        char = LocalPlayer.Character
    end

    local root = getRootPart()
    if not root then return end

    local stages = workspace:FindFirstChild("BoatStages") and workspace.BoatStages:FindFirstChild("NormalStages")
    if not stages then
        Notify("Error", "NormalStages not found!", "error")
        Settings.farmActive = false
        return
    end

    for i = 1, 10 do
        if not Settings.farmActive then return end

        local stage = stages:FindFirstChild("CaveStage" .. i)
        if stage then
            local darkPart = stage:FindFirstChild("DarknessPart")
            if darkPart then
                root.CFrame = darkPart.CFrame

                -- Create temporary floor to prevent fall
                local floor = Instance.new("Part")
                floor.Anchored = true
                floor.CanCollide = true
                floor.Size = Vector3.new(10, 1, 10)
                floor.Transparency = 1
                floor.Position = root.Position - Vector3.new(0, 3, 0)
                floor.Parent = char

                task.wait(Settings.tpDelay)
                floor:Destroy()

                currentStage = i
            end
        end
    end

    if not Settings.farmActive then return end

    local theEnd = stages:FindFirstChild("TheEnd")
    if theEnd then
        local chest = theEnd:FindFirstChild("GoldenChest")
        if chest then
            local trigger = chest:FindFirstChild("Trigger")
            if trigger then
                root.CFrame = trigger.CFrame

                local waited = 0
                local collected = false
                while waited < 10 and Settings.farmActive do
                    task.wait(0.5)
                    waited = waited + 0.5
                    if Lighting.ClockTime ~= 14 then
                        collected = true
                        break
                    end
                end

                if collected then
                    totalGold = totalGold + 100
                    Notify("Gold Collected!", "Total: " .. totalGold .. " gold", "success")
                end
            end
        end
    end

    if not Settings.farmActive then return end

    -- Wait for respawn if needed
    local spawned = false
    local conn = LocalPlayer.CharacterAdded:Connect(function()
        spawned = true
        conn:Disconnect()
    end)

    local t = 0
    while not spawned and Settings.farmActive and t < 30 do
        task.wait(1)
        t = t + 1
    end

    if spawned then task.wait(2) end
    task.wait(Settings.runDelay)
end

local function farmLoop()
    while Settings.farmActive do
        local ok, err = pcall(doRun)
        if not ok then
            Notify("Farm Error", tostring(err), "error")
            task.wait(3)
        end
    end
end

-- ══════════════════════════════════════════
