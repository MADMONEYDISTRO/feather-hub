local function Notify(title, msg, nType)
    local sg = CoreGui:FindFirstChild("BoatFarmerGUI")
    if not sg then return end

    local col = T.accent
    if nType == "success" then col = T.green
    elseif nType == "error" then col = T.red
    elseif nType == "warning" then col = T.gold end

    local n = Instance.new("Frame")
    n.Size = UDim2.new(0, 0, 0, 58)
    n.Position = UDim2.new(1, -14, 1, -72)
    n.AnchorPoint = Vector2.new(1, 1)
    n.BackgroundColor3 = T.card
    n.BorderSizePixel = 0
    n.ZIndex = 100
    n.Parent = sg
    Instance.new("UICorner", n).CornerRadius = UDim.new(0, 10)
    local ns = Instance.new("UIStroke")
    ns.Color = col
    ns.Thickness = 1
    ns.Parent = n

    local bar = Instance.new("Frame")
    bar.Size = UDim2.new(0, 3, 0.55, 0)
    bar.Position = UDim2.new(0, 0, 0.225, 0)
    bar.BackgroundColor3 = col
    bar.BorderSizePixel = 0
    bar.Parent = n
    Instance.new("UICorner", bar).CornerRadius = UDim.new(1, 0)

    local t1 = Instance.new("TextLabel")
    t1.Size = UDim2.new(1, -18, 0, 18)
    t1.Position = UDim2.new(0, 14, 0, 9)
    t1.Text = title
    t1.Font = Enum.Font.GothamBold
    t1.TextSize = 11
    t1.TextColor3 = T.text
    t1.TextXAlignment = Enum.TextXAlignment.Left
    t1.BackgroundTransparency = 1
    t1.ZIndex = 101
    t1.Parent = n

    local t2 = Instance.new("TextLabel")
    t2.Size = UDim2.new(1, -18, 0, 16)
    t2.Position = UDim2.new(0, 14, 0, 28)
    t2.Text = msg or ""
    t2.Font = Enum.Font.Gotham
    t2.TextSize = 9
    t2.TextColor3 = T.text
    t2.TextTransparency = 0.35
    t2.TextXAlignment = Enum.TextXAlignment.Left
    t2.TextWrapped = true
    t2.BackgroundTransparency = 1
    t2.ZIndex = 101
    t2.Parent = n

    TweenService:Create(n, tw(0.3, Enum.EasingStyle.Back, Enum.EasingDirection.Out), {Size = UDim2.new(0, 280, 0, 58)}):Play()
    task.delay(3.5, function()
        TweenService:Create(n, tw(0.25), {Size = UDim2.new(0, 0, 0, 58), BackgroundTransparency = 1}):Play()
        task.wait(0.3)
        if n and n.Parent then n:Destroy() end
    end)
end

