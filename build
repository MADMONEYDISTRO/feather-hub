    local function makeHdrBtn(xPos, symbol)
        local b = Instance.new("TextButton")
        b.Size = UDim2.new(0, 28, 0, 28)
        b.Position = UDim2.new(1, xPos, 0.5, -14)
        b.Text = symbol
        b.Font = Enum.Font.GothamBold
        b.TextSize = 16
        b.TextColor3 = T.muted
        b.BackgroundColor3 = T.dim
        b.BorderSizePixel = 0
        b.AutoButtonColor = false
        b.ZIndex = 5
        b.Parent = hdr
        Instance.new("UICorner", b).CornerRadius = UDim.new(0, 7)
        return b
    end
    local minBtn = makeHdrBtn(-66, "–")
    local closeBtn = makeHdrBtn(-34, "×")

    closeBtn.MouseEnter:Connect(function() TweenService:Create(closeBtn, tw(), {BackgroundColor3 = T.red, TextColor3 = Color3.new(1,1,1)}):Play() end)
    closeBtn.MouseLeave:Connect(function() TweenService:Create(closeBtn, tw(), {BackgroundColor3 = T.dim, TextColor3 = T.muted}):Play() end)
    closeBtn.MouseButton1Click:Connect(function() sg:Destroy() end)

    -- CONTENT AREA
    local contentArea = Instance.new("Frame")
    contentArea.Size = UDim2.new(1, -SIDE_W, 1, -HDR_H)
    contentArea.Position = UDim2.new(0, SIDE_W, 0, HDR_H)
    contentArea.BackgroundTransparency = 1
    contentArea.BorderSizePixel = 0
    contentArea.ZIndex = 2
    contentArea.Parent = win

    -- Minimize logic
    local isMinimized = false
    local function toggleMinimize()
        isMinimized = not isMinimized
        if isMinimized then
            TweenService:Create(win, tw(0.3), {Size = UDim2.new(0, WIN_W, 0, HDR_H)}):Play()
            sidebar.Visible = false
            contentArea.Visible = false
            TweenService:Create(hdr, tw(0.3), {Size = UDim2.new(1, 0, 0, HDR_H), Position = UDim2.new(0, 0, 0, 0)}):Play()
            hdrLC.Visible = false
            hdrBC.Visible = false
            hdrLine.Visible = false
            minBtn.Text = "+"
        else
            TweenService:Create(win, tw(0.3), {Size = UDim2.new(0, WIN_W, 0, WIN_H)}):Play()
            TweenService:Create(hdr, tw(0.3), {Size = UDim2.new(1, -SIDE_W, 0, HDR_H), Position = UDim2.new(0, SIDE_W, 0, 0)}):Play()
            hdrLC.Visible = true
            hdrBC.Visible = true
            hdrLine.Visible = true
            task.delay(0.1, function() sidebar.Visible = true; contentArea.Visible = true end)
            minBtn.Text = "–"
        end
    end
    minBtn.MouseButton1Click:Connect(toggleMinimize)
    minBtn.MouseEnter:Connect(function() TweenService:Create(minBtn, tw(), {BackgroundColor3 = T.accent, TextColor3 = Color3.new(1,1,1)}):Play() end)
    minBtn.MouseLeave:Connect(function() TweenService:Create(minBtn, tw(), {BackgroundColor3 = T.dim, TextColor3 = T.muted}):Play() end)

    -- DRAG
    do
        local dragging, dragReady, dragInput, dragStart, startPos, holdThread = false, false, nil, nil, nil, nil
        hdr.InputBegan:Connect(function(i)
            local t = i.UserInputType
            if t == Enum.UserInputType.MouseButton1 or t == Enum.UserInputType.Touch then
                dragStart = i.Position
                startPos = win.Position
                dragReady = false
                dragging = false
                holdThread = task.delay(0.14, function() dragReady = true end)
            end
        end)
        hdr.InputChanged:Connect(function(i)
            if i.UserInputType == Enum.UserInputType.MouseMovement or i.UserInputType == Enum.UserInputType.Touch then dragInput = i end
        end)
        UserInputService.InputChanged:Connect(function(i)
            if i == dragInput and dragReady then
                dragging = true
                local d = i.Position - dragStart
                local vp = workspace.CurrentCamera.ViewportSize
                win.Position = UDim2.new(0, math.clamp(startPos.X.Offset + d.X, 0, vp.X - WIN_W), 0, math.clamp(startPos.Y.Offset + d.Y, 0, vp.Y - WIN_H))
            end
        end)
        UserInputService.InputEnded:Connect(function(i)
            if i.UserInputType == Enum.UserInputType.MouseButton1 or i.UserInputType == Enum.UserInputType.Touch then
                dragging = false
                dragReady = false
                if holdThread then task.cancel(holdThread); holdThread = nil end
            end
        end)
    end

    -- PAGE BUILDER
    local function makePage()
        local pg = Instance.new("ScrollingFrame")
        pg.Size = UDim2.new(1, 0, 1, 0)
        pg.BackgroundTransparency = 1
        pg.BorderSizePixel = 0
        pg.ScrollBarThickness = 3
        pg.ScrollBarImageColor3 = T.accent
        pg.CanvasSize = UDim2.new(0, 0, 0, 0)
        pg.AutomaticCanvasSize = Enum.AutomaticSize.Y
        pg.ScrollingDirection = Enum.ScrollingDirection.Y
        pg.ElasticBehavior = Enum.ElasticBehavior.Never
        pg.Visible = false
        pg.ZIndex = 2
        pg.Parent = contentArea
        local l = Instance.new("UIListLayout")
        l.SortOrder = Enum.SortOrder.LayoutOrder
        l.HorizontalAlignment = Enum.HorizontalAlignment.Center
        l.Padding = UDim.new(0, 8)
        l.Parent = pg
        local p = Instance.new("UIPadding")
        p.PaddingTop = UDim.new(0, 12)
        p.PaddingBottom = UDim.new(0, 14)
        p.PaddingLeft = UDim.new(0, 14)
        p.PaddingRight = UDim.new(0, 14)
        p.Parent = pg
        return pg
    end

