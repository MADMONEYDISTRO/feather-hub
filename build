    local function makeSection(parent, label, order)
        local f = Instance.new("Frame")
        f.Size = UDim2.new(1, 0, 0, 22)
        f.BackgroundTransparency = 1
        f.BorderSizePixel = 0
        f.LayoutOrder = order
        f.ZIndex = 3
        f.Parent = parent
        local lbl = Instance.new("TextLabel")
        lbl.Size = UDim2.new(1, 0, 1, 0)
        lbl.Text = string.upper(label)
        lbl.Font = Enum.Font.GothamBold
        lbl.TextSize = 8
        lbl.TextColor3 = T.accent
        lbl.TextXAlignment = Enum.TextXAlignment.Left
        lbl.BackgroundTransparency = 1
        lbl.ZIndex = 3
        lbl.Parent = f
        local line = Instance.new("Frame")
        line.Size = UDim2.new(0, 28, 0, 2)
        line.Position = UDim2.new(0, 0, 1, -2)
        line.BackgroundColor3 = T.accent
        line.BorderSizePixel = 0
        line.ZIndex = 3
        line.Parent = f
        Instance.new("UICorner", line).CornerRadius = UDim.new(1, 0)
        return f
    end

    local function CreateToggle(parent, order, title, desc, getter, setter, isLast)
        local row = makeRow(parent, order, isLast, 48)

        local strip = Instance.new("Frame")
        strip.Size = UDim2.new(0, 3, 0.45, 0)
        strip.Position = UDim2.new(0, 0, 0.275, 0)
        strip.BackgroundColor3 = getter() and T.accent or T.sep
        strip.BorderSizePixel = 0
        strip.ZIndex = 5
        strip.Parent = row
        Instance.new("UICorner", strip).CornerRadius = UDim.new(1, 0)

        local titleLbl = Instance.new("TextLabel")
        titleLbl.Size = UDim2.new(0.65, -20, 0, 18)
        titleLbl.Position = UDim2.new(0, 16, 0, 8)
        titleLbl.BackgroundTransparency = 1
        titleLbl.Text = title
        titleLbl.TextColor3 = T.text
        titleLbl.Font = Enum.Font.GothamSemibold
        titleLbl.TextSize = 11
        titleLbl.TextXAlignment = Enum.TextXAlignment.Left
        titleLbl.ZIndex = 5
        titleLbl.Parent = row

        local descLbl = Instance.new("TextLabel")
        descLbl.Size = UDim2.new(0.65, -20, 0, 13)
        descLbl.Position = UDim2.new(0, 16, 0, 27)
        descLbl.BackgroundTransparency = 1
        descLbl.Text = desc
        descLbl.TextColor3 = T.muted
        descLbl.Font = Enum.Font.Gotham
        descLbl.TextSize = 8
        descLbl.TextXAlignment = Enum.TextXAlignment.Left
        descLbl.ZIndex = 5
        descLbl.Parent = row

        local toggleBg = Instance.new("Frame")
        toggleBg.Size = UDim2.new(0, 44, 0, 22)
        toggleBg.Position = UDim2.new(1, -60, 0.5, -11)
        toggleBg.BackgroundColor3 = getter() and T.toggleOn or T.toggleOff
        toggleBg.BorderSizePixel = 0
        toggleBg.ZIndex = 5
        toggleBg.Parent = row
        Instance.new("UICorner", toggleBg).CornerRadius = UDim.new(1, 0)
        local toggleStroke = Instance.new("UIStroke")
        toggleStroke.Color = getter() and T.accent or T.sep
        toggleStroke.Thickness = 1
        toggleStroke.Parent = toggleBg

        local toggleKnob = Instance.new("Frame")
        toggleKnob.Size = UDim2.new(0, 16, 0, 16)
        toggleKnob.Position = getter() and UDim2.new(1, -19, 0.5, -8) or UDim2.new(0, 3, 0.5, -8)
        toggleKnob.BackgroundColor3 = Color3.new(1, 1, 1)
        toggleKnob.BorderSizePixel = 0
        toggleKnob.ZIndex = 6
        toggleKnob.Parent = toggleBg
        Instance.new("UICorner", toggleKnob).CornerRadius = UDim.new(1, 0)

        local hitBtn = Instance.new("TextButton")
        hitBtn.Size = UDim2.new(0, 60, 0, 30)
        hitBtn.Position = UDim2.new(1, -70, 0.5, -15)
        hitBtn.BackgroundTransparency = 1
        hitBtn.Text = ""
        hitBtn.ZIndex = 7
        hitBtn.Parent = row

        hitBtn.MouseButton1Click:Connect(function()
            setter(not getter())
            local on = getter()
            TweenService:Create(toggleBg, tw(0.2), {BackgroundColor3 = on and T.toggleOn or T.toggleOff}):Play()
            TweenService:Create(toggleStroke, tw(0.2), {Color = on and T.accent or T.sep}):Play()
            TweenService:Create(toggleKnob, tw(0.2, Enum.EasingStyle.Back), {Position = on and UDim2.new(1, -19, 0.5, -8) or UDim2.new(0, 3, 0.5, -8)}):Play()
            TweenService:Create(strip, tw(0.2), {BackgroundColor3 = on and T.accent or T.sep}):Play()
            Notify(title, on and "Enabled" or "Disabled", on and "success" or nil)
        end)
        return row
    end

    local function CreateSlider(parent, order, title, desc, minVal, maxVal, getter, setter, isInt, isLast)
        local row = makeRow(parent, order, isLast, 68)

        local titleLbl = Instance.new("TextLabel")
        titleLbl.Size = UDim2.new(0.65, -16, 0, 16)
        titleLbl.Position = UDim2.new(0, 16, 0, 8)
        titleLbl.BackgroundTransparency = 1
        titleLbl.Text = title
        titleLbl.TextColor3 = T.text
        titleLbl.Font = Enum.Font.GothamSemibold
        titleLbl.TextSize = 11
        titleLbl.TextXAlignment = Enum.TextXAlignment.Left
        titleLbl.ZIndex = 5
        titleLbl.Parent = row

        local descLbl = Instance.new("TextLabel")
        descLbl.Size = UDim2.new(0.65, -16, 0, 12)
        descLbl.Position = UDim2.new(0, 16, 0, 24)
        descLbl.BackgroundTransparency = 1
        descLbl.Text = desc
        descLbl.TextColor3 = T.muted
        descLbl.Font = Enum.Font.Gotham
        descLbl.TextSize = 8
        descLbl.TextXAlignment = Enum.TextXAlignment.Left
        descLbl.ZIndex = 5
        descLbl.Parent = row

        local valueBox = Instance.new("TextBox")
        valueBox.Size = UDim2.new(0, 55, 0, 22)
        valueBox.Position = UDim2.new(1, -70, 0, 8)
        valueBox.BackgroundColor3 = T.inputBg
        valueBox.Text = tostring(getter())
        valueBox.TextColor3 = T.gold
        valueBox.Font = Enum.Font.GothamBold
        valueBox.TextSize = 10
        valueBox.BorderSizePixel = 0
        valueBox.ZIndex = 5
        valueBox.Parent = row
        Instance.new("UICorner", valueBox).CornerRadius = UDim.new(0, 5)
        local vbStroke = Instance.new("UIStroke")
        vbStroke.Color = T.border
        vbStroke.Thickness = 1
        vbStroke.Parent = valueBox

        local track = Instance.new("Frame")
        track.Size = UDim2.new(1, -32, 0, 4)
        track.Position = UDim2.new(0, 16, 0, 50)
        track.BackgroundColor3 = T.dim
        track.BorderSizePixel = 0
        track.ZIndex = 5
        track.Parent = row
        Instance.new("UICorner", track).CornerRadius = UDim.new(1, 0)

        local fill = Instance.new("Frame")
        fill.Size = UDim2.new((getter() - minVal) / (maxVal - minVal), 0, 1, 0)
        fill.BackgroundColor3 = T.accent
        fill.BorderSizePixel = 0
        fill.ZIndex = 6
        fill.Parent = track
        Instance.new("UICorner", fill).CornerRadius = UDim.new(1, 0)

        local knob = Instance.new("TextButton")
        knob.Size = UDim2.new(0, 14, 0, 14)
        knob.Position = UDim2.new((getter() - minVal) / (maxVal - minVal), -7, 0.5, -7)
        knob.BackgroundColor3 = T.gold
        knob.Text = ""
        knob.BorderSizePixel = 0
        knob.ZIndex = 7
        knob.Parent = track
        Instance.new("UICorner", knob).CornerRadius = UDim.new(1, 0)
        local knobStroke = Instance.new("UIStroke")
        knobStroke.Color = T.accentLt
        knobStroke.Thickness = 1.5
        knobStroke.Parent = knob

        local sliding = false
        local function updateFromMouse(x)
            local relative = (x - track.AbsolutePosition.X) / track.AbsoluteSize.X
            local newVal = math.clamp(minVal + (maxVal - minVal) * relative, minVal, maxVal)
            if isInt then newVal = math.floor(newVal) end
            setter(newVal)
            local pct = (newVal - minVal) / (maxVal - minVal)
            fill.Size = UDim2.new(pct, 0, 1, 0)
            knob.Position = UDim2.new(pct, -7, 0.5, -7)
            valueBox.Text = tostring(newVal)
        end
        knob.MouseButton1Down:Connect(function()
            sliding = true
            updateFromMouse(UserInputService:GetMouseLocation().X)
        end)
        UserInputService.InputChanged:Connect(function(input)
            if sliding and input.UserInputType == Enum.UserInputType.MouseMovement then
                updateFromMouse(input.Position.X)
            end
        end)
        UserInputService.InputEnded:Connect(function(input)
            if input.UserInputType == Enum.UserInputType.MouseButton1 then sliding = false end
        end)
        valueBox.FocusLost:Connect(function()
            local num = tonumber(valueBox.Text)
            if num then
                num = math.clamp(num, minVal, maxVal)
                if isInt then num = math.floor(num) end
                setter(num)
                local pct = (num - minVal) / (maxVal - minVal)
                fill.Size = UDim2.new(pct, 0, 1, 0)
                knob.Position = UDim2.new(pct, -7, 0.5, -7)
                valueBox.Text = tostring(num)
            else
                valueBox.Text = tostring(getter())
            end
        end)
        return row
    end

    local function CreateInfoRow(parent, order, label, value, isLast)
        local row = makeRow(parent, order, isLast, 36)
        local l = Instance.new("TextLabel")
        l.Size = UDim2.new(0.55, 0, 1, 0)
        l.Position = UDim2.new(0, 16, 0, 0)
        l.Text = label
        l.Font = Enum.Font.GothamSemibold
        l.TextSize = 9
        l.TextColor3 = T.muted
        l.TextXAlignment = Enum.TextXAlignment.Left
        l.BackgroundTransparency = 1
        l.ZIndex = 5
        l.Parent = row
        local r = Instance.new("TextLabel")
        r.Size = UDim2.new(0.45, -16, 1, 0)
        r.Position = UDim2.new(0.55, 0, 0, 0)
        r.Text = value
        r.Font = Enum.Font.GothamBold
        r.TextSize = 9
        r.TextColor3 = T.gold
        r.TextXAlignment = Enum.TextXAlignment.Right
        r.BackgroundTransparency = 1
        r.ZIndex = 5
        r.Parent = row
        return row, r
    end

    -- TABS & PAGES
    local TABS = {"Farm", "Settings"}
    local TAB_TITLES = {"Auto Farm", "Settings"}
    local pages = {}
    local navBtns = {}
    local activeTab = 1

    for i = 1, #TABS do
        pages[i] = makePage()
    end

    local function setTab(idx)
        if isMinimized then toggleMinimize() end
        activeTab = idx
        hdrTitle.Text = TAB_TITLES[idx] or "Boat Farmer"
        for i, btn in ipairs(navBtns) do
            local on = (i == idx)
            TweenService:Create(btn.bg, tw(0.16), {
                BackgroundColor3 = on and T.accent or T.dim,
                BackgroundTransparency = on and 0.12 or 0,
            }):Play()
            TweenService:Create(btn.lbl, tw(0.16), {TextColor3 = on and T.accent or T.muted}):Play()
            btn.bar.BackgroundTransparency = on and 0 or 1
            pages[i].Visible = on
        end
    end

    for i, tabName in ipairs(TABS) do
        local row = Instance.new("Frame")
        row.Size = UDim2.new(1, -8, 0, 34)
        row.BackgroundTransparency = 1
        row.LayoutOrder = i
        row.ZIndex = 4
        row.Parent = navCont

        local bar = Instance.new("Frame")
        bar.Size = UDim2.new(0, 3, 0.45, 0)
        bar.Position = UDim2.new(0, 0, 0.275, 0)
        bar.BackgroundColor3 = T.accent
        bar.BackgroundTransparency = 1
        bar.BorderSizePixel = 0
        bar.ZIndex = 5
        bar.Parent = row
        Instance.new("UICorner", bar).CornerRadius = UDim.new(1, 0)

        local bg = Instance.new("Frame")
        bg.Size = UDim2.new(1, -5, 1, -4)
        bg.Position = UDim2.new(0, 5, 0, 2)
        bg.BackgroundColor3 = T.dim
        bg.BackgroundTransparency = 0
        bg.BorderSizePixel = 0
        bg.ZIndex = 4
        bg.Parent = row
        Instance.new("UICorner", bg).CornerRadius = UDim.new(0, 7)

        local lbl = Instance.new("TextLabel")
        lbl.Size = UDim2.new(1, -14, 1, 0)
        lbl.Position = UDim2.new(0, 10, 0, 0)
        lbl.Text = string.upper(tabName)
        lbl.Font = Enum.Font.GothamBold
        lbl.TextSize = 7
        lbl.TextColor3 = T.muted
        lbl.BackgroundTransparency = 1
        lbl.TextXAlignment = Enum.TextXAlignment.Left
        lbl.ZIndex = 5
        lbl.Parent = row

        local hit = Instance.new("TextButton")
        hit.Size = UDim2.new(1, 0, 1, 0)
        hit.BackgroundTransparency = 1
        hit.Text = ""
        hit.ZIndex = 6
        hit.Parent = row
        local ci = i
        hit.MouseButton1Click:Connect(function() setTab(ci) end)

        navBtns[i] = {bg = bg, lbl = lbl, bar = bar}
    end

    -- PAGE 1: FARM
    local pgFarm = pages[1]
    makeSection(pgFarm, "Auto Farm", 1)
    local farmCard = makeCard(pgFarm, 2)
    CreateToggle(farmCard, 1, "Auto Farm", "Start/stop farming loop", function() return Settings.farmActive end, function(v)
        Settings.farmActive = v
        if v then
            task.spawn(farmLoop)
            Notify("Farm", "Started!", "success")
        else
            Notify("Farm", "Stopped.", nil)
        end
    end, false)
    CreateSlider(farmCard, 2, "Teleport Delay", "Delay between teleports (sec)", 0.1, 5, function() return Settings.tpDelay end, function(v) Settings.tpDelay = v end, false, false)
    CreateSlider(farmCard, 3, "Run Delay", "Delay between full runs (sec)", 1, 15, function() return Settings.runDelay end, function(v) Settings.runDelay = v end, false, true)

    makeSection(pgFarm, "Statistics", 3)
    local statsCard = makeCard(pgFarm, 4)
    CreateInfoRow(statsCard, 1, "Total Gold", tostring(totalGold), false)
    CreateInfoRow(statsCard, 2, "Current Stage", tostring(currentStage), true)

    -- PAGE 2: SETTINGS
    local pgSettings = pages[2]
    makeSection(pgSettings, "Miscellaneous", 1)
    local miscCard = makeCard(pgSettings, 2)
    CreateToggle(miscCard, 1, "Anti AFK", "Prevents being kicked", function() return Settings.antiAfk end, function(v)
        Settings.antiAfk = v
        if v then startAntiAfk() end
        Notify("Anti AFK", v and "Enabled" or "Disabled", v and "success" or nil)
    end, true)

    makeSection(pgSettings, "About", 3)
    local aboutCard = makeCard(pgSettings, 4)
    CreateInfoRow(aboutCard, 1, "Version", "Gold Edition v1", false)
    CreateInfoRow(aboutCard, 2, "Theme", "Private Gold & Black", false)
    CreateInfoRow(aboutCard, 3, "Keybind", "] to toggle UI", true)

    -- FLOATING TOGGLE BUTTON
    local toggleBtn = Instance.new("TextButton")
    toggleBtn.Size = UDim2.new(0, 46, 0, 46)
    toggleBtn.Position = UDim2.new(0.02, 0, 0.9, -56)
    toggleBtn.BackgroundColor3 = T.card
    toggleBtn.TextColor3 = T.gold
    toggleBtn.Text = "BF"
    toggleBtn.TextSize = 18
    toggleBtn.Font = Enum.Font.GothamBold
    toggleBtn.BorderSizePixel = 0
    toggleBtn.AutoButtonColor = false
    toggleBtn.ZIndex = 50
    toggleBtn.Parent = sg
    Instance.new("UICorner", toggleBtn).CornerRadius = UDim.new(1, 0)
    local tbStroke = Instance.new("UIStroke")
    tbStroke.Color = T.accent
    tbStroke.Thickness = 2
    tbStroke.Parent = toggleBtn

    local draggingBtn = false
    local dragStartBtn, startPosBtn
    toggleBtn.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            draggingBtn = true
            dragStartBtn = input.Position
            startPosBtn = toggleBtn.Position
            input.Changed:Connect(function()
                if input.UserInputState == Enum.UserInputState.End then draggingBtn = false end
            end)
        end
    end)
    UserInputService.InputChanged:Connect(function(input)
        if draggingBtn and input.UserInputType == Enum.UserInputType.MouseMovement then
            local delta = input.Position - dragStartBtn
            toggleBtn.Position = UDim2.new(startPosBtn.X.Scale, startPosBtn.X.Offset + delta.X, startPosBtn.Y.Scale, startPosBtn.Y.Offset + delta.Y)
        end
    end)
    toggleBtn.MouseButton1Click:Connect(function()
        win.Visible = not win.Visible
    end)
    toggleBtn.MouseEnter:Connect(function() TweenService:Create(tbStroke, tw(), {Color = T.accentLt}):Play() end)
    toggleBtn.MouseLeave:Connect(function() TweenService:Create(tbStroke, tw(), {Color = T.accent}):Play() end)

    -- KEYBIND ] = toggle
    UserInputService.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.Keyboard and input.KeyCode == Enum.KeyCode.RightBracket then
            win.Visible = not win.Visible
        end
    end)

    -- GLOW PULSE
    task.spawn(function()
        while sg and sg.Parent do
            TweenService:Create(winGlow, TweenInfo.new(2.6, Enum.EasingStyle.Sine, Enum.EasingDirection.InOut), {ImageTransparency = 0.80}):Play()
            task.wait(2.6)
            TweenService:Create(winGlow, TweenInfo.new(2.6, Enum.EasingStyle.Sine, Enum.EasingDirection.InOut), {ImageTransparency = 0.91}):Play()
            task.wait(2.6)
        end
    end)

    -- OPEN ANIMATION
    TweenService:Create(win, TweenInfo.new(0.45, Enum.EasingStyle.Back, Enum.EasingDirection.Out), {
        Size = UDim2.new(0, WIN_W, 0, WIN_H),
        BackgroundTransparency = 0
    }):Play()

    setTab(1)
    return sg
end

-- STARTUP
CreateBoatFarmerUI()
Notify("Boat Farmer", "Gold Edition Loaded! Click BF to open menu.", "success")
