	ll.SortOrder = Enum.SortOrder.LayoutOrder; ll.HorizontalAlignment = Enum.HorizontalAlignment.Center; ll.Padding = UDim.new(0, 8)
	pages[i] = page

	local btn = Instance.new("TextButton", sideScroll)
	btn.Size = UDim2.new(1, -16, 0, 36)
	if i == 1 then btn.BackgroundColor3 = Theme.accent else btn.BackgroundColor3 = Theme.dim end
	btn.BorderSizePixel = 0; btn.AutoButtonColor = false
	btn.Text = TAB_NAMES[i]; btn.Font = Enum.Font.GothamBold; btn.TextSize = 10
	if i == 1 then btn.TextColor3 = Color3.new(1, 1, 1) else btn.TextColor3 = Theme.text end
	btn.ZIndex = 4; Instance.new("UICorner", btn).CornerRadius = UDim.new(0, 7)
	local idx = i
	btn.MouseButton1Click:Connect(function()
		for j = 1, #pages do pages[j].Visible = (j == idx) end
		for j = 1, #tabBtns do
			local on = (j == idx)
			local bg, tc
			if on then bg = Theme.accent; tc = Color3.new(1, 1, 1) else bg = Theme.dim; tc = Theme.text end
			TweenService:Create(tabBtns[j], tw(0.15), {BackgroundColor3 = bg, TextColor3 = tc}):Play()
		end
	end)
	tabBtns[i] = btn
end

-- UI Element Factories
local function makeCard(parent, order)
	local c = Instance.new("Frame", parent)
	c.Size = UDim2.new(1, 0, 0, 0); c.AutomaticSize = Enum.AutomaticSize.Y
	c.BackgroundColor3 = Theme.card; c.BorderSizePixel = 0; c.LayoutOrder = order; c.ZIndex = 3
	Instance.new("UICorner", c).CornerRadius = UDim.new(0, 10)
	local s = Instance.new("UIStroke", c); s.Color = Theme.border; s.Thickness = 1
	local ll = Instance.new("UIListLayout", c); ll.SortOrder = Enum.SortOrder.LayoutOrder; ll.HorizontalAlignment = Enum.HorizontalAlignment.Center
	return c
end
local function makeRow(card, order, isLast, height)
	local h = height; if h == nil then h = 46 end
	local row = Instance.new("Frame", card)
	row.Size = UDim2.new(1, 0, 0, h); row.BackgroundTransparency = 1; row.BorderSizePixel = 0; row.LayoutOrder = order; row.ZIndex = 4
	if not isLast then
		local sep = Instance.new("Frame", row)
		sep.Size = UDim2.new(1, -28, 0, 1); sep.Position = UDim2.new(0, 14, 1, -1)
		sep.BackgroundColor3 = Theme.sep; sep.BorderSizePixel = 0; sep.ZIndex = 4
	end
	return row
end
local function makeSection(parent, label, order)
	local f = Instance.new("Frame", parent)
	f.Size = UDim2.new(1, 0, 0, 22); f.BackgroundTransparency = 1; f.BorderSizePixel = 0; f.LayoutOrder = order; f.ZIndex = 3
	local lbl = Instance.new("TextLabel", f)
	lbl.Size = UDim2.new(1, 0, 1, 0); lbl.Text = string.upper(label); lbl.Font = Enum.Font.GothamBold; lbl.TextSize = 8
	lbl.TextColor3 = Theme.accent; lbl.TextXAlignment = Enum.TextXAlignment.Left; lbl.BackgroundTransparency = 1; lbl.ZIndex = 3
	local line = Instance.new("Frame", f)
	line.Size = UDim2.new(0, 28, 0, 2); line.Position = UDim2.new(0, 0, 1, -2)
	line.BackgroundColor3 = Theme.accent; line.BorderSizePixel = 0; line.ZIndex = 3
	Instance.new("UICorner", line).CornerRadius = UDim.new(1, 0)
	return f
end
local function CreateToggle(parent, order, title, desc, getter, setter, isLast, tabIdx)
	registerFeature(title, tabIdx)
	local row = makeRow(parent, order, isLast, 48)
	local strip = Instance.new("Frame", row)
	strip.Size = UDim2.new(0, 3, 0.45, 0); strip.Position = UDim2.new(0, 0, 0.275, 0)
	local init = getter(); strip.BackgroundColor3 = init and Theme.accent or Theme.sep; strip.BorderSizePixel = 0; strip.ZIndex = 5
	Instance.new("UICorner", strip).CornerRadius = UDim.new(1, 0)
	local titleLbl = Instance.new("TextLabel", row)
	titleLbl.Size = UDim2.new(0.65, -20, 0, 18); titleLbl.Position = UDim2.new(0, 16, 0, 8)
	titleLbl.BackgroundTransparency = 1; titleLbl.Text = title; titleLbl.TextColor3 = Theme.text; titleLbl.Font = Enum.Font.GothamSemibold; titleLbl.TextSize = 11
	titleLbl.TextXAlignment = Enum.TextXAlignment.Left; titleLbl.ZIndex = 5
	local toggleBg = Instance.new("Frame", row)
	toggleBg.Size = UDim2.new(0, 44, 0, 22); toggleBg.Position = UDim2.new(1, -60, 0.5, -11)
	toggleBg.BackgroundColor3 = init and Theme.toggleOn or Theme.toggleOff; toggleBg.BorderSizePixel = 0; toggleBg.ZIndex = 5
	Instance.new("UICorner", toggleBg).CornerRadius = UDim.new(1, 0)
	local toggleStroke = Instance.new("UIStroke", toggleBg)
	toggleStroke.Color = init and Theme.accent or Theme.sep; toggleStroke.Thickness = 1
	local toggleKnob = Instance.new("Frame", toggleBg)
	toggleKnob.Size = UDim2.new(0, 16, 0, 16); toggleKnob.Position = init and UDim2.new(1, -19, 0.5, -8) or UDim2.new(0, 3, 0.5, -8)
	toggleKnob.BackgroundColor3 = Color3.new(1, 1, 1); toggleKnob.BorderSizePixel = 0; toggleKnob.ZIndex = 6
	Instance.new("UICorner", toggleKnob).CornerRadius = UDim.new(1, 0)
	local hitBtn = Instance.new("TextButton", row)
	hitBtn.Size = UDim2.new(0, 60, 0, 30); hitBtn.Position = UDim2.new(1, -70, 0.5, -15)
	hitBtn.BackgroundTransparency = 1; hitBtn.Text = ""; hitBtn.ZIndex = 7
	local state = init
	hitBtn.MouseButton1Click:Connect(function()
		state = not state; setter(state)
		local on = getter()
		local newBg, newStroke, newStripBg, newPos
		if on then newBg = Theme.toggleOn; newStroke = Theme.accent; newStripBg = Theme.accent; newPos = UDim2.new(1, -19, 0.5, -8)
		else newBg = Theme.toggleOff; newStroke = Theme.sep; newStripBg = Theme.sep; newPos = UDim2.new(0, 3, 0.5, -8) end
		TweenService:Create(toggleBg, tw(0.2), {BackgroundColor3 = newBg}):Play()
		TweenService:Create(toggleStroke, tw(0.2), {Color = newStroke}):Play()
		TweenService:Create(toggleKnob, tw(0.2, Enum.EasingStyle.Back), {Position = newPos}):Play()
		TweenService:Create(strip, tw(0.2), {BackgroundColor3 = newStripBg}):Play()
	end)
	return row
end
local function CreateButton(parent, order, title, desc, callback, isLast, tabIdx)
	registerFeature(title, tabIdx)
	local row = makeRow(parent, order, isLast, 50)
	local titleLbl = Instance.new("TextLabel", row)
	titleLbl.Size = UDim2.new(0.6, -16, 0, 16); titleLbl.Position = UDim2.new(0, 16, 0, 9)
	titleLbl.BackgroundTransparency = 1; titleLbl.Text = title; titleLbl.TextColor3 = Theme.text; titleLbl.Font = Enum.Font.GothamSemibold; titleLbl.TextSize = 11
	titleLbl.TextXAlignment = Enum.TextXAlignment.Left; titleLbl.ZIndex = 5
	local btn = Instance.new("TextButton", row)
	btn.Size = UDim2.new(0, 80, 0, 28); btn.Position = UDim2.new(1, -96, 0.5, -14)
	btn.BackgroundColor3 = Theme.accentDim; btn.Text = "EXECUTE"; btn.TextColor3 = Color3.new(1, 1, 1); btn.Font = Enum.Font.GothamBold; btn.TextSize = 9
	btn.BorderSizePixel = 0; btn.AutoButtonColor = false; btn.ZIndex = 5; Instance.new("UICorner", btn).CornerRadius = UDim.new(0, 6)
	btn.MouseEnter:Connect(function() TweenService:Create(btn, tw(), {BackgroundColor3 = Theme.accent}):Play() end)
	btn.MouseLeave:Connect(function() TweenService:Create(btn, tw(), {BackgroundColor3 = Theme.accentDim}):Play() end)
	btn.MouseButton1Click:Connect(callback)
	return row
end

-- ====================== BUILD TABS ======================
local function BuildTabs()
	-- Main Tab
	local pg1 = pages[1]
	makeSection(pg1, "Toggles", 1)
	local mainCard = makeCard(pg1, 2)
	CreateToggle(mainCard, 1, "Speed Boost", "Move much faster", function() return Settings.SpeedBoost end, function(v)
		Settings.SpeedBoost = v
		if v then startSpeedBoost() else stopSpeedBoost() end
	end, false, 1)
	CreateToggle(mainCard, 2, "Noclip", "Walk through walls", function() return Settings.Noclip end, function(v)
		Settings.Noclip = v
		if v then startNoclip() else stopNoclip() end
	end, false, 1)
	CreateToggle(mainCard, 3, "Remove Fall Damage", "No more fall damage", function() return Settings.RmvFallDamage end, function(v)
		Settings.RmvFallDamage = v
		local fd = getChar() and getChar():FindFirstChild("FallDamage")
		if fd then fd.Enabled = not v end
	end, false, 1)
	CreateToggle(mainCard, 4, "Item Aura", "Auto collect nearby items", function() return Settings.ItemAura end, function(v)
		Settings.ItemAura = v
		if v then startItemAura() end
	end, false, 1)
	CreateToggle(mainCard, 5, "Instant Collect", "Auto collect all items every sec", function() return Settings.InstantItem end, function(v)
		Settings.InstantItem = v
		if v then startInstantItem() end
	end, true, 1)

	makeSection(pg1, "Actions", 3)
	local actionCard = makeCard(pg1, 4)
	CreateButton(actionCard, 1, "Collect All Items", "Gather everything on the map", function() task.spawn(getItems) end, false, 1)
	CreateButton(actionCard, 2, "FullBright", "Remove darkness", function() fullBright() end, false, 1)
	CreateButton(actionCard, 3, "Safe Zone", "Teleport to safe spot and back", function() toggleSafeZone() end, false, 1)
	CreateButton(actionCard, 4, "Visible Landmines", "Make landmines visible", function() visibleLandmines() end, true, 1)

	-- ESP Tab
	local pg2 = pages[2]
	makeSection(pg2, "ESP", 1)
	local espCard = makeCard(pg2, 2)
	CreateToggle(espCard, 1, "Items ESP", "Highlight items with names", function() return Settings.ItemESP end, function(v)
		Settings.ItemESP = v
		if v then
			for _, item in pairs(Workspace:GetChildren()) do createESP(item) end
		else
			clearESP()
		end
	end, false, 2)
	CreateToggle(espCard, 2, "Players ESP", "See players through walls", function() return Settings.PlayerESP end, function(v)
		Settings.PlayerESP = v
		if v then
			for _, player in pairs(Players:GetPlayers()) do createPlayerESP(player) end
			startPlayerESPUpdate()
		else
			clearPlayerESP()
			stopPlayerESPUpdate()
		end
	end, true, 2)

	-- Misc Tab
	local pg3 = pages[3]
	makeSection(pg3, "Tweaks", 1)
	local miscCard = makeCard(pg3, 2)
	CreateToggle(miscCard, 1, "No Hit Cooldown", "Remove melee cooldown", function() return Settings.RmvHitCooldown end, function(v)
		Settings.RmvHitCooldown = v
		local h = getHum()
		if h then
			h:GetAttributeChangedSignal("HitCooldown"):Connect(function()
				if Settings.RmvHitCooldown then h:SetAttribute("HitCooldown", false) end
			end)
		end
	end, false, 3)
	CreateToggle(miscCard, 2, "Infinite Jump", "Jump non-stop", function() return Settings.InfJump end, function(v)
		Settings.InfJump = v
		if v then startInfJump() else stopInfJump() end
	end, true, 3)

	makeSection(pg3, "Actions", 3)
	local actionCard2 = makeCard(pg3, 4)
	CreateButton(actionCard2, 1, "Infinite Stamina", "Never run out of stamina", function()
		local h = getHum()
		if h then
			h:SetAttribute("MaxStamina", math.huge)
			h:SetAttribute("Stamina", math.huge)
		end
	end, false, 3)
	CreateButton(actionCard2, 2, "Infinite Inventory", "Carry unlimited items", function()
		local h = getHum()
		if h then h:SetAttribute("InventorySize", math.huge) end
	end, true, 3)
end
BuildTabs()

