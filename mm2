local function switchTab(name)
    if selectedTab == name then return end
    selectedTab = name
    for _, t in pairs(tabs) do
        if t.content then t.content.Visible = false end
        if t.button  then TS:Create(t.button, tw(0.12), {BackgroundColor3 = dimCol,  TextColor3 = txtCol}):Play() end
    end
    local t = tabs[name]
    if t then
        if t.content then t.content.Visible = true end
        if t.button  then TS:Create(t.button, tw(0.12), {BackgroundColor3 = accent, TextColor3 = Color3.new(1,1,1)}):Play() end
    end
end

