local coinESP = false
local coinBoxes = {} -- part -> {box, bb}

local function addCoinBox(part)
    if not part or not part.Parent then return end
    if coinBoxes[part] then return end

    -- 3D wireframe box around the coin, slightly oversized so it floats in the air
    local box = Instance.new("BoxHandleAdornment")
    box.Adornee = part
    box.AlwaysOnTop = true
    box.ZIndex = 5
    box.Color3 = Color3.fromRGB(255, 215, 0)
    box.Transparency = 0.3
    -- Make box bigger than the actual part so it surrounds it in the air
    local partSize = Vector3.new(2, 2, 2)
    pcall(function() partSize = part.Size end)
    box.Size = partSize + Vector3.new(1.5, 1.5, 1.5)
    box.Parent = espContainer.ScreenGui

    -- Small distance label floating above
    local bb = Instance.new("BillboardGui")
    bb.Adornee = part
    bb.Size = UDim2.new(0, 36, 0, 14)
    bb.StudsOffset = Vector3.new(0, 2.5, 0)
    bb.AlwaysOnTop = true
    bb.MaxDistance = 400
    bb.Parent = espContainer.ScreenGui
    local dl = Instance.new("TextLabel")
    dl.Size = UDim2.new(1, 0, 1, 0)
    dl.BackgroundTransparency = 1
    dl.Font = Enum.Font.GothamBold
    dl.TextSize = 10
    dl.TextColor3 = Color3.fromRGB(255, 215, 0)
    dl.Text = ""
    dl.Parent = bb
    Instance.new("UIStroke", dl).Thickness = 1

    coinBoxes[part] = {box = box, bb = bb, distLabel = dl}
end

local function removeCoinBox(part)
    local m = coinBoxes[part]
    if m then
        pcall(function() m.box:Destroy() end)
        pcall(function() m.bb:Destroy() end)
        coinBoxes[part] = nil
    end
end

local function clearCoinBoxes()
    for part, m in pairs(coinBoxes) do
        pcall(function() m.box:Destroy() end)
        pcall(function() m.bb:Destroy() end)
    end
    coinBoxes = {}
end

local function tryAddCoin(obj)
    pcall(function()
        if obj:IsA("BasePart") and obj.Transparency < 1 then
            addCoinBox(obj)
        elseif obj:IsA("Model") then
            local visual = obj:FindFirstChild("CoinVisual")
            if visual and visual:IsA("BasePart") then
                addCoinBox(visual)
            else
                for _, p in ipairs(obj:GetDescendants()) do
                    if p:IsA("BasePart") and p.Transparency < 1 then
                        addCoinBox(p); break
                    end
                end
            end
        end
    end)
end

local function scanCoins()
    clearCoinBoxes()
    if not coinESP then return end
    local m = getMap()
    if not m then return end

    local cc = m:FindFirstChild("CoinContainer")
    if cc then
        for _, coin in ipairs(cc:GetChildren()) do
            tryAddCoin(coin)
        end
    end

    for _, obj in ipairs(m:GetDescendants()) do
        pcall(function()
            if obj.Name:lower():find("coin") and obj:IsA("BasePart") and obj.Transparency < 1 and not coinBoxes[obj] then
                addCoinBox(obj)
            end
        end)
    end
end

