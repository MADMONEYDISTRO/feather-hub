--  COIN AUTOFARM LOGIC (ported from TravHub)
-- ═══════════════════════════════════════════════
local coinFarmEnabled  = false
local roundActive      = false   -- true while a MM2 round is running
local farmSpeed        = 25      -- tween studs/sec
local distThreshold    = 150     -- teleport instead of tween if coin is this far
local coinsCollected   = 0
local currentTween     = nil

-- helpers
local function getHRP()
    local char = Player.Character or Player.CharacterAdded:Wait()
    return char:WaitForChild("HumanoidRootPart")
end

-- Find nearest coin in any CoinContainer across the map
-- Matches the exact logic from the reference script
local function findNearestCoin()
    local hrp     = Player.Character and Player.Character:FindFirstChild("HumanoidRootPart")
    if not hrp then return nil, math.huge end
    local best     = nil
    local bestDist = math.huge
    for _, obj in ipairs(workspace:GetChildren()) do
        local container = obj:FindFirstChild("CoinContainer")
        if container then
            for _, part in ipairs(container:GetChildren()) do
                -- coin must be a BasePart with a TouchInterest (i.e. still collectible)
                if part:IsA("BasePart") and part:FindFirstChild("TouchInterest") then
                    local d = (hrp.Position - part.Position).Magnitude
                    if d < bestDist then
                        best     = part
                        bestDist = d
                    end
                end
            end
        end
    end
    return best, bestDist
end

-- Cancel any in-progress tween
local function cancelTween()
    if currentTween then
        currentTween:Cancel()
        currentTween = nil
    end
end

-- Move to a coin: teleport if far, tween if close
local function moveToCoin(coin, dist)
    local hrp = Player.Character and Player.Character:FindFirstChild("HumanoidRootPart")
    if not hrp then return end
    cancelTween()
    if dist > distThreshold then
        -- snap directly on top of the coin
        hrp.CFrame = CFrame.new(coin.Position)
    else
        local duration = math.max(dist / farmSpeed, 0.05)
        currentTween = TS:Create(hrp, TweenInfo.new(duration, Enum.EasingStyle.Linear), {
            CFrame = CFrame.new(coin.Position)
        })
        currentTween:Play()
        -- wait until coin is gone or round ends
        repeat task.wait() until
            not coin:FindFirstChild("TouchInterest") or
            not coinFarmEnabled or
            not roundActive
        cancelTween()
    end
end

-- Prevent character collision blocking the tween (mirrors reference script)
RS.Stepped:Connect(function()
    if coinFarmEnabled and roundActive then
        local char = Player.Character
        if char and char:IsDescendantOf(workspace) then
            for _, p in ipairs(char:GetDescendants()) do
                if p:IsA("BasePart") then
                    p.CanCollide = false
                end
            end
        end
    end
end)

-- Main farm loop
task.spawn(function()
    while true do
        task.wait(0.15)
        if coinFarmEnabled and roundActive then
            local coin, dist = findNearestCoin()
            if coin then
                moveToCoin(coin, dist)
                -- small delay before scanning for next coin
                task.wait(0.05)
                coinsCollected = coinsCollected + 1
            end
        end
    end
end)

-- ═══ Round detection via MM2 remote events ═══
-- RoundStart fires when a new MM2 round begins
-- RoundEndFade fires when the round ends
local function hookRoundEvents()
    local remotes = ReplicatedStorage:FindFirstChild("Remotes")
    if not remotes then return end
    local gameplay = remotes:FindFirstChild("Gameplay")
    if not gameplay then return end

    local roundStart = gameplay:FindFirstChild("RoundStart")
    local roundEnd   = gameplay:FindFirstChild("RoundEndFade")

    if roundStart then
        roundStart.OnClientEvent:Connect(function()
            roundActive     = true
            coinsCollected  = 0
            notify("Round started — coin farm active!")
        end)
    end

    if roundEnd then
        roundEnd.OnClientEvent:Connect(function()
            roundActive = false
            cancelTween()
            notify("Round ended — farming paused.")
        end)
    end
end

-- Try to hook immediately, retry if RS isn't ready yet
task.spawn(function()
    local ok = pcall(hookRoundEvents)
    if not ok then
        -- wait for Remotes to appear
        local remotes = ReplicatedStorage:WaitForChild("Remotes", 30)
        if remotes then hookRoundEvents() end
    end
end)

-- Reset on character respawn
Player.CharacterAdded:Connect(function()
    roundActive    = false
    coinsCollected = 0
    cancelTween()
end)

