-- Shared builders
local function makeCard(parent, order)
    local c = Instance.new("Frame"); c.Size = UDim2.new(1, 0, 0, 0); c.AutomaticSize = Enum.AutomaticSize.Y
    c.BackgroundColor3 = T.card; c.BorderSizePixel = 0; c.LayoutOrder = order; c.ZIndex = 3; c.Parent = parent
    Instance.new("UICorner", c).CornerRadius = UDim.new(0, 10)
    local s = Instance.new("UIStroke"); s.Color = T.border; s.Thickness = 1; s.Parent = c
    local l = Instance.new("UIListLayout"); l.SortOrder = Enum.SortOrder.LayoutOrder
    l.HorizontalAlignment = Enum.HorizontalAlignment.Center; l.Padding = UDim.new(0, 0); l.Parent = c
    return c
end

local function makeSection(parent, label, order)
    local f = Instance.new("Frame"); f.Size = UDim2.new(1, 0, 0, 18); f.BackgroundTransparency = 1
    f.BorderSizePixel = 0; f.LayoutOrder = order; f.ZIndex = 3; f.Parent = parent
    local lbl = Instance.new("TextLabel"); lbl.Size = UDim2.new(1, 0, 1, 0)
    lbl.Text = string.upper(label); lbl.Font = Enum.Font.GothamBold; lbl.TextSize = 8
    lbl.TextColor3 = accent; lbl.TextXAlignment = Enum.TextXAlignment.Left
    lbl.BackgroundTransparency = 1; lbl.ZIndex = 3; lbl.Parent = f
    local line = Instance.new("Frame"); line.Size = UDim2.new(0, 22, 0, 2); line.Position = UDim2.new(0, 0, 1, -2)
    line.BackgroundColor3 = accent; line.BorderSizePixel = 0; line.ZIndex = 3; line.Parent = f
    Instance.new("UICorner", line).CornerRadius = UDim.new(1, 0)
end

local function makeRow(card, order, isLast, h)
    local row = Instance.new("Frame"); row.Size = UDim2.new(1, 0, 0, h or 38)
    row.BackgroundTransparency = 1; row.BorderSizePixel = 0; row.LayoutOrder = order; row.ZIndex = 4; row.Parent = card
    if not isLast then
        local sep = Instance.new("Frame"); sep.Size = UDim2.new(1, -20, 0, 1); sep.Position = UDim2.new(0, 10, 1, -1)
        sep.BackgroundColor3 = T.sep; sep.BorderSizePixel = 0; sep.ZIndex = 4; sep.Parent = row
    end
    return row
end

local function makeToggleRow(card, order, labelText, enabledKey, callback, isLast)
    local row = makeRow(card, order, isLast, 38)
    local label = Instance.new("TextLabel"); label.Size = UDim2.new(1, -60, 1, 0)
    label.Position = UDim2.new(0, 12, 0, 0); label.Text = labelText
    label.Font = Enum.Font.GothamSemibold; label.TextSize = 10; label.TextColor3 = T.text
    label.TextXAlignment = Enum.TextXAlignment.Left; label.BackgroundTransparency = 1; label.ZIndex = 5; label.Parent = row

    local defaultOn = Enabled[enabledKey]
    local toggleBg = Instance.new("Frame"); toggleBg.Size = UDim2.new(0, 36, 0, 18)
    toggleBg.Position = UDim2.new(1, -48, 0.5, -9)
    toggleBg.BackgroundColor3 = defaultOn and accent or T.dim; toggleBg.ZIndex = 5; toggleBg.Parent = row
    Instance.new("UICorner", toggleBg).CornerRadius = UDim.new(1, 0)
    local tgS = Instance.new("UIStroke"); tgS.Color = T.border; tgS.Thickness = 1; tgS.Parent = toggleBg

    local toggleCircle = Instance.new("Frame"); toggleCircle.Size = UDim2.new(0, 14, 0, 14)
    toggleCircle.Position = defaultOn and UDim2.new(1, -16, 0.5, -7) or UDim2.new(0, 2, 0.5, -7)
    toggleCircle.BackgroundColor3 = Color3.new(1, 1, 1); toggleCircle.ZIndex = 6; toggleCircle.Parent = toggleBg
    Instance.new("UICorner", toggleCircle).CornerRadius = UDim.new(1, 0)

    local clickBtn = Instance.new("TextButton"); clickBtn.Size = UDim2.new(0, 50, 1, 0)
    clickBtn.Position = UDim2.new(1, -56, 0, 0); clickBtn.BackgroundTransparency = 1; clickBtn.Text = ""; clickBtn.ZIndex = 7; clickBtn.Parent = row

    local isOn = defaultOn
    clickBtn.MouseButton1Click:Connect(function()
        isOn = not isOn; Enabled[enabledKey] = isOn
        TweenService:Create(toggleBg, tw(0.25), {BackgroundColor3 = isOn and accent or T.dim}):Play()
        TweenService:Create(toggleCircle, tw(0.25, Enum.EasingStyle.Back), {Position = isOn and UDim2.new(1, -16, 0.5, -7) or UDim2.new(0, 2, 0.5, -7)}):Play()
        callback(isOn)
    end)
end

