-- Auto Kill Shark
local autoKillConn = nil
local center = Vector3.new(0, -100, 0)
local radius = 1000
local speed = math.pi * 2
local angle = 0

local function startAutoKill()
    if autoKillConn then return end
    if not getrawmetatable or not setreadonly or not newcclosure then return end
    local lastNotify = 0
    autoKillConn = RunService.Heartbeat:Connect(function(dt)
        if Player.Team and Player.Team.Name ~= "Shark" and hrp then
            if not remote then return end
            KillShark()
            getShark()
            if not sharkName then
                local chinook = workspace:FindFirstChild("Chinook")
                local interior = chinook and chinook:FindFirstChild("interior")
                if interior then hrp.CFrame = interior.CFrame end
            else
                angle = angle + speed * dt
                local t = (angle % (math.pi * 2)) / (math.pi * 2)
                local offset
                if t < 0.25 then offset = Vector3.new(radius, 0, -radius + 8 * radius * t)
                elseif t < 0.5 then offset = Vector3.new(radius - 8 * radius * (t - 0.25), 0, radius)
                elseif t < 0.75 then offset = Vector3.new(-radius, 0, radius - 8 * radius * (t - 0.5))
                else offset = Vector3.new(-radius + 8 * radius * (t - 0.75), 0, -radius) end
                hrp.CFrame = CFrame.new(center + offset, center)
            end
        end
    end)
end

local function stopAutoKill()
    if autoKillConn then autoKillConn:Disconnect(); autoKillConn = nil end
end

-- Auto Win Shark
local autoWinConn = nil
local sharksDescConn = nil
local DestructionParts = {}

local function addDestructionPart(part)
    table.insert(DestructionParts, part)
    part.AncestryChanged:Connect(function(_, parent)
        if not parent then
            for i = #DestructionParts, 1, -1 do
                if DestructionParts[i] == part then table.remove(DestructionParts, i); break end
            end
        end
    end)
end

local function getNearestSurvivorToPart(part)
    local nearest, nearestDist = nil, math.huge
    for _, plr in ipairs(Players:GetPlayers()) do
        if plr ~= Player and plr.Team and plr.Team.Name == "Survivor" then
            local char = plr.Character
            local h = char and char:FindFirstChild("HumanoidRootPart")
            if h and not h:FindFirstChild("Attachment") then
                local dist = (h.Position - part.Position).Magnitude
                if dist < nearestDist then nearestDist = dist; nearest = plr end
            end
        end
    end
    return nearest
end

local function startAutoWin()
    if autoWinConn then return end
    local sharksFolder = workspace:FindFirstChild("Sharks")
    if sharksFolder then
        for _, d in ipairs(sharksFolder:GetDescendants()) do
            if d:IsA("BasePart") and d.Name == "DestructionPart" then addDestructionPart(d) end
        end
        sharksDescConn = sharksFolder.DescendantAdded:Connect(function(desc)
            if desc:IsA("BasePart") and desc.Name == "DestructionPart" then addDestructionPart(desc) end
        end)
    end
    autoWinConn = RunService.Heartbeat:Connect(function()
        if Player.Team and Player.Team.Name == "Shark" and #DestructionParts > 0 then
            for i = #DestructionParts, 1, -1 do
                if not DestructionParts[i] or not DestructionParts[i].Parent then table.remove(DestructionParts, i) end
            end
            if #DestructionParts > 0 then
                local randomPart = DestructionParts[math.random(1, #DestructionParts)]
                local target = getNearestSurvivorToPart(randomPart)
                if randomPart and target and target.Character and target.Character:FindFirstChild("HumanoidRootPart") then
                    randomPart.CFrame = CFrame.new(target.Character.HumanoidRootPart.Position)
                end
            end
        end
    end)
end

local function stopAutoWin()
    if autoWinConn then autoWinConn:Disconnect(); autoWinConn = nil end
    if sharksDescConn then sharksDescConn:Disconnect(); sharksDescConn = nil end
    table.clear(DestructionParts)
end

-- Shark Nametags
local sharkTagConns = {}
local sharkTagEnabled = false

local function createSharkTag(sharkModel)
    if not sharkModel:IsA("Model") then return end
    local root = sharkModel:FindFirstChild("HumanoidRootPart") or sharkModel:FindFirstChild("RootPart") or sharkModel.PrimaryPart
    if not root then
        for _, p in ipairs(sharkModel:GetDescendants()) do
            if p:IsA("BasePart") then root = p; break end
        end
    end
    if not root then return end

    -- Remove existing
    for _, v in ipairs(root:GetChildren()) do
        if v.Name == "SharkTag" then v:Destroy() end
    end

    local bb = Instance.new("BillboardGui")
    bb.Name = "SharkTag"
    bb.Adornee = root
    bb.Size = UDim2.new(0, 180, 0, 24)
    bb.StudsOffset = Vector3.new(0, 6, 0)
    bb.AlwaysOnTop = true
    bb.MaxDistance = 9999
    bb.Parent = root

    local pill = Instance.new("Frame")
    pill.Size = UDim2.new(1, 0, 1, 0)
    pill.BackgroundColor3 = Color3.fromRGB(20, 20, 25)
    pill.BackgroundTransparency = 0.35
    pill.BorderSizePixel = 0
    pill.Parent = bb
    Instance.new("UICorner", pill).CornerRadius = UDim.new(1, 0)
    local stroke = Instance.new("UIStroke")
    stroke.Color = Color3.fromRGB(255, 60, 60)
    stroke.Thickness = 1
    stroke.Transparency = 0.5
    stroke.Parent = pill

    local label = Instance.new("TextLabel")
    label.Size = UDim2.new(1, -16, 1, 0)
    label.Position = UDim2.new(0, 8, 0, 0)
    label.BackgroundTransparency = 1
    label.RichText = true
    label.Font = Enum.Font.Gotham
    label.TextSize = 10
    label.TextColor3 = Color3.new(1, 1, 1)
    label.TextXAlignment = Enum.TextXAlignment.Center
    label.Parent = pill

    -- Update distance in label
    local distConn
    distConn = RunService.Heartbeat:Connect(function()
        if not sharkTagEnabled or not bb or not bb.Parent then
            if distConn then distConn:Disconnect() end
            return
        end
        if not root or not root.Parent then
            if distConn then distConn:Disconnect() end
            if bb and bb.Parent then bb:Destroy() end
            return
        end
        local dist = 0
        pcall(function()
            if Player.Character and Player.Character:FindFirstChild("HumanoidRootPart") then
                dist = math.floor((Player.Character.HumanoidRootPart.Position - root.Position).Magnitude)
            end
        end)
        label.Text = '<font color="#ff4444"><b>SHARK</b></font>  <font color="#888899">' .. sharkModel.Name .. '</font>  <font color="#ffaa44">[' .. dist .. 'm]</font>'
    end)
    table.insert(sharkTagConns, distConn)
end

local function removeSharkTags()
    local sharksFolder = workspace:FindFirstChild("Sharks")
    if sharksFolder then
        for _, d in ipairs(sharksFolder:GetDescendants()) do
            if d.Name == "SharkTag" and d:IsA("BillboardGui") then d:Destroy() end
        end
    end
end

local function enableSharkTags()
    sharkTagEnabled = true
    local sharksFolder = workspace:FindFirstChild("Sharks")
    if not sharksFolder then return end
    for _, shark in ipairs(sharksFolder:GetChildren()) do
        if shark:IsA("Model") then createSharkTag(shark) end
    end
    -- Watch for new sharks
    local addConn = sharksFolder.ChildAdded:Connect(function(child)
        if sharkTagEnabled and child:IsA("Model") then
            task.wait(0.3)
            createSharkTag(child)
        end
    end)
    table.insert(sharkTagConns, addConn)
end

local function disableSharkTags()
    sharkTagEnabled = false
    for _, conn in ipairs(sharkTagConns) do pcall(function() conn:Disconnect() end) end
    sharkTagConns = {}
    removeSharkTags()
end

-- Auto Vases (efficient - one at a time, nearest first, with cooldown)
local vaseLoopRunning = false

local function getAllVaseParts()
    local parts = {}
    local folder = workspace:FindFirstChild("Vases")
    if not folder then return parts end
    for _, d in ipairs(folder:GetDescendants()) do
        if d:IsA("TouchTransmitter") and d.Parent and d.Parent:IsA("BasePart") then
            table.insert(parts, d.Parent)
        end
    end
    return parts
end

local function getNearestVase(vases)
    if not Player.Character or not Player.Character:FindFirstChild("HumanoidRootPart") then return nil end
    local myPos = Player.Character.HumanoidRootPart.Position
    local nearest, nearestDist = nil, math.huge
    for _, part in ipairs(vases) do
        if part and part.Parent then
            local dist = (part.Position - myPos).Magnitude
            if dist < nearestDist then nearestDist = dist; nearest = part end
        end
    end
    return nearest
end

local function startAutoVases()
    if vaseLoopRunning then return end
    vaseLoopRunning = true
    task.spawn(function()
        while vaseLoopRunning and Enabled.AutoVases do
            local vases = getAllVaseParts()
            if #vases == 0 then
                task.wait(1)
            else
                local target = getNearestVase(vases)
                if target and target.Parent and Player.Character and Player.Character:FindFirstChild("HumanoidRootPart") then
                    Player.Character.HumanoidRootPart.CFrame = target.CFrame
                    task.wait(0.1)
                    pcall(function()
                        firetouchinterest(Player.Character.HumanoidRootPart, target, 0)
                        firetouchinterest(Player.Character.HumanoidRootPart, target, 1)
                    end)
                    task.wait(0.4)
                else
                    task.wait(0.5)
                end
            end
        end
    end)
end

local function stopAutoVases()
    vaseLoopRunning = false
end

-- Server-Side Vase Farm (uses game remotes directly — more reliable)
local serverVaseRunning = false

local function startServerVaseFarm()
    if serverVaseRunning then return end
    serverVaseRunning = true
    task.spawn(function()
        while serverVaseRunning and Enabled.ServerVaseFarm do
            pcall(function()
                local vasesFolder = workspace:FindFirstChild("Vases")
                if not vasesFolder then task.wait(1); return end

                local found = false
                for _, v in ipairs(vasesFolder:GetDescendants()) do
                    if not serverVaseRunning then break end
                    -- Match the vase mesh name the game uses
                    if v.Name == "Meshes/Vase smashed open 2_Cylinder.003" or (v:IsA("BasePart") and v.Parent and v.Parent:FindFirstChild("TouchInterest")) then
                        if Player.Character and Player.Character:FindFirstChild("HumanoidRootPart") then
                            Player.Character.HumanoidRootPart.CFrame = v.CFrame
                            task.wait(0.05)
                            -- Fire the server remotes directly
                            pcall(function()
                                ReplicatedStorage:WaitForChild("EventsFolder"):WaitForChild("Vases"):WaitForChild("VaseTouched"):InvokeServer()
                            end)
                            pcall(function()
                                ReplicatedStorage:WaitForChild("EventsFolder"):WaitForChild("Vases"):WaitForChild("VaseBroken"):FireServer()
                            end)
                            found = true
                            task.wait(0.15)
                        end
                    end
                end
                if not found then task.wait(1) end
            end)
            task.wait(0.1)
        end
    end)
end

local function stopServerVaseFarm()
    serverVaseRunning = false
end

-- Anti Sit (prevents getting knocked into seats)
