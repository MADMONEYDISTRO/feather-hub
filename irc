task.spawn(function()
    task.wait(0.5)

    addSystemMessage("Welcome, " .. DisplayName .. " (@" .. Username .. ")")
    syncMessages()

    -- Post join message to shared chat
    task.spawn(function()
        task.wait(1)
        local msgs = readMessages() or {}
        local t = os.date("*t")
        table.insert(msgs, {
            id       = string.format("%.0f", tick()*1000) .. "_join_" .. Username,
            user     = "System",
            username = "_system_",
            text     = DisplayName .. " (@" .. Username .. ") joined the chat",
            time     = string.format("%02d:%02d", t.hour, t.min),
            system   = true,
        })
        while #msgs > MAX_MSGS do table.remove(msgs, 1) end
        writeMessages(msgs)
    end)

    -- Poll loop
    while task.wait(POLL_RATE) do
        if not sg or not sg.Parent then break end
        syncMessages()
    end
end)
