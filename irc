-- ══════════════════════════════════════════
--  POLL & SYNC
-- ══════════════════════════════════════════

local function syncMessages()
    local msgs = readMessages()
    if not msgs then
        statusLbl.Text = "⚠ Could not reach jsonbin — retrying..."
        statusLbl.TextColor3 = C.error
        onlineDot.BackgroundColor3 = C.error
        return
    end

    onlineDot.BackgroundColor3 = C.success

    local seen = {}
    for _, m in ipairs(msgs) do
        if m.username and m.username ~= "_system_" then seen[m.username] = true end
    end
    local count = 0
    for _ in pairs(seen) do count = count + 1 end
    onlineLbl.Text = count .. (count == 1 and "" or "")
    onlineLbl.TextColor3 = C.success
    statusLbl.Text = "Connected  •  updates every " .. POLL_RATE .. "s"
    statusLbl.TextColor3 = C.muted

    for _, msg in ipairs(msgs) do
        if msg.id and msg.text and msg.username then
            addMessageBubble({
                id       = tostring(msg.id),
                user     = tostring(msg.user or msg.username),
                username = tostring(msg.username),
                text     = tostring(msg.text),
                time     = tostring(msg.time or ""),
                system   = (msg.system == true),
            })
        end
    end
end

