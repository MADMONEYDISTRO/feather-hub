-- ══════════════════════════════════════════
--  HTTP HELPER
-- ══════════════════════════════════════════

local function httpRequest(method, url, headers, body)
    body = body or ""
    local opts = { Url = url, Method = method, Headers = headers, Body = body }

    local function try(fn)
        if not fn then return nil end
        local ok, res = pcall(fn, opts)
        if ok and type(res) == "table" and res.Body and res.Body ~= "" then
            return res
        end
        return nil
    end

    local res = nil
    if not res then pcall(function() if syn and syn.request then res = try(syn.request) end end) end
    if not res then pcall(function() if http and http.request then res = try(http.request) end end) end
    if not res then pcall(function() if request then res = try(request) end end) end
    if not res then pcall(function() if fluxus and fluxus.request then res = try(fluxus.request) end end) end
    return res
end

-- ══════════════════════════════════════════
--  JSONBIN API  (Access Key only)
-- ══════════════════════════════════════════

local function readMessages()
    local res = httpRequest("GET", BASE_URL .. BIN_ID .. "/latest", {
        ["X-Access-Key"] = ACCESS_KEY,
        ["X-Bin-Meta"]   = "false",
    })
    if not res then return nil end

    local ok, data = pcall(HttpService.JSONDecode, HttpService, res.Body)
    if not ok or not data then return nil end

    local record = data.record or data
    if type(record) == "table" and type(record.messages) == "table" then
        return record.messages
    end
    return nil
end

local function writeMessages(msgs)
    local body = HttpService:JSONEncode({ messages = msgs })
    local res = httpRequest("PUT", BASE_URL .. BIN_ID, {
        ["Content-Type"] = "application/json",
        ["X-Access-Key"] = ACCESS_KEY,
    }, body)
    if not res then return false end
    local ok, data = pcall(HttpService.JSONDecode, HttpService, res.Body)
    return ok and data and not data["error"]
end

-- ══════════════════════════════════════════
--  SEND MESSAGE
-- ══════════════════════════════════════════

local isSending = false

local function sendMessage(text)
    text = tostring(text):match("^%s*(.-)%s*$")
    if text == "" or #text > 200 then return end
    if isSending then return end
    isSending = true

    local t       = os.date("*t")
    local msgId   = string.format("%.0f", tick() * 1000) .. "_" .. Username
    local timeStr = string.format("%02d:%02d", t.hour, t.min)

    -- Show locally immediately
    addMessageBubble({
        id = msgId, user = DisplayName, username = Username, text = text, time = timeStr,
    })
    textBox.Text = ""

    task.spawn(function()
        local msgs = readMessages() or {}
        table.insert(msgs, {
            id = msgId, user = DisplayName, username = Username, text = text, time = timeStr,
        })
        while #msgs > MAX_MSGS do table.remove(msgs, 1) end
        local success = writeMessages(msgs)
        if not success then
            addSystemMessage("⚠ Message may not have saved")
        end
        isSending = false
    end)
end

local function onSend()
    local txt = textBox.Text
    if txt and txt ~= "" then sendMessage(txt) end
end

sendBtn.MouseButton1Click:Connect(onSend)
