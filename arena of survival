-- Card factory
local function makeCard(parent, order)
    local c = Instance.new("Frame", parent)
    c.Size = UDim2.new(1, -8, 0, 0)
    c.AutomaticSize = Enum.AutomaticSize.Y
    c.BackgroundColor3 = Theme.card
    c.BorderSizePixel = 0
    c.LayoutOrder = order
    c.ZIndex = 3
    Instance.new("UICorner", c).CornerRadius = UDim.new(0, 10)
    local s = Instance.new("UIStroke", c)
    s.Color = Theme.border
    s.Thickness = 1
    local ll = Instance.new("UIListLayout", c)
    ll.SortOrder = Enum.SortOrder.LayoutOrder
    ll.HorizontalAlignment = Enum.HorizontalAlignment.Center
    return c
end

local function makeRow(card, order, isLast, height)
    local h = height or 46
    local row = Instance.new("Frame", card)
    row.Size = UDim2.new(1, 0, 0, h)
    row.BackgroundTransparency = 1
    row.BorderSizePixel = 0
    row.LayoutOrder = order
    row.ZIndex = 4
    if not isLast then
        local sep = Instance.new("Frame", row)
        sep.Size = UDim2.new(1, -28, 0, 1)
        sep.Position = UDim2.new(0, 14, 1, -1)
        sep.BackgroundColor3 = Theme.sep
        sep.BorderSizePixel = 0
        sep.ZIndex = 4
    end
    return row
end

local function makeSection(parent, label, order)
    local f = Instance.new("Frame", parent)
    f.Size = UDim2.new(1, -8, 0, 22)
    f.BackgroundTransparency = 1
    f.BorderSizePixel = 0
    f.LayoutOrder = order
    f.ZIndex = 3
    local lbl = Instance.new("TextLabel", f)
    lbl.Size = UDim2.new(1, 0, 1, 0)
    lbl.Text = string.upper(label)
    lbl.Font = Enum.Font.GothamBold
    lbl.TextSize = 8
    lbl.TextColor3 = Theme.accent
    lbl.TextXAlignment = Enum.TextXAlignment.Left
    lbl.BackgroundTransparency = 1
    lbl.ZIndex = 3
    local line = Instance.new("Frame", f)
    line.Size = UDim2.new(0, 28, 0, 2)
    line.Position = UDim2.new(0, 0, 1, -2)
    line.BackgroundColor3 = Theme.accent
    line.BorderSizePixel = 0
    line.ZIndex = 3
    Instance.new("UICorner", line).CornerRadius = UDim.new(1, 0)
    return f
end

local function CreateToggle(parent, order, title, desc, getter, setter, isLast)
    local row = makeRow(parent, order, isLast, 48)
    local strip = Instance.new("Frame", row)
    strip.Size = UDim2.new(0, 3, 0.45, 0)
    strip.Position = UDim2.new(0, 0, 0.275, 0)
    local init = getter()
    strip.BackgroundColor3 = init and Theme.accent or Theme.sep
    strip.BorderSizePixel = 0
    strip.ZIndex = 5
    Instance.new("UICorner", strip).CornerRadius = UDim.new(1, 0)

    local titleLbl = Instance.new("TextLabel", row)
    titleLbl.Size = UDim2.new(0.65, -20, 0, 18)
    titleLbl.Position = UDim2.new(0, 16, 0, 8)
    titleLbl.BackgroundTransparency = 1
    titleLbl.Text = title
    titleLbl.TextColor3 = Theme.text
    titleLbl.Font = Enum.Font.GothamSemibold
    titleLbl.TextSize = 11
    titleLbl.TextXAlignment = Enum.TextXAlignment.Left
    titleLbl.ZIndex = 5

    local toggleBg = Instance.new("Frame", row)
    toggleBg.Size = UDim2.new(0, 44, 0, 22)
    toggleBg.Position = UDim2.new(1, -60, 0.5, -11)
    toggleBg.BackgroundColor3 = init and Theme.toggleOn or Theme.toggleOff
    toggleBg.BorderSizePixel = 0
    toggleBg.ZIndex = 5
    Instance.new("UICorner", toggleBg).CornerRadius = UDim.new(1, 0)
    local toggleStroke = Instance.new("UIStroke", toggleBg)
    toggleStroke.Color = init and Theme.accent or Theme.sep
    toggleStroke.Thickness = 1

    local toggleKnob = Instance.new("Frame", toggleBg)
    toggleKnob.Size = UDim2.new(0, 16, 0, 16)
    toggleKnob.Position = init and UDim2.new(1, -19, 0.5, -8) or UDim2.new(0, 3, 0.5, -8)
    toggleKnob.BackgroundColor3 = Color3.new(1, 1, 1)
    toggleKnob.BorderSizePixel = 0
    toggleKnob.ZIndex = 6
    Instance.new("UICorner", toggleKnob).CornerRadius = UDim.new(1, 0)

    local hitBtn = Instance.new("TextButton", row)
    hitBtn.Size = UDim2.new(0, 60, 0, 30)
    hitBtn.Position = UDim2.new(1, -70, 0.5, -15)
    hitBtn.BackgroundTransparency = 1
    hitBtn.Text = ""
    hitBtn.ZIndex = 7

    hitBtn.MouseButton1Click:Connect(function()
        local newState = not getter()
        setter(newState)
        local on = getter()
        local newBg, newStroke, newStripBg, newPos
        if on then
            newBg = Theme.toggleOn
            newStroke = Theme.accent
            newStripBg = Theme.accent
            newPos = UDim2.new(1, -19, 0.5, -8)
        else
            newBg = Theme.toggleOff
            newStroke = Theme.sep
            newStripBg = Theme.sep
            newPos = UDim2.new(0, 3, 0.5, -8)
        end
        TweenService:Create(toggleBg, tw(0.2), {BackgroundColor3 = newBg}):Play()
        TweenService:Create(toggleStroke, tw(0.2), {Color = newStroke}):Play()
        TweenService:Create(toggleKnob, tw(0.2, Enum.EasingStyle.Back), {Position = newPos}):Play()
        TweenService:Create(strip, tw(0.2), {BackgroundColor3 = newStripBg}):Play()
    end)
    return row
end

