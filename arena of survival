-- ESP Categories
local healthItems = {"Medkit"}
local weaponItems = {"Hammer", "Knife", "Mace", "Torch", "Spear", "Kunai", "Bow", "Bottle", "ArrowsDrop"}
local foodItems = {"Darkberry", "Raw Meat", "Bread", "Firewood"}

local espStates = {
    Health = false,
    Weapons = false,
    Food = false,
}

-- Helper to find Loot folder and ignore Cornocopia
local function getLootFolder()
    return Workspace:FindFirstChild("Loot")
end

local function shouldIgnore(item)
    return item.Name == "Cornocopia"
end

local function createESP(item, category)
    if shouldIgnore(item) then return end
    local folder = item:FindFirstChild("ESP_"..category)
    if not folder then
        folder = Instance.new("Folder")
        folder.Name = "ESP_"..category
        folder.Parent = item

        local bgui = Instance.new("BillboardGui")
        bgui.Name = "NameTag"
        bgui.Size = UDim2.new(0, 200, 0, 50)
        bgui.StudsOffset = Vector3.new(0, 2, 0)
        bgui.AlwaysOnTop = true
        bgui.Enabled = true
        bgui.Parent = folder
        bgui.Adornee = item

        local textLabel = Instance.new("TextLabel")
        textLabel.Size = UDim2.new(1, 0, 1, 0)
        textLabel.BackgroundTransparency = 1
        textLabel.TextColor3 = Color3.fromRGB(195, 160, 60)  -- Gold, matches UI accent
        textLabel.TextStrokeTransparency = 0
        textLabel.Text = item.Name
        textLabel.Font = Enum.Font.GothamBold
        textLabel.TextSize = 12
        textLabel.Parent = bgui
    end
end

local function removeESP(item, category)
    local folder = item:FindFirstChild("ESP_"..category)
    if folder then
        folder:Destroy()
    end
end

local function clearCategory(category)
    local loot = getLootFolder()
    if not loot then return end
    for _, item in pairs(loot:GetChildren()) do
        if item:IsA("BasePart") or item:IsA("Model") then
            removeESP(item, category)
        end
    end
end

local function refreshCategory(category)
    local loot = getLootFolder()
    if not loot then return end
    local itemsList
    if category == "Health" then
        itemsList = healthItems
    elseif category == "Weapons" then
        itemsList = weaponItems
    elseif category == "Food" then
        itemsList = foodItems
    else
        return
    end

    for _, item in pairs(loot:GetChildren()) do
        if (item:IsA("BasePart") or item:IsA("Model")) and not shouldIgnore(item) then
            local match = false
            for _, name in ipairs(itemsList) do
                if item.Name == name then
                    match = true
                    break
                end
            end
            if match then
                if espStates[category] then
                    createESP(item, category)
                else
                    removeESP(item, category)
                end
            end
        end
    end
end

-- Watch for new items
local lootFolder = getLootFolder()
if lootFolder then
    lootFolder.ChildAdded:Connect(function(child)
        if espStates.Health then
            for _, name in ipairs(healthItems) do
                if child.Name == name then
                    createESP(child, "Health")
                    break
                end
            end
        end
        if espStates.Weapons then
            for _, name in ipairs(weaponItems) do
                if child.Name == name then
                    createESP(child, "Weapons")
                    break
                end
            end
        end
        if espStates.Food then
            for _, name in ipairs(foodItems) do
                if child.Name == name then
                    createESP(child, "Food")
                    break
                end
            end
        end
    end)
end

