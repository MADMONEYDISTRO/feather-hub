task.spawn(function()
    while task.wait(0.01) do
        if getgenv().triggerbotEnabled then
            local ray = Camera:ScreenPointToRay(Mouse.X, Mouse.Y, 1)
            local hit = Workspace:FindPartOnRayWithIgnoreList(Ray.new(ray.Origin, ray.Direction * getgenv().maxDistance2), {LocalPlayer.Character, Camera})
            if hit then
                local char = hit:FindFirstChildOfClass("Humanoid") and hit.Parent or hit
                if char and char:FindFirstChildOfClass("Humanoid") and not isTeammate(char) then
                    local dist = (char.HumanoidRootPart.Position - (LocalPlayer.Character and LocalPlayer.Character.HumanoidRootPart.Position)).magnitude
                    if dist <= getgenv().maxDistance2 then
                        VirtualInputManager:SendMouseButtonEvent(0,0,0,true,game,1)
                        VirtualInputManager:SendMouseButtonEvent(0,0,0,false,game,1)
                        task.wait(getgenv().checkInterval)
                    end
                end
            end
        end
    end
end)

-- Anti Aim
local antiAimConn
function toggleAntiAim(state)
    if state then
        antiAimConn = RunService.RenderStepped:Connect(function()
            local nearest, minDist = nil, getgenv().AntiAimMaxRadius
            for _, plr in ipairs(Players:GetPlayers()) do
                if plr ~= LocalPlayer and plr.Character then
                    local hrp = plr.Character:FindFirstChild("HumanoidRootPart")
                    if hrp and not (getgenv().antiaimTeamCheck and isTeammate(plr.Character)) then
                        local dist = (LocalPlayer.Character and LocalPlayer.Character.HumanoidRootPart.Position - hrp.Position).magnitude
                        if dist < minDist then nearest = hrp; minDist = dist end
                    end
                end
            end
            if nearest then
                local root = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
                if root then
                    root.CFrame = CFrame.new(nearest.Position - nearest.CFrame.LookVector * getgenv().AttachDistance + Vector3.new(0, getgenv().offsetY, 0), nearest.Position)
                end
            end
        end)
    else
        if antiAimConn then antiAimConn:Disconnect() antiAimConn = nil end
    end
end

