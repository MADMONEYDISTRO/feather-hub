        autoQueueConn = RunService.Heartbeat:Connect(function()
            if not isPlayerInArea() then
                ReplicatedStorage.Remotes.Matchmaking.JoinQueue:InvokeServer(getgenv().QueueModeSelect)
            end
            task.wait(12)
