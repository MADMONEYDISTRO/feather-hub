local autoKillConn
function toggleAutoKill(state)
    if state then
        autoKillConn = RunService.Heartbeat:Connect(function()
            local nearest, minDist = nil, getgenv().AutoKillMaxRadius
            for _, plr in ipairs(Players:GetPlayers()) do
                if plr ~= LocalPlayer and plr.Character then
                    local hrp = plr.Character:FindFirstChild("HumanoidRootPart")
                    if hrp and not isTeammate(plr.Character) then
                        local dist = (LocalPlayer.Character.HumanoidRootPart.Position - hrp.Position).magnitude
                        if dist < minDist then nearest = hrp; minDist = dist end
                    end
                end
            end
            if nearest then
                local root = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
                if root then
                    root.CFrame = CFrame.new(nearest.Position - nearest.CFrame.LookVector * math.abs(getgenv().offsetZ) + Vector3.new(0, getgenv().offsetY, 0), nearest.Position)
                    VirtualInputManager:SendMouseButtonEvent(0,0,0,true,game,1)
                    VirtualInputManager:SendMouseButtonEvent(0,0,0,false,game,1)
                end
            end
        end)
    else
        if autoKillConn then autoKillConn:Disconnect() autoKillConn = nil end
    end
end

