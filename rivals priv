function UI:AddSlider(parent, text, min, max, def, inc, callback)
    local card = Instance.new("Frame"); card.Size = UDim2.new(1,0,0,60); card.BackgroundColor3 = T.card
    card.BorderSizePixel = 0; card.LayoutOrder = nextOrder(); card.Parent = parent
    Instance.new("UICorner", card).CornerRadius = UDim.new(0,11)
    Instance.new("UIStroke", card).Color = T.border; card.UIStroke.Thickness = 1
    local lbl = Instance.new("TextLabel"); lbl.Size = UDim2.new(0.45,0,0,20); lbl.Position = UDim2.new(0,16,0,8)
    lbl.Text = text; lbl.Font = Enum.Font.GothamSemibold; lbl.TextSize = 10; lbl.TextColor3 = T.text
    lbl.BackgroundTransparency = 1; lbl.Parent = card
    local valLbl = Instance.new("TextLabel"); valLbl.Size = UDim2.new(0,40,0,20); valLbl.Position = UDim2.new(1,-52,0,8)
    valLbl.Text = tostring(def); valLbl.Font = Enum.Font.GothamBold; valLbl.TextSize = 9; valLbl.TextColor3 = T.accent
    valLbl.BackgroundTransparency = 1; valLbl.Parent = card
    local track = Instance.new("Frame"); track.Size = UDim2.new(1,-32,0,6); track.Position = UDim2.new(0,16,0,38)
    track.BackgroundColor3 = T.dim; track.BorderSizePixel = 0; track.Parent = card
    Instance.new("UICorner", track).CornerRadius = UDim.new(1,0)
    local fill = Instance.new("Frame"); fill.Size = UDim2.new((def-min)/(max-min),0,1,0); fill.BackgroundColor3 = T.accent
    fill.BorderSizePixel = 0; fill.Parent = track; Instance.new("UICorner", fill).CornerRadius = UDim.new(1,0)
    local knob = Instance.new("TextButton"); knob.Size = UDim2.new(0,14,0,14); knob.Position = UDim2.new((def-min)/(max-min),-7,0.5,-7)
    knob.BackgroundColor3 = Color3.new(1,1,1); knob.BorderSizePixel = 0; knob.AutoButtonColor = false; knob.Text = ""
    knob.Parent = track; Instance.new("UICorner", knob).CornerRadius = UDim.new(1,0)
    local dragging = false
    local function setVal(r)
        local val = math.clamp(min + r*(max-min), min, max)
        if inc then val = math.round(val/inc)*inc end
        fill.Size = UDim2.new((val-min)/(max-min),0,1,0)
        knob.Position = UDim2.new((val-min)/(max-min),-7,0.5,-7)
        valLbl.Text = tostring(val)
        callback(val)
    end
    knob.InputBegan:Connect(function(i) if i.UserInputType == Enum.UserInputType.MouseButton1 or i.UserInputType == Enum.UserInputType.Touch then dragging = true end end)
    UserInputService.InputEnded:Connect(function(i) if i.UserInputType == Enum.UserInputType.MouseButton1 or i.UserInputType == Enum.UserInputType.Touch then dragging = false end end)
    UserInputService.InputChanged:Connect(function(i) if dragging and (i.UserInputType == Enum.UserInputType.MouseMovement or i.UserInputType == Enum.UserInputType.Touch) then
        local ap = track.AbsolutePosition.X; local az = track.AbsoluteSize.X
        setVal(math.clamp((i.Position.X - ap)/az, 0, 1)) end end)
    setVal((def-min)/(max-min))
end

