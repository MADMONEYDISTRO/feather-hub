function isPlayerInArea()
    local char = LocalPlayer.Character; if not char then return false end
    local hrp = char:FindFirstChild("HumanoidRootPart"); if not hrp then return false end
    local min = Vector3.new(-120, -678.25, 1138.94995)
    local max = Vector3.new(-117.83525085449219, -682.286376953125, 1338.8934326171875)
    local pos = hrp.Position
    return pos.X >= min.X and pos.X <= max.X and pos.Y >= min.Y and pos.Y <= max.Y and pos.Z >= min.Z and pos.Z <= max.Z
end

