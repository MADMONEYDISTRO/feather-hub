        r,g,b = math.clamp(r,0,255), math.clamp(g,0,255), math.clamp(b,0,255)
        apply()
    end)
    apply()
end

function UI:AddKeybind(parent, text, defaultKey, hold, callback)
    local card = Instance.new("Frame"); card.Size = UDim2.new(1,0,0,44); card.BackgroundColor3 = T.card
    card.BorderSizePixel = 0; card.LayoutOrder = nextOrder(); card.Parent = parent
    Instance.new("UICorner", card).CornerRadius = UDim.new(0,11)
    Instance.new("UIStroke", card).Color = T.border; card.UIStroke.Thickness = 1
    local lbl = Instance.new("TextLabel"); lbl.Size = UDim2.new(0.45,0,1,0); lbl.Position = UDim2.new(0,16,0,0)
    lbl.Text = text; lbl.Font = Enum.Font.GothamSemibold; lbl.TextSize = 10; lbl.TextColor3 = T.text
    lbl.BackgroundTransparency = 1; lbl.Parent = card
    local bindBtn = Instance.new("TextButton"); bindBtn.Size = UDim2.new(0,100,0,28); bindBtn.Position = UDim2.new(1,-108,0.5,-14)
    bindBtn.Text = tostring(defaultKey); bindBtn.Font = Enum.Font.GothamBold; bindBtn.TextSize = 9; bindBtn.TextColor3 = T.text
    bindBtn.BackgroundColor3 = T.dim; bindBtn.BorderSizePixel = 0; bindBtn.AutoButtonColor = false; bindBtn.Parent = card
    Instance.new("UICorner", bindBtn).CornerRadius = UDim.new(0,6)
    local curKey = defaultKey
    bindBtn.MouseButton1Click:Connect(function()
        local waiting = true
        local conn = UserInputService.InputBegan:Connect(function(input)
            if waiting and input.KeyCode ~= Enum.KeyCode.Unknown then
                curKey = input.KeyCode; bindBtn.Text = tostring(curKey); waiting = false; conn:Disconnect()
            end
        end)
    end)
    UserInputService.InputBegan:Connect(function(input)
        if input.KeyCode == curKey then callback() end
    end)
end

