-- ====================== HELPERS ======================
local function getRoot()
    local char = plr.Character
    return char and char:FindFirstChild("HumanoidRootPart")
end

local function getHum()
    local char = plr.Character
    return char and char:FindFirstChildWhichIsA("Humanoid")
end

-- Simulate a click at the centre of the screen (for prompt buttons)
local function clickCenter()
    local cam = Workspace.CurrentCamera
    if not cam then return end
    local vs = cam.ViewportSize
    local x, y = vs.X / 2, vs.Y / 2
    VirtualInputManager:SendMouseButtonEvent(x, y, 0, true, game)
    task.wait(0.05)
    VirtualInputManager:SendMouseButtonEvent(x, y, 0, false, game)
end

-- ====================== FARM LOOPS ======================
-- Strength Farm
local function strengthFarm()
    task.spawn(function()
        while Settings.StrengthFarm do
            local root = getRoot()
            if not root then task.wait(0.5); continue end

            pcall(function()
                root.CFrame = CFrame.new(5385, 37, -2857)
                for _, item in ipairs(workspace.Areas.Area29_Bank.DraggableItems:GetDescendants()) do
                    if not Settings.StrengthFarm then break end
                    if item.Name:find("Safe") then
                        for _, child in ipairs(item:GetDescendants()) do
                            if not Settings.StrengthFarm then break end
                            if child.Name == "InteractionPoint" and child:FindFirstChild("ProximityPrompt") then
                                root = getRoot()
                                if not root then break end
                                root.CFrame = CFrame.new(child.Position) * CFrame.Angles(math.rad(-90), 0, 0)
                                VirtualInputManager:SendKeyEvent(true, Enum.KeyCode.E, false, game)
                                task.wait(0.1)
                                VirtualInputManager:SendKeyEvent(false, Enum.KeyCode.E, false, game)
                                fireproximityprompt(child.ProximityPrompt)
                                task.wait(0.2)
                            end
                        end
                    end
                end
                workspace.Areas.Area29_Bank.Goal.CFrame = root.CFrame * CFrame.new(0, 0, 100)
                task.wait(0.5)
                workspace.Areas.Area29_Bank.Goal.CFrame = root.CFrame
            end)
            task.wait(0.5)
        end
    end)
end

-- Workout Boost (auto-click + prompt)
local function workoutBoost()
    task.spawn(function()
        while Settings.WorkoutBoost do
            local root = getRoot()
            if not root then task.wait(0.5); continue end

            pcall(function()
                for _, prompt in ipairs(workspace.Areas.Area29_Bank.Gym:GetDescendants()) do
                    if not Settings.WorkoutBoost then break end
                    if prompt:IsA("ProximityPrompt") then
                        root = getRoot()
                        if not root then break end
                        root.CFrame = CFrame.new(prompt.Parent.Position)
                        prompt.HoldDuration = 0
                        task.wait(0.15) -- wait for prompt to appear
                        clickCenter()    -- click the centre of the screen
                        task.wait(0.05)
                        fireproximityprompt(prompt, 1, true)
                        task.wait(0.15)
                    end
                end
                if Settings.WorkoutBoost then
                    ReplicatedStorage.StrongMan_UpgradeStrength:InvokeServer(100, "Default")
                    task.wait(0.8)
                end
            end)
        end
        local hum = getHum()
        if hum then hum.Jump = true end
    end)
end

-- Auto Rebirth
local function autoRebirth()
    task.spawn(function()
        while Settings.AutoRebirth do
            pcall(function()
                ReplicatedStorage.StrongMan_Rebirth:FireServer()
            end)
            task.wait(6)
        end
    end)
end

-- Buy Bank Pets
local function buyPets()
    task.spawn(function()
        while Settings.BuyPets do
            pcall(function()
                ReplicatedStorage.TGSPetShopRoll:InvokeServer("28Bank")
            end)
            task.wait(2)
        end
    end)
end

