local function updateSearch(query)
    local children = srScroll:GetChildren()
    for i = 1, #children do
        local c = children[i]
        if c:IsA("Frame") or c:IsA("TextButton") or c:IsA("TextLabel") then c:Destroy() end
    end
    query = query:lower():gsub("^%s+", ""):gsub("%s+$", "")
    if query == "" then srPanel.Visible = false; return end
    local matches = {}
    for i = 1, #FeatureRegistry do
        local e = FeatureRegistry[i]
        if e.label:lower():find(query, 1, true) then table.insert(matches, e) end
    end
    if #matches == 0 then
        local noRes = Instance.new("TextLabel", srScroll)
        noRes.Size = UDim2.new(1, -8, 0, 32); noRes.Text = 'No results for "' .. query .. '"'
        noRes.Font = Enum.Font.Gotham; noRes.TextSize = 9; noRes.TextColor3 = Theme.muted
        noRes.BackgroundTransparency = 1; noRes.ZIndex = 42; noRes.LayoutOrder = 1
    else
        for idx = 1, #matches do
            local e = matches[idx]; local tabName = TAB_NAMES[e.tab] or "?"
            local row = Instance.new("Frame", srScroll)
            row.Size = UDim2.new(1, -4, 0, 34); row.BackgroundColor3 = Theme.dim; row.BorderSizePixel = 0; row.ZIndex = 42; row.LayoutOrder = idx
            Instance.new("UICorner", row).CornerRadius = UDim.new(0, 6)
            local hitbox = Instance.new("TextButton", row)
            hitbox.Size = UDim2.new(1, 0, 1, 0); hitbox.BackgroundTransparency = 1; hitbox.Text = ""; hitbox.ZIndex = 43
            local nameLbl = Instance.new("TextLabel", row)
            nameLbl.Size = UDim2.new(0.65, 0, 1, 0); nameLbl.Position = UDim2.new(0, 10, 0, 0)
            nameLbl.Text = e.label; nameLbl.Font = Enum.Font.GothamSemibold; nameLbl.TextSize = 10
            nameLbl.TextColor3 = Theme.text; nameLbl.TextXAlignment = Enum.TextXAlignment.Left; nameLbl.BackgroundTransparency = 1; nameLbl.ZIndex = 43
            local badge = Instance.new("TextLabel", row)
            badge.Size = UDim2.new(0, 64, 0, 18); badge.Position = UDim2.new(1, -70, 0.5, -9)
            badge.Text = tabName; badge.Font = Enum.Font.GothamBold; badge.TextSize = 8
            badge.TextColor3 = Theme.accent; badge.BackgroundColor3 = Theme.accentDim; badge.BackgroundTransparency = 0.5; badge.BorderSizePixel = 0; badge.ZIndex = 43
            Instance.new("UICorner", badge).CornerRadius = UDim.new(0, 4)
            hitbox.MouseEnter:Connect(function() TweenService:Create(row, tw(0.1), {BackgroundColor3 = Theme.accentDim}):Play() end)
            hitbox.MouseLeave:Connect(function() TweenService:Create(row, tw(0.1), {BackgroundColor3 = Theme.dim}):Play() end)
            local capturedTab = e.tab
            hitbox.MouseButton1Click:Connect(function()
                searchBox.Text = ""; srPanel.Visible = false
                for i = 1, #tabBtns do
                    if tabBtns[i].Text == TAB_NAMES[capturedTab] then tabBtns[i].MouseButton1Click:Fire(); break end
                end
            end)
        end
    end
    local absPos = searchFrame.AbsolutePosition; local absSize = searchFrame.AbsoluteSize
    srPanel.Position = UDim2.new(0, absPos.X, 0, absPos.Y + absSize.Y + 4)
    srPanel.Size = UDim2.new(0, absSize.X, 0, math.min(#matches, 5) * 36 + 8)
    srPanel.Visible = true
end
