        else newBg = Theme.toggleOff; newStroke = Theme.sep; newStripBg = Theme.sep; newPos = UDim2.new(0, 3, 0.5, -8) end
        TweenService:Create(toggleBg, tw(0.2), {BackgroundColor3 = newBg}):Play()
        TweenService:Create(toggleStroke, tw(0.2), {Color = newStroke}):Play()
        TweenService:Create(toggleKnob, tw(0.2, Enum.EasingStyle.Back), {Position = newPos}):Play()
        TweenService:Create(strip, tw(0.2), {BackgroundColor3 = newStripBg}):Play()
    end)
    return row
end

local function CreateKeybind(parent, order, title, getter, setter, isLast, tabIdx)
    registerFeature(title, tabIdx)
    local row = makeRow(parent, order, isLast, 48)
    local titleLbl = Instance.new("TextLabel", row)
    titleLbl.Size = UDim2.new(0.5, -16, 0, 18); titleLbl.Position = UDim2.new(0, 16, 0, 8)
    titleLbl.BackgroundTransparency = 1; titleLbl.Text = title; titleLbl.TextColor3 = Theme.text; titleLbl.Font = Enum.Font.GothamSemibold; titleLbl.TextSize = 11
    titleLbl.TextXAlignment = Enum.TextXAlignment.Left; titleLbl.ZIndex = 5
    local keyBtn = Instance.new("TextButton", row)
    keyBtn.Size = UDim2.new(0, 80, 0, 28); keyBtn.Position = UDim2.new(1, -96, 0.5, -14)
    keyBtn.BackgroundColor3 = Theme.accentDim; keyBtn.Text = "[" .. tostring(getter()):match("KeyCode%.(.+)") .. "]"
    keyBtn.TextColor3 = Color3.new(1, 1, 1); keyBtn.Font = Enum.Font.GothamBold; keyBtn.TextSize = 9
    keyBtn.BorderSizePixel = 0; keyBtn.AutoButtonColor = false; keyBtn.ZIndex = 5
    Instance.new("UICorner", keyBtn).CornerRadius = UDim.new(0, 6)

    local function captureKey()
        keyBtn.Text = "Press a key..."
        local conn
        conn = UserInputService.InputBegan:Connect(function(input, gp)
            if gp then return end
            if input.UserInputType == Enum.UserInputType.Keyboard then
                setter(input.KeyCode)
                keyBtn.Text = "[" .. tostring(input.KeyCode):match("KeyCode%.(.+)") .. "]"
                conn:Disconnect()
            end
        end)
    end
    keyBtn.MouseButton1Click:Connect(captureKey)
    return row
end

local function CreateLabel(parent, order, text, tabIdx)
    registerFeature(text, tabIdx)
    local row = makeRow(parent, order, true, 32)
    local lbl = Instance.new("TextLabel", row)
    lbl.Size = UDim2.new(1, 0, 1, 0); lbl.BackgroundTransparency = 1
    lbl.Text = text; lbl.Font = Enum.Font.Gotham; lbl.TextSize = 10
    lbl.TextColor3 = Theme.muted; lbl.TextXAlignment = Enum.TextXAlignment.Center
    return row
end

