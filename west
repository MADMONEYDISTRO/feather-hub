    box.Size = UDim2.new(1,-28,0,32)
    box.Position = UDim2.new(0,14,0.5,-16)
    box.PlaceholderText = placeholder
    box.Text = default or ""
    box.Font = Enum.Font.GothamMedium
    box.TextSize = 11
    box.TextColor3 = T.text
    box.PlaceholderColor3 = T.muted
    box.BackgroundColor3 = T.inputBg
    box.BorderSizePixel = 0
    box.ZIndex = 5
    box.Parent = card
    Instance.new("UICorner", box).CornerRadius = UDim.new(0,8)
    local strokeBox = Instance.new("UIStroke")
    strokeBox.Color = T.border
    strokeBox.Thickness = 1
    strokeBox.Parent = box
    box.Focused:Connect(function()
        TweenService:Create(strokeBox, tw(), {Color = T.accent, Thickness = 1.5}):Play()
    end)
    box.FocusLost:Connect(function()
        TweenService:Create(strokeBox, tw(), {Color = T.border, Thickness = 1}):Play()
        if callback then callback(box.Text) end
    end)
    return box
end

