UI:AddSection(tabFarm, "Legendary / Thunderstruck")
UI:AddButton(tabFarm, "Legendary / Thunderstruck ESP", function()
    local function scanAnimals()
        local found = {}
        for _,animal in next, Workspace.WORKSPACE_Entities.Animals:GetChildren() do
            if animal:IsA("Model") and animal:FindFirstChild("Health") then
                local hp = animal.Health.Value
                if hp > 480 then
                    local ty = hp <= 700 and "Legendary" or "Thunderstruck"
                    table.insert(found, {model=animal, type=ty, color=hp<=700 and T.gold or T.green})
                end
            end
        end
        for _,desc in next, Workspace.WORKSPACE_Geometry:GetDescendants() do
            if desc:IsA("ParticleEmitter") and desc.Name == "Strike2" then
                local tree = desc.Parent.Parent
                if tree and tree.PrimaryPart then
                    table.insert(found, {model=tree, type="Thunderstruck Tree", color=T.green})
                end
            end
        end
        return found
    end
    local drawings = {}
    local function addDraw(model, ty, color)
        local txt = Drawing.new("Text"); txt.Size = 16; txt.Center = true; txt.Outline = true; txt.Color = color; txt.Font = 3
        local distTxt = Drawing.new("Text"); distTxt.Size = 14; distTxt.Center = true; distTxt.Outline = true; distTxt.Color = T.muted; distTxt.Font = 3
        table.insert(drawings, {model=model, text=txt, dist=distTxt, type=ty})
    end
    for _,v in ipairs(scanAnimals()) do addDraw(v.model, v.type, v.color) end
    RunService.RenderStepped:Connect(function()
        local root = LocalPlayer.Character and LocalPlayer.Character.PrimaryPart
        for _,d in ipairs(drawings) do
            if d.model.Parent and d.model.PrimaryPart then
                local pos,vis = Workspace.CurrentCamera:WorldToViewportPoint(d.model.PrimaryPart.Position)
                if vis then
                    d.text.Position = Vector2.new(pos.X, pos.Y)
                    d.text.Text = d.type
                    d.text.Visible = true
                    if root then
                        d.dist.Position = d.text.Position + Vector2.new(0, 14)
                        d.dist.Text = "["..math.round((root.Position - d.model.PrimaryPart.Position).magnitude).."m]"
                        d.dist.Visible = true
                    end
                else d.text.Visible = false; d.dist.Visible = false end
            else d.text.Visible = false; d.dist.Visible = false end
        end
    end)
end)

