-- Ore ESP (unified, includes both mining deposits and ReplicatedStorage.Resources.Items.Ore)
local oreColors = {
    Gold = T.accent,
    Silver = T.accentLt,
    Limestone = T.dim,
    Iron = T.accentDim,
    Zinc = T.muted,
    Copper = T.special,
    Coal = T.border,
    Ruby = Color3.fromRGB(210,75,95), -- red-ish
    Sapphire = Color3.fromRGB(0,150,255),
    Quartz = Color3.fromRGB(200,200,200),
    Emerald = Color3.fromRGB(0,200,100),
    Dubloons = Color3.fromRGB(255,200,0),
    Amethyst = Color3.fromRGB(170,0,255),
    Diamond = Color3.fromRGB(185,242,255),
}

local oreDrawings = {}  -- [oreName] = { {square=..., text=...}, ... }
local oreESPActive = {}  -- [oreName] = bool
local allESPToggle = false

local function scanOreFolder(name)
    -- First check mining deposits
    local miningFolder = Workspace.WORKSPACE_Interactables and Workspace.WORKSPACE_Interactables.Mining and Workspace.WORKSPACE_Interactables.Mining.OreDeposits:FindFirstChild(name)
    if miningFolder then
        for _, dep in next, miningFolder:GetDescendants() do
            if dep:IsA("Model") and dep.PrimaryPart then
                local sq = Drawing.new("Square")
                sq.Thickness = 2; sq.Filled = false; sq.Color = oreColors[name] or T.accent
                local txt = Drawing.new("Text")
                txt.Text = name; txt.Size = 14; txt.Color = oreColors[name] or T.accent
                table.insert(oreDrawings[name], {square=sq, text=txt, model=dep})
            end
        end
    end
    -- Then check ReplicatedStorage.Resources.Items.Ore
    local rsFolder = ReplicatedStorage:FindFirstChild("Resources") and ReplicatedStorage.Resources:FindFirstChild("Items") and ReplicatedStorage.Resources.Items:FindFirstChild("Ore")
    if rsFolder then
        local oreParent = rsFolder:FindFirstChild(name)
        if oreParent then
            for _, oreObj in next, oreParent:GetDescendants() do
                if oreObj:IsA("Model") and oreObj.PrimaryPart then
                    local sq = Drawing.new("Square")
                    sq.Thickness = 2; sq.Filled = false; sq.Color = oreColors[name] or T.accent
                    local txt = Drawing.new("Text")
                    txt.Text = name; txt.Size = 14; txt.Color = oreColors[name] or T.accent
                    table.insert(oreDrawings[name], {square=sq, text=txt, model=oreObj})
                end
            end
        end
    end
end

