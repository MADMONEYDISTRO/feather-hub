                ry = math.clamp(ry - delta.Y * 0.3, -80, 80)
            end
            cam.CFrame = target.PrimaryPart.CFrame * CFrame.Angles(0, math.rad(rx), 0) * CFrame.Angles(math.rad(ry), 0, 0) * CFrame.new(0, 0, 10)
