UI:AddSection(tabFarm, "Animal Cheat")
UI:AddButton(tabFarm, "Animal Silent Aim", function()
    local mouse = LocalPlayer:GetMouse()
    local cam = Workspace.CurrentCamera
    local oldHit = require(ReplicatedStorage.SharedModules.Global).Utils.GetMouseHit
    require(ReplicatedStorage.SharedModules.Global).Utils.GetMouseHit = function(self, ...)
        local nearestAnimal = nil
        local minDist = math.huge
        for _, animal in next, Workspace.WORKSPACE_Entities.Animals:GetChildren() do
            if animal:IsA("Model") and animal:FindFirstChild("Body") then
                local screenPos, onScreen = cam:WorldToViewportPoint(animal.Body.Position)
                if onScreen then
                    local mousePos = Vector2.new(mouse.X, mouse.Y)
                    local animalPos = Vector2.new(screenPos.X, screenPos.Y)
                    local dist = (animalPos - mousePos).Magnitude
                    if dist < minDist then
                        minDist = dist
                        nearestAnimal = animal
                    end
                end
            end
        end
        if nearestAnimal then
            return nearestAnimal.Body.Position
        else
            return oldHit(self, ...)
        end
    end
end)

