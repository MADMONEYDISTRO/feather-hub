local function getCurrency() return CurrencyCmds.Get(WorldsUtil.GetWorld().MapName == "World 1" and "Coins" or WorldsUtil.GetWorld().MapName == "World 2" and "TechCoins" or "VoidCoins") end
local function getClosestBreakables()
    local breakables = {}
    local char = Player.Character
    if not char or not char:FindFirstChild("HumanoidRootPart") then return breakables end
    local pos = char.HumanoidRootPart.Position
    local instance = InstancingCmds.Get()
    local zone = MapCmds.GetCurrentZone()
    for _, b in pairs(workspace.__THINGS.Breakables:GetChildren()) do
        if b:IsA("Model") and (b:GetAttribute("ParentID") == zone or b:GetAttribute("ParentID") == (instance and instance.instanceID)) and (b.WorldPivot.Position - pos).Magnitude < 85 then
            table.insert(breakables, b.Name)
        end
    end
    return breakables
end
local function playerPets()
    local pets = {}
    for _, pet in pairs(PlayerPet.GetAll()) do if pet.owner == Player then table.insert(pets, pet) end end
    return pets
end
local function fastFarm()
    local breakables = getClosestBreakables()
    local pets = playerPets()
    if #breakables == 0 or #pets == 0 then return end
    local assignments = {}
    local perBreakable = math.floor(#pets / #breakables)
    local remainder = #pets % #breakables
    local idx = 1
    for i, b in ipairs(breakables) do
        local count = perBreakable + (i <= remainder and 1 or 0)
        for _ = 1, count do
            assignments[pets[idx].euid] = b
            idx = idx + 1
        end
    end
    Network.Fire("Breakables_JoinPetBulk", assignments)
end
local function fastFarm2()
    local breakables = getClosestBreakables()
    local pets = playerPets()
    local assignments = {}
    for _, pet in ipairs(pets) do
        assignments[pet.Name] = breakables[math.random(1, #breakables)]
    end
    Network.Fire("Breakables_JoinPetBulk", assignments)
end
local function collectOrbs()
    for _, orb in pairs(workspace.__THINGS.Orbs:GetChildren()) do
        Network.Fire("Orbs: Collect", tonumber(orb.Name))
        orb:Destroy()
    end
end
local function clickAura()
    local char = Player.Character
    if not char then return end
    local pos = char.HumanoidRootPart.Position
    for _, b in pairs(workspace.__THINGS.Breakables:GetChildren()) do
        if b:IsA("Model") and (b.WorldPivot.Position - pos).Magnitude <= values.ClickAuraRange then
            Network.UnreliableFire("Breakables_PlayerDealDamage", b.Name)
            break
        end
    end
end
local function openClosestEgg()
    local maxHatch = EggCmds.GetMaxHatch()
    local customEgg, customDist = nil, math.huge
    for _, egg in pairs(workspace.__THINGS.CustomEggs:GetChildren()) do
        if egg:IsA("Model") then
            local dist = (Player.Character.HumanoidRootPart.Position - egg.WorldPivot.Position).Magnitude
            if dist < customDist then customEgg, customDist = egg, dist end
        end
    end
    local normalEgg, normalDist = nil, math.huge
    local eggFolder = workspace.__THINGS.Eggs[WorldsUtil.GetEggsModelName()]
    for _, egg in pairs(eggFolder:GetChildren()) do
        if egg:IsA("Model") then
            local dist = (Player.Character.HumanoidRootPart.Position - egg.Light.CFrame.Position).Magnitude
            if dist < normalDist then normalEgg, normalDist = egg, dist end
        end
    end
    if customDist < normalDist then
        Network.Invoke("CustomEggs_Hatch", tostring(customEgg), maxHatch)
    elseif normalEgg then
        local eggId = nil
        for _, v in pairs(require(game.ReplicatedStorage.__DIRECTORY.Eggs["Zone Eggs"][WorldsUtil.GetWorld()._id]):GetDescendants()) do
            if v.Name:match(string.split(normalEgg.Name, " ")[1]) then eggId = v.Name break end
        end
        if eggId then Network.Invoke("Eggs_RequestPurchase", eggId, maxHatch) end
    end
end
