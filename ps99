        local fruitId = fruitName:gsub("Shiny ", "")
        local uid, data = nil, nil
        for u, d in pairs(Save.Get().Inventory.Fruit) do
            if d.id == fruitId and (isShiny and d.sh or not isShiny and not d.sh) then
                uid, data = u, d
                break
