local function makeSlider(card, order, text, min, max, default, callback)
    local row = makeRow(card, order, false, 52)
    local lbl = Instance.new("TextLabel", row)
    lbl.Size = UDim2.new(0.5,0,0,20)
    lbl.Position = UDim2.new(0,14,0,6)
    lbl.Text = text
    lbl.Font = Enum.Font.GothamSemibold
    lbl.TextSize = 10
    lbl.TextColor3 = T.text
    lbl.TextXAlignment = Enum.TextXAlignment.Left
    lbl.BackgroundTransparency = 1
    local valLbl = Instance.new("TextLabel", row)
    valLbl.Size = UDim2.new(0,40,0,20)
    valLbl.Position = UDim2.new(1,-50,0,6)
    valLbl.Text = tostring(default)
    valLbl.Font = Enum.Font.Gotham
    valLbl.TextSize = 10
    valLbl.TextColor3 = T.accent
    valLbl.BackgroundTransparency = 1
    local slider = Instance.new("Frame", row)
    slider.Size = UDim2.new(1,-28,0,4)
    slider.Position = UDim2.new(0,14,0,32)
    slider.BackgroundColor3 = T.dim
    slider.BorderSizePixel = 0
    Instance.new("UICorner", slider).CornerRadius = UDim.new(1,0)
    local fill = Instance.new("Frame", slider)
    fill.Size = UDim2.new((default-min)/(max-min),0,1,0)
    fill.BackgroundColor3 = T.accent
    fill.BorderSizePixel = 0
    Instance.new("UICorner", fill).CornerRadius = UDim.new(1,0)
    local knob2 = Instance.new("TextButton", slider)
    knob2.Size = UDim2.new(0,14,0,14)
    knob2.Position = UDim2.new((default-min)/(max-min),-7,0.5,-7)
    knob2.BackgroundColor3 = Color3.new(1,1,1)
    knob2.BorderSizePixel = 0
    knob2.Text = ""
    knob2.AutoButtonColor = false
    Instance.new("UICorner", knob2).CornerRadius = UDim.new(1,0)
    local draggingSlider = false
    knob2.MouseButton1Down:Connect(function() draggingSlider = true end)
    UserInputService.InputEnded:Connect(function(i) if i.UserInputType == Enum.UserInputType.MouseButton1 then draggingSlider = false end end)
    UserInputService.InputChanged:Connect(function(i)
        if draggingSlider and i.UserInputType == Enum.UserInputType.MouseMovement then
            local mousePos = UserInputService:GetMouseLocation()
            local sliderAbs = slider.AbsolutePosition
            local sliderSize = slider.AbsoluteSize
            local relX = math.clamp((mousePos.X - sliderAbs.X) / sliderSize.X, 0, 1)
            local val = min + relX * (max - min)
            val = math.floor(val / 1) * 1
            fill.Size = UDim2.new(relX,0,1,0)
            knob2.Position = UDim2.new(relX,-7,0.5,-7)
            valLbl.Text = tostring(val)
            callback(val)
        end
    end)
    return row
end

