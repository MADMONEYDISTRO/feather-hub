            knob.Position = table.find(selectedTable, opt) and UDim2.new(1,-16,0.5,-7) or UDim2.new(0,2,0.5,-7)
            knob.BackgroundColor3 = Color3.new(1,1,1)
            Instance.new("UICorner", knob).CornerRadius = UDim.new(1,0)
            optionToggles[opt] = {toggle = toggle, knob = knob}
            toggle.MouseButton1Click:Connect(function()
                if table.find(selectedTable, opt) then
                    table.remove(selectedTable, table.find(selectedTable, opt))
                    TweenService:Create(toggle, tw(0.15), {BackgroundColor3 = T.dim}):Play()
                    TweenService:Create(knob, tw(0.15), {Position = UDim2.new(0,2,0.5,-7)}):Play()
                else
                    table.insert(selectedTable, opt)
                    TweenService:Create(toggle, tw(0.15), {BackgroundColor3 = T.accent}):Play()
                    TweenService:Create(knob, tw(0.15), {Position = UDim2.new(1,-16,0.5,-7)}):Play()
                end
            end)
        end
        panel.Size = UDim2.new(0,180,0, math.min(#options * 30 + 8, 200))
    end
    buildPanel()
    
    local function updatePosition()
        if not panel.Visible then return end
        local btnAbs = btn.AbsolutePosition
        local btnSize = btn.AbsoluteSize
        local panelHeight = panel.AbsoluteSize.Y
        local screenSize = workspace.CurrentCamera.ViewportSize
        local posX = btnAbs.X
        local posY = btnAbs.Y + btnSize.Y + 5
        if posY + panelHeight > screenSize.Y - 20 then posY = btnAbs.Y - panelHeight - 5 end
        if posX + 180 > screenSize.X then posX = screenSize.X - 180 - 5 end
        panel.Position = UDim2.new(0, posX, 0, posY)
    end
    
    btn.MouseButton1Click:Connect(function()
        if activeMultiSelect and activeMultiSelect ~= panel then activeMultiSelect.Visible = false end
        panel.Visible = not panel.Visible
        if panel.Visible then
            updatePosition()
            activeMultiSelect = panel
        else
            activeMultiSelect = nil
        end
    end)
    
    UserInputService.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 and panel.Visible then
            local mousePos = UserInputService:GetMouseLocation()
            local panelAbs = panel.AbsolutePosition
            local panelSize = panel.AbsoluteSize
            local btnAbs = btn.AbsolutePosition
            local btnSize = btn.AbsoluteSize
            if not ((mousePos.X >= panelAbs.X and mousePos.X <= panelAbs.X + panelSize.X and mousePos.Y >= panelAbs.Y and mousePos.Y <= panelAbs.Y + panelSize.Y) or
                    (mousePos.X >= btnAbs.X and mousePos.X <= btnAbs.X + btnSize.X and mousePos.Y >= btnAbs.Y and mousePos.Y <= btnAbs.Y + btnSize.Y)) then
                panel.Visible = false
                activeMultiSelect = nil
            end
        end
    end)
    
    return row
end

