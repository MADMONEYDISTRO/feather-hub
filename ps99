-- Visualizer loop
task.spawn(function()
    local visualizerPart
    while true do
        if toggles.ClickAuraVisualizer then
            if not visualizerPart or not visualizerPart.Parent then
                visualizerPart = Instance.new("Part", workspace)
                visualizerPart.Name = "ClickAuraVisual"
                visualizerPart.Anchored = true
                visualizerPart.CanCollide = false
                visualizerPart.Shape = Enum.PartType.Cylinder
                visualizerPart.Size = Vector3.new(0.2, values.ClickAuraRange*2, values.ClickAuraRange*2)
                visualizerPart.Transparency = 0.5
                visualizerPart.BrickColor = BrickColor.new("Lavender")
                visualizerPart.Rotation = Vector3.new(0,0,90)
            end
            if Player.Character and Player.Character:FindFirstChild("HumanoidRootPart") then
                visualizerPart.Position = Player.Character.HumanoidRootPart.Position
            end
        elseif visualizerPart then
            visualizerPart:Destroy()
            visualizerPart = nil
        end
        task.wait()
    end
end)

-- Optimize breakables connection management
task.spawn(function()
    local conn
    while true do
        if toggles.OptimizeBreakables and not conn then
            conn = workspace.__DEBRIS.ChildAdded:Connect(function(obj) pcall(function() game.Debris:AddItem(obj, 0) end) end)
        elseif not toggles.OptimizeBreakables and conn then
            conn:Disconnect()
            conn = nil
        end
        task.wait(1)
    end
end)

