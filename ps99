if not game:IsLoaded() then game.Loaded:Wait() end

local function antiAFK()
    if getgenv().AA then return end
    print('Anti-AFK Initialized')
    local v3 = require(game.ReplicatedStorage.Library.Client.Network)
    local _Fire = v3.Fire
    setreadonly(v3, false)
    function v3.Fire(...)
        if ({...})[1] ~= 'Idle Tracking: Update Timer' then return _Fire(...) end
    end
    setreadonly(v3, true)
    for _, v in pairs(getconnections(game.UserInputService.WindowFocusReleased)) do if v.Disable then v:Disable() end end
    for _, v in pairs(getconnections(game.UserInputService.WindowFocused)) do if v.Disable then v:Disable() end end
    getgenv().AA = true
    while true do
        game:GetService('VirtualInputManager'):SendKeyEvent(true, Enum.KeyCode.Unknown, false, nil)
        wait(math.random(15, 120))
    end
end
task.spawn(antiAFK)

