        if uid then
            local limit = FruitCmds.ComputeFruitQueueLimit() - (FruitCmds.GetActiveFruits()[fruitId] and #FruitCmds.GetActiveFruits()[fruitId][isShiny and "Shiny" or "Normal"] or 0)
            local amt = math.min(data._am or 1, limit)
            if amt > 0 then Network.Fire("Fruits: Consume", uid, amt) end
        end
        wait(0.5)
    end
end
