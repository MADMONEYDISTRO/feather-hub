        if not table.find(save.FreeGiftsRedeemed, gift._id) then
            return Network.Invoke("Redeem Free Gift", gift._id)
        end
    end
end
local function putPetsInDaycare()
    local maxSlots = DaycareCmds.GetMaxSlots()
    local usedSlots = DaycareCmds.GetUsedSlots()
    if usedSlots >= maxSlots then
        for uid, data in pairs(Save.Get().DaycareActive) do
            if DaycareCmds.ComputeRemainingTime(uid, workspace:GetServerTimeNow()) == 0 then
                DaycareCmds.Claim(uid)
            end
        end
        return
    end
    local pets = {}
    local needed = (maxSlots - usedSlots) * 10
    for uid, data in pairs(Save.Get().Inventory.Pet) do
        local item = Items.Pet(data.id)
        if item:GetExclusiveLevel() < 4 and (data._am or 1) >= 10 then
            local _, loot = require(game.ReplicatedStorage.Library.Modules.DaycareLoot).ComputePetLootPool(Player, item)
            if loot == 1 and needed >= data._am then
                local amt = math.min(data._am, needed - needed % 10)
                if amt > 0 then
                    pets[uid] = amt / 10
                    needed = needed - amt
                end
            end
        end
        if needed <= 0 then break end
    end
    if next(pets) then DaycareCmds.Enroll(pets) end
end
local function activateFlag()
    if not selected.SelectedFlag then return end
    local amt = values.FlagAmount
    local flagUtil = {computeMaxFlags = function() return 24 end, computeDuration = function(d) return d.Duration end, flagPlaced = function(m) return m and tonumber(m:FindFirstChild("FlagPole"):FindFirstChild("Attachment"):FindFirstChild("ZoneFlag"):FindFirstChild("Title").Text:match("%d+")) or 0 end}
    local save = Save.Get()
    local misc = save.Inventory.Misc
    local flagId = nil
    for uid, data in pairs(misc) do if data.id == selected.SelectedFlag then flagId = uid; amt = math.min(data._am or 1, amt); break end end
    if not flagId then return end
    local activeFlags = getupvalue(FlexibleFlagCmds.GetActiveFlag, 3)
    local instance = MapCmds.GetCurrentInstanceInfo()
    local key, model
    if instance then
        key = "2!" .. instance.InstanceId .. "!" .. instance.AreaId
        model = activeFlags[key] and activeFlags[key].Model
    else
        key = "1!" .. MapCmds.GetCurrentZone() .. "!Main"
        model = activeFlags[key] and activeFlags[key].Model
    end
    local placed = flagUtil.flagPlaced(model)
    if placed < amt then
        FlexibleFlagCmds.Consume(selected.SelectedFlag, flagId, amt - placed)
    end
end
local function claimRankRewards()
    local save = Save.Get()
    local rank = nil
    for _, r in pairs(RankDirectory) do if r.RankNumber == save.Rank then rank = r break end end
    if not rank then return end
    for idx, reward in ipairs(rank.Rewards) do
        if reward.StarsRequired > save.RankStars then break end
        if not save.RedeemedRankRewards[tostring(idx)] then
            Network.Fire("Ranks_ClaimReward", idx)
            wait(1)
        end
    end
end
