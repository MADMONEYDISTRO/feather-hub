local function makeSlider(card, label, min, max, default, callback)
    local row = makeRow(card, 50)
    local lbl = Instance.new("TextLabel"); lbl.Size = UDim2.new(1,-80,0,18); lbl.Position = UDim2.new(0,14,0,2); lbl.Text = label; lbl.Font = Enum.Font.GothamSemibold; lbl.TextSize = 9; lbl.TextColor3 = T.text; lbl.TextXAlignment = Enum.TextXAlignment.Left; lbl.BackgroundTransparency = 1; lbl.Parent = row
    local valLbl = Instance.new("TextLabel"); valLbl.Size = UDim2.new(0,50,0,18); valLbl.Position = UDim2.new(1,-64,0,2); valLbl.Text = tostring(default); valLbl.Font = Enum.Font.GothamBold; valLbl.TextSize = 9; valLbl.TextColor3 = T.accent; valLbl.TextXAlignment = Enum.TextXAlignment.Right; valLbl.BackgroundTransparency = 1; valLbl.Parent = row
    local sFrame = Instance.new("Frame"); sFrame.Size = UDim2.new(1,-28,0,6); sFrame.Position = UDim2.new(0,14,1,-12); sFrame.BackgroundColor3 = T.dim; sFrame.BorderSizePixel = 0; sFrame.Parent = row; mkC(sFrame,3)
    local fill = Instance.new("Frame"); fill.Size = UDim2.new((default-min)/(max-min),0,1,0); fill.BackgroundColor3 = T.accent; fill.BorderSizePixel = 0; fill.Parent = sFrame; mkC(fill,3)
    local dragging2 = false
    local function upd(input)
        local relX = math.clamp((input.Position.X - sFrame.AbsolutePosition.X) / sFrame.AbsoluteSize.X, 0, 1)
        local v = math.floor(min + relX*(max-min))
        fill.Size = UDim2.new(relX,0,1,0); valLbl.Text = tostring(v); pcall(callback, v)
    end
    sFrame.InputBegan:Connect(function(i) if i.UserInputType == Enum.UserInputType.MouseButton1 or i.UserInputType == Enum.UserInputType.Touch then dragging2 = true; upd(i) end end)
    UIS.InputChanged:Connect(function(i) if dragging2 and (i.UserInputType == Enum.UserInputType.MouseMovement or i.UserInputType == Enum.UserInputType.Touch) then upd(i) end end)
    UIS.InputEnded:Connect(function(i) if i.UserInputType == Enum.UserInputType.MouseButton1 or i.UserInputType == Enum.UserInputType.Touch then dragging2 = false end end)
    return row
end

local function switchTab(name)
    if selectedTab == name then return end
    selectedTab = name
    for _, t in pairs(tabs) do if t.page then t.page.Visible = false end; if t.btn then t.btn.BackgroundColor3 = T.dim; t.btn.TextColor3 = T.muted end end
    local t = tabs[name]
    if t then if t.page then t.page.Visible = true end; if t.btn then t.btn.BackgroundColor3 = T.accentDim; t.btn.TextColor3 = Color3.new(1,1,1) end end
end

local function createTab(name, order)
    local btn = Instance.new("TextButton"); btn.Size = UDim2.new(0.85,0,0,32); btn.Text = name; btn.Font = Enum.Font.GothamBold; btn.TextSize = 10; btn.TextColor3 = T.muted; btn.BackgroundColor3 = T.dim; btn.AutoButtonColor = false; btn.BorderSizePixel = 0; btn.LayoutOrder = order; btn.Parent = navCont; mkC(btn,8)
    local page = makePage()
    tabs[name] = {btn = btn, page = page}
    btn.MouseButton1Click:Connect(function() switchTab(name) end)
    return page
end

