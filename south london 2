-- Notification system
local function notify(title, msg, duration)
    local n = Instance.new("Frame")
    n.Size = UDim2.new(0, 0, 0, 52)
    n.Position = UDim2.new(1, -12, 1, -70)
    n.AnchorPoint = Vector2.new(1, 1)
    n.BackgroundColor3 = T.card
    n.BorderSizePixel = 0
    n.ZIndex = 100
    n.Parent = sg
    Instance.new("UICorner", n).CornerRadius = UDim.new(0, 10)
    local ns = Instance.new("UIStroke")
    ns.Color = T.accent
    ns.Thickness = 1
    ns.Parent = n
    
    local bar = Instance.new("Frame")
    bar.Size = UDim2.new(0, 3, 0.65, 0)
    bar.Position = UDim2.new(0, 0, 0.175, 0)
    bar.BackgroundColor3 = T.accent
    bar.BorderSizePixel = 0
    bar.Parent = n
    Instance.new("UICorner", bar).CornerRadius = UDim.new(1, 0)
    
    local t1 = Instance.new("TextLabel")
    t1.Size = UDim2.new(1, -18, 0, 20)
    t1.Position = UDim2.new(0, 14, 0, 9)
    t1.Text = title
    t1.Font = Enum.Font.GothamBold
    t1.TextSize = 11
    t1.TextColor3 = T.text
    t1.BackgroundTransparency = 1
    t1.Parent = n
    
    local t2 = Instance.new("TextLabel")
    t2.Size = UDim2.new(1, -18, 0, 20)
    t2.Position = UDim2.new(0, 14, 0, 29)
    t2.Text = msg
    t2.Font = Enum.Font.Gotham
    t2.TextSize = 9
    t2.TextColor3 = T.text
    t2.TextTransparency = 0.35
    t2.TextWrapped = true
    t2.BackgroundTransparency = 1
    t2.Parent = n
    
    n.Size = UDim2.new(0, 0, 0, 52)
    TweenService:Create(n, TweenInfo.new(0.25, Enum.EasingStyle.Quart), {Size = UDim2.new(0, 200, 0, 52)}):Play()
    task.delay(duration or 3, function()
        if n and n.Parent then
            TweenService:Create(n, TweenInfo.new(0.25, Enum.EasingStyle.Quart), {Position = UDim2.new(1, 12, 1, -70)}):Play()
            task.delay(0.3, function() n:Destroy() end)
        end
    end)
end

