local tabs       = {}
local activeTab  = nil

local tabDefs = {
    { id = "main",    label = "Main",     icon = "" },
    { id = "auto",    label = "Auto",     icon = "" },
    { id = "itemtp",  label = "Item TP",  icon = "" },
    { id = "gametp",  label = "Game TP",  icon = "" },
    { id = "mobtp",   label = "Mob TP",   icon = "" },
    { id = "player",  label = "Player",   icon = "" },
    { id = "visuals", label = "Visuals",  icon = "" },
    { id = "misc",    label = "Misc",     icon = "" },
}

local function createPage()
    local page = Instance.new("ScrollingFrame")
    page.Size = UDim2.new(1,-12,1,-12); page.Position = UDim2.new(0,6,0,6)
    page.BackgroundTransparency = 1; page.BorderSizePixel = 0
    page.ScrollBarThickness = 3; page.ScrollBarImageColor3 = C.accentG
    page.CanvasSize = UDim2.new(0,0,0,0); page.AutomaticCanvasSize = Enum.AutomaticSize.Y
    page.ZIndex = 5; page.Visible = false; page.Parent = contentContainer
    local layout = Instance.new("UIListLayout", page)
    layout.SortOrder = Enum.SortOrder.LayoutOrder; layout.Padding = UDim.new(0,4)
    return page
end

local function switchTab(id)
    if activeTab == id then return end
    activeTab = id
    for tid, tdata in pairs(tabs) do
        local on = (tid == id)
        tdata.page.Visible = on
        TweenService:Create(tdata.btn, ti(0.15), {
            BackgroundColor3 = on and C.dim or Color3.fromRGB(0,0,0),
            BackgroundTransparency = on and 0 or 1,
        }):Play()
        TweenService:Create(tdata.iconLbl, ti(0.15), {TextColor3 = on and C.accent or C.muted}):Play()
        TweenService:Create(tdata.nameLbl, ti(0.15), {TextColor3 = on and C.text or C.muted}):Play()
        if on then
            local bar = tdata.btn:FindFirstChild("ActiveBar")
            if not bar then
                bar = Instance.new("Frame"); bar.Name = "ActiveBar"
                bar.Size = UDim2.new(0,2,0.6,0); bar.Position = UDim2.new(0,0,0.2,0)
                bar.BackgroundColor3 = C.accent; bar.BorderSizePixel = 0; bar.ZIndex = 7; bar.Parent = tdata.btn
                Instance.new("UICorner", bar).CornerRadius = UDim.new(0,2)
            end
            bar.Visible = true
        else
            local bar = tdata.btn:FindFirstChild("ActiveBar")
            if bar then bar.Visible = false end
        end
    end
end

for i, def in ipairs(tabDefs) do
    local page = createPage()
    local btn = Instance.new("TextButton")
    btn.Size = UDim2.new(1,0,0,34); btn.BackgroundTransparency = 1
    btn.BackgroundColor3 = C.dim; btn.BorderSizePixel = 0
    btn.Text = ""; btn.AutoButtonColor = false; btn.LayoutOrder = i; btn.ZIndex = 6; btn.Parent = sideInner
    Instance.new("UICorner", btn).CornerRadius = UDim.new(0,6)

    local iconL = Instance.new("TextLabel")
    iconL.Size = UDim2.new(0,18,1,0); iconL.Position = UDim2.new(0,8,0,0)
    iconL.Text = def.icon; iconL.Font = Enum.Font.GothamBold; iconL.TextSize = 13
    iconL.TextColor3 = C.muted; iconL.BackgroundTransparency = 1; iconL.ZIndex = 7; iconL.Parent = btn

    local nameL = Instance.new("TextLabel")
    nameL.Size = UDim2.new(1,-28,1,0); nameL.Position = UDim2.new(0,28,0,0)
    nameL.Text = def.label; nameL.Font = Enum.Font.GothamSemibold; nameL.TextSize = 11
    nameL.TextColor3 = C.muted; nameL.TextXAlignment = Enum.TextXAlignment.Left
    nameL.BackgroundTransparency = 1; nameL.ZIndex = 7; nameL.Parent = btn

    btn.MouseEnter:Connect(function()
        if activeTab ~= def.id then
            TweenService:Create(btn,ti(0.1),{BackgroundTransparency=0.7,BackgroundColor3=C.dim}):Play()
        end
    end)
    btn.MouseLeave:Connect(function()
        if activeTab ~= def.id then
            TweenService:Create(btn,ti(0.1),{BackgroundTransparency=1}):Play()
        end
    end)
    btn.MouseButton1Click:Connect(function() switchTab(def.id) end)

    tabs[def.id] = { page = page, btn = btn, iconLbl = iconL, nameLbl = nameL }
end

