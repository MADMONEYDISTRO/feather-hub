local layoutOrder = {}
for k, _ in pairs(tabs) do layoutOrder[k] = 0 end

local function nextOrder(tabId)
    layoutOrder[tabId] = (layoutOrder[tabId] or 0) + 1
    return layoutOrder[tabId]
end

-- Section header
local function addSection(tabId, text)
    local page = tabs[tabId].page
    local f = Instance.new("Frame")
    f.Size = UDim2.new(1,0,0,22); f.BackgroundTransparency = 1
    f.LayoutOrder = nextOrder(tabId); f.ZIndex = 5; f.Parent = page

    local lbl = Instance.new("TextLabel", f)
    lbl.Size = UDim2.new(1,-8,1,0); lbl.Position = UDim2.new(0,8,0,0)
    lbl.Text = text:upper(); lbl.Font = Enum.Font.GothamBold; lbl.TextSize = 9
    lbl.TextColor3 = C.accentG; lbl.TextXAlignment = Enum.TextXAlignment.Left
    lbl.BackgroundTransparency = 1; lbl.ZIndex = 6

    local line = Instance.new("Frame", f)
    line.Size = UDim2.new(1,-8,0,1); line.Position = UDim2.new(0,8,1,-1)
    line.BackgroundColor3 = C.sep; line.BorderSizePixel = 0; line.ZIndex = 6
end

-- Toggle row (checkbox)
local function addToggle(tabId, label, desc, callback)
    local page = tabs[tabId].page
    local row = Instance.new("Frame")
    row.Size = UDim2.new(1,0,0,42); row.BackgroundColor3 = C.panel
    row.BorderSizePixel = 0; row.LayoutOrder = nextOrder(tabId); row.ZIndex = 5; row.Parent = page
    Instance.new("UICorner", row).CornerRadius = UDim.new(0,7)

    local nameLbl = Instance.new("TextLabel", row)
    nameLbl.Size = UDim2.new(1,-70,0,18); nameLbl.Position = UDim2.new(0,12,0,6)
    nameLbl.Text = label; nameLbl.Font = Enum.Font.GothamSemibold; nameLbl.TextSize = 12
    nameLbl.TextColor3 = C.text; nameLbl.TextXAlignment = Enum.TextXAlignment.Left
    nameLbl.BackgroundTransparency = 1; nameLbl.ZIndex = 6

    if desc then
        local descLbl = Instance.new("TextLabel", row)
        descLbl.Size = UDim2.new(1,-70,0,14); descLbl.Position = UDim2.new(0,12,0,24)
        descLbl.Text = desc; descLbl.Font = Enum.Font.Gotham; descLbl.TextSize = 10
        descLbl.TextColor3 = C.muted; descLbl.TextXAlignment = Enum.TextXAlignment.Left
        descLbl.BackgroundTransparency = 1; descLbl.ZIndex = 6
    end

    local state = false

    -- pill
    local pill = Instance.new("TextButton", row)
    pill.Size = UDim2.new(0,46,0,24); pill.Position = UDim2.new(1,-56,0.5,-12)
    pill.BackgroundColor3 = C.dim; pill.BorderSizePixel = 0; pill.Text = ""
    pill.AutoButtonColor = false; pill.ZIndex = 6
    Instance.new("UICorner", pill).CornerRadius = UDim.new(1,0)

    local knob = Instance.new("Frame", pill)
    knob.Size = UDim2.new(0,18,0,18); knob.Position = UDim2.new(0,3,0.5,-9)
    knob.BackgroundColor3 = C.muted; knob.BorderSizePixel = 0; knob.ZIndex = 7
    Instance.new("UICorner", knob).CornerRadius = UDim.new(1,0)

    local function setToggleState(on)
        state = on
        TweenService:Create(pill,ti(0.15),{BackgroundColor3 = on and C.accent or C.dim}):Play()
        TweenService:Create(knob,ti(0.15),{
            Position = on and UDim2.new(1,-21,0.5,-9) or UDim2.new(0,3,0.5,-9),
            BackgroundColor3 = on and C.bg or C.muted,
        }):Play()
        if callback then callback(on) end
    end

    pill.MouseButton1Click:Connect(function() setToggleState(not state) end)
    return setToggleState
end

-- Slider row
local function addSlider(tabId, label, min, max, default, callback)
    local page = tabs[tabId].page
    local row = Instance.new("Frame")
    row.Size = UDim2.new(1,0,0,52); row.BackgroundColor3 = C.panel
    row.BorderSizePixel = 0; row.LayoutOrder = nextOrder(tabId); row.ZIndex = 5; row.Parent = page
    Instance.new("UICorner", row).CornerRadius = UDim.new(0,7)

    local currentVal = default or min

    local topRow = Instance.new("Frame", row)
    topRow.Size = UDim2.new(1,-24,0,18); topRow.Position = UDim2.new(0,12,0,8)
    topRow.BackgroundTransparency = 1; topRow.ZIndex = 6

    local nameLbl = Instance.new("TextLabel", topRow)
    nameLbl.Size = UDim2.new(0.7,0,1,0); nameLbl.Text = label
    nameLbl.Font = Enum.Font.GothamSemibold; nameLbl.TextSize = 11
    nameLbl.TextColor3 = C.text; nameLbl.TextXAlignment = Enum.TextXAlignment.Left
    nameLbl.BackgroundTransparency = 1; nameLbl.ZIndex = 6

    local valLbl = Instance.new("TextLabel", topRow)
    valLbl.Size = UDim2.new(0.3,0,1,0); valLbl.Text = tostring(currentVal)
    valLbl.Font = Enum.Font.GothamBold; valLbl.TextSize = 11
    valLbl.TextColor3 = C.accent; valLbl.TextXAlignment = Enum.TextXAlignment.Right
    valLbl.BackgroundTransparency = 1; valLbl.ZIndex = 6

    local track = Instance.new("Frame", row)
    track.Size = UDim2.new(1,-24,0,6); track.Position = UDim2.new(0,12,0,32)
    track.BackgroundColor3 = C.dim; track.BorderSizePixel = 0; track.ZIndex = 6
    Instance.new("UICorner", track).CornerRadius = UDim.new(1,0)

    local fill = Instance.new("Frame", track)
    fill.Size = UDim2.new((currentVal-min)/(max-min),0,1,0)
    fill.BackgroundColor3 = C.accent; fill.BorderSizePixel = 0; fill.ZIndex = 7
    Instance.new("UICorner", fill).CornerRadius = UDim.new(1,0)

    local handle = Instance.new("TextButton", track)
    handle.Size = UDim2.new(0,14,0,14); handle.AnchorPoint = Vector2.new(0.5,0.5)
    handle.Position = UDim2.new((currentVal-min)/(max-min),0,0.5,0)
    handle.BackgroundColor3 = Color3.new(1,1,1); handle.BorderSizePixel = 0
    handle.Text = ""; handle.AutoButtonColor = false; handle.ZIndex = 8
    Instance.new("UICorner", handle).CornerRadius = UDim.new(1,0)

    local sliding = false
    handle.MouseButton1Down:Connect(function() sliding = true end)
    UserInputService.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then sliding = false end
    end)
    UserInputService.InputChanged:Connect(function(input)
        if sliding and input.UserInputType == Enum.UserInputType.MouseMovement then
            local trackPos = track.AbsolutePosition.X
            local trackW   = track.AbsoluteSize.X
            local rel = math.clamp((input.Position.X - trackPos) / trackW, 0, 1)
            currentVal = math.floor(min + (max - min) * rel)
            valLbl.Text = tostring(currentVal)
            fill.Size = UDim2.new(rel,0,1,0)
            handle.Position = UDim2.new(rel,0,0.5,0)
            if callback then callback(currentVal) end
        end
    end)
end

-- Button row
local function addButton(tabId, label, callback)
    local page = tabs[tabId].page
    local btn = Instance.new("TextButton")
    btn.Size = UDim2.new(1,0,0,34); btn.BackgroundColor3 = C.panel
    btn.BorderSizePixel = 0; btn.Text = ""
    btn.AutoButtonColor = false; btn.LayoutOrder = nextOrder(tabId); btn.ZIndex = 5; btn.Parent = page
    Instance.new("UICorner", btn).CornerRadius = UDim.new(0,7)

    local lbl = Instance.new("TextLabel", btn)
    lbl.Size = UDim2.new(1,-12,1,0); lbl.Position = UDim2.new(0,12,0,0)
    lbl.Text = label; lbl.Font = Enum.Font.GothamSemibold; lbl.TextSize = 12
    lbl.TextColor3 = C.text; lbl.TextXAlignment = Enum.TextXAlignment.Left
    lbl.BackgroundTransparency = 1; lbl.ZIndex = 6

    local arrow = Instance.new("TextLabel", btn)
    arrow.Size = UDim2.new(0,20,1,0); arrow.Position = UDim2.new(1,-26,0,0)
    arrow.Text = "›"; arrow.Font = Enum.Font.GothamBold; arrow.TextSize = 16
    arrow.TextColor3 = C.accentG; arrow.BackgroundTransparency = 1; arrow.ZIndex = 6

    btn.MouseEnter:Connect(function()
        TweenService:Create(btn,ti(0.1),{BackgroundColor3=C.dim}):Play()
        TweenService:Create(arrow,ti(0.1),{TextColor3=C.accent}):Play()
    end)
    btn.MouseLeave:Connect(function()
        TweenService:Create(btn,ti(0.1),{BackgroundColor3=C.panel}):Play()
        TweenService:Create(arrow,ti(0.1),{TextColor3=C.accentG}):Play()
    end)
    btn.MouseButton1Click:Connect(function()
        TweenService:Create(btn,ti(0.08),{BackgroundColor3=C.accentG}):Play()
        task.wait(0.08)
        TweenService:Create(btn,ti(0.12),{BackgroundColor3=C.panel}):Play()
        if callback then callback() end
    end)
end

-- Dropdown (collapsible list of buttons/toggles)
local function addDropdown(tabId, label)
    local page = tabs[tabId].page

    local wrapper = Instance.new("Frame")
    wrapper.Size = UDim2.new(1,0,0,34); wrapper.BackgroundColor3 = C.panel
    wrapper.BorderSizePixel = 0; wrapper.LayoutOrder = nextOrder(tabId); wrapper.ClipsDescendants = false
    wrapper.ZIndex = 5; wrapper.Parent = page
    Instance.new("UICorner", wrapper).CornerRadius = UDim.new(0,7)
    wrapper.AutomaticSize = Enum.AutomaticSize.None

    local header = Instance.new("TextButton", wrapper)
    header.Size = UDim2.new(1,0,0,34); header.BackgroundTransparency = 1
    header.Text = ""; header.AutoButtonColor = false; header.ZIndex = 6

    local headerLbl = Instance.new("TextLabel", header)
    headerLbl.Size = UDim2.new(1,-36,1,0); headerLbl.Position = UDim2.new(0,12,0,0)
    headerLbl.Text = label; headerLbl.Font = Enum.Font.GothamSemibold; headerLbl.TextSize = 12
    headerLbl.TextColor3 = C.text; headerLbl.TextXAlignment = Enum.TextXAlignment.Left
    headerLbl.BackgroundTransparency = 1; headerLbl.ZIndex = 7

    local chevron = Instance.new("TextLabel", header)
    chevron.Size = UDim2.new(0,20,1,0); chevron.Position = UDim2.new(1,-28,0,0)
    chevron.Text = "›"; chevron.Font = Enum.Font.GothamBold; chevron.TextSize = 14
    chevron.TextColor3 = C.accentG; chevron.BackgroundTransparency = 1; chevron.ZIndex = 7
    chevron.Rotation = 90

    local list = Instance.new("Frame", wrapper)
    list.Size = UDim2.new(1,0,0,0); list.Position = UDim2.new(0,0,0,34)
    list.BackgroundTransparency = 1; list.ClipsDescendants = false; list.ZIndex = 6
    list.AutomaticSize = Enum.AutomaticSize.Y; list.Visible = false

    local listLayout = Instance.new("UIListLayout", list)
    listLayout.SortOrder = Enum.SortOrder.LayoutOrder; listLayout.Padding = UDim.new(0,2)

    local listPad = Instance.new("UIPadding", list)
    listPad.PaddingTop = UDim.new(0,4); listPad.PaddingBottom = UDim.new(0,4)
    listPad.PaddingLeft = UDim.new(0,8); listPad.PaddingRight = UDim.new(0,8)

    local open = false

    local function refreshHeight()
        if open then
            local h = listLayout.AbsoluteContentSize.Y + 8
            wrapper.Size = UDim2.new(1,0,0,34+h)
        else
            wrapper.Size = UDim2.new(1,0,0,34)
        end
    end

    header.MouseButton1Click:Connect(function()
        open = not open
        list.Visible = open
        chevron.Rotation = open and 270 or 90
        TweenService:Create(chevron,ti(0.15),{TextColor3 = open and C.accent or C.accentG}):Play()
        task.wait(0.01)
        refreshHeight()
    end)

    listLayout:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(function()
        if open then refreshHeight() end
    end)

    local dd = {}

    function dd:AddButton(btnLabel, callback)
        local b = Instance.new("TextButton", list)
        b.Size = UDim2.new(1,0,0,30); b.BackgroundColor3 = C.dim
        b.BorderSizePixel = 0; b.Text = ""
        b.AutoButtonColor = false; b.LayoutOrder = #list:GetChildren(); b.ZIndex = 7
        Instance.new("UICorner", b).CornerRadius = UDim.new(0,6)

        local bl = Instance.new("TextLabel", b)
        bl.Size = UDim2.new(1,-10,1,0); bl.Position = UDim2.new(0,10,0,0)
        bl.Text = btnLabel; bl.Font = Enum.Font.Gotham; bl.TextSize = 11
        bl.TextColor3 = C.text; bl.TextXAlignment = Enum.TextXAlignment.Left
        bl.BackgroundTransparency = 1; bl.ZIndex = 8

        b.MouseEnter:Connect(function() TweenService:Create(b,ti(0.1),{BackgroundColor3=C.bar}):Play() end)
        b.MouseLeave:Connect(function() TweenService:Create(b,ti(0.1),{BackgroundColor3=C.dim}):Play() end)
        b.MouseButton1Click:Connect(function()
            if callback then callback() end
        end)
        refreshHeight()
    end

    function dd:AddToggle(toggleLabel, callback)
        local f = Instance.new("Frame", list)
        f.Size = UDim2.new(1,0,0,30); f.BackgroundColor3 = C.dim
        f.BorderSizePixel = 0; f.LayoutOrder = #list:GetChildren(); f.ZIndex = 7
        Instance.new("UICorner", f).CornerRadius = UDim.new(0,6)

        local fl = Instance.new("TextLabel", f)
        fl.Size = UDim2.new(1,-50,1,0); fl.Position = UDim2.new(0,10,0,0)
        fl.Text = toggleLabel; fl.Font = Enum.Font.Gotham; fl.TextSize = 11
        fl.TextColor3 = C.text; fl.TextXAlignment = Enum.TextXAlignment.Left
        fl.BackgroundTransparency = 1; fl.ZIndex = 8

        local tState = false
        local tPill = Instance.new("TextButton", f)
        tPill.Size = UDim2.new(0,36,0,18); tPill.Position = UDim2.new(1,-44,0.5,-9)
        tPill.BackgroundColor3 = C.bar; tPill.BorderSizePixel = 0; tPill.Text = ""
        tPill.AutoButtonColor = false; tPill.ZIndex = 8
        Instance.new("UICorner", tPill).CornerRadius = UDim.new(1,0)

        local tKnob = Instance.new("Frame", tPill)
        tKnob.Size = UDim2.new(0,12,0,12); tKnob.Position = UDim2.new(0,3,0.5,-6)
        tKnob.BackgroundColor3 = C.muted; tKnob.BorderSizePixel = 0; tKnob.ZIndex = 9
        Instance.new("UICorner", tKnob).CornerRadius = UDim.new(1,0)

        local function setTs(on)
            tState = on
            TweenService:Create(tPill,ti(0.12),{BackgroundColor3 = on and C.accent or C.bar}):Play()
            TweenService:Create(tKnob,ti(0.12),{
                Position = on and UDim2.new(1,-15,0.5,-6) or UDim2.new(0,3,0.5,-6),
                BackgroundColor3 = on and C.bg or C.muted,
            }):Play()
            if callback then callback(on) end
        end

        tPill.MouseButton1Click:Connect(function() setTs(not tState) end)
        refreshHeight()
    end

    return dd
end

