-- GUI PROTECTION
-- ═══════════════════════════════════════════════════════════════════════════════
local owned = {}
local function own(inst) owned[inst] = true; return inst end
local function guard(parent)
    parent.ChildAdded:Connect(function(child)
        task.defer(function()
            if not owned[child] then pcall(function() child:Destroy() end) end
        end)
    end)
end

