local function notify(title, msg, nType)
    local col = ({success = C.green, error = C.red, warning = C.gold})[nType] or C.accent
    local n = Instance.new("Frame")
    n.Size = UDim2.new(0, 0, 0, 50)
    n.Position = UDim2.new(1, -10, 1, -60)
    n.AnchorPoint = Vector2.new(1, 1)
    n.BackgroundColor3 = C.bg
    n.BorderSizePixel = 0
    n.ZIndex = 20
    n.Parent = sg
    Instance.new("UICorner", n).CornerRadius = UDim.new(0, 8)
    local ns = Instance.new("UIStroke"); ns.Color = C.border; ns.Thickness = 1; ns.Parent = n
    local bar = Instance.new("Frame")
    bar.Size = UDim2.new(0, 3, 0.6, 0); bar.Position = UDim2.new(0, 0, 0.2, 0)
    bar.BackgroundColor3 = col; bar.BorderSizePixel = 0; bar.ZIndex = 21; bar.Parent = n
    Instance.new("UICorner", bar).CornerRadius = UDim.new(0, 4)
    local t1 = Instance.new("TextLabel")
    t1.Size = UDim2.new(1, -16, 0, 16); t1.Position = UDim2.new(0, 12, 0, 6)
    t1.Text = title; t1.Font = Enum.Font.GothamBold; t1.TextSize = 10
    t1.TextColor3 = C.text; t1.TextXAlignment = Enum.TextXAlignment.Left
    t1.BackgroundTransparency = 1; t1.ZIndex = 21; t1.Parent = n
    local t2 = Instance.new("TextLabel")
    t2.Size = UDim2.new(1, -16, 0, 16); t2.Position = UDim2.new(0, 12, 0, 24)
    t2.Text = msg; t2.Font = Enum.Font.Gotham; t2.TextSize = 8
    t2.TextColor3 = C.muted; t2.TextXAlignment = Enum.TextXAlignment.Left
    t2.BackgroundTransparency = 1; t2.TextWrapped = true; t2.ZIndex = 21; t2.Parent = n
    TweenService:Create(n, tw(), {Size = UDim2.new(0, 240, 0, 50)}):Play()
    task.delay(2.5, function()
        TweenService:Create(n, tw(), {Size = UDim2.new(0, 0, 0, 50), BackgroundTransparency = 1}):Play()
        task.wait(0.3); if n.Parent then n:Destroy() end
    end)
end

