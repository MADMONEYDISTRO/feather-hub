-- CLEAN FARM LOGIC
-- ═══════════════════════════════════════════════════════════════════════════════
local function findCleanNPC()
    local function search(folder)
        for _, child in ipairs(folder:GetChildren()) do
            if child.Name == "CleanNPC" then return child end
            if child:IsA("Folder") or child:IsA("Model") then
                local found = search(child); if found then return found end
            end
        end
    end
    return search(workspace)
end

local function cleanTweenTo(x, z)
    refreshChar()
    local dest = Vector3.new(x, CLEAN_Y, z)
    local dist = (rootPart.Position - dest).Magnitude
    if dist < 1 then return end
    humanoid.PlatformStand = true; rootPart.Velocity = Vector3.zero
    local tween = TweenService:Create(rootPart, TweenInfo.new(math.max(0.1, dist / CLEAN_TWEEN_SPEED), Enum.EasingStyle.Linear), {CFrame = CFrame.new(dest)})
    tween:Play(); tween.Completed:Wait()
    humanoid.PlatformStand = false
end

local function cleanLoop(statusLbl, cycleLbl, phaseLbl)
    while cleanRunning do
        statusLbl.Text = "Searching..."; statusLbl.TextColor3 = C.gold
        local npc = findCleanNPC()
        if not npc then statusLbl.Text = "CleanNPC not found!"; statusLbl.TextColor3 = C.red; task.wait(2); continue end
        local folder = npc:FindFirstChild("Clean")
        if not folder then statusLbl.Text = "Clean folder missing!"; statusLbl.TextColor3 = C.red; task.wait(2); continue end
        local spots = {}
        for i = 1, 8 do local s = folder:FindFirstChild(tostring(i)); if s and s:IsA("BasePart") then table.insert(spots, s) end end
        if #spots == 0 then statusLbl.Text = "No spots"; statusLbl.TextColor3 = C.red; task.wait(2); continue end
        statusLbl.Text = "Cleaning..."; statusLbl.TextColor3 = C.green
        for idx, spot in ipairs(spots) do
            if not cleanRunning then break end
            phaseLbl.Text = "Spot " .. spot.Name .. " (" .. idx .. "/" .. #spots .. ")"
            cleanTweenTo(spot.Position.X, spot.Position.Z)
            if not cleanRunning then break end
            task.wait(CLEAN_WAIT)
            if not cleanRunning then break end
            local prompt = spot:FindFirstChildWhichIsA("ProximityPrompt")
            if prompt then holdPrompt(prompt, CLEAN_HOLD) end
            task.wait(0.3)
        end
        if cleanRunning then
            cleanCycles = cleanCycles + 1; cycleLbl.Text = "x" .. cleanCycles
            statusLbl.Text = "Cycle " .. cleanCycles; phaseLbl.Text = ""; task.wait(1)
        end
    end
    statusLbl.Text = "Idle"; statusLbl.TextColor3 = C.muted; phaseLbl.Text = ""
    pcall(function() humanoid.PlatformStand = false end)
end

-- ═══════════════════════════════════════════════════════════════════════════════
-- BOX FARM LOGIC
-- ═══════════════════════════════════════════════════════════════════════════════
local function boxTweenPath(cframes)
    refreshChar(); humanoid.PlatformStand = true; rootPart.Velocity = Vector3.zero
    for _, cf in ipairs(cframes) do
        if not boxRunning then break end
        local dist = (rootPart.Position - cf.Position).Magnitude
        local tween = TweenService:Create(rootPart, TweenInfo.new(math.max(0.1, dist / BOX_TWEEN_SPEED), Enum.EasingStyle.Linear), {CFrame = cf})
        tween:Play(); tween.Completed:Wait()
    end
    humanoid.PlatformStand = false
end

local function boxTweenTo(cf)
    refreshChar()
    local dist = (rootPart.Position - cf.Position).Magnitude
    if dist < 1 then return end
    humanoid.PlatformStand = true; rootPart.Velocity = Vector3.zero
    local tween = TweenService:Create(rootPart, TweenInfo.new(math.max(0.1, dist / BOX_TWEEN_SPEED), Enum.EasingStyle.Linear), {CFrame = cf})
    tween:Play(); tween.Completed:Wait()
    humanoid.PlatformStand = false
end

local function boxLoop(statusLbl, cycleLbl, phaseLbl)
    local pickupCF = boxPath[1]
    local dropoffCF = boxPath[#boxPath]
    while boxRunning do
        -- Go to pickup
        statusLbl.Text = "To pickup..."; statusLbl.TextColor3 = Color3.fromRGB(180, 160, 255)
        phaseLbl.Text = "Travelling to box"
        boxTweenTo(pickupCF)
        if not boxRunning then break end
        -- Wait + grab
        statusLbl.Text = "Picking up..."; statusLbl.TextColor3 = C.gold
        phaseLbl.Text = "Waiting at pickup"
        task.wait(BOX_PICKUP_WAIT)
        if not boxRunning then break end
        phaseLbl.Text = "Grabbing box (hold E)"
        holdPrompt(findPrompt(pickupCF.Position), BOX_HOLD)
        if not boxRunning then break end
        task.wait(0.3)
        -- Deliver
        statusLbl.Text = "Delivering..."; statusLbl.TextColor3 = C.green
        phaseLbl.Text = "Carrying box"
        boxTweenPath(boxPath)
        if not boxRunning then break end
        -- Drop
        statusLbl.Text = "Dropping off..."; statusLbl.TextColor3 = C.gold
        phaseLbl.Text = "Placing box (hold E)"
        task.wait(0.3)
        if not boxRunning then break end
        holdPrompt(findPrompt(dropoffCF.Position), BOX_HOLD)
        if not boxRunning then break end
        task.wait(0.3)
        -- Return
        statusLbl.Text = "Returning..."; statusLbl.TextColor3 = Color3.fromRGB(180, 160, 255)
        phaseLbl.Text = "Heading back"
        boxTweenPath(boxPathReversed)
        if not boxRunning then break end
        -- Cycle
        boxCycles = boxCycles + 1; cycleLbl.Text = "x" .. boxCycles
        statusLbl.Text = "Cycle " .. boxCycles; phaseLbl.Text = ""; task.wait(0.5)
    end
    statusLbl.Text = "Idle"; statusLbl.TextColor3 = C.muted; phaseLbl.Text = ""
    pcall(function() humanoid.PlatformStand = false end)
end

