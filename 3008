local employeeDrawings = {}
local playerDrawings   = {}
local itemDrawings     = {}

local function newDrawBox(color, thickness)
    local d = Drawing.new("Square")
    d.Visible, d.Color, d.Thickness, d.Filled = false, color, thickness or 1, false
    return d
end
local function newDrawLine(color, thickness)
    local d = Drawing.new("Line")
    d.Visible, d.Color, d.Thickness = false, color, thickness or 1
    return d
end
local function newDrawText(text, color, size, outline)
    local d = Drawing.new("Text")
    d.Visible, d.Text, d.Color, d.Size, d.Center, d.Outline = false, text, color, size or 14, true, outline ~= false
    return d
end

local function removeDrawings(tbl, key)
    local entry = tbl[key]
    if not entry then return end
    for _, d in pairs(entry) do pcall(function() d:Remove() end) end
    tbl[key] = nil
end
local function clearAllDrawings(tbl)
    for k in pairs(tbl) do removeDrawings(tbl, k) end
end

-- Employee helpers
local function getEmployeeFolder()
    local go = workspace:FindFirstChild("GameObjects")
    if not go then return nil end
    local ph = go:FindFirstChild("Physical")
    if not ph then return nil end
    return ph:FindFirstChild("Employees")
end

local function buildEmployeeDrawing(emp)
    if employeeDrawings[emp] then return end
    local s = espState.employee
    employeeDrawings[emp] = {
        box = newDrawBox(s.boxColor, 1),
        tracer = newDrawLine(s.tracerColor, 1),
        nameLbl = newDrawText("Employee", s.nameColor, s.textSize),
        distLbl = newDrawText("", Color3.new(1,1,1), s.textSize-2),
        hpLbl = newDrawText("", Color3.fromRGB(50,255,80), s.textSize-2),
    }
end

local function refreshEmployees()
    clearAllDrawings(employeeDrawings)
    if not espState.employee.enabled then return end
    local folder = getEmployeeFolder()
    if folder then
        for _, emp in ipairs(folder:GetChildren()) do buildEmployeeDrawing(emp) end
    end
end

-- Player helpers
local function buildPlayerDrawing(plr)
    if playerDrawings[plr] or plr == Player then return end
    local s = espState.player
    playerDrawings[plr] = {
        box = newDrawBox(s.boxColor, s.boxThick),
        tracer = newDrawLine(s.tracerColor, 1),
        nameLbl = newDrawText(plr.Name, s.nameColor, s.textSize, s.textOutline),
        distLbl = newDrawText("", s.distColor, s.textSize-2, false),
        hpLbl = newDrawText("", s.healthColor, s.textSize-2, false),
    }
end

local function refreshPlayers()
    clearAllDrawings(playerDrawings)
    if not espState.player.enabled then return end
    for _, plr in ipairs(Players:GetPlayers()) do
        if plr ~= Player then buildPlayerDrawing(plr) end
    end
end

-- Item helpers
local ITEM_FOLDERS = {"Items", "Droppable", "GroundItems"}
local function getItems()
    local found = {}
    local go = workspace:FindFirstChild("GameObjects")
    if not go then return found end
    local ph = go:FindFirstChild("Physical")
    if not ph then return found end
    for _, fn in ipairs(ITEM_FOLDERS) do
        local folder = ph:FindFirstChild(fn)
        if folder then
            for _, item in ipairs(folder:GetDescendants()) do
                if item:IsA("BasePart") or item:IsA("Model") then
                    table.insert(found, item)
                end
            end
        end
    end
    return found
end

local function buildItemDrawing(item)
    if itemDrawings[item] then return end
    itemDrawings[item] = {
        nameLbl = newDrawText(item.Name, Color3.fromRGB(255,220,80), espState.item.textSize),
    }
end

local function refreshItems()
    clearAllDrawings(itemDrawings)
    if not espState.item.enabled then return end
    for _, item in ipairs(getItems()) do buildItemDrawing(item) end
end

-- ============================================================
-- RENDER LOOP (ESP update)
-- ============================================================
local function worldToScreen(pos)
    local sp, onScreen = Camera:WorldToViewportPoint(pos)
    return Vector2.new(sp.X, sp.Y), onScreen, sp.Z
end

local function getBoundingBox(model)
    local ok, cf, size = pcall(function() return model:GetBoundingBox() end)
    if not ok then return nil, nil end
    return cf, size
end

local function getHealthFraction(model)
    local hum = model:FindFirstChildOfClass("Humanoid")
    if hum then return hum.Health / math.max(hum.MaxHealth, 1) end
    return 1
end

local function getTracerOrigin()
    local vp = Camera.ViewportSize
    local s = espState.player
    if s.tracerOrigin == "Top" then return Vector2.new(vp.X/2, 0)
    elseif s.tracerOrigin == "Mouse" then return UserInputService:GetMouseLocation()
    else return Vector2.new(vp.X/2, vp.Y) end
end

local renderConn
local function startRenderLoop()
    if renderConn then renderConn:Disconnect() end
    renderConn = RunService.RenderStepped:Connect(function()
        -- Employee ESP
        for emp, drw in pairs(employeeDrawings) do
            if not emp.Parent or not espState.employee.enabled then
                for _, d in pairs(drw) do d.Visible = false end
            else
                local cf, size = getBoundingBox(emp)
                if cf and size then
                    local rootPos = cf.Position
                    local dist = (rootPos - Camera.CFrame.Position).Magnitude
                    if dist <= espState.employee.maxDist then
                        local top = rootPos + Vector3.new(0, size.Y/2, 0)
                        local bot = rootPos - Vector3.new(0, size.Y/2, 0)
                        local top2D, topOn = worldToScreen(top)
                        local bot2D, botOn = worldToScreen(bot)
                        if topOn or botOn then
                            local h = math.abs(bot2D.Y - top2D.Y)
                            local w = h * 0.45
                            if espState.employee.box then
                                drw.box.Visible = true
                                drw.box.Color = espState.employee.boxColor
                                drw.box.Position = Vector2.new(top2D.X - w/2, top2D.Y)
                                drw.box.Size = Vector2.new(w, h)
                            else drw.box.Visible = false end
                            if espState.employee.tracer then
                                drw.tracer.Visible = true
                                drw.tracer.Color = espState.employee.tracerColor
                                drw.tracer.From = Vector2.new(Camera.ViewportSize.X/2, Camera.ViewportSize.Y)
                                drw.tracer.To = bot2D
                            else drw.tracer.Visible = false end
                            if espState.employee.name then
                                drw.nameLbl.Visible = true
                                drw.nameLbl.Color = espState.employee.nameColor
                                drw.nameLbl.Size = espState.employee.textSize
                                drw.nameLbl.Position = Vector2.new(top2D.X, top2D.Y - 16)
                                drw.nameLbl.Text = "Employee"
                            else drw.nameLbl.Visible = false end
                            if espState.employee.distance then
                                drw.distLbl.Visible = true
                                drw.distLbl.Position = Vector2.new(top2D.X, top2D.Y - 4)
                                drw.distLbl.Text = string.format("%.0f st", dist)
                            else drw.distLbl.Visible = false end
                            if espState.employee.health then
                                drw.hpLbl.Visible = true
                                drw.hpLbl.Position = Vector2.new(top2D.X, bot2D.Y + 2)
                                drw.hpLbl.Text = "HP: "..math.floor(getHealthFraction(emp)*100).."%"
                            else drw.hpLbl.Visible = false end
                        else for _, d in pairs(drw) do d.Visible = false end end
                    else for _, d in pairs(drw) do d.Visible = false end end
                end
            end
        end
        -- Player ESP
        local tracerOrigin = getTracerOrigin()
        for plr, drw in pairs(playerDrawings) do
            local char = plr.Character
            local root = char and char:FindFirstChild("HumanoidRootPart")
            if not root or not espState.player.enabled then
                for _, d in pairs(drw) do d.Visible = false end
            else
                local rootPos = root.Position
                local dist = (rootPos - Camera.CFrame.Position).Magnitude
                if dist <= espState.player.maxDist then
                    local hum = char:FindFirstChildOfClass("Humanoid")
                    local headY = hum and (hum.RootPart and hum.RootPart.Size.Y * 3) or 5
                    local top = rootPos + Vector3.new(0, headY/2, 0)
                    local bot = rootPos - Vector3.new(0, headY/2, 0)
                    local top2D, topOn = worldToScreen(top)
                    local bot2D, botOn = worldToScreen(bot)
                    if topOn or botOn then
                        local h = math.abs(bot2D.Y - top2D.Y)
                        local w = h * 0.45
                        if espState.player.box then
                            drw.box.Visible = true
                            drw.box.Color = espState.player.boxColor
                            drw.box.Thickness = espState.player.boxThick
                            drw.box.Position = Vector2.new(top2D.X - w/2, top2D.Y)
                            drw.box.Size = Vector2.new(w, h)
                        else drw.box.Visible = false end
                        if espState.player.tracer then
                            drw.tracer.Visible = true
                            drw.tracer.Color = espState.player.tracerColor
                            drw.tracer.From = tracerOrigin
                            drw.tracer.To = bot2D
                        else drw.tracer.Visible = false end
                        if espState.player.name then
                            drw.nameLbl.Visible = true
                            drw.nameLbl.Color = espState.player.nameColor
                            drw.nameLbl.Size = espState.player.textSize
                            drw.nameLbl.Outline = espState.player.textOutline
                            drw.nameLbl.Position = Vector2.new(top2D.X, top2D.Y - 16)
                            drw.nameLbl.Text = plr.Name
                        else drw.nameLbl.Visible = false end
                        if espState.player.distance then
                            drw.distLbl.Visible = true
                            drw.distLbl.Color = espState.player.distColor
                            drw.distLbl.Position = Vector2.new(top2D.X, top2D.Y - 4)
                            drw.distLbl.Text = string.format("%.0f st", dist)
                        else drw.distLbl.Visible = false end
                        if espState.player.health and hum then
                            drw.hpLbl.Visible = true
                            drw.hpLbl.Color = espState.player.healthColor
                            drw.hpLbl.Position = Vector2.new(top2D.X, bot2D.Y + 2)
                            drw.hpLbl.Text = "HP: "..math.floor((hum.Health/hum.MaxHealth)*100).."%"
                        else drw.hpLbl.Visible = false end
                    else for _, d in pairs(drw) do d.Visible = false end end
                else for _, d in pairs(drw) do d.Visible = false end end
            end
        end
        -- Item ESP
        for item, drw in pairs(itemDrawings) do
            local part = item:IsA("BasePart") and item or (item:IsA("Model") and item.PrimaryPart)
            if not part or not part.Parent or not espState.item.enabled then
                drw.nameLbl.Visible = false
            else
                local pos2D, onScreen = worldToScreen(part.Position)
                local dist = (part.Position - Camera.CFrame.Position).Magnitude
                if onScreen and dist <= espState.item.maxDist then
                    drw.nameLbl.Visible = true
                    drw.nameLbl.Size = espState.item.textSize
                    drw.nameLbl.Position = pos2D
                    drw.nameLbl.Text = item.Name
                else drw.nameLbl.Visible = false end
            end
        end
    end)
end
startRenderLoop()

