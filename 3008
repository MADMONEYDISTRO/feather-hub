-- ============================================================
local function getEmployeeFolder()
    local go = workspace:FindFirstChild("GameObjects")
    if not go then return nil end
    local ph = go:FindFirstChild("Physical")
    if not ph then return nil end
    return ph:FindFirstChild("Employees")
end

local function buildEmployeeDrawing(emp)
    if employeeDrawings[emp] then return end
    local s = espState.employee
    employeeDrawings[emp] = {
        box    = newDrawBox(s.boxColor, 1),
        tracer = newDrawLine(s.tracerColor, 1),
        nameLbl = newDrawText("Employee", s.nameColor, s.textSize),
        distLbl = newDrawText("",          Color3.new(1,1,1), s.textSize - 2),
        hpLbl   = newDrawText("",          Color3.fromRGB(50,255,80), s.textSize - 2),
    }
end

local function removeEmployeeDrawing(emp)
    removeDrawings(employeeDrawings, emp)
end

local function refreshEmployees()
    clearAllDrawings(employeeDrawings)
    if not espState.employee.enabled then return end
    local folder = getEmployeeFolder()
    if not folder then return end
    for _, emp in ipairs(folder:GetChildren()) do
        buildEmployeeDrawing(emp)
    end
end

