local function newDrawBox(color, thickness)
    local d = Drawing.new("Square")
    d.Visible   = false
    d.Color     = color
    d.Thickness = thickness or 1
    d.Filled    = false
    return d
end
local function newDrawLine(color, thickness)
    local d = Drawing.new("Line")
    d.Visible   = false
    d.Color     = color
    d.Thickness = thickness or 1
    return d
end
local function newDrawText(text, color, size, outline)
    local d = Drawing.new("Text")
    d.Visible = false
    d.Text    = text
    d.Color   = color
    d.Size    = size or 14
    d.Center  = true
    d.Outline = outline ~= false
    return d
end

local function removeDrawings(tbl, key)
    local entry = tbl[key]
    if not entry then return end
    for _, d in pairs(entry) do pcall(function() d:Remove() end) end
    tbl[key] = nil
end
local function clearAllDrawings(tbl)
    for k in pairs(tbl) do removeDrawings(tbl, k) end
end

-- ============================================================
-- WORLD → SCREEN HELPERS
-- ============================================================
local function worldToScreen(pos)
    local sp, onScreen = Camera:WorldToViewportPoint(pos)
    return Vector2.new(sp.X, sp.Y), onScreen, sp.Z
end

local function getBoundingBox(model)
    local ok, cf, size = pcall(function()
        return model:GetBoundingBox()
    end)
    if not ok then return nil, nil end
    return cf, size
end

local function getHealthFraction(model)
    local hum = model:FindFirstChildOfClass("Humanoid")
    if hum then return hum.Health / math.max(hum.MaxHealth, 1) end
    return 1
end

