    makeToggle(main, "Enable Item ESP", false, 2, function(v)
        espState.item.enabled = v
        if v then refreshItems(); notify("Item ESP","Enabled","success")
        else clearAllDrawings(itemDrawings); notify("Item ESP","Disabled","warning") end
    end)
    makeButton(main, "Refresh Items", 4, function()
        refreshItems()
        local count = 0; for _ in pairs(itemDrawings) do count=count+1 end
        notify("Item ESP","Refreshed — "..count.." items","success")
    end)
    makeButton(main, "Clear Item ESP", 6, function()
        clearAllDrawings(itemDrawings)
        notify("Item ESP","Drawings cleared","warning")
    end)
    local vis = makeCard(pg, 2)
    makeSection(vis, "Visual Settings", 1)
    makeToggle(vis, "Show Icons",   true, 2, function(v) espState.item.icons   = v end)
    makeSlider(vis, "Max Distance", 50, 500, 200, 4, function(v) espState.item.maxDist  = v end)
    makeSlider(vis, "Text Size",    8,  20,  14,  6, function(v) espState.item.textSize = v end)
    local filters = makeCard(pg, 3)
    makeSection(filters, "Item Filters", 1)
    local KNOWN_TYPES = {"Chair","Bed","Lamp","Bookshelf","Couch","Table","Stool","Desk"}
    local itemFilters = {}
    for _, t in ipairs(KNOWN_TYPES) do itemFilters[t] = true end
    for oi, t in ipairs(KNOWN_TYPES) do
        makeToggle(filters, t, true, oi*2, function(v)
            itemFilters[t] = v
            for item, drw in pairs(itemDrawings) do
                if item.Name == t then drw.nameLbl.Visible = v and espState.item.enabled end
            end
        end)
    end
end

