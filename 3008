-- Teleport to closest item of chosen type
local itemNamesList = {
    "2 Litre Dr. Bob", "Apple", "Banana", "Bloxy Soda", "Beans", "Burger",
    "Chips", "Cookie", "Dr. Bob Soda", "Hotdog", "Ice Cream", "Lemon",
    "Lemon Slice", "Meatballs", "Medkit", "Pizza", "Scrubber Duds",
    "Striped Donut", "Water"
}
local selectedItem = itemNamesList[1]

local function getClosestItem(itemName)
    local char = Player.Character
    local root = char and char:FindFirstChild("HumanoidRootPart")
    if not root then return nil end
    local itemsFolder = workspace:FindFirstChild("GameObjects")
    if not itemsFolder then return nil end
    local physical = itemsFolder:FindFirstChild("Physical")
    if not physical then return nil end
    local items = physical:FindFirstChild("Items")
    if not items then return nil end
    local closest, bestDist = nil, math.huge
    for _, model in ipairs(items:GetChildren()) do
        if model:IsA("Model") and model.Name == itemName then
            local part = model.PrimaryPart or model:FindFirstChild("HumanoidRootPart") or model:GetPivot()
            local dist = (root.Position - part.Position).Magnitude
            if dist < bestDist then
                bestDist = dist
                closest = model
            end
        end
    end
    return closest, bestDist
end

local function teleportToItem()
    local item, dist = getClosestItem(selectedItem)
    if item then
        local char = Player.Character
        local root = char and char:FindFirstChild("HumanoidRootPart")
        if root then
            local pos = (item.PrimaryPart and item.PrimaryPart.CFrame or item:GetPivot()) + Vector3.new(0,3,0)
            root.CFrame = pos
            notify("Teleport", "Teleported to "..selectedItem, "success")
        end
    else
        notify("Teleport", "No "..selectedItem.." found nearby", "error")
    end
end

-- Rejoin & server hop
local function rejoin()
    TeleportService:Teleport(game.PlaceId, Player)
end
local function serverHop()
    local servers = HttpService:JSONDecode(game:HttpGet("https://games.roblox.com/v1/games/"..game.PlaceId.."/servers/Public?sortOrder=Asc&limit=100"))
    for _, server in ipairs(servers.data) do
        if server.id ~= game.JobId and server.playing < server.maxPlayers then
            TeleportService:TeleportToPlaceInstance(game.PlaceId, server.id, Player)
            break
        end
    end
end

