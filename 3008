    knob.BackgroundColor3 = Color3.new(1,1,1); knob.BorderSizePixel = 0
    knob.AutoButtonColor = false; knob.Text = ""; knob.ZIndex = 3; knob.Parent = track; makeCorner(knob,7)

    local dragging = false
    knob.InputBegan:Connect(function(i)
        if i.UserInputType == Enum.UserInputType.MouseButton1 then dragging = true end
    end)
    UserInputService.InputEnded:Connect(function(i)
        if i.UserInputType == Enum.UserInputType.MouseButton1 then dragging = false end
    end)
    UserInputService.InputChanged:Connect(function(i)
        if dragging and i.UserInputType == Enum.UserInputType.MouseMovement then
            local ap = track.AbsolutePosition; local az = track.AbsoluteSize
            local ratio = math.clamp((i.Position.X - ap.X) / az.X, 0, 1)
            local val = math.floor(minV + ratio * (maxV - minV))
            fill.Size = UDim2.new(ratio,0,1,0)
            knob.Position = UDim2.new(ratio,-7,0.5,-7)
            valLbl.Text = tostring(val)
            onChange(val)
        end
    end)
    return row
end

-- Dropdown (simple cycling)
local function makeDropdown(parent, label, options, initVal, rowOrder, onChange)
    local row = makeRow(parent, 42, rowOrder)
    rowLabel(row, label)
    local current = initVal or options[1]
    local idx = 1
    for i,v in ipairs(options) do if v==current then idx=i break end end

    local btn = Instance.new("TextButton")
    btn.Size = UDim2.new(0,110,0,26); btn.Position = UDim2.new(1,-122,0.5,-13)
    btn.Text = current; btn.Font = Enum.Font.GothamBold; btn.TextSize = 9
    btn.TextColor3 = T.text; btn.BackgroundColor3 = T.inputBg
    btn.BorderSizePixel = 0; btn.AutoButtonColor = false; btn.Parent = row
    makeCorner(btn, 6); makeStroke(btn, T.border)

    btn.MouseButton1Click:Connect(function()
        idx = (idx % #options) + 1
        current = options[idx]
        btn.Text = current
        onChange(current)
    end)
    return row
end

-- Color swatch button (opens a basic RGB notify — full colorpicker is complex; swatches below)
local function makeColorPicker(parent, label, initColor, rowOrder, onChange)
    local row = makeRow(parent, 42, rowOrder)
    rowLabel(row, label)
    local swatch = Instance.new("TextButton")
    swatch.Size = UDim2.new(0,30,0,22); swatch.Position = UDim2.new(1,-42,0.5,-11)
    swatch.BackgroundColor3 = initColor; swatch.BorderSizePixel = 0
    swatch.AutoButtonColor = false; swatch.Text = ""; swatch.Parent = row
    makeCorner(swatch, 5); makeStroke(swatch, T.border)

    -- Cycle through a palette on click (practical without a full color wheel)
    local palette = {
        Color3.fromRGB(255,50,50),   Color3.fromRGB(50,255,100),
        Color3.fromRGB(50,150,255),  Color3.fromRGB(255,220,50),
        Color3.fromRGB(255,120,20),  Color3.fromRGB(220,50,255),
        Color3.fromRGB(255,255,255), Color3.fromRGB(120,120,120),
    }
    local pi = 1
    for i,c in ipairs(palette) do if c==initColor then pi=i break end end
    swatch.MouseButton1Click:Connect(function()
        pi = (pi % #palette) + 1
        swatch.BackgroundColor3 = palette[pi]
        onChange(palette[pi])
    end)
    return row
end

