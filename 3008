end

local function makeRow(parent, h, order)
    local sep = Instance.new("Frame")
    sep.Size = UDim2.new(1,0,0,1); sep.BackgroundColor3 = T.sep
    sep.BorderSizePixel = 0; sep.LayoutOrder = order; sep.Parent = parent
    local row = Instance.new("Frame")
    row.Size = UDim2.new(1,0,0, h or 42); row.BackgroundTransparency = 1
    row.BorderSizePixel = 0; row.LayoutOrder = order+1; row.Parent = parent
    return row
end

local function rowLabel(parent, text, xOff, small)
    local lbl = Instance.new("TextLabel")
    lbl.Size = UDim2.new(0.58,0,1,0); lbl.Position = UDim2.new(0, xOff or 14, 0, 0)
    lbl.Text = text; lbl.Font = Enum.Font.GothamSemibold
    lbl.TextSize = small and 9 or 10; lbl.TextColor3 = T.text
    lbl.TextXAlignment = Enum.TextXAlignment.Left; lbl.BackgroundTransparency = 1; lbl.Parent = parent
    return lbl
end

local function makeToggle(parent, label, initState, rowOrder, onChange)
    local row = makeRow(parent, 42, rowOrder)
    rowLabel(row, label)
    local track = Instance.new("TextButton")
    track.Size = UDim2.new(0,38,0,20); track.Position = UDim2.new(1,-52,0.5,-10)
    track.BackgroundColor3 = initState and T.accent or T.dim
    track.BorderSizePixel = 0; track.AutoButtonColor = false; track.Text = ""; track.ZIndex = 2; track.Parent = row
    makeCorner(track,10)
    local knob = Instance.new("Frame")
    knob.Size = UDim2.new(0,16,0,16)
    knob.Position = initState and UDim2.new(1,-18,0.5,-8) or UDim2.new(0,2,0.5,-8)
    knob.BackgroundColor3 = Color3.new(1,1,1); knob.BorderSizePixel = 0; knob.ZIndex = 3; knob.Parent = track
    makeCorner(knob,8)
    local state = initState
    track.MouseButton1Click:Connect(function()
        state = not state
        TweenService:Create(track, tw(0.15), {BackgroundColor3 = state and T.accent or T.dim}):Play()
        TweenService:Create(knob,  tw(0.15), {Position = state and UDim2.new(1,-18,0.5,-8) or UDim2.new(0,2,0.5,-8)}):Play()
        onChange(state)
    end)
    return row, track, knob
end

local function makeButton(parent, label, rowOrder, onClick)
    local row = makeRow(parent, 42, rowOrder)
    local btn = Instance.new("TextButton")
    btn.Size = UDim2.new(1,-28,0,28); btn.Position = UDim2.new(0,14,0.5,-14)
    btn.Text = label; btn.Font = Enum.Font.GothamBold; btn.TextSize = 10
    btn.TextColor3 = Color3.new(1,1,1); btn.BackgroundColor3 = T.accentDm
    btn.BorderSizePixel = 0; btn.AutoButtonColor = false; btn.Parent = row
    makeCorner(btn,7); makeStroke(btn, T.accent, 1)
    btn.MouseEnter:Connect(function() TweenService:Create(btn, tw(0.12), {BackgroundColor3=T.accent}):Play() end)
    btn.MouseLeave:Connect(function() TweenService:Create(btn, tw(0.12), {BackgroundColor3=T.accentDm}):Play() end)
    btn.MouseButton1Click:Connect(onClick)
    return row, btn
end

local function makeSlider(parent, label, minV, maxV, initV, rowOrder, onChange)
    local row = makeRow(parent, 54, rowOrder)
    rowLabel(row, label, 14)
    local valLbl = Instance.new("TextLabel")
    valLbl.Size = UDim2.new(0,36,0,20); valLbl.Position = UDim2.new(1,-48,0,6)
    valLbl.Text = tostring(initV); valLbl.Font = Enum.Font.GothamBold; valLbl.TextSize = 9
    valLbl.TextColor3 = T.accent; valLbl.TextXAlignment = Enum.TextXAlignment.Right
    valLbl.BackgroundTransparency = 1; valLbl.Parent = row

    local track = Instance.new("Frame")
    track.Size = UDim2.new(1,-28,0,6); track.Position = UDim2.new(0,14,0,36)
    track.BackgroundColor3 = T.dim; track.BorderSizePixel = 0; track.Parent = row; makeCorner(track,3)
    local fill = Instance.new("Frame")
    fill.Size = UDim2.new((initV-minV)/(maxV-minV),0,1,0); fill.BackgroundColor3 = T.accent
    fill.BorderSizePixel = 0; fill.Parent = track; makeCorner(fill,3)
    local knob = Instance.new("TextButton")
    knob.Size = UDim2.new(0,14,0,14); knob.Position = UDim2.new((initV-minV)/(maxV-minV),-7,0.5,-7)
    knob.BackgroundColor3 = Color3.new(1,1,1); knob.BorderSizePixel = 0
    knob.AutoButtonColor = false; knob.Text = ""; knob.ZIndex = 3; knob.Parent = track; makeCorner(knob,7)

    local dragging = false
    knob.InputBegan:Connect(function(i) if i.UserInputType == Enum.UserInputType.MouseButton1 then dragging = true end end)
    UserInputService.InputEnded:Connect(function(i) if i.UserInputType == Enum.UserInputType.MouseButton1 then dragging = false end end)
    UserInputService.InputChanged:Connect(function(i)
        if dragging and i.UserInputType == Enum.UserInputType.MouseMovement then
            local ap = track.AbsolutePosition; local az = track.AbsoluteSize
            local ratio = math.clamp((i.Position.X - ap.X) / az.X, 0, 1)
            local val = math.floor(minV + ratio * (maxV - minV))
            fill.Size = UDim2.new(ratio,0,1,0)
            knob.Position = UDim2.new(ratio,-7,0.5,-7)
            valLbl.Text = tostring(val)
            onChange(val)
        end
    end)
    return row
end

local function makeDropdown(parent, label, options, initVal, rowOrder, onChange)
    local row = makeRow(parent, 42, rowOrder)
    rowLabel(row, label)
    local current = initVal or options[1]
    local idx = 1
    for i,v in ipairs(options) do if v==current then idx=i break end end
    local btn = Instance.new("TextButton")
    btn.Size = UDim2.new(0,110,0,26); btn.Position = UDim2.new(1,-122,0.5,-13)
    btn.Text = current; btn.Font = Enum.Font.GothamBold; btn.TextSize = 9
    btn.TextColor3 = T.text; btn.BackgroundColor3 = T.inputBg
    btn.BorderSizePixel = 0; btn.AutoButtonColor = false; btn.Parent = row
    makeCorner(btn, 6); makeStroke(btn, T.border)
    btn.MouseButton1Click:Connect(function()
        idx = (idx % #options) + 1
        current = options[idx]
        btn.Text = current
        onChange(current)
    end)
    return row
end

local function makeColorPicker(parent, label, initColor, rowOrder, onChange)
    local row = makeRow(parent, 42, rowOrder)
    rowLabel(row, label)
    local swatch = Instance.new("TextButton")
    swatch.Size = UDim2.new(0,30,0,22); swatch.Position = UDim2.new(1,-42,0.5,-11)
    swatch.BackgroundColor3 = initColor; swatch.BorderSizePixel = 0
    swatch.AutoButtonColor = false; swatch.Text = ""; swatch.Parent = row
    makeCorner(swatch, 5); makeStroke(swatch, T.border)
    local palette = {
        Color3.fromRGB(255,50,50),   Color3.fromRGB(50,255,100),
        Color3.fromRGB(50,150,255),  Color3.fromRGB(255,220,50),
        Color3.fromRGB(255,120,20),  Color3.fromRGB(220,50,255),
        Color3.fromRGB(255,255,255), Color3.fromRGB(120,120,120),
    }
    local pi = 1
    for i,c in ipairs(palette) do if c==initColor then pi=i break end end
    swatch.MouseButton1Click:Connect(function()
        pi = (pi % #palette) + 1
        swatch.BackgroundColor3 = palette[pi]
        onChange(palette[pi])
    end)
    return row
end

