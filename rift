-- Get CFrame from any rift object — prefer Sign child for accuracy
local function getCF(obj)
    -- First check for a Sign child (most accurate rift position)
    if obj:IsA("Model") then
        local sign = obj:FindFirstChild("Sign")
        if sign then
            if sign:IsA("BasePart") then
                return sign.CFrame
            elseif sign:IsA("Model") then
                if sign.PrimaryPart then
                    return sign.PrimaryPart.CFrame
                end
                local ok2, piv2 = pcall(function() return sign:GetPivot() end)
                if ok2 and piv2 then return piv2 end
                for _, ch in ipairs(sign:GetDescendants()) do
                    if ch:IsA("BasePart") then return ch.CFrame end
                end
            end
        end
    end
    -- Fallback to the rift object itself
    if obj:IsA("BasePart") then
        return obj.CFrame
    elseif obj:IsA("Model") then
        if obj.PrimaryPart then
            return obj.PrimaryPart.CFrame
        end
        local ok, piv = pcall(function() return obj:GetPivot() end)
        if ok and piv then
            return piv
        end
        for _, child in ipairs(obj:GetDescendants()) do
            if child:IsA("BasePart") then
                return child.CFrame
            end
        end
    end
    return nil
end

local function getTimer(obj)
    if not obj:IsA("Model") then return nil end
    for _, child in ipairs(obj:GetChildren()) do
        local display = child:FindFirstChild("Display")
        if not display then display = child end
        local surfGui = display:FindFirstChildOfClass("SurfaceGui")
        if not surfGui then surfGui = child:FindFirstChildOfClass("SurfaceGui") end
        if surfGui then
            local timer = surfGui:FindFirstChild("Timer")
            if timer and timer:IsA("TextLabel") then
                return timer.Text
            end
        end
    end
    -- Also check direct children
    for _, desc in ipairs(obj:GetDescendants()) do
        if desc.Name == "Timer" and desc:IsA("TextLabel") then
            return desc.Text
        end
    end
    return nil
end

local function scan()
    -- Find all current rifts
    local found = {}
    local timers = {}
    pcall(function()
        local rendered = workspace:FindFirstChild("Rendered")
        if not rendered then return end
        local riftsFolder = rendered:FindFirstChild("Rifts")
        if not riftsFolder then return end
        for _, obj in ipairs(riftsFolder:GetChildren()) do
            local cf = getCF(obj)
            if cf then
                found[obj.Name] = cf
                local t = getTimer(obj)
                if t and t ~= "" then
                    timers[obj.Name] = t
                end
            end
        end
    end)

    -- Update existing rows and create new ones
    for name, cf in pairs(found) do
        local d = makeRow(name)
        d.cf = cf
        d.alive = true
        d.dot.BackgroundColor3 = onCol
        d.nm.TextColor3 = onCol
        if timers[name] then
            d.nm.Text = name .. "  " .. timers[name]
        else
            d.nm.Text = name
        end
        d.tp.Text = "TP"
        d.tp.TextColor3 = Color3.new(1, 1, 1)
        d.tp.BackgroundColor3 = tpCol
        d.row.BackgroundColor3 = secCol
        d.row.BackgroundTransparency = 0
    end

    -- Mark gone rifts as offline
    for name, d in pairs(rowData) do
        if not found[name] then
            d.alive = false
            d.cf = nil
            d.dot.BackgroundColor3 = offCol
            d.nm.TextColor3 = offCol
            d.nm.Text = name
            d.tp.Text = "---"
            d.tp.TextColor3 = offCol
            d.tp.BackgroundColor3 = drkCol
            d.row.BackgroundColor3 = drkCol
            d.row.BackgroundTransparency = 0.3
        end
    end

    -- Update title and canvas
    local count = 0
    local total = 0
    for _, d in pairs(rowData) do
        total = total + 1
        if d.alive then count = count + 1 end
    end
    tLbl.Text = "Rifts (" .. count .. "/" .. total .. " active)"
end

