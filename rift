local Players = game:GetService("Players")
local UserInputService = game:GetService("UserInputService")
local player = Players.LocalPlayer
local playerGui = player:WaitForChild("PlayerGui")

if playerGui:FindFirstChild("RiftTP") then
    playerGui.RiftTP.Enabled = true
    return
end

local bgCol = Color3.fromRGB(25, 25, 30)
local hdrCol = Color3.fromRGB(35, 35, 42)
local secCol = Color3.fromRGB(40, 40, 48)
local accCol = Color3.fromRGB(60, 60, 70)
local txtCol = Color3.fromRGB(180, 180, 190)
local drkCol = Color3.fromRGB(30, 30, 35)
local onCol = Color3.fromRGB(50, 220, 90)
local offCol = Color3.fromRGB(80, 80, 90)
local tpCol = Color3.fromRGB(100, 60, 200)

local function mkC(p, r)
    Instance.new("UICorner", p).CornerRadius = UDim.new(0, r or 6)
end

local RIFT_NAMES = {
    "brainrot-rift",
    "bubble-rift",
    "dev-rift",
    "dice-rift",
    "festival-rift-1",
    "festival-rift-2",
    "festival-rift-3",
    "fortune-rift-1",
    "fortune-rift-2",
    "fortune-rift-3",
    "gift-rift",
    "lunar-rift-1",
    "lunar-rift-2",
    "lunar-rift-3",
    "moon-rift",
    "og-rift",
    "rift-vendor",
    "stpat-rift-1",
    "stpat-rift-2",
    "stpat-rift-3",
}

local liveCFs = {}

local ROW_H = 24
local BODY_H = #RIFT_NAMES * (ROW_H + 2) + 4
