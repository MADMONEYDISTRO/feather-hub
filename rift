-- Get chest timer: chest > Countdown > BillboardGui > Label
local function getChestTimer(obj)
    if not obj:IsA("Model") then return nil end
    local countdown = obj:FindFirstChild("Countdown")
    if countdown then
        local bbg = countdown:FindFirstChildOfClass("BillboardGui")
        if bbg then
            local label = bbg:FindFirstChild("Label")
            if label and label:IsA("TextLabel") then
                return label.Text
            end
        end
    end
    -- Fallback: search all descendants for a Label inside BillboardGui
    for _, desc in ipairs(obj:GetDescendants()) do
        if desc.Name == "Label" and desc:IsA("TextLabel") then
            local parent = desc.Parent
            if parent and parent:IsA("BillboardGui") then
                return desc.Text
            end
        end
    end
    return nil
end

local function scanChests()
    local found = {}
    pcall(function()
        local rendered = workspace:FindFirstChild("Rendered")
        if not rendered then return end
        -- Names to look for (case insensitive check)
        local function isChest(name)
            local low = name:lower()
            return low:find("chest") or low:find("pot o gold") or low:find("pot_o_gold")
        end
        -- Search all folders under Rendered
        for _, folder in ipairs(rendered:GetChildren()) do
            if folder:IsA("Folder") or folder:IsA("Model") then
                for _, obj in ipairs(folder:GetChildren()) do
                    if obj:IsA("Model") and isChest(obj.Name) then
                        local cf = getCF(obj)
                        if cf then
                            local timer = getChestTimer(obj)
                            found[obj.Name] = {cf = cf, timer = timer}
                        end
                    end
                end
            end
        end
        -- Also check direct children of Rendered
        for _, obj in ipairs(rendered:GetChildren()) do
            if obj:IsA("Model") and isChest(obj.Name) then
                local cf = getCF(obj)
                if cf then
                    local timer = getChestTimer(obj)
                    found[obj.Name] = {cf = cf, timer = timer}
                end
            end
        end
    end)

    -- Update or create chest rows
    local goldCol = Color3.fromRGB(220, 170, 40)
    for name, info in pairs(found) do
        local d = makeChestRow(name)
        d.cf = info.cf
        d.alive = true
        d.dot.BackgroundColor3 = goldCol
        d.nm.TextColor3 = goldCol
        if info.timer and info.timer ~= "" then
            d.nm.Text = name .. "  " .. info.timer
        else
            d.nm.Text = name
        end
        d.tp.Text = "TP"
        d.tp.TextColor3 = Color3.new(1, 1, 1)
        d.tp.BackgroundColor3 = Color3.fromRGB(200, 150, 30)
        d.row.BackgroundColor3 = secCol
        d.row.BackgroundTransparency = 0
    end

    -- Mark gone chests as offline
    for name, d in pairs(chestData) do
        if not found[name] then
            d.alive = false
            d.cf = nil
            d.dot.BackgroundColor3 = offCol
            d.nm.TextColor3 = offCol
            d.nm.Text = name
            d.tp.Text = "---"
            d.tp.TextColor3 = offCol
            d.tp.BackgroundColor3 = drkCol
            d.row.BackgroundColor3 = drkCol
            d.row.BackgroundTransparency = 0.3
        end
    end

    -- Update chest count in divider
    local cCount = 0
    local cTotal = 0
    for _, d in pairs(chestData) do
        cTotal = cTotal + 1
        if d.alive then cCount = cCount + 1 end
    end
    chestTitle.Text = "Chests (" .. cCount .. "/" .. cTotal .. " found)"
end

-- Combined scan
local function scanAll()
    scan()
    scanChests()
    -- Update total canvas
    local totalRows = 0
    for _ in pairs(rowData) do totalRows = totalRows + 1 end
    for _ in pairs(chestData) do totalRows = totalRows + 1 end
    totalRows = totalRows + 1 -- divider
    scroll.CanvasSize = UDim2.new(0, 0, 0, totalRows * (ROW_H + 2) + 10)
end

-- Scan every 2 seconds
task.spawn(function()
    while sg and sg.Parent do
        pcall(scanAll)
        task.wait(2)
    end
end)
