local function stopFarmForRift(name)
    local thread = activeFarmThreads[name]
    if thread then
        pcall(task.cancel, thread)
        activeFarmThreads[name] = nil
    end
end

local function startFarmForRift(name, cf)
    stopFarmForRift(name)
    local thread = task.spawn(function()
        local riftName = name
        local riftCF = cf
        local riftData = rowData[riftName]
        while riftData and riftData.farmActive and riftData.alive and riftData.cf do
            pcall(function()
                local root = player.Character and player.Character:FindFirstChild("HumanoidRootPart")
                if root and riftData.cf then
                    local dist = (root.Position - riftData.cf.Position).Magnitude
                    if dist > 20 then
                        root.CFrame = riftData.cf
                    end
                end
            end)
            for _ = 1, 3 do
                if not (riftData and riftData.farmActive and riftData.alive) then break end
                pressR()
                task.wait(0.2)
            end
            task.wait(1)
            pcall(scanRifts) -- refresh rift status
            riftData = rowData[riftName]
            if not (riftData and riftData.alive) then
                break
            end
        end
        if rowData[riftName] then
            rowData[riftName].farmActive = false
            rowData[riftName].farmBtn.Text = "Farm"
            rowData[riftName].farmBtn.BackgroundColor3 = drkCol
            rowData[riftName].farmBtn.TextColor3 = txtCol
        end
        activeFarmThreads[riftName] = nil
    end)
    activeFarmThreads[name] = thread
end

