    mkC(dot, 4)

    local nm = Instance.new("TextLabel")
    nm.Size = UDim2.new(1, -75, 1, 0)
    nm.Position = UDim2.new(0, 20, 0, 0)
    nm.Text = r.n
    nm.Font = Enum.Font.Gotham
    nm.TextSize = 9
    nm.TextColor3 = offCol
    nm.TextXAlignment = Enum.TextXAlignment.Left
    nm.BackgroundTransparency = 1
    nm.Parent = row

    local tp = Instance.new("TextButton")
    tp.Size = UDim2.new(0, 50, 0, 16)
    tp.Position = UDim2.new(1, -56, 0.5, -8)
    tp.Text = "TP"
    tp.Font = Enum.Font.GothamBold
    tp.TextSize = 8
    tp.TextColor3 = Color3.new(1, 1, 1)
    tp.BackgroundColor3 = tpCol
    tp.BorderSizePixel = 0
    tp.Parent = row
    mkC(tp, 4)

    local ci = i
    tp.MouseButton1Click:Connect(function()
        pcall(function()
            local root = player.Character and player.Character:FindFirstChild("HumanoidRootPart")
            if root then
                root.CFrame = CFrame.new(rifts[ci].x, rifts[ci].y, rifts[ci].z)
            end
        end)
        tp.Text = "OK"
        tp.BackgroundColor3 = Color3.fromRGB(50, 180, 100)
        task.delay(1, function()
            if tp.Parent then
                tp.Text = "TP"
                tp.BackgroundColor3 = tpCol
            end
        end)
    end)

    rows[i] = {dot = dot, nm = nm, row = row}
end

-- Check which rifts are active every 5s
task.spawn(function()
    while sg and sg.Parent do
        pcall(function()
            local active = {}
            pcall(function()
                local rf = workspace.Rendered.Rifts
                for _, obj in ipairs(rf:GetChildren()) do
                    active[obj.Name] = true
                end
            end)

            local count = 0
            for i, r in ipairs(rifts) do
                local isActive = false
                for name in pairs(active) do
                    if name:lower():find(r.n:lower():sub(1,8), 1, true) then
                        isActive = true
                        break
                    end
                end
                if isActive then
                    count = count + 1
                    rows[i].dot.BackgroundColor3 = onCol
                    rows[i].nm.TextColor3 = onCol
                else
                    rows[i].dot.BackgroundColor3 = offCol
                    rows[i].nm.TextColor3 = offCol
                end
            end

            tLbl.Text = "Rift Teleporter (" .. count .. " active)"
        end)
        task.wait(5)
    end
end)
