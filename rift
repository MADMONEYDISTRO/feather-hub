-- Track all rift rows
local rowData = {}
local nextOrder = 1
local ROW_H = 24

local function makeRow(name)
    if rowData[name] then return rowData[name] end

    local row = Instance.new("Frame")
    row.Size = UDim2.new(1, -4, 0, ROW_H)
    row.BackgroundColor3 = secCol
    row.BorderSizePixel = 0
    row.LayoutOrder = nextOrder
    row.Parent = scroll
    mkC(row, 4)
    nextOrder = nextOrder + 1

    local dot = Instance.new("Frame")
    dot.Size = UDim2.new(0, 8, 0, 8)
    dot.Position = UDim2.new(0, 6, 0.5, -4)
    dot.BackgroundColor3 = onCol
    dot.BorderSizePixel = 0
    dot.Parent = row
    mkC(dot, 4)

    local nm = Instance.new("TextLabel")
    nm.Size = UDim2.new(1, -75, 1, 0)
    nm.Position = UDim2.new(0, 20, 0, 0)
    nm.Text = name
    nm.Font = Enum.Font.Gotham
    nm.TextSize = 9
    nm.TextColor3 = onCol
    nm.TextXAlignment = Enum.TextXAlignment.Left
    nm.BackgroundTransparency = 1
    nm.Parent = row

    local tp = Instance.new("TextButton")
    tp.Size = UDim2.new(0, 50, 0, 16)
    tp.Position = UDim2.new(1, -56, 0.5, -8)
    tp.Text = "TP"
    tp.Font = Enum.Font.GothamBold
    tp.TextSize = 8
    tp.TextColor3 = Color3.new(1, 1, 1)
    tp.BackgroundColor3 = tpCol
    tp.BorderSizePixel = 0
    tp.Parent = row
    mkC(tp, 4)

    local d = {row = row, dot = dot, nm = nm, tp = tp, cf = nil, alive = true}
    rowData[name] = d

    tp.MouseButton1Click:Connect(function()
        if not d.cf then return end
        pcall(function()
            local root = player.Character and player.Character:FindFirstChild("HumanoidRootPart")
            if root then
                root.CFrame = d.cf
            end
        end)
        tp.Text = "OK"
        tp.BackgroundColor3 = Color3.fromRGB(50, 180, 100)
        task.delay(1, function()
            if tp.Parent then
                tp.Text = "TP"
                tp.BackgroundColor3 = tpCol
            end
        end)
    end)

    return d
end

-- Get CFrame from any rift object
local function getCF(obj)
    if obj:IsA("BasePart") then
        return obj.CFrame
    elseif obj:IsA("Model") then
        if obj.PrimaryPart then
            return obj.PrimaryPart.CFrame
        end
        local ok, piv = pcall(function() return obj:GetPivot() end)
        if ok and piv then
            return piv
        end
        -- Fallback: find any BasePart inside
        for _, child in ipairs(obj:GetDescendants()) do
            if child:IsA("BasePart") then
                return child.CFrame
            end
        end
    end
    return nil
end

local function scan()
    -- Find all current rifts
    local found = {}
    pcall(function()
        local rendered = workspace:FindFirstChild("Rendered")
        if not rendered then return end
        local riftsFolder = rendered:FindFirstChild("Rifts")
        if not riftsFolder then return end
        for _, obj in ipairs(riftsFolder:GetChildren()) do
            local cf = getCF(obj)
            if cf then
                found[obj.Name] = cf
            end
        end
    end)

    -- Update existing rows and create new ones
    for name, cf in pairs(found) do
        local d = makeRow(name)
        d.cf = cf
        d.alive = true
        d.dot.BackgroundColor3 = onCol
        d.nm.TextColor3 = onCol
        d.tp.Text = "TP"
        d.tp.TextColor3 = Color3.new(1, 1, 1)
        d.tp.BackgroundColor3 = tpCol
    end

    -- Mark gone rifts as offline
    for name, d in pairs(rowData) do
        if not found[name] then
            d.alive = false
            d.cf = nil
            d.dot.BackgroundColor3 = offCol
            d.nm.TextColor3 = offCol
            d.tp.Text = "---"
            d.tp.TextColor3 = Color3.fromRGB(120, 120, 130)
            d.tp.BackgroundColor3 = drkCol
        end
    end

    -- Update title and canvas
    local count = 0
    local total = 0
    for _, d in pairs(rowData) do
        total = total + 1
        if d.alive then count = count + 1 end
    end
    tLbl.Text = "Rifts (" .. count .. "/" .. total .. " active)"
    scroll.CanvasSize = UDim2.new(0, 0, 0, total * (ROW_H + 2) + 4)
end

-- Scan every 2 seconds
task.spawn(function()
    while sg and sg.Parent do
        pcall(scan)
        task.wait(2)
    end
end)
