hdr.BackgroundColor3 = hdrCol
hdr.BorderSizePixel = 0
hdr.Parent = win
mkC(hdr, 8)

local tLbl = Instance.new("TextLabel")
tLbl.Size = UDim2.new(1, -55, 1, 0)
tLbl.Position = UDim2.new(0, 10, 0, 0)
tLbl.Text = "Rift Teleporter"
tLbl.Font = Enum.Font.GothamBold
tLbl.TextSize = 11
tLbl.TextColor3 = txtCol
tLbl.TextXAlignment = Enum.TextXAlignment.Left
tLbl.BackgroundTransparency = 1
tLbl.Parent = hdr

local isMin = false
local minB = Instance.new("TextButton")
minB.Size = UDim2.new(0, 20, 0, 20)
minB.Position = UDim2.new(1, -48, 0.5, -10)
minB.Text = "-"
minB.Font = Enum.Font.GothamBold
minB.TextSize = 14
minB.TextColor3 = txtCol
minB.BackgroundColor3 = drkCol
minB.BorderSizePixel = 0
minB.Parent = hdr
mkC(minB, 4)

minB.MouseButton1Click:Connect(function()
    isMin = not isMin
    if isMin then
        win.Size = UDim2.new(0, 240, 0, 30)
        minB.Text = "+"
    else
        win.Size = UDim2.new(0, 240, 0, WIN_H)
        minB.Text = "-"
    end
end)

local clsB = Instance.new("TextButton")
clsB.Size = UDim2.new(0, 20, 0, 20)
clsB.Position = UDim2.new(1, -24, 0.5, -10)
clsB.Text = "X"
clsB.Font = Enum.Font.GothamBold
clsB.TextSize = 10
clsB.TextColor3 = txtCol
clsB.BackgroundColor3 = drkCol
clsB.BorderSizePixel = 0
clsB.Parent = hdr
mkC(clsB, 4)

clsB.MouseButton1Click:Connect(function()
    sg.Enabled = false
end)

local dragging, dragStart, startPos
hdr.InputBegan:Connect(function(i)
    if i.UserInputType == Enum.UserInputType.MouseButton1 or i.UserInputType == Enum.UserInputType.Touch then
        dragging = true
        dragStart = i.Position
        startPos = win.Position
    end
end)
hdr.InputEnded:Connect(function(i)
    if i.UserInputType == Enum.UserInputType.MouseButton1 or i.UserInputType == Enum.UserInputType.Touch then
        dragging = false
    end
end)
UserInputService.InputChanged:Connect(function(i)
    if dragging and (i.UserInputType == Enum.UserInputType.MouseMovement or i.UserInputType == Enum.UserInputType.Touch) then
        local d = i.Position - dragStart
        win.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + d.X, startPos.Y.Scale, startPos.Y.Offset + d.Y)
    end
end)
UserInputService.InputEnded:Connect(function(i)
    if i.UserInputType == Enum.UserInputType.MouseButton1 or i.UserInputType == Enum.UserInputType.Touch then
        dragging = false
    end
end)

local scroll = Instance.new("ScrollingFrame")
scroll.Size = UDim2.new(1, -8, 1, -34)
scroll.Position = UDim2.new(0, 4, 0, 32)
scroll.BackgroundTransparency = 1
scroll.BorderSizePixel = 0
scroll.ScrollBarThickness = 3
scroll.ScrollBarImageColor3 = accCol
scroll.CanvasSize = UDim2.new(0, 0, 0, BODY_H)
scroll.Parent = win

local lay = Instance.new("UIListLayout")
lay.SortOrder = Enum.SortOrder.LayoutOrder
lay.Padding = UDim.new(0, 2)
lay.Parent = scroll

local rows = {}
for i, rn in ipairs(RIFT_NAMES) do
    local row = Instance.new("Frame")
    row.Size = UDim2.new(1, -4, 0, ROW_H)
    row.BackgroundColor3 = secCol
    row.BorderSizePixel = 0
    row.LayoutOrder = i
    row.Parent = scroll
    mkC(row, 4)

    local dot = Instance.new("Frame")
    dot.Size = UDim2.new(0, 8, 0, 8)
    dot.Position = UDim2.new(0, 6, 0.5, -4)
    dot.BackgroundColor3 = offCol
    dot.BorderSizePixel = 0
    dot.Parent = row
    mkC(dot, 4)

    local nm = Instance.new("TextLabel")
    nm.Size = UDim2.new(1, -75, 1, 0)
    nm.Position = UDim2.new(0, 20, 0, 0)
    nm.Text = rn
    nm.Font = Enum.Font.Gotham
    nm.TextSize = 9
    nm.TextColor3 = offCol
    nm.TextXAlignment = Enum.TextXAlignment.Left
    nm.BackgroundTransparency = 1
    nm.Parent = row

    local tp = Instance.new("TextButton")
    tp.Size = UDim2.new(0, 50, 0, 16)
    tp.Position = UDim2.new(1, -56, 0.5, -8)
    tp.Text = "---"
    tp.Font = Enum.Font.GothamBold
    tp.TextSize = 8
    tp.TextColor3 = Color3.fromRGB(120, 120, 130)
    tp.BackgroundColor3 = Color3.fromRGB(45, 45, 52)
    tp.BorderSizePixel = 0
    tp.Parent = row
    mkC(tp, 4)

    local capName = rn
    tp.MouseButton1Click:Connect(function()
        local cf = liveCFs[capName]
        if not cf then return end
        pcall(function()
            local root = player.Character and player.Character:FindFirstChild("HumanoidRootPart")
            if root then root.CFrame = cf end
        end)
        tp.Text = "OK"
        tp.BackgroundColor3 = Color3.fromRGB(50, 180, 100)
        task.delay(1, function()
            if tp.Parent then
                if liveCFs[capName] then
                    tp.Text = "TP"
                    tp.BackgroundColor3 = tpCol
                    tp.TextColor3 = Color3.new(1, 1, 1)
                else
                    tp.Text = "---"
                    tp.BackgroundColor3 = Color3.fromRGB(45, 45, 52)
                    tp.TextColor3 = Color3.fromRGB(120, 120, 130)
                end
            end
        end)
    end)

    rows[rn] = {dot = dot, nm = nm, tp = tp}
end

local function getCF(obj)
    if obj:IsA("BasePart") then
        return obj.CFrame
    end
    if obj:IsA("Model") then
        if obj.PrimaryPart then
            return obj.PrimaryPart.CFrame
        end
        local ok, piv = pcall(function() return obj:GetPivot() end)
        if ok and piv then return piv end
        for _, ch in ipairs(obj:GetDescendants()) do
            if ch:IsA("BasePart") then return ch.CFrame end
        end
    end
    return nil
end

local function scanRifts()
    liveCFs = {}
    local found = {}

    pcall(function()
        local rendered = workspace:FindFirstChild("Rendered")
        if not rendered then return end
        local riftsFolder = rendered:FindFirstChild("Rifts")
        if not riftsFolder then return end
        for _, obj in ipairs(riftsFolder:GetChildren()) do
            local cf = getCF(obj)
            if cf then
                found[obj.Name] = cf
            end
        end
    end)

    local count = 0
    for _, rn in ipairs(RIFT_NAMES) do
        local cf = found[rn]
        local r = rows[rn]
        if cf then
            count = count + 1
            liveCFs[rn] = cf
            r.dot.BackgroundColor3 = onCol
            r.nm.TextColor3 = onCol
            r.tp.Text = "TP"
            r.tp.TextColor3 = Color3.new(1, 1, 1)
            r.tp.BackgroundColor3 = tpCol
        else
            r.dot.BackgroundColor3 = offCol
            r.nm.TextColor3 = offCol
            r.tp.Text = "---"
            r.tp.TextColor3 = Color3.fromRGB(120, 120, 130)
            r.tp.BackgroundColor3 = Color3.fromRGB(45, 45, 52)
        end
    end

    tLbl.Text = "Rifts (" .. count .. "/" .. #RIFT_NAMES .. " active)"
end

task.spawn(function()
    while sg and sg.Parent do
        pcall(scanRifts)
        task.wait(2)
    end
end)
