                tp.Text = d.alive and "TP" or "---"
                tp.BackgroundColor3 = d.alive and Color3.fromRGB(200, 150, 30) or drkCol
            end
        end)
    end)

    return d
end

local function getChestTimer(obj)
    if not obj:IsA("Model") then return nil end
    for _, desc in ipairs(obj:GetDescendants()) do
        if desc.Name == "Label" and desc:IsA("TextLabel") then
            local parent = desc.Parent
            if parent and parent:IsA("BillboardGui") then
                return desc.Text
            end
        end
    end
    for _, desc in ipairs(obj:GetDescendants()) do
        if desc.Name == "Timer" and desc:IsA("TextLabel") then
            return desc.Text
        end
    end
    return nil
end

local function scanChests()
    local found = {}
    pcall(function()
        local rendered = workspace:FindFirstChild("Rendered")
        if not rendered then return end
        local function isChest(name)
            local low = name:lower()
            return low:find("chest") or low:find("pot o gold") or low:find("pot_o_gold")
        end
        for _, folder in ipairs(rendered:GetChildren()) do
            if folder:IsA("Folder") or folder:IsA("Model") then
                for _, obj in ipairs(folder:GetChildren()) do
                    if obj:IsA("Model") and isChest(obj.Name) then
                        local cf = getCF(obj)
                        if cf then
                            found[obj.Name] = {cf = cf, timer = getChestTimer(obj)}
                        end
                    end
                end
            end
        end
        for _, obj in ipairs(rendered:GetChildren()) do
            if obj:IsA("Model") and isChest(obj.Name) then
                local cf = getCF(obj)
                if cf then
                    found[obj.Name] = {cf = cf, timer = getChestTimer(obj)}
                end
            end
        end
    end)

    for name, info in pairs(found) do
        local d = makeChestRow(name)
        d.cf = info.cf
        d.alive = true
        d.dot.BackgroundColor3 = goldCol
        d.nm.TextColor3 = goldCol
        if info.timer and info.timer ~= "" then
            d.nm.Text = name .. "  " .. info.timer
        else
            d.nm.Text = name
        end
        d.tp.Text = "TP"
        d.tp.TextColor3 = Color3.new(1, 1, 1)
        d.tp.BackgroundColor3 = Color3.fromRGB(200, 150, 30)
        d.row.BackgroundColor3 = secCol
        d.row.BackgroundTransparency = 0
    end

    for name, d in pairs(chestData) do
        if not found[name] then
            d.alive = false
            d.cf = nil
            d.dot.BackgroundColor3 = offCol
            d.nm.TextColor3 = offCol
            d.nm.Text = name
            d.tp.Text = "---"
            d.tp.TextColor3 = offCol
            d.tp.BackgroundColor3 = drkCol
            d.row.BackgroundColor3 = drkCol
            d.row.BackgroundTransparency = 0.3
        end
    end

    local cCount = 0
    local cTotal = 0
    for _, d in pairs(chestData) do
        cTotal = cTotal + 1
        if d.alive then cCount = cCount + 1 end
    end
    chestTitle.Text = "Chests (" .. cCount .. "/" .. cTotal .. " found)"
end

