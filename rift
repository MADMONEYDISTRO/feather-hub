local function getActiveRifts()
    local categorized = {}
    for _, kw in ipairs(EVENT_KEYWORDS) do
        categorized[kw] = {}
    end
    local normal = {}

    for name, d in pairs(rowData) do
        if d.alive and d.cf then
            local low = name:lower()
            local matched = false
            for _, kw in ipairs(EVENT_KEYWORDS) do
                if low:find(kw, 1, true) then
                    table.insert(categorized[kw], {name = name, cf = d.cf})
                    matched = true
                    break
                end
            end
            if not matched then
                table.insert(normal, {name = name, cf = d.cf})
            end
        end
    end
    return categorized, normal
end

local function getBestRift(prioritizeEvents)
    if prioritizeEvents then
        local categorized, _ = getActiveRifts()
        for _, kw in ipairs(EVENT_KEYWORDS) do
            if #categorized[kw] > 0 then
                return categorized[kw][1]
            end
        end
        return nil
    else
        local active = {}
        for name, d in pairs(rowData) do
            if d.alive and d.cf then
                table.insert(active, {name = name, cf = d.cf})
            end
        end
        if #active == 0 then
            return nil
        end
        return active[math.random(#active)]
    end
end

local function autoFarmLoop()
    while autoEnabled and sg and sg.Parent do
        pcall(scanRifts)

        local target = getBestRift(priOn)

        if not target then
            autoStatusLbl.Text = "No active rifts - waiting..."
            autoStatusLbl.TextColor3 = goldCol
            task.wait(3)
        else
            autoStatusLbl.Text = "Going to " .. target.name
            autoStatusLbl.TextColor3 = onCol
            pcall(function()
                local root = player.Character and player.Character:FindFirstChild("HumanoidRootPart")
                if root then
                    root.CFrame = target.cf
                end
            end)
            task.wait(0.5)

            autoStatusLbl.Text = "Hatching at " .. target.name
            while autoEnabled and sg and sg.Parent do
                for _ = 1, 3 do
                    if not autoEnabled then break end
                    pressR()
                    task.wait(0.2)
                end

                pcall(scanRifts)
                local still = rowData[target.name]
                if not still or not still.alive then
                    autoStatusLbl.Text = target.name .. " expired - finding next..."
                    autoStatusLbl.TextColor3 = goldCol
                    task.wait(1)
                    break
                end

                pcall(function()
                    local root = player.Character and player.Character:FindFirstChild("HumanoidRootPart")
                    if root and still.cf then
                        local dist = (root.Position - still.cf.Position).Magnitude
                        if dist > 20 then
                            root.CFrame = still.cf
                        end
                    end
                end)

                autoStatusLbl.Text = "Hatching at " .. target.name
                autoStatusLbl.TextColor3 = onCol
                task.wait(1)
            end
        end

        task.wait(0.5)
    end

    autoStatusLbl.Text = "Idle"
    autoStatusLbl.TextColor3 = offCol
end

autoBtn.MouseButton1Click:Connect(function()
    autoEnabled = not autoEnabled
    if autoEnabled then
        autoBtn.Text = "STOP AUTO FARM"
        autoBtn.BackgroundColor3 = redBtn
        autoStatusLbl.Text = "Starting..."
        autoStatusLbl.TextColor3 = onCol
        if autoThread then pcall(task.cancel, autoThread) end
        autoThread = task.spawn(autoFarmLoop)
    else
        autoBtn.Text = "START AUTO FARM"
        autoBtn.BackgroundColor3 = greenBtn
        if autoThread then pcall(task.cancel, autoThread); autoThread = nil end
        autoStatusLbl.Text = "Idle"
        autoStatusLbl.TextColor3 = offCol
    end
end)

