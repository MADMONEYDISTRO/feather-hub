function setTab(idx)
    if isMinimized then _G.toggleMinimize() end
    currentTab = idx
    hdrTitle.Text = tabs[idx]

    for i, btn in ipairs(navBtns) do
        local on = (i == idx)
        TweenService:Create(btn.bg, tw(0.16), {BackgroundColor3 = on and T.accent or T.dim, BackgroundTransparency = on and 0.12 or 0}):Play()
        TweenService:Create(btn.lbl, tw(0.16), {TextColor3 = on and Color3.new(1,1,1) or T.text}):Play()
        btn.bar.BackgroundTransparency = on and 0 or 1
    end

    for i = 1, #pages do
        pages[i].Visible = (i == idx)
    end
end

