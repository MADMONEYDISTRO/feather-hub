local function getEnemyCharacters()
    local enemies = {}
    local myChar = LocalPlayer.Character
    for _, player in pairs(Players:GetPlayers()) do
        if player ~= LocalPlayer then
            local char = player.Character
            if char and char:FindFirstChild("Humanoid") and char:FindFirstChild("HumanoidRootPart") then
                local humanoid = char:FindFirstChild("Humanoid")
                if humanoid and humanoid.Health > 0 then
                    table.insert(enemies, char)
                end
            end
        end
    end
    return enemies
end

local function getBestAimPart(character)
    if settings.aimPart then
        local part = character:FindFirstChild(settings.aimPart)
        if part then return part end
    end
    local candidates = {"Head", "HitboxHead", "HitboxHeadSmall", "PhysicalHitboxHead"}
    for _, name in ipairs(candidates) do
        local part = character:FindFirstChild(name)
        if part then return part end
    end
    return character:FindFirstChild("HumanoidRootPart")
end

local function getHitboxPosition(character)
    local part = getBestAimPart(character)
    return part and part.Position or nil
end

-- Wall check using modern Raycast
local function isVisible(character)
    if not settings.wallCheck then return true end
    local aimPart = getBestAimPart(character)
    if not aimPart then return false end
    
    local origin = Camera.CFrame.Position
    local direction = aimPart.Position - origin
    local raycastParams = RaycastParams.new()
    raycastParams.FilterType = Enum.RaycastFilterType.Blacklist
    raycastParams.FilterDescendantsInstances = {LocalPlayer.Character, Camera}
    local result = workspace:Raycast(origin, direction, raycastParams)
    
    if result then
        local hit = result.Instance
        local hitParent = hit.Parent
        while hitParent do
            if hitParent == character then return true end
            hitParent = hitParent.Parent
        end
        return false
    end
    return true
end

local function getEnemyUnderCrosshair()
    local viewport = Camera.ViewportSize
    local center = Vector2.new(viewport.X / 2, viewport.Y / 2)
    local bestEnemy = nil
    local bestDist = 50  -- pixel tolerance
    
    for _, enemy in ipairs(getEnemyCharacters()) do
        local pos = getHitboxPosition(enemy)
        if pos then
            local screenPoint, onScreen = Camera:WorldToViewportPoint(pos)
            if onScreen then
                local screenDist = (Vector2.new(screenPoint.X, screenPoint.Y) - center).Magnitude
                if screenDist <= bestDist then
                    bestDist = screenDist
                    bestEnemy = enemy
                end
            end
        end
    end
    return bestEnemy
end

local function startTriggerbot()
    if triggerbotRunning then return end
    triggerbotRunning = true
    task.spawn(function()
        while settings.autoFireEnabled and triggerbotRunning do
            local enemy = getEnemyUnderCrosshair()
            if enemy and isVisible(enemy) then
                clickMouse()
            end
            task.wait(settings.triggerDelay)
        end
    end)
end

local function stopTriggerbot()
    triggerbotRunning = false
end

local function isTargetValid(target)
    if not target or not target.Parent then return false end
    local humanoid = target:FindFirstChild("Humanoid")
    if not humanoid or humanoid.Health <= 0 then return false end
    
    local pos = getHitboxPosition(target)
    if not pos then return false end
    
    local cameraPos = Camera.CFrame.Position
    local distWorld = (pos - cameraPos).Magnitude
    if distWorld > settings.fovDistance then return false end
    
    if settings.targetMode == "mouse" then
        local screenPoint, onScreen = Camera:WorldToViewportPoint(pos)
        if not onScreen then return false end
    end
    return true
end

local function getBestTarget()
    local best = nil
    local bestScore = math.huge
    local mousePos = UserInputService:GetMouseLocation()
    local cameraPos = Camera.CFrame.Position

    for _, enemy in ipairs(getEnemyCharacters()) do
        local pos = getHitboxPosition(enemy)
        if pos then
            local distWorld = (pos - cameraPos).Magnitude
            if distWorld <= settings.fovDistance then
                local screenPoint, onScreen = Camera:WorldToViewportPoint(pos)
                if onScreen then
                    local screenDist = (Vector2.new(screenPoint.X, screenPoint.Y) - mousePos).Magnitude
                    local score = (settings.targetMode == "mouse") and screenDist or distWorld
                    if score < bestScore then
                        bestScore = score
                        best = enemy
                    end
                end
            end
        end
    end
    return best
end

local function getCurrentTarget()
    if settings.lockOnTarget and lockedTarget and isTargetValid(lockedTarget) then
        return lockedTarget
    end
    lockedTarget = nil
    return getBestTarget()
end

local function aimAt(targetChar)
    local aimPart = getBestAimPart(targetChar)
    if not aimPart then return end
    local targetPos = aimPart.Position

    if settings.smoothing <= 0 then
        Camera.CFrame = CFrame.new(Camera.CFrame.Position, targetPos)
    else
        local newCF = CFrame.new(Camera.CFrame.Position, targetPos)
        Camera.CFrame = Camera.CFrame:Lerp(newCF, 1 - settings.smoothing)
    end
end

RunService.RenderStepped:Connect(function()
    if settings.aimbotEnabled then
        local target = getCurrentTarget()
        if target then
            aimAt(target)
            if settings.lockOnTarget and not lockedTarget then
                lockedTarget = target
            end
        else
            lockedTarget = nil
        end
    end
end)

local function updateTriggerbot()
    if settings.autoFireEnabled then
        startTriggerbot()
    else
        stopTriggerbot()
    end
end

-- ==================== ESP ====================
local function destroyAllESP()
    for _, line in pairs(tracers) do
        pcall(function() line:Remove() end)
    end
    for _, hl in pairs(highlights) do
        pcall(function() hl:Destroy() end)
    end
    tracers = {}
    highlights = {}
end

local function refreshESP()
    if not settings.espEnabled then
        destroyAllESP()
        return
    end

    local enemies = getEnemyCharacters()
    local enemyMap = {}
    for _, enemy in ipairs(enemies) do
        enemyMap[enemy] = true
    end

    for enemy, line in pairs(tracers) do
        if not enemyMap[enemy] then
            pcall(function() line:Remove() end)
            tracers[enemy] = nil
        end
    end
    for enemy, hl in pairs(highlights) do
        if not enemyMap[enemy] then
            pcall(function() hl:Destroy() end)
            highlights[enemy] = nil
        end
    end

    for _, enemy in ipairs(enemies) do
        if settings.tracersEnabled and drawingSupported and not tracers[enemy] then
            local line = Drawing.new("Line")
            line.Color = settings.espColor
            line.Thickness = 1
            line.Transparency = settings.espTransparency
            line.Visible = true
            tracers[enemy] = line
        end
        if settings.highlightsEnabled and not highlights[enemy] then
            local hl = Instance.new("Highlight")
            hl.FillColor = settings.espColor
            hl.FillTransparency = settings.espTransparency
            hl.OutlineColor = settings.espColor
            hl.OutlineTransparency = 0.3
            hl.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
            hl.Adornee = enemy
            hl.Parent = enemy
            highlights[enemy] = hl
        end
        if settings.tracersEnabled and tracers[enemy] then
            tracers[enemy].Color = settings.espColor
            tracers[enemy].Transparency = settings.espTransparency
        end
        if settings.highlightsEnabled and highlights[enemy] then
            highlights[enemy].FillColor = settings.espColor
            highlights[enemy].FillTransparency = settings.espTransparency
            highlights[enemy].OutlineColor = settings.espColor
        end
    end
end

task.spawn(function()
    while true do
        task.wait(0.5)
        if settings.espEnabled then
            refreshESP()
        else
            destroyAllESP()
        end
    end
end)

RunService.RenderStepped:Connect(function()
    if not settings.espEnabled or not settings.tracersEnabled or not drawingSupported then
        for _, line in pairs(tracers) do if line then line.Visible = false end end
        return
    end
    local viewport = Camera.ViewportSize
    local center = Vector2.new(viewport.X / 2, viewport.Y / 2)
    for enemy, line in pairs(tracers) do
        if enemy and enemy.Parent then
            local pos = getHitboxPosition(enemy)
            if pos then
                local vec = Camera:WorldToViewportPoint(pos)
                local screenPos = Vector2.new(vec.X, vec.Y)
                if vec.Z < 0 then screenPos = center + (center - screenPos) end
                screenPos = Vector2.new(math.clamp(screenPos.X, 0, viewport.X), math.clamp(screenPos.Y, 0, viewport.Y))
                line.From = center
                line.To = screenPos
                line.Visible = true
            else
                line.Visible = false
            end
        else
            line.Visible = false
        end
    end
end)

