            local menuStroke = Instance.new("UIStroke")
            menuStroke.Color = T.border
            menuStroke.Thickness = 1
            menuStroke.Parent = menu

            local scroll = Instance.new("ScrollingFrame")
            scroll.Size = UDim2.new(1, 0, 1, 0)
            scroll.BackgroundTransparency = 1
            scroll.BorderSizePixel = 0
            scroll.CanvasSize = UDim2.new(0, 0, 0, menuHeight)
            scroll.AutomaticCanvasSize = Enum.AutomaticSize.Y
            scroll.ScrollBarThickness = 4
            scroll.Parent = menu
            local layout = Instance.new("UIListLayout")
            layout.SortOrder = Enum.SortOrder.LayoutOrder
            layout.Padding = UDim.new(0, 1)
            layout.Parent = scroll

            for _, opt in ipairs(options) do
                local btn = Instance.new("TextButton")
                btn.Size = UDim2.new(1, 0, 0, 26)
                btn.Text = opt
                btn.Font = Enum.Font.Gotham
                btn.TextSize = 10
                btn.BackgroundColor3 = T.dim
                btn.TextColor3 = T.text
                btn.BorderSizePixel = 0
                btn.Parent = scroll
                btn.MouseButton1Click:Connect(function()
                    setter(opt)
                    drop.Text = opt
                    menu:Destroy()
                    menuOpen = false
                end)
            end

            local function closeMenu()
                if menu then menu:Destroy() end
                menuOpen = false
            end
            local clickConn
            clickConn = UserInputService.InputBegan:Connect(function(inp)
                if inp.UserInputType == Enum.UserInputType.MouseButton1 then
                    local mousePos = inp.Position
                    if menu and menu.Parent then
                        local mAbs = menu.AbsolutePosition
                        local mSize = menu.AbsoluteSize
                        if mousePos.X < mAbs.X or mousePos.X > mAbs.X + mSize.X or mousePos.Y < mAbs.Y or mousePos.Y > mAbs.Y + mSize.Y then
                            closeMenu()
                            clickConn:Disconnect()
                        end
                    else
                        clickConn:Disconnect()
                    end
                end
            end)
        end)
        return frame
    end

