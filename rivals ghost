-- ==================== CLICK FUNCTION (compatible with most executors) ====================
local function clickMouse()
    local success, err = pcall(function()
        -- Method 1: VirtualUser (works on many)
        if VirtualUser and VirtualUser.ClickButton1 then
            VirtualUser:ClickButton1(Vector2.new(0, 0))
            return
        end
        -- Method 2: keypress / keyrelease (Synapse, Krnl, etc.)
        if keypress and keyrelease then
            keypress(Enum.KeyCode.Button1)
            task.wait(0.02)
            keyrelease(Enum.KeyCode.Button1)
            return
        end
        -- Method 3: mouse1click (legacy)
        if mouse1click then
            mouse1click()
            return
        end
        -- Method 4: VirtualInput (last resort)
        local VirtualInput = game:GetService("VirtualInput")
        if VirtualInput then
            VirtualInput:SendMouseButtonEvent(Vector2.new(0, 0), 0, true, Enum.UserInputType.MouseButton1, 1)
            task.wait(0.02)
            VirtualInput:SendMouseButtonEvent(Vector2.new(0, 0), 0, false, Enum.UserInputType.MouseButton1, 1)
            return
        end
        warn("No click method available")
    end)
    if not success then
        warn("Click simulation failed: " .. tostring(err))
    end
end

