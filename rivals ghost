    n.BorderSizePixel = 0
    n.ZIndex = 100
    n.Parent = sg

    Instance.new("UICorner", n).CornerRadius = UDim.new(0, 10)
    local ns = Instance.new("UIStroke")
    ns.Color = col
    ns.Thickness = 1
    ns.Parent = n

    local bar = Instance.new("Frame")
    bar.Size = UDim2.new(0, 3, 0.65, 0)
