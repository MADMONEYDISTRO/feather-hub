local function addHighlight(char, plr)
    if plr == player then return end
    if char:FindFirstChild("AimESPHighlight") then return end
    local h = Instance.new("Highlight")
    h.Name = "AimESPHighlight"
    h.FillTransparency = 1
    h.OutlineTransparency = 0
    h.OutlineColor = highlightColor
    h.Enabled = HighlightEnabled
    h.Parent = char
end

local function setupESP()
    for _, plr in ipairs(Players:GetPlayers()) do
        if plr ~= player and plr.Character then
            addHighlight(plr.Character, plr)
        end
        plr.CharacterAdded:Connect(function(char)
            task.wait(0.5)
            addHighlight(char, plr)
        end)
    end
end

setupESP()

Players.PlayerAdded:Connect(function(plr)
    plr.CharacterAdded:Connect(function(char)
        task.wait(0.5)
        addHighlight(char, plr)
    end)
end)

