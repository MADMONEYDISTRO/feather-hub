UserInputService.InputBegan:Connect(function(input, gameProcessed)
    if gameProcessed then return end
    
    if waitingForKeybind then
        if input.KeyCode ~= Enum.KeyCode.Unknown then
            settings.aimKey = input.KeyCode
            waitingForKeybind = false
            if uiElements.keyButton then uiElements.keyButton.Text = settings.aimKey.Name end
            if uiElements.infoLabel then uiElements.infoLabel.Text = "Open/close UI:  ]\nToggle aimbot: " .. settings.aimKey.Name .. "\nToggle auto fire: " .. settings.triggerKey.Name end
        end
        return
    end
    
    if waitingForTriggerKeybind then
        if input.KeyCode ~= Enum.KeyCode.Unknown then
            settings.triggerKey = input.KeyCode
            waitingForTriggerKeybind = false
            if uiElements.triggerKeyButton then uiElements.triggerKeyButton.Text = settings.triggerKey.Name end
            if uiElements.infoLabel then uiElements.infoLabel.Text = "Open/close UI:  ]\nToggle aimbot: " .. settings.aimKey.Name .. "\nToggle auto fire: " .. settings.triggerKey.Name end
        end
        return
    end
    
    if input.KeyCode == settings.aimKey then
        settings.aimbotEnabled = not settings.aimbotEnabled
        if not settings.aimbotEnabled then lockedTarget = nil end
        if uiElements.aimbotPill then
            uiElements.aimbotPill.BackgroundColor3 = settings.aimbotEnabled and Color3.fromRGB(80, 180, 80) or Color3.fromRGB(180, 60, 60)
        end
    end
    
    if input.KeyCode == settings.triggerKey then
        settings.autoFireEnabled = not settings.autoFireEnabled
        updateTriggerbot()
        if uiElements.autoFirePill then
            uiElements.autoFirePill.BackgroundColor3 = settings.autoFireEnabled and Color3.fromRGB(80, 180, 80) or Color3.fromRGB(180, 60, 60)
        end
    end
    
    if input.KeyCode == Enum.KeyCode.RightBracket then
        settings.uiVisible = not settings.uiVisible
        if screenGui then screenGui.Enabled = settings.uiVisible end
    end
end)

