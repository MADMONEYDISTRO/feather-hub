    local function updateDrag()
        if not dragData.active then
            local delta = dragData.targetPos - Vector2.new(win.Position.X.Offset, win.Position.Y.Offset)
            dragData.currentVel = dragData.currentVel * 0.85 + delta * 0.2
            local newX = math.clamp(win.Position.X.Offset + dragData.currentVel.X, 0, Camera.ViewportSize.X - win.AbsoluteSize.X)
            local newY = math.clamp(win.Position.Y.Offset + dragData.currentVel.Y, 0, Camera.ViewportSize.Y - win.AbsoluteSize.Y)
            win.Position = UDim2.new(0, newX, 0, newY)
            dragData.targetPos = Vector2.new(newX, newY)
            if delta.Magnitude < 0.5 and dragData.currentVel.Magnitude < 0.5 and dragData.connection then
                dragData.connection:Disconnect()
                dragData.connection = nil
            end
        end
    end
