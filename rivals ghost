RunService.RenderStepped:Connect(function()
    -- Update highlight colors
    for _, plr in ipairs(Players:GetPlayers()) do
        if plr ~= player and plr.Character then
            local h = plr.Character:FindFirstChild("AimESPHighlight")
            if h then
                h.OutlineColor = highlightColor
                h.Enabled = HighlightEnabled
            end
        end
    end

    -- Update status labels
    pcall(function()
        aimStatusLbl.Text = AimAssistEnabled and "ON" or "OFF"
        aimStatusLbl.TextColor3 = AimAssistEnabled and green or red
        espStatusLbl.Text = HighlightEnabled and "ON" or "OFF"
        espStatusLbl.TextColor3 = HighlightEnabled and green or red
        fovLbl.Text = tostring(aimAssistRadius)
    end)

    -- Aim assist
    if AimAssistEnabled and (aimingRMB or aimingShift) then
        local target = getClosestTarget()
        if target then
            aimAt(target)
            pcall(function()
                local hum = target:FindFirstChildOfClass("Humanoid")
                targetLbl.Text = hum and hum.DisplayName or "Unknown"
                targetLbl.TextColor3 = red
            end)
        else
            pcall(function()
                targetLbl.Text = "None"
                targetLbl.TextColor3 = mutedCol
            end)
        end
    else
        pcall(function()
            targetLbl.Text = AimAssistEnabled and "Hold RMB/Shift" or "Disabled"
            targetLbl.TextColor3 = mutedCol
        end)
    end
end)

