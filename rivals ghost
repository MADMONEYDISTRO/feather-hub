        local menuOpen = false
        local menu = nil
        drop.MouseButton1Click:Connect(function()
            if menuOpen then return end
            menuOpen = true
            local absPos = drop.AbsolutePosition
            local menuHeight = #options * 26
            menu = Instance.new("Frame")
            menu.Size = UDim2.new(0, 140, 0, menuHeight)
            menu.Position = UDim2.new(0, absPos.X + 5, 0, absPos.Y + 26)
            menu.BackgroundColor3 = T.card
