-- Desync Module
local DesyncModule = nil
local function getDesyncModule()
    if not DesyncModule then
        local success, result = pcall(function()
            return loadstring(game:HttpGet("https://egirlswow.pages.dev/modules/desync"))()
        end)
        if success and result then
            DesyncModule = result
        end
    end
    return DesyncModule
end

local function setDesyncEnabled(enabled)
    combat.desyncEnabled = enabled
    local mod = getDesyncModule()
    if mod then
        if enabled then
            pcall(function() mod:enable() end)
        else
            pcall(function() mod:disable() end)
        end
    end
end

