-- Minimize functionality
local isMinimized = false
function _G.toggleMinimize()
    isMinimized = not isMinimized
    if isMinimized then
        TweenService:Create(win, tw(0.3), {Size = UDim2.new(0, WIN_W, 0, HDR_H)}):Play()
        sidebar.Visible = false
        content.Visible = false
        TweenService:Create(hdr, tw(0.3), {Size = UDim2.new(1, 0, 0, HDR_H), Position = UDim2.new(0, 0, 0, 0)}):Play()
        hdrLC.Visible = false
        hdrBC.Visible = false
        hdrLine.Visible = false
        minBtn.Text = "+"
    else
        TweenService:Create(win, tw(0.3), {Size = UDim2.new(0, WIN_W, 0, WIN_H)}):Play()
        TweenService:Create(hdr, tw(0.3), {Size = UDim2.new(1, -SIDE_W, 0, HDR_H), Position = UDim2.new(0, SIDE_W, 0, 0)}):Play()
        hdrLC.Visible = true
        hdrBC.Visible = true
        hdrLine.Visible = true
        task.delay(0.1, function()
            sidebar.Visible = true
            content.Visible = true
        end)
        minBtn.Text = "–"
    end
end
minBtn.MouseButton1Click:Connect(_G.toggleMinimize)
minBtn.MouseEnter:Connect(function()
