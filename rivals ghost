    sep.Position = UDim2.new(0, 12, 1, -1)
    sep.BackgroundColor3 = sepCol
    sep.BorderSizePixel = 0
    sep.Parent = row

    local state = initVal

    local lbl = Instance.new("TextLabel")
    lbl.Size = UDim2.new(1, -80, 1, 0)
    lbl.Position = UDim2.new(0, 14, 0, 0)
    lbl.Text = label
    lbl.Font = Enum.Font.GothamSemibold
    lbl.TextSize = isMobile and 12 or 10
    lbl.TextColor3 = txtCol
    lbl.TextXAlignment = Enum.TextXAlignment.Left
    lbl.BackgroundTransparency = 1
    lbl.Parent = row

    local pill = Instance.new("Frame")
    pill.Size = UDim2.new(0, 44, 0, 22)
    pill.Position = UDim2.new(1, -54, 0.5, -11)
    pill.BackgroundColor3 = state and color or dimCol
    pill.BorderSizePixel = 0
    pill.Parent = row
    mkC(pill, 11)

    local knob = Instance.new("Frame")
    knob.Size = UDim2.new(0, 16, 0, 16)
    knob.Position = state and UDim2.new(1, -19, 0.5, -8) or UDim2.new(0, 3, 0.5, -8)
    knob.BackgroundColor3 = state and Color3.new(1, 1, 1) or mutedCol
    knob.BorderSizePixel = 0
    knob.Parent = pill
    mkC(knob, 8)

    local hit = Instance.new("TextButton")
    hit.Size = UDim2.new(0, 60, 1, 0)
    hit.Position = UDim2.new(1, -62, 0, 0)
    hit.BackgroundTransparency = 1
    hit.Text = ""
    hit.Parent = row

    local function toggle()
        state = not state
        TweenService:Create(pill, tw(0.15), {BackgroundColor3 = state and color or dimCol}):Play()
        TweenService:Create(knob, tw(0.15), {
            Position = state and UDim2.new(1, -19, 0.5, -8) or UDim2.new(0, 3, 0.5, -8),
            BackgroundColor3 = state and Color3.new(1, 1, 1) or mutedCol
        }):Play()
        pcall(cb, state)
    end
    hit.MouseButton1Click:Connect(toggle)
    hit.TouchTap:Connect(toggle)

    return row
end

local function makeSliderRow(card, order, label, min, max, initVal, cb)
    local row = Instance.new("Frame")
    row.Size = UDim2.new(1, 0, 0, 52)
    row.BackgroundTransparency = 1
    row.LayoutOrder = order
    row.Parent = card

    local sep = Instance.new("Frame")
    sep.Size = UDim2.new(1, -24, 0, 1)
    sep.Position = UDim2.new(0, 12, 1, -1)
    sep.BackgroundColor3 = sepCol
    sep.BorderSizePixel = 0
    sep.Parent = row

    local lbl = Instance.new("TextLabel")
    lbl.Size = UDim2.new(0.6, 0, 0, 20)
    lbl.Position = UDim2.new(0, 14, 0, 4)
    lbl.Text = label
    lbl.Font = Enum.Font.GothamSemibold
    lbl.TextSize = isMobile and 11 or 10
    lbl.TextColor3 = txtCol
    lbl.TextXAlignment = Enum.TextXAlignment.Left
    lbl.BackgroundTransparency = 1
    lbl.Parent = row

    local valLbl = Instance.new("TextLabel")
    valLbl.Size = UDim2.new(0.4, -14, 0, 20)
    valLbl.Position = UDim2.new(0.6, 0, 0, 4)
    valLbl.Text = tostring(initVal)
    valLbl.Font = Enum.Font.GothamBold
    valLbl.TextSize = isMobile and 11 or 10
    valLbl.TextColor3 = accent
    valLbl.TextXAlignment = Enum.TextXAlignment.Right
    valLbl.BackgroundTransparency = 1
    valLbl.Parent = row

    local track = Instance.new("Frame")
    track.Size = UDim2.new(1, -28, 0, 6)
    track.Position = UDim2.new(0, 14, 0, 30)
    track.BackgroundColor3 = dimCol
    track.BorderSizePixel = 0
    track.Parent = row
    mkC(track, 3)

    local initRel = math.clamp((initVal - min) / (max - min), 0, 1)

    local fill = Instance.new("Frame")
    fill.Size = UDim2.new(initRel, 0, 1, 0)
    fill.BackgroundColor3 = accent
    fill.BorderSizePixel = 0
    fill.Parent = track
    mkC(fill, 3)

    local knobSize = isMobile and 18 or 14
    local sliderKnob = Instance.new("TextButton")
    sliderKnob.Size = UDim2.new(0, knobSize, 0, knobSize)
    sliderKnob.AnchorPoint = Vector2.new(0.5, 0.5)
    sliderKnob.Position = UDim2.new(initRel, 0, 0.5, 0)
    sliderKnob.BackgroundColor3 = Color3.new(1, 1, 1)
    sliderKnob.Text = ""
    sliderKnob.BorderSizePixel = 0
    sliderKnob.ZIndex = 3
    sliderKnob.Parent = track
    mkC(sliderKnob, knobSize)

    local slideDragging = false

    local function updateSlider(xPos)
        local rel = math.clamp((xPos - track.AbsolutePosition.X) / track.AbsoluteSize.X, 0, 1)
        local val = math.floor((min + rel * (max - min)) * 100) / 100
        fill.Size = UDim2.new(rel, 0, 1, 0)
        sliderKnob.Position = UDim2.new(rel, 0, 0.5, 0)
        valLbl.Text = tostring(val)
        pcall(cb, val)
    end

    sliderKnob.InputBegan:Connect(function(i)
        if i.UserInputType == Enum.UserInputType.MouseButton1 or i.UserInputType == Enum.UserInputType.Touch then
            slideDragging = true
        end
    end)
    track.InputBegan:Connect(function(i)
        if i.UserInputType == Enum.UserInputType.MouseButton1 or i.UserInputType == Enum.UserInputType.Touch then
            slideDragging = true
            updateSlider(i.Position.X)
        end
    end)
    UserInputService.InputEnded:Connect(function(i)
        if i.UserInputType == Enum.UserInputType.MouseButton1 or i.UserInputType == Enum.UserInputType.Touch then
            slideDragging = false
        end
    end)
    UserInputService.InputChanged:Connect(function(i)
        if slideDragging and (i.UserInputType == Enum.UserInputType.MouseMovement or i.UserInputType == Enum.UserInputType.Touch) then
            updateSlider(i.Position.X)
        end
    end)

    return row
end

