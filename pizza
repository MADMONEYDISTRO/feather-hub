local toggleRefs = {}
local function refreshToggles()
    for _, ref in ipairs(toggleRefs) do
        local state
        if ref.role == 'cashier' then state = u2
        elseif ref.role == 'cook' then state = u4
        elseif ref.role == 'boxer' then state = u3
        elseif ref.role == 'delivery' then state = u6
        elseif ref.role == 'supplier' then state = u5
        end
        TweenService:Create(ref.track, tw(0.15), {BackgroundColor3 = state and T.accent or T.dim}):Play()
        TweenService:Create(ref.knob, tw(0.15), {Position = state and UDim2.new(1, -18, 0.5, -8) or UDim2.new(0, 2, 0.5, -8)}):Play()
    end
end

