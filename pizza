local function GetDough(preferSausagePepperoni)
    local allDough = workspace.AllDough:GetChildren()
    local burned, sauced, plain, bestSauced
    for i = #allDough, 2, -1 do
        local j = math.random(1, i)
        allDough[i], allDough[j] = allDough[j], allDough[i]
    end
    for _, dough in ipairs(allDough) do
        if not dough.Anchored and #dough:GetChildren() > 9 then
            if dough.IsBurned.Value or dough.HasBugs.Value or dough.Cold.Value or (dough.BrickColor.Name == 'Bright orange' and FindFirstChild(dough, 'XBillboard')) then
                if not burned and dough.Position.Y <= 0 then burned = dough end
            elseif not sauced and dough.BrickColor.Name == 'Bright orange' then
                sauced = dough
            elseif not plain and dough.Position.X < 55 and dough.BrickColor.Name == 'Brick yellow' and (preferSausagePepperoni and not FindFirstChild(dough.SG.Frame, preferSausagePepperoni) or not preferSausagePepperoni and (not FindFirstChild(dough.SG.Frame, 'Sausage') and not FindFirstChild(dough.SG.Frame, 'Pepperoni'))) then
                if dough.Mesh.Scale.Y >= 1.1 then bestSauced = dough else plain = dough end
            end
        end
    end
    return plain or bestSauced, sauced, burned
end

local function OvenIsOpen(oven)
    return oven.IsOpen.Value and (oven.Door.Meter.RotVelocity.Z ^ 2) ^ 0.5 < 0.0001
end

-- Delivery tools
local currentDeliveryTool
local deliveryInProgress = false

local function EndDelivery()
    if currentDeliveryTool then
        if currentDeliveryTool.Parent == LocalPlayer.Backpack then currentDeliveryTool.Parent = character end
        if currentDeliveryTool.Parent == character then wait(0.1) currentDeliveryTool.Parent = workspace wait(0.1) end
    end
    currentDeliveryTool = nil
    deliveryInProgress = false
    if FindFirstChild(character, 'RightHand') and FindFirstChild(character.RightHand, 'RightGrip') then
        character.RightHand.RightGrip:Destroy()
    end
end

local function FindDeliveryTool()
    local tool
    for _, obj in ipairs(workspace:GetChildren()) do
        if obj.ClassName == 'Tool' and obj.Name:match('^%u%d$') and FindFirstChild(obj, 'House') and FindFirstChild(obj, 'Handle') and FindFirstChild(obj, 'Order') then
            if obj.Order.Value:match('%a') then
                if FindFirstChild(obj.Handle, 'X10') then return obj end
                tool = obj
            end
        end
    end
    return tool
end

local function GetGivePizzaPart(address)
    for _, house in ipairs(workspace.Houses:GetChildren()) do
        if FindFirstChild(house, 'Address') and house.Address.Value == address then
            if FindFirstChild(house, 'GivePizza', true) then return FindFirstChild(house, 'GivePizza', true) end
        end
    end
end

