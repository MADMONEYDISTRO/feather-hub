local function GetNearestCustomer()
    for _, customer in ipairs(workspace.Customers:GetChildren()) do
        if FindFirstChild(customer, 'Head') and FindFirstChild(customer, 'Humanoid') then
            if customer.Head.CFrame.Z < 102 and FindFirstChild(customer.Head, 'Dialog') and FindFirstChild(customer.Head.Dialog, 'Correct') then
                if customer.Humanoid.SeatPart and customer.Humanoid.SeatPart.Anchored then
                    return customer
                end
                if not customer.Humanoid.SeatPart and (customer.Head.Velocity.Z ^ 2) ^ 0.5 < 0.0001 then
                    return customer
                end
            end
        end
    end
end

