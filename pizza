local function GetBoxes()
    local closedBox, openBox, other
    for _, box in ipairs(workspace.AllBox:GetChildren()) do
        if FindFirstChild(box, 'HasPizzaInside') or FindFirstChild(box, 'Pizza') then
            if not closedBox and box.Name == 'BoxClosed' and not box.Anchored and not box.HasPizzaInside.Value then
                closedBox = box
            elseif not openBox and box.Name == 'BoxOpen' and not box.Anchored and not box.Pizza.Value then
                openBox = box
            elseif not other then
                other = box
            end
        end
    end
    return closedBox, openBox, other
