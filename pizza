-- ============================================================
--  MAIN FARM LOOP (starts after the UI is built)
-- ============================================================
getgenv().Mainloop = true

print('Feather Hub – Pizza Farm ready.')

while getgenv().Mainloop do
    task.wait(0.3)

    if humanoid.Sit and humanoid.SeatPart then humanoid.Jump = true end

    -- Cashier
    if u2 then
        local customer = GetNearestCustomer()
        if customer then
            local resp = customer.Head.Dialog.Correct.ResponseDialog or ''
            local teleported = false
            if (rootPart.Position - Vector3.new(46.34, 3.8, 82.02)).magnitude > 9 then
                network:FireServer('OrderComplete', customer, resp:find('pepperoni') and 'PepperoniPizza' or (resp:find('sausage') and 'SausagePizza' or (resp:find('cheese') and 'CheesePizza' or 'MountainDew')), workspace.Register3)
                teleported = true
            else
                network:FireServer('OrderComplete', customer, resp:find('pepperoni') and 'PepperoniPizza' or (resp:find('sausage') and 'SausagePizza' or (resp:find('cheese') and 'CheesePizza' or 'MountainDew')), workspace.Register3)
            end
            if teleported then task.wait(0.1) end
        end
    end

    -- Cook
    if u4 then
        local needed = GetNeededIngredients()[1]
        local specialIngr = (needed == 'Pepperoni' or needed == 'Sausage') and needed or nil
        local dew = GetAvailableDew()
        local dough, sauced, burned = GetDough(specialIngr and (specialIngr == 'Pepperoni' and 'Sausage' or 'Pepperoni'))
        local ovens = workspace.Ovens:GetChildren()
        local teleported = false

        if sauced and tick() - lastCookAction > 0.8 then
            local oven = GetOvenNear(sauced.Position)
            if not oven or OvenIsOpen(oven) then
                lastCookAction = tick()
                network:FireServer('UpdateProperty', sauced, 'CFrame', CFrame.new(56, 4.1, 38))
            end
        end

        if needed then
            if needed ~= 'Dew' or (not dew or tick() - lastDewTime <= 0.8) then
                if needed ~= 'Dew' and dough and dough.Parent and supplyCounts[needed] > 0 and supplyCounts.TomatoSauce > 0 and supplyCounts.Cheese > 0 then
                    if dough.Mesh.Scale.Y <= 1.5 then
                        local targetOven
                        for _, oven in ipairs(ovens) do
                            if OvenIsOpen(oven) then
                                local existing = GetDoughNear(oven.Bottom.Position)
                                if not existing or (existing.BrickColor.Name ~= 'Bright orange' or not (FindFirstChild(existing.SG.Frame, 'TomatoSauce') and FindFirstChild(existing.SG.Frame, 'MeltedCheese'))) then
                                    if existing then network:FireServer('UpdateProperty', existing, 'CFrame', CFrame.new(math.random(296, 446)/10, 3.7, math.random(425, 485)/10)) task.wait() end
                                else targetOven = oven; break end
                            end
                        end
                        if not targetOven then targetOven = ovens[math.random(#ovens)] end
                        if targetOven and dough.Parent == workspace.AllDough then
                            network:FireServer('AddIngredientToPizza', dough, 'TomatoSauce')
                            network:FireServer('AddIngredientToPizza', dough, 'Cheese')
                            network:FireServer('AddIngredientToPizza', dough, specialIngr or needed)
                            network:FireServer('UpdateProperty', dough, 'CFrame', targetOven.Bottom.CFrame + Vector3.new(0, 0.7, 0))
                            targetOven.Door.ClickDetector.Detector:FireServer()
                            pendingOrders[needed] = pendingOrders[needed] + 1
                            local cancelled = false
                            spawn(function() dough.AncestryChanged:Wait(); if not cancelled then pendingOrders[needed] = pendingOrders[needed] - 1; cancelled = true end end)
                            delay(40, function() if not cancelled then pendingOrders[needed] = pendingOrders[needed] - 1; cancelled = true end end)
                        end
                    else
                        network:FireServer('UpdateProperty', dough, 'CFrame', CFrame.new(math.random(296, 446)/10, 3.7, math.random(425, 485)/10))
                        task.wait()
                        network:FireServer('SquishDough', dough)
                    end
                end
            else
                lastDewTime = tick()
                network:FireServer('UpdateProperty', dew, 'CFrame', CFrame.new(53, 4.68, 36.5))
            end
        end

        for _, oven in ipairs(ovens) do
            local bar = oven.Door.Meter.SurfaceGui.ProgressBar.Bar
            if not oven.IsOpen.Value and (not oven.IsCooking.Value or (Vector3.new(bar.ImageColor3.r, bar.ImageColor3.g, bar.ImageColor3.b) - Vector3.new(0.871, 0.518, 0.224)).magnitude > 0.1) then
                oven.Door.ClickDetector.Detector:FireServer()
                break
            end
        end

        if burned and (not GetOvenNear(burned.Position) or OvenIsOpen(GetOvenNear(burned.Position))) then
            network:FireServer('UpdateProperty', burned, 'CFrame', CFrame.new(0, -100, 0))
        end
    end

    -- Boxer
    if u3 then
        local pizza, dew = GetLooseItems()
        local closedBox, openBox, other = GetBoxes()
        local teleported = false

        if dew and tick() - lastDewTime > 0.8 then
            lastDewTime = tick()
            network:FireServer('UpdateProperty', dew, 'CFrame', CFrame.new(63, 4.9, -1, -1, 0, 0, 0, 1, 0, 0, 0, -1))
            teleported = true
        end
        if other then
            if other.Name ~= 'BoxOpen' then
                if tick() - lastBoxTime > 0.8 then
                    network:FireServer('UpdateProperty', other, 'CFrame', CFrame.new(68.2, 4.4, -1, -1, 0, 0, 0, 1, 0, 0, 0, -1))
                    lastBoxTime = tick()
                    teleported = true
                end
            else
                network:FireServer('CloseBox', other)
            end
        end
        if closedBox and not openBox then
            network:FireServer('UpdateProperty', closedBox, 'CFrame', CFrame.new(math.random(625, 705)/10, 3.5, math.random(110, 250)/10))
            task.wait()
            network:FireServer('OpenBox', closedBox)
        end
        if openBox and pizza then
            network:FireServer('UpdateProperty', pizza, 'Anchored', true)
            network:FireServer('UpdateProperty', openBox, 'Anchored', true)
            task.wait()
            network:FireServer('UpdateProperty', pizza, 'CFrame', openBox.CFrame + Vector3.new(0, -2, 0))
            task.wait()
            network:FireServer('AssignPizzaToBox', openBox, pizza)
        end
        if teleported then task.wait(0.1) end
    end

    -- Supplier
    if u5 then
        local needRefill = false
        for _, count in pairs(supplyCounts) do if count <= u1.refill_at then needRefill = true; break end end
        if needRefill then
            pcall(function() for _, box in ipairs(workspace.AllSupplyBoxes:GetChildren()) do if box:IsA('Part') and box.Position.Y > -100 then network:FireServer('UpdateProperty', box, 'CFrame', CFrame.new(0, -1000, 0)) end end end)
            local placed = 0
            while needRefill and u5 do
                for _, btn in ipairs(supplyButtons) do
                    local ingr = ingredientColorMap[btn.BrickColor.Name]
                    if supplyCounts[ingr] < u1.refill_end then
                        network:FireServer('UpdateProperty', btn, 'CFrame', btn.Position + Vector3.new(0, 0.2, 0))
                        task.wait(0.05)
                        network:FireServer('UpdateProperty', btn, 'CFrame', btn.Position)
                        for _, box in ipairs(workspace.AllSupplyBoxes:GetChildren()) do
                            if box.BrickColor.Name == btn.BrickColor.Name then
                                placed = placed + 1
                                network:FireServer('UpdateProperty', box, 'CFrame', CFrame.new(38 - 4.3 * math.floor(math.random(1, 15) / 2), 5, -7 - 5 * (math.random(1, 15) % 2)))
                                if placed >= 30 then
                                    network:FireServer('UpdateProperty', box, 'CFrame', CFrame.new(21, 9, -20))
                                    local count = 0
                                    for _, b in ipairs(workspace.AllSupplyBoxes:GetChildren()) do
                                        count = count + 1
                                        network:FireServer('UpdateProperty', b, 'CFrame', CFrame.new(38 - 4.3 * math.floor(count / 2), 5, -7 - 5 * (count % 2)))
                                    end
                                    placed = 0
                                end
                            end
                        end
                    end
                end
                local stillNeeded = false
                for _, count in pairs(supplyCounts) do if count <= u1.refill_at then stillNeeded = true; break end end
                if not stillNeeded then needRefill = false end
                task.wait()
            end
        end
    end

    -- Delivery
    if u6 then
        local tool = FindDeliveryTool()
        if not currentDeliveryTool and tool then
            currentDeliveryTool = tool
            if (rootPart.Position - currentDeliveryTool.Handle.Position).magnitude > 19 then
                network:FireServer('UpdateProperty', currentDeliveryTool, 'CFrame', currentDeliveryTool.Handle.Position + Vector3.new(0, 1, -15))
            end
            currentDeliveryTool.Handle.CanCollide = false
            currentDeliveryTool.Handle.CFrame = rootPart.CFrame
            wait(0.9)
            delay(6, EndDelivery)
        elseif currentDeliveryTool and currentDeliveryTool.Parent == character and not deliveryInProgress then
            local givePart = GetGivePizzaPart(currentDeliveryTool.Name)
            if givePart then
                deliveryInProgress = true
                network:FireServer('UpdateProperty', givePart, 'CFrame', givePart.Position + Vector3.new(0, 2, 0))
                wait(0.1)
                firetouchinterest(givePart, rootPart, 0)
                firetouchinterest(givePart, rootPart, 1)
                wait(0.2)
                deliveryInProgress = false
            end
        end
    end

    -- Anti‑idle
    if u1.stay_in_kitchen then
        VirtualUser:CaptureController()
        VirtualUser:ClickButton2(Vector2.new())
    end
end
