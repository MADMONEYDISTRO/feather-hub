local function GetNeededIngredients()
    local needed = {}
    local tempOrders = { Cheese = 0, Sausage = 0, Pepperoni = 0, Dew = 0 }
    for _, order in ipairs(workspace.Orders:GetChildren()) do
        local ingr = ingredientMap[order.SG.ImageLabel.Image:match('%d+$')]
        if ingr then
            if tempOrders[ingr] <= 0 then
                if ingr == 'Dew' and #workspace.AllMountainDew:GetChildren() > 0 then
                    table.insert(needed, ingr)
                elseif supplyCounts[ingr] > 0 and supplyCounts.TomatoSauce > 0 and supplyCounts.Cheese > 0 then
                    table.insert(needed, ingr)
                end
            else
                tempOrders[ingr] = tempOrders[ingr] - 1
            end
        end
    end
    return needed
end

