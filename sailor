-- GLOBAL ANNOUNCEMENT (MessagingService)
-- ══════════════════════════════════════════════════════════════════
task.spawn(function()
    pcall(function()
        MessagingService:SubscribeAsync("GlobalScriptAnnouncements", function(msg)
