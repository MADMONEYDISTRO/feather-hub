-- NOTIFICATION HELPER
-- ══════════════════════════════════════════════════════════════════
local function notify(title, msg, nType)
    local col = T.accent
    if nType=="success" then col=T.green
    elseif nType=="error"   then col=T.red
    elseif nType=="warning" then col=T.gold end

    local sg = Instance.new("ScreenGui")
    sg.Name = "VH_Notif"; sg.ResetOnSpawn = false
    sg.ZIndexBehavior = Enum.ZIndexBehavior.Sibling
    sg.DisplayOrder = 9999; sg.IgnoreGuiInset = true
    pcall(function() sg.Parent = CoreGui end)

    local n = Instance.new("Frame")
    n.Size = UDim2.new(0,0,0,62)
    n.Position = UDim2.new(1,-12,1,-76)
    n.AnchorPoint = Vector2.new(1,1)
    n.BackgroundColor3 = T.card
    n.BorderSizePixel = 0
    n.Parent = sg
    Instance.new("UICorner",n).CornerRadius = UDim.new(0,10)

    local ns = Instance.new("UIStroke"); ns.Color=col; ns.Thickness=1; ns.Parent=n
    local bar = Instance.new("Frame")
    bar.Size = UDim2.new(0,3,0.65,0); bar.Position = UDim2.new(0,0,0.175,0)
    bar.BackgroundColor3=col; bar.BorderSizePixel=0; bar.Parent=n
    Instance.new("UICorner",bar).CornerRadius=UDim.new(1,0)

    local t1 = Instance.new("TextLabel")
    t1.Size=UDim2.new(1,-18,0,20); t1.Position=UDim2.new(0,14,0,9)
    t1.Text=title; t1.Font=Enum.Font.GothamBold; t1.TextSize=11
    t1.TextColor3=T.text; t1.TextXAlignment=Enum.TextXAlignment.Left
    t1.BackgroundTransparency=1; t1.Parent=n

    local t2 = Instance.new("TextLabel")
    t2.Size=UDim2.new(1,-18,0,20); t2.Position=UDim2.new(0,14,0,29)
    t2.Text=msg; t2.Font=Enum.Font.Gotham; t2.TextSize=9
    t2.TextColor3=T.text; t2.TextTransparency=0.35
    t2.TextXAlignment=Enum.TextXAlignment.Left; t2.TextWrapped=true
    t2.BackgroundTransparency=1; t2.Parent=n

    TweenService:Create(n, tw(0.3,Enum.EasingStyle.Back,Enum.EasingDirection.Out),
        {Size=UDim2.new(0,290,0,62)}):Play()
    task.delay(3.5, function()
        TweenService:Create(n, tw(0.25), {Size=UDim2.new(0,0,0,62), BackgroundTransparency=1}):Play()
        task.wait(0.3)
        if sg and sg.Parent then sg:Destroy() end
    end)
end

