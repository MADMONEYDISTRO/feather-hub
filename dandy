        hdrLC.Visible = false
    else
        -- restore full window
        TweenService:Create(win,tw(0.25),{Size=UDim2.new(0,WIN_W,0,WIN_H)}):Play()
        task.delay(0.15, function()
            sidebar.Visible = true
