-- switch tab
local function setTab(idx)
    activeTab=idx
    hdrTitle.Text = TABS[idx].name == "HOME" and "Feather Hub | Dandy's World" or
                    TABS[idx].name .. " Features"
    for i,btn in ipairs(navBtns) do
        local on=(i==idx)
        TweenService:Create(btn.bg,tw(0.15),{
            BackgroundColor3=on and btn.color or T.dim,
            BackgroundTransparency=on and 0.15 or 0,
        }):Play()
        TweenService:Create(btn.lbl,tw(0.15),{TextColor3=on and btn.color or T.muted}):Play()
        btn.bar.BackgroundTransparency=on and 0 or 1
        pages[i].Visible=on
    end
end

