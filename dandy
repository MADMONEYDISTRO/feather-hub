    local pg=Instance.new("ScrollingFrame"); pg.Size=UDim2.new(1,0,1,0)
    pg.BackgroundTransparency=1; pg.BorderSizePixel=0; pg.ScrollBarThickness=3
    pg.ScrollBarImageColor3=color; pg.CanvasSize=UDim2.new(0,0,0,0)
