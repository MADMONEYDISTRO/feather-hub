local autoSkillActive = false
local skillConnection
local function autoSkillCheck()
    local screenGui = Player.PlayerGui:FindFirstChild("ScreenGui")
    if not screenGui then return end
    local menu = screenGui:FindFirstChild("Menu")
    if not menu then return end
    local skillFrame = menu:FindFirstChild("SkillCheckFrame")
    if not skillFrame then return end

    local function check()
        if skillFrame.Visible then
            local m = skillFrame:FindFirstChild("Marker")
            local g = skillFrame:FindFirstChild("GoldArea")
            if m and g then
                local mx = m.AbsolutePosition.X
                local gx = g.AbsolutePosition.X
                local gw = g.AbsoluteSize.X
                if mx >= gx and mx <= gx + gw + 5 then
                    VirtualInputManager:SendKeyEvent(true, Enum.KeyCode.Space, false, game)
                end
            end
        end
    end

    skillFrame.Changed:Connect(function(prop)
        if prop == "Visible" then check() end
    end)

    local marker = skillFrame:FindFirstChild("Marker")
    local goldArea = skillFrame:FindFirstChild("GoldArea")
    if marker then
        marker.Changed:Connect(function(prop)
            if prop == "AbsolutePosition" then check() end
        end)
    end
    if goldArea then
        goldArea.Changed:Connect(function(prop)
            if prop == "AbsolutePosition" or prop == "AbsoluteSize" then check() end
        end)
    end
end

local function toggleAutoSkill(state)
    autoSkillActive = state
    if state then
        if not skillConnection then autoSkillCheck() end
    end
end

