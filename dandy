local function applyTheme()
    T = isDark and DARK or LIGHT
    applyReg()
    thBtn.Text = isDark and "Light" or "Dark"
    winGlow.ImageColor3 = isDark and Color3.fromRGB(80,80,120) or Color3.fromRGB(180,180,220)
    for i,btn in ipairs(navBtns) do
        if i~=activeTab then
            btn.bg.BackgroundColor3=T.dim; btn.lbl.TextColor3=T.muted end
    end
end

local function doTheme() isDark=not isDark; applyTheme() end
thBtn.MouseButton1Click:Connect(doTheme); thBtn.TouchTap:Connect(doTheme)
thBtn.MouseEnter:Connect(function() TweenService:Create(thBtn,tw(0.12),{BackgroundColor3=accent,TextColor3=Color3.new(1,1,1)}):Play() end)
thBtn.MouseLeave:Connect(function() TweenService:Create(thBtn,tw(0.12),{BackgroundColor3=T.dim,TextColor3=T.muted}):Play() end)

