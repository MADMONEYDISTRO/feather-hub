local flySpeed = 50
local function startFly()
    flyConnection = RunService.RenderStepped:Connect(function()
        if flyActive and Player.Character then
            local hrp = Player.Character:FindFirstChild("HumanoidRootPart")
            if hrp then
                local move = Player.Character.Humanoid.MoveDirection
                if move.Magnitude > 0 then
                    local look = workspace.CurrentCamera.CFrame.LookVector
                    local dir = (move * Vector3.new(1,0,1)) + Vector3.new(0,look.Y,0)
                    dir = dir.Unit
                    hrp.CFrame = CFrame.new(hrp.Position, hrp.Position + Vector3.new(look.X,0,look.Z))
                    hrp.Velocity = dir * flySpeed
                else
                    hrp.Anchored = true
                end
            end
        end
    end)
end
local function stopFly()
    if flyConnection then flyConnection:Disconnect(); flyConnection=nil end
    if Player.Character and Player.Character:FindFirstChild("HumanoidRootPart") then
        Player.Character.HumanoidRootPart.Anchored = false
        Player.Character.HumanoidRootPart.Velocity = Vector3.new(0,0,0)
