-- Emote helpers
local currentEmoteTrack = nil
local function playEmote(emoteName)
    local char = Player.Character
    if not char then return end
    local hum = char:FindFirstChildWhichIsA("Humanoid")
    if not hum then return end
    local animModule = ReplicatedStorage:FindFirstChild("Modules"):FindFirstChild("Emotes"):FindFirstChild(emoteName)
    if animModule then
        local loop = animModule:FindFirstChild("Loop")
        if loop and loop:IsA("Animation") then
            if currentEmoteTrack then currentEmoteTrack:Stop() end
            currentEmoteTrack = hum:LoadAnimation(loop)
            currentEmoteTrack:Play()
        end
    end
end

