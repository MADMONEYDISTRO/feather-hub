    knob.BackgroundColor3 = Theme.gold; knob.Text = ""; knob.BorderSizePixel = 0; knob.ZIndex = 7; Instance.new("UICorner", knob).CornerRadius = UDim.new(1, 0)
    local ds = false
    knob.InputBegan:Connect(function(i) if i.UserInputType == Enum.UserInputType.MouseButton1 then ds = true end end)
    UserInputService.InputEnded:Connect(function(i) if i.UserInputType == Enum.UserInputType.MouseButton1 then ds = false end end)
    UserInputService.InputChanged:Connect(function(i)
        if ds and i.UserInputType == Enum.UserInputType.MouseMovement then
            local ap = track.AbsolutePosition; local sz = track.AbsoluteSize
            local ratio = math.clamp((i.Position.X - ap.X) / sz.X, 0, 1)
            local newVal = isInt and math.floor(min + ratio*(max - min)) or min + ratio*(max - min)
            setter(newVal)
            valueBox.Text = tostring(newVal); fill.Size = UDim2.new(ratio, 0, 1, 0); knob.Position = UDim2.new(ratio, -7, 0.5, -7)
        end
    end)
    valueBox.FocusLost:Connect(function()
        local num = tonumber(valueBox.Text)
        if num then
            num = math.clamp(num, min, max); if isInt then num = math.floor(num) end
            setter(num)
            local pct = (num - min) / (max - min)
            fill.Size = UDim2.new(pct, 0, 1, 0); knob.Position = UDim2.new(pct, -7, 0.5, -7); valueBox.Text = tostring(num)
