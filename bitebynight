-- ESP
local ESP_Objects = {} -- store highlights and drawings for cleanup
local ESP_Settings = {
    Trap = false, Gen = false, Killer = false,
    TrapLabelSize = 13, GenProx = 20
}

local function clearESP()
    for _, obj in pairs(ESP_Objects) do
        if obj.Highlight then obj.Highlight:Destroy() end
        if obj.Text then obj.Text:Remove() end
    end
    table.clear(ESP_Objects)
end

local function refreshESP()
    clearESP()
    if ESP_Settings.Trap then
        for _, obj in ipairs(WS:FindFirstChild("IGNORE"):GetChildren()) do
            if obj:IsA("Model") then
                local hl = Instance.new("Highlight")
                hl.FillColor = Color3.fromRGB(255,100,0)
                hl.OutlineColor = Color3.new(1,1,1)
                hl.FillTransparency = 0.35
                hl.OutlineTransparency = 0
                hl.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
                hl.Adornee = obj
                hl.Parent = obj
                local text = Drawing and Drawing.new("Text")
                if text then
                    text.Text = "Trap"
                    text.Size = ESP_Settings.TrapLabelSize
                    text.Color = Color3.fromRGB(255,100,0)
                    text.Outline = true
                    text.Center = true
                    text.Visible = false
                    text.Font = Drawing.Fonts.UI
                end
                ESP_Objects[#ESP_Objects+1] = {Highlight = hl, Text = text}
            end
        end
    end
    if ESP_Settings.Gen then
        local gens = WS:FindFirstChild("MAPS"):FindFirstChild("GAME MAP"):FindFirstChild("Generators")
        for _, obj in ipairs(gens:GetChildren()) do
            if obj:GetAttribute("Progress") then
                local hl = Instance.new("Highlight")
                hl.FillColor = Color3.fromRGB(0,210,255)
                hl.OutlineColor = Color3.new(1,1,1)
                hl.FillTransparency = 0.35
                hl.OutlineTransparency = 0
                hl.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
                hl.Adornee = obj
                hl.Parent = obj
                local text = Drawing and Drawing.new("Text")
                if text then
                    text.Text = "Generator"
                    text.Size = 13
                    text.Color = Color3.fromRGB(0,210,255)
                    text.Outline = true
                    text.Center = true
                    text.Visible = false
                    text.Font = Drawing.Fonts.UI
                end
                ESP_Objects[#ESP_Objects+1] = {Highlight = hl, Text = text}
            end
        end
    end
    if ESP_Settings.Killer then
        for _, obj in ipairs(WS:FindFirstChild("PLAYERS"):FindFirstChild("KILLER"):GetChildren()) do
            if obj:IsA("Model") then
                local hl = Instance.new("Highlight")
                hl.FillColor = Color3.fromRGB(220,30,30)
                hl.OutlineColor = Color3.new(1,0,0)
                hl.FillTransparency = 0.15
                hl.OutlineTransparency = 0
                hl.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
                hl.Adornee = obj
                hl.Parent = obj
                local text = Drawing and Drawing.new("Text")
                if text then
                    text.Text = "KILLER"
                    text.Size = 15
                    text.Color = Color3.fromRGB(220,30,30)
                    text.Outline = true
                    text.Center = true
                    text.Visible = false
                    text.Font = Drawing.Fonts.UI
                end
                ESP_Objects[#ESP_Objects+1] = {Highlight = hl, Text = text}
            end
        end
    end
end

