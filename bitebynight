local safeTeleporting = false
local function tpChar(target, bypass)
    if safeTeleporting then return end
    local hrp = getHRP()
    if not hrp then return end
    
    if Flags.SafeTeleport and not bypass then
        safeTeleporting = true
        local startCF = hrp.CFrame
        local dist = (startCF.Position - target.Position).Magnitude
        local speed = getCharacter():GetAttribute("RunSpeed") or 24
        local duration = dist / speed
        local tween = game:GetService("TweenService"):Create(hrp, TweenInfo.new(duration, Enum.EasingStyle.Linear), {CFrame = target})
        tween:Play()
        tween.Completed:Wait()
        safeTeleporting = false
    else
        hrp.CFrame = target
    end
end

-- Map object finders (original logic)
local function getGens()
    local gens = {}
    local map = workspace:FindFirstChild("MAPS") and workspace.MAPS:FindFirstChild("GAME MAP")
    local standardFolders = {
        map and map:FindFirstChild("Generators"),
        map and map:FindFirstChild("Tasks") and map.Tasks:FindFirstChild("Generators"),
        map and map:FindFirstChild("Gens")
    }
    for _, folder in ipairs(standardFolders) do
        if folder then
            for _, v in ipairs(folder:GetChildren()) do
                if v:IsA("Model") and v:GetAttribute("Progress") then table.insert(gens, v) end
            end
        end
    end
    if #gens == 0 then
        for _, v in ipairs(workspace:GetDescendants()) do
            if v:IsA("Model") and v:GetAttribute("Progress") then table.insert(gens, v) end
        end
    end
    return gens
end
local function getBatteries()
    local bats = {}
    local map = workspace:FindFirstChild("MAPS") and workspace.MAPS:FindFirstChild("GAME MAP")
    local folders = {
        workspace:FindFirstChild("IGNORE"),
        map and map:FindFirstChild("Tasks") and map.Tasks:FindFirstChild("Batteries")
    }
    for _, f in ipairs(folders) do
        if f then
            for _, v in ipairs(f:GetChildren()) do
                if v.Name == "Battery" or v:GetAttribute("Battery") then table.insert(bats, v) end
            end
        end
    end
    if #bats == 0 then
        for _, v in ipairs(workspace:GetDescendants()) do
            if v.Name == "Battery" then table.insert(bats, v) end
        end
    end
    return bats
end
local function getFuseBoxes()
    local fbs = {}
    local map = workspace:FindFirstChild("MAPS") and workspace.MAPS:FindFirstChild("GAME MAP")
    local folder = map and (map:FindFirstChild("FuseBoxes") or (map:FindFirstChild("Tasks") and map.Tasks:FindFirstChild("FuseBoxes")))
    if folder then
        for _, v in ipairs(folder:GetChildren()) do table.insert(fbs, v) end
    else
        for _, v in ipairs(workspace:GetDescendants()) do
            if v.Name:match("FuseBox") or v.Name:match("Fuse_Box") then table.insert(fbs, v) end
        end
    end
    return fbs
end
local function getTraps()
    local traps = {}
    local ignore = workspace:FindFirstChild("IGNORE")
    if ignore then
        for _, v in ipairs(ignore:GetChildren()) do
            if v.Name == "Trap" then table.insert(traps, v) end
        end
    end
    if #traps == 0 then
        for _, v in ipairs(workspace:GetDescendants()) do
            if v.Name == "Trap" then table.insert(traps, v) end
        end
    end
    return traps
end

local function completeAllGenerators()
    Flags.AutoGen = true
    local gens = getGens()
    if #gens == 0 then return end
    for _, gen in ipairs(gens) do
        if gen:GetAttribute("Progress") < 100 then
            local primary = gen.PrimaryPart or gen:FindFirstChildWhichIsA("BasePart", true)
            if primary then
                tpChar(primary.CFrame + Vector3.new(0, 3, 0))
                task.wait(0.5)
                local points = {}
                for _, d in ipairs(gen:GetDescendants()) do
                    if d:IsA("ProximityPrompt") then table.insert(points, d) end
                end
                local found = nil
                for _, p in ipairs(points) do if p and p.Enabled then found = p; break end end
                if found then
                    fireproximityprompt(found)
                    task.wait(3)
                end
            end
        end
        if not Flags.AutoFarm then break end
    end
end

local function escapeMap()
    if not workspace.GAME.CAN_ESCAPE.Value then return end
    local escapes = {}
    local gameMap = workspace.MAPS:FindFirstChild("GAME MAP")
    if gameMap then
        local a = gameMap:FindFirstChild("Escapes") and gameMap.Escapes:GetChildren() or {}
        if a[1] then escapes = a else
            for _, v in ipairs(workspace.IGNORE:GetChildren()) do if v.Name == "EscapePoint" then table.insert(escapes, v) end end
        end
    end
    for _, e in ipairs(escapes) do if e:GetAttribute("Enabled") then tpChar(e.CFrame, true); break end end
end

