-- Minimize functionality
local isMinimized = false
local function toggleMinimize()
    isMinimized = not isMinimized
    if isMinimized then
        createTween(Win, {Size = UDim2.new(0, WIN_W, 0, HDR_H)}, 0.3):Play()
        Sidebar.Visible = false
        Content.Visible = false
        createTween(Header, {Size = UDim2.new(1, 0, 0, HDR_H), Position = UDim2.new(0, 0, 0, 0)}, 0.3):Play()
        HeaderLeftCover.Visible = false
        HeaderBotCover.Visible = false
        HeaderLine.Visible = false
        MinimizeBtn.Text = "+"
    else
        createTween(Win, {Size = UDim2.new(0, WIN_W, 0, WIN_H)}, 0.3):Play()
        createTween(Header, {Size = UDim2.new(1, -SIDE_W, 0, HDR_H), Position = UDim2.new(0, SIDE_W, 0, 0)}, 0.3):Play()
        HeaderLeftCover.Visible = true
        HeaderBotCover.Visible = true
        HeaderLine.Visible = true
        task.delay(0.1, function()
            Sidebar.Visible = true
            Content.Visible = true
        end)
        MinimizeBtn.Text = "–"
    end
end
MinimizeBtn.MouseButton1Click:Connect(toggleMinimize)
MinimizeBtn.MouseEnter:Connect(function()
    createTween(MinimizeBtn, {BackgroundColor3 = T.accent, TextColor3 = Color3.new(1,1,1)}):Play()
end)
MinimizeBtn.MouseLeave:Connect(function()
    createTween(MinimizeBtn, {BackgroundColor3 = T.dim, TextColor3 = T.muted}):Play()
end)

-- Dragging
local dragging, dragStart, startPos
Header.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
        dragging = true
        dragStart = input.Position
        startPos = Win.Position
        input.Changed:Connect(function()
            if input.UserInputState == Enum.UserInputState.End then
                dragging = false
            end
        end)
    end
end)
UserInputService.InputChanged:Connect(function(input)
    if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
        local delta = input.Position - dragStart
        local viewport = workspace.CurrentCamera.ViewportSize
        Win.Position = UDim2.new(0, math.clamp(startPos.X.Offset + delta.X, 0, viewport.X - WIN_W), 0, math.clamp(startPos.Y.Offset + delta.Y, 0, viewport.Y - WIN_H))
    end
end)

