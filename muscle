-- Status Tab
do
    local page = Pages[7]
    makeSection(page, "Stats Gained", 1)
    local para = makeParagraph(page, 2, "Session Stats", "Loading...")
    local function format(num)
        if num >= 1e15 then return string.format("%.1fQa", num / 1e15)
        elseif num >= 1e12 then return string.format("%.1fT", num / 1e12)
        elseif num >= 1e9 then return string.format("%.1fB", num / 1e9)
        elseif num >= 1e6 then return string.format("%.1fM", num / 1e6)
        elseif num >= 1e3 then return string.format("%.1fK", num / 1e3)
        else return tostring(num) end
    end
    task.spawn(function()
        local leaderstats = LocalPlayer:WaitForChild("leaderstats")
        local strength = leaderstats:WaitForChild("Strength")
        local durability = LocalPlayer:WaitForChild("Durability")
        local agility = LocalPlayer:WaitForChild("Agility")
        local kills = leaderstats:WaitForChild("Kills")
        local evilKarma = LocalPlayer:WaitForChild("evilKarma")
        local goodKarma = LocalPlayer:WaitForChild("goodKarma")
        local startVals = {
            Strength = strength.Value,
            Durability = durability.Value,
            Agility = agility.Value,
            Kills = kills.Value,
            Evil = evilKarma.Value,
            Good = goodKarma.Value,
        }
        local startTime = tick()
        local function update()
            local elapsed = tick() - startTime
            local mins = math.floor(elapsed / 60)
            local secs = math.floor(elapsed % 60)
            para.Text = string.format([[
Time spent in this server: %02d:%02d

Strength gained: %s
Durability gained: %s
Agility gained: %s
Kills gained: %s
Evil Karma gained: %s
Good Karma gained: %s
            ]], mins, secs,
                format(strength.Value - startVals.Strength),
                format(durability.Value - startVals.Durability),
                format(agility.Value - startVals.Agility),
                format(kills.Value - startVals.Kills),
                format(evilKarma.Value - startVals.Evil),
                format(goodKarma.Value - startVals.Good))
        end
        strength.Changed:Connect(update)
        durability.Changed:Connect(update)
        agility.Changed:Connect(update)
        kills.Changed:Connect(update)
        evilKarma.Changed:Connect(update)
        goodKarma.Changed:Connect(update)
        RunService.Heartbeat:Connect(update)
        update()
    end)
end

