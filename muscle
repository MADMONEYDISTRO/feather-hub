    msgLabel.TextColor3 = T.text
    msgLabel.TextTransparency = 0.35
    msgLabel.TextXAlignment = Enum.TextXAlignment.Left
    msgLabel.TextWrapped = true
    msgLabel.BackgroundTransparency = 1
    msgLabel.ZIndex = 101

    notif.Size = UDim2.new(0, 0, 0, 62)
    createTween(notif, {Size = UDim2.new(0, 210, 0, 62)}, 0.25):Play()
    task.delay(3.5, function()
        if notif and notif.Parent then
            createTween(notif, {Position = UDim2.new(1, 12, 1, -76)}, 0.25):Play()
            task.delay(0.3, function() if notif and notif.Parent then notif:Destroy() end end)
