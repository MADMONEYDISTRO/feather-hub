-- Dropdown System (Polished, opens lower)
local activeDropdown = nil  -- { menu, button, updateConn }

local function closeActiveDropdown()
    if activeDropdown then
        activeDropdown.menu.Visible = false
        if activeDropdown.updateConn then
            activeDropdown.updateConn:Disconnect()
        end
        activeDropdown = nil
    end
end

-- Close dropdown when clicking outside
UserInputService.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 and activeDropdown then
        local mousePos = UserInputService:GetMouseLocation()
        local menuAbs = activeDropdown.menu.AbsolutePosition
        local menuSize = activeDropdown.menu.AbsoluteSize
        local btnAbs = activeDropdown.button.AbsolutePosition
        local btnSize = activeDropdown.button.AbsoluteSize
        -- Check if click is outside both menu and button
        if not ((mousePos.X >= menuAbs.X and mousePos.X <= menuAbs.X + menuSize.X and mousePos.Y >= menuAbs.Y and mousePos.Y <= menuAbs.Y + menuSize.Y) or
                (mousePos.X >= btnAbs.X and mousePos.X <= btnAbs.X + btnSize.X and mousePos.Y >= btnAbs.Y and mousePos.Y <= btnAbs.Y + btnSize.Y)) then
            closeActiveDropdown()
        end
    end
end)

local function makeDropdown(card, order, text, options, default, callback)
    local row = makeRow(card, order, false, 44)
    local lbl = Instance.new("TextLabel")
    lbl.Size = UDim2.new(0.5, 0, 1, 0)
    lbl.Position = UDim2.new(0, 14, 0, 0)
    lbl.Text = text
    lbl.Font = Enum.Font.GothamSemibold
    lbl.TextSize = 10
    lbl.TextColor3 = T.text
    lbl.TextXAlignment = Enum.TextXAlignment.Left
    lbl.BackgroundTransparency = 1
    lbl.Parent = row

    local dropdownBtn = Instance.new("TextButton")
    dropdownBtn.Size = UDim2.new(0, 130, 0, 28)
    dropdownBtn.Position = UDim2.new(1, -140, 0.5, -14)
    dropdownBtn.Text = default
    dropdownBtn.Font = Enum.Font.GothamMedium
    dropdownBtn.TextSize = 10
    dropdownBtn.TextColor3 = T.text
    dropdownBtn.BackgroundColor3 = T.inputBg or T.dim
    dropdownBtn.BorderSizePixel = 0
    dropdownBtn.AutoButtonColor = false
    dropdownBtn.Parent = row
    Instance.new("UICorner", dropdownBtn).CornerRadius = UDim.new(0, 6)

    -- Create dropdown menu
    local menu = Instance.new("Frame")
    menu.Size = UDim2.new(0, 130, 0, 0)
    menu.BackgroundColor3 = T.card
    menu.BorderSizePixel = 0
    menu.Visible = false
    menu.ZIndex = 100
    menu.ClipsDescendants = true
    menu.Parent = sg
    Instance.new("UICorner", menu).CornerRadius = UDim.new(0, 6)
    local menuStroke = Instance.new("UIStroke", menu)
    menuStroke.Color = T.border
    menuStroke.Thickness = 1

    -- Scrolling frame for options
    local scroll = Instance.new("ScrollingFrame", menu)
    scroll.Size = UDim2.new(1, 0, 1, 0)
    scroll.BackgroundTransparency = 1
    scroll.BorderSizePixel = 0
    scroll.ScrollBarThickness = 2
    scroll.ScrollBarImageColor3 = T.accent
    scroll.CanvasSize = UDim2.new(0, 0, 0, 0)
    scroll.AutomaticCanvasSize = Enum.AutomaticSize.Y
    scroll.ScrollingDirection = Enum.ScrollingDirection.Y
    scroll.ElasticBehavior = Enum.ElasticBehavior.Never
    local scrollLayout = Instance.new("UIListLayout", scroll)
    scrollLayout.SortOrder = Enum.SortOrder.LayoutOrder
    scrollLayout.Padding = UDim.new(0, 2)

    local function buildMenu()
        -- Clear existing
        for _, child in pairs(scroll:GetChildren()) do
            if child:IsA("TextButton") then child:Destroy() end
        end
        for _, opt in ipairs(options) do
            local btn = Instance.new("TextButton")
            btn.Size = UDim2.new(1, -4, 0, 26)
            btn.Position = UDim2.new(0, 2, 0, 0)
            btn.Text = opt
            btn.Font = Enum.Font.GothamMedium
            btn.TextSize = 10
            btn.TextColor3 = T.text
            btn.BackgroundColor3 = T.dim
            btn.BorderSizePixel = 0
            btn.AutoButtonColor = false
            btn.ZIndex = 101
            btn.Parent = scroll
            Instance.new("UICorner", btn).CornerRadius = UDim.new(0, 4)
            btn.MouseButton1Click:Connect(function()
                dropdownBtn.Text = opt
                closeActiveDropdown()
                callback(opt)
            end)
            btn.MouseEnter:Connect(function() btn.BackgroundColor3 = T.accentDim end)
            btn.MouseLeave:Connect(function() btn.BackgroundColor3 = T.dim end)
        end
        -- Set menu height (max 5 items visible then scroll)
        local itemCount = #options
        local itemHeight = 28  -- 26 + 2 padding
        local maxVisible = 5
        local menuHeight = math.min(itemCount, maxVisible) * itemHeight + 4
        menu.Size = UDim2.new(0, 130, 0, menuHeight)
    end

    buildMenu()

    local function updateMenuPosition()
        if not menu.Visible then return end
        local btnAbs = dropdownBtn.AbsolutePosition
        local btnSize = dropdownBtn.AbsoluteSize
        local menuHeight = menu.AbsoluteSize.Y
        local screenSize = workspace.CurrentCamera.ViewportSize

        local posX = btnAbs.X
        local posY = btnAbs.Y + btnSize.Y + 8  -- Increased offset to open lower

        -- Prevent going off bottom
        if posY + menuHeight > screenSize.Y - 20 then
            posY = btnAbs.Y - menuHeight - 8  -- Flip above with same offset
        end
        -- Prevent going off right side
        if posX + 130 > screenSize.X then
            posX = screenSize.X - 130 - 5
        end

        menu.Position = UDim2.new(0, posX, 0, posY)
    end

    local updateConn
    dropdownBtn.MouseButton1Click:Connect(function()
        if activeDropdown and activeDropdown.menu == menu then
            closeActiveDropdown()
        else
            closeActiveDropdown()  -- close any other
            menu.Visible = true
            updateMenuPosition()
            -- Continuously update position while open (for window dragging)
            updateConn = RunService.RenderStepped:Connect(updateMenuPosition)
            activeDropdown = { menu = menu, button = dropdownBtn, updateConn = updateConn }
        end
    end)

    -- When menu closed, disconnect update
    local originalVisibleChanged = menu:GetPropertyChangedSignal("Visible"):Connect(function()
        if not menu.Visible and activeDropdown and activeDropdown.menu == menu then
            if activeDropdown.updateConn then
                activeDropdown.updateConn:Disconnect()
            end
            activeDropdown = nil
        end
    end)

    return row
end

