-- ==================== FIXED DROPDOWN ====================
-- The original bug: btn.AbsolutePosition was read at creation time (always 0,0)
-- Fix: read AbsolutePosition inside the click handler, after the button is rendered,
--      and also account for the ScreenGui IgnoreGuiInset offset.

local function makeDropdown(parent, order, title, values, defaultIndex, callback)
    local row = makeRow(parent, order, false, 52)

    local lbl = Instance.new("TextLabel", row)
    lbl.Size = UDim2.new(0.4, 0, 0, 20)
    lbl.Position = UDim2.new(0, 16, 0, 8)
    lbl.Text = title
    lbl.Font = Enum.Font.GothamSemibold
    lbl.TextSize = 10
    lbl.TextColor3 = T.text
    lbl.TextXAlignment = Enum.TextXAlignment.Left
    lbl.BackgroundTransparency = 1
    lbl.ZIndex = 5

    local selected = values[defaultIndex] or values[1]

    local btnWidth = 140
    local btn = Instance.new("TextButton", row)
    btn.Size = UDim2.new(0, btnWidth, 0, 30)
    btn.Position = UDim2.new(1, -(btnWidth + 16), 0.5, -15)
    btn.Text = selected .. " ▾"
    btn.Font = Enum.Font.GothamMedium
    btn.TextSize = 10
    btn.TextColor3 = T.text
    btn.BackgroundColor3 = T.inputBg
    btn.BorderSizePixel = 0
    btn.AutoButtonColor = false
    btn.ZIndex = 5
    Instance.new("UICorner", btn).CornerRadius = UDim.new(0, 6)
    local stroke = Instance.new("UIStroke", btn)
    stroke.Color = T.border
    stroke.Thickness = 1

    local dropdownOpen = false
    local dropdownFrame = nil
    local closeConnection = nil

    local function closeDropdown()
        if dropdownFrame then
            dropdownFrame:Destroy()
            dropdownFrame = nil
        end
        if closeConnection then
            closeConnection:Disconnect()
            closeConnection = nil
        end
        dropdownOpen = false
        stroke.Color = T.border
    end

    btn.MouseButton1Click:Connect(function()
        if dropdownOpen then
            closeDropdown()
            return
        end
        dropdownOpen = true
        stroke.Color = T.accent

        -- Read AbsolutePosition HERE (after render), not at creation time
        local absPos = btn.AbsolutePosition
        local absSize = btn.AbsoluteSize

        -- Account for IgnoreGuiInset (top bar offset is usually 36px on PC)
        local inset = game:GetService("GuiService"):GetGuiInset()

        local dropH = math.min(#values * 30, 180) -- cap height so it doesn't go off screen

        dropdownFrame = Instance.new("Frame")
        dropdownFrame.Size = UDim2.new(0, absSize.X, 0, dropH)
        dropdownFrame.Position = UDim2.new(0, absPos.X, 0, absPos.Y + absSize.Y - inset.Y)
        dropdownFrame.BackgroundColor3 = T.card
        dropdownFrame.BorderSizePixel = 0
        dropdownFrame.ZIndex = 200
        dropdownFrame.ClipsDescendants = true
        dropdownFrame.Parent = ScreenGui
        Instance.new("UICorner", dropdownFrame).CornerRadius = UDim.new(0, 6)
        local ddStroke = Instance.new("UIStroke", dropdownFrame)
        ddStroke.Color = T.accent
        ddStroke.Thickness = 1

        -- Scrolling support for long lists
        local scroll = Instance.new("ScrollingFrame", dropdownFrame)
        scroll.Size = UDim2.new(1, 0, 1, 0)
        scroll.BackgroundTransparency = 1
        scroll.BorderSizePixel = 0
        scroll.ScrollBarThickness = 3
        scroll.ScrollBarImageColor3 = T.accent
        scroll.CanvasSize = UDim2.new(0, 0, 0, #values * 30)
        scroll.ScrollingDirection = Enum.ScrollingDirection.Y
        scroll.ZIndex = 201

        local ddLayout = Instance.new("UIListLayout", scroll)
        ddLayout.SortOrder = Enum.SortOrder.LayoutOrder

        for idx, v in ipairs(values) do
            local opt = Instance.new("TextButton", scroll)
            opt.Size = UDim2.new(1, 0, 0, 30)
            opt.Text = v
            opt.Font = Enum.Font.GothamMedium
            opt.TextSize = 10
            opt.TextColor3 = (v == selected) and T.accentLt or T.text
            opt.BackgroundColor3 = T.card
            opt.BorderSizePixel = 0
            opt.ZIndex = 202
            opt.AutoButtonColor = false
            opt.LayoutOrder = idx
            opt.MouseEnter:Connect(function()
                createTween(opt, {BackgroundColor3 = T.dim}):Play()
            end)
            opt.MouseLeave:Connect(function()
                createTween(opt, {BackgroundColor3 = T.card}):Play()
            end)
            opt.MouseButton1Click:Connect(function()
                selected = v
                btn.Text = v .. " ▾"
                closeDropdown()
                callback(v)
            end)
        end

        -- Close when clicking outside
        task.wait(0.05)
        closeConnection = UserInputService.InputBegan:Connect(function(input)
            if input.UserInputType == Enum.UserInputType.MouseButton1 then
                local mousePos = UserInputService:GetMouseLocation()
                local inDropdown = false
                if dropdownFrame and dropdownFrame.Parent then
                    local dfPos = dropdownFrame.AbsolutePosition
                    local dfSize = dropdownFrame.AbsoluteSize
                    if mousePos.X >= dfPos.X and mousePos.X <= dfPos.X + dfSize.X and
                       mousePos.Y >= dfPos.Y and mousePos.Y <= dfPos.Y + dfSize.Y then
                        inDropdown = true
                    end
                end
                local btnPos2 = btn.AbsolutePosition
                local btnSize2 = btn.AbsoluteSize
                if mousePos.X >= btnPos2.X and mousePos.X <= btnPos2.X + btnSize2.X and
                   mousePos.Y >= btnPos2.Y and mousePos.Y <= btnPos2.Y + btnSize2.Y then
                    inDropdown = true
                end
                if not inDropdown then
                    closeDropdown()
                end
            end
        end)
    end)

    return {
        SetValues = function(self, newValues)
            values = newValues
            selected = newValues[1] or ""
            btn.Text = selected .. " ▾"
            if dropdownOpen then closeDropdown() end
        end,
        SetValue = function(self, val)
            selected = val
            btn.Text = val .. " ▾"
        end,
        GetValue = function(self)
            return selected
        end,
        Value = selected
    }
end

