local function setTab(index)
    if isMinimized then toggleMinimize() end
    local oldIndex = ActiveTab
    ActiveTab = index
    HeaderTitle.Text = Tabs[index].name
    for i, btn in ipairs(NavButtons) do
        local isActive = (i == index)
        createTween(btn.bg, {BackgroundColor3 = isActive and T.accent or T.dim, BackgroundTransparency = isActive and 0.12 or 0}, 0.16):Play()
        createTween(btn.lbl, {TextColor3 = isActive and Color3.new(1,1,1) or T.text}, 0.16):Play()
        btn.bar.BackgroundTransparency = isActive and 0 or 1
        btn.bar.BackgroundColor3 = T.accent
    end
    if oldIndex ~= index then
        if Pages[oldIndex] then Pages[oldIndex].Visible = false end
        if Pages[index] then
            Pages[index].Position = UDim2.new(0, 0, 0, 0)
            Pages[index].CanvasPosition = Vector2.new(0, 0)
            Pages[index].Visible = true
            local cover = Instance.new("Frame")
            cover.Size = UDim2.new(1, 0, 1, 0)
            cover.BackgroundColor3 = T.bg
            cover.BackgroundTransparency = 0
            cover.BorderSizePixel = 0
            cover.ZIndex = 8
            cover.Parent = Pages[index]
            createTween(cover, {BackgroundTransparency = 1}, 0.18, Enum.EasingStyle.Quad):Play()
            task.delay(0.2, function() if cover and cover.Parent then cover:Destroy() end end)
        end
    else
        for i = 1, #Pages do Pages[i].Visible = (i == index) end
    end
end

