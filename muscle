local function createTween(obj, props, duration, easing, direction)
    return TweenService:Create(obj, TweenInfo.new(duration or 0.22, easing or Enum.EasingStyle.Quart, direction or Enum.EasingDirection.Out), props)
end

local function notify(title, msg, nType)
    local col = T.accent
    if nType == "success" then col = T.green
    elseif nType == "error" then col = T.red
    elseif nType == "warning" then col = T.gold end

    local notif = Instance.new("Frame")
    notif.Size = UDim2.new(0, 0, 0, 62)
    notif.Position = UDim2.new(1, -12, 1, -76)
    notif.AnchorPoint = Vector2.new(1, 1)
    notif.BackgroundColor3 = T.card
    notif.BorderSizePixel = 0
    notif.ZIndex = 100
    notif.Parent = ScreenGui
    Instance.new("UICorner", notif).CornerRadius = UDim.new(0, 10)
    local stroke = Instance.new("UIStroke", notif)
    stroke.Color = col
    stroke.Thickness = 1
    local bar = Instance.new("Frame", notif)
    bar.Size = UDim2.new(0, 3, 0.65, 0)
    bar.Position = UDim2.new(0, 0, 0.175, 0)
    bar.BackgroundColor3 = col
    bar.BorderSizePixel = 0
    Instance.new("UICorner", bar).CornerRadius = UDim.new(1, 0)

    local titleLabel = Instance.new("TextLabel", notif)
    titleLabel.Size = UDim2.new(1, -18, 0, 20)
    titleLabel.Position = UDim2.new(0, 14, 0, 9)
    titleLabel.Text = title
    titleLabel.Font = Enum.Font.GothamBold
    titleLabel.TextSize = 11
    titleLabel.TextColor3 = T.text
    titleLabel.TextXAlignment = Enum.TextXAlignment.Left
    titleLabel.BackgroundTransparency = 1
    titleLabel.ZIndex = 101

    local msgLabel = Instance.new("TextLabel", notif)
    msgLabel.Size = UDim2.new(1, -18, 0, 20)
    msgLabel.Position = UDim2.new(0, 14, 0, 29)
    msgLabel.Text = msg
