end

local workoutLoop
local function startWorkout()
    if workoutLoop then return end
    workoutLoop = task.spawn(function()
        while working do
            local char = Player.Character
            if char and char:FindFirstChild("HumanoidRootPart") then
                local pos = workoutPositions[selectedLocation] and workoutPositions[selectedLocation][selectedWorkout]
                if pos then
                    char.HumanoidRootPart.CFrame = pos
                end
                sendKeyE()
                muscleEvent:FireServer()
            end
            task.wait(0.25)
        end
        workoutLoop = nil
    end)
end

local repLoop
local function startAutoRep()
    if repLoop then return end
    repLoop = task.spawn(function()
        while autoRep do
            muscleEvent:FireServer("rep")
            task.wait(0.2)
        end
        repLoop = nil
    end)
end

local function startToolEquip(toolName, enabledVar)
    task.spawn(function()
        while getgenv()[enabledVar] do
            local tool = Player.Backpack:FindFirstChild(toolName)
            if tool and tool.Parent ~= Player.Character then
                tool.Parent = Player.Character
            end
            task.wait(0.1)
        end
    end)
end

local rebirthTargetLoop
local function startRebirthTarget()
    if rebirthTargetLoop then return end
    rebirthTargetLoop = task.spawn(function()
        while rebirthTargetRunning do
            local stats = Player:FindFirstChild("leaderstats")
            local rebirths = stats and stats:FindFirstChild("Rebirths") and stats.Rebirths.Value or 0
            if rebirths >= rebirthTarget then
                rebirthTargetRunning = false
                break
            end
            doRebirth()
            task.wait(0.1)
        end
        rebirthTargetLoop = nil
    end)
end

local muscleKingLoop1, muscleKingLoop2, muscleKingLoop3, muscleKingLoop4
local function startMuscleKing()
    if posLock then posLock:Disconnect() end
    local char = Player.Character or Player.CharacterAdded:Wait()
    local hrp = char:WaitForChild("HumanoidRootPart")
    local lockCF = CFrame.new(-8745.51855, 29.7460375, -5853.76807, -0.819156051, 0, -0.573571265, 0, 1, 0, 0.573571265, 0, -0.819156051)
    hrp.CFrame = lockCF
    posLock = RunService.Heartbeat:Connect(function()
        if Player.Character and Player.Character:FindFirstChild("HumanoidRootPart") then
            Player.Character.HumanoidRootPart.CFrame = lockCF
        end
    end)

    muscleKingLoop1 = task.spawn(function()
        while muscleKingCombo do
            local weight = Player.Backpack:FindFirstChild("Weight") or Player.Character:FindFirstChild("Weight")
            if weight and weight.Parent ~= Player.Character then
                weight.Parent = Player.Character
            end
            task.wait(0.1)
        end
    end)
    muscleKingLoop2 = task.spawn(function()
        while muscleKingCombo do
            muscleEvent:FireServer("rep")
            task.wait(0.001)
        end
    end)
    muscleKingLoop3 = task.spawn(function()
        while muscleKingCombo do
            doRebirth()
            task.wait(0.01)
        end
    end)
    muscleKingLoop4 = task.spawn(function()
        while muscleKingCombo do
            REvents.changeSpeedSizeRemote:InvokeServer("changeSize", 2)
            task.wait(0.1)
        end
    end)
end

local function stopMuscleKing()
    if posLock then posLock:Disconnect(); posLock = nil end
    if muscleKingLoop1 then task.cancel(muscleKingLoop1); muscleKingLoop1 = nil end
    if muscleKingLoop2 then task.cancel(muscleKingLoop2); muscleKingLoop2 = nil end
    if muscleKingLoop3 then task.cancel(muscleKingLoop3); muscleKingLoop3 = nil end
    if muscleKingLoop4 then task.cancel(muscleKingLoop4); muscleKingLoop4 = nil end
end

